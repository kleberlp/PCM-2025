@model PCM.WEB.MODELS.Empresa

<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action("Index", "Home")">@PCM.ADM.WEB.Properties.Resources.sistema</a>
                <span class="breadcrumb-item">@PCM.ADM.WEB.Properties.Resources.cadastro_basico</span>
                <a class="breadcrumb-item" href="@Url.Action("EmpresaIndex", "CadastroBasico")">@PCM.ADM.WEB.Properties.Resources.empresa</a>
                <span class="breadcrumb-item active">@PCM.ADM.WEB.Properties.Resources.editar</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->
    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">
                @using (Html.BeginForm("EmpresaEdit", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data", autocomplete = "off" }))
                {
                    @Html.AntiForgeryToken()

                    <input type="hidden" id="codigo" name="codigo" value="@Model.codigo">

                    <div class="block block-rounded border">

                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.ADM.WEB.Properties.Resources.cadastrar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.ADM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("EmpresaIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.ADM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>

                        <div class="block-content block-content-full">

                            <div class="form-group row">
                                <div class="col-md-3">
                                    <label for="tipo_empresa">@PCM.ADM.WEB.Properties.Resources.tipo_empresa</label>
                                    @Html.DropDownList("tipo_empresa", null, "", new { @class = "form-control" })
                                </div>
                                <div class="col-md-9">
                                    <label for="nome_fantasia">@PCM.ADM.WEB.Properties.Resources.nome_fantasia</label>
                                    <input type="text" class="form-control js-maxlength" id="nome_fantasia" name="nome_fantasia" maxlength="120" value="@Model.nome_fantasia">
                                </div>
                            </div>

                            <div class="form-group row">
                                <div class="col-md-3">
                                    <label for="cnpj">@PCM.ADM.WEB.Properties.Resources.cnpj</label>
                                    <input type="text" class="form-control" id="cnpj" name="cnpj" value="@Model.cnpj">
                                </div>
                                <div class="col-md-3">
                                    <label for="inscricao_estadual">@PCM.ADM.WEB.Properties.Resources.inscricao_estadual</label>
                                    <input type="text" class="js-maxlength form-control" id="inscricao_estadual" name="inscricao_estadual" maxlength="20" value="@Model.inscricao_estadual">
                                </div>
                                <div class="col-md-3">
                                    <label for="inscricao_municipal">@PCM.ADM.WEB.Properties.Resources.inscricao_municipal</label>
                                    <input type="text" class="js-maxlength form-control" id="inscricao_municipal" name="inscricao_municipal" maxlength="20" value="@Model.inscricao_municipal">
                                </div>
                                <div class="col-md-3">
                                    <label for="cep">@PCM.ADM.WEB.Properties.Resources.cep</label>
                                    <input type="text" class="form-control" id="cep" name="cep" maxlength="10" onblur="LoadCEP();" value="@Model.cep">
                                </div>
                            </div>

                            <div class="form-group row">
                                <div class="col-md-2">
                                    <label for="uf">@PCM.ADM.WEB.Properties.Resources.uf</label>
                                    @Html.DropDownList("uf", null, "", new { @class = "form-control" })
                                </div>
                                <div class="col-md-4">
                                    <label for="municipio">@PCM.ADM.WEB.Properties.Resources.municipio</label>
                                    <input type="text" class="js-maxlength form-control" id="municipio" name="municipio" maxlength="100" value="@Model.municipio">
                                </div>
                                <div class="col-md-4">
                                    <label for="logradouro">@PCM.ADM.WEB.Properties.Resources.logradouro</label>
                                    <input type="text" class="js-maxlength form-control" id="logradouro" name="logradouro" maxlength="100" value="@Model.logradouro">
                                </div>
                                <div class="col-md-2">
                                    <label for="numero">@PCM.ADM.WEB.Properties.Resources.numero</label>
                                    <input type="text" class="js-maxlength form-control" id="numero" name="numero" maxlength="60" value="@Model.numero">
                                </div>
                            </div>

                            <div class="form-group row">
                                <div class="col-md-3">
                                    <label for="bairro">@PCM.ADM.WEB.Properties.Resources.bairro</label>
                                    <input type="text" class="js-maxlength form-control" id="bairro" name="bairro" maxlength="100" value="@Model.bairro">
                                </div>
                                <div class="col-md-6">
                                    <label for="complemento">@PCM.ADM.WEB.Properties.Resources.complemento</label>
                                    <input type="text" class="js-maxlength form-control" id="complemento" name="complemento" maxlength="100" value="@Model.complemento">
                                </div>
                                <div class="col-md-3">
                                    <label for="telefone">@PCM.ADM.WEB.Properties.Resources.telefone</label>
                                    <input type="text" class="js-maxlength form-control" id="telefone" name="telefone" maxlength="60" value="@Model.telefone">
                                </div>
                            </div>

                            <div class="form-group row">
                                <div class="col-md-2">
                                    <div>
                                        <label for="ativo">@PCM.ADM.WEB.Properties.Resources.ativo</label>
                                        <div>
                                            <label class="css-control css-control-success css-switch">
                                                @Html.CheckBoxFor(model => model.ativo, new { @class = "css-control-input" })
                                                <span class="css-control-indicator"></span>
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.ADM.WEB.Properties.Resources.financeiro</h3>
                        </div>

                        <div class="block-content block-content-full">

                            <div class="form-group row">
                                <div class="col-md-2">
                                    <label for="valor">@PCM.ADM.WEB.Properties.Resources.valor</label>
                                    <input type="text" id="valor" name="valor" class="form-control" value="@Model.valor" />
                                </div>
                                <div class="col-md-2">
                                    <label for="data_inicio">@PCM.ADM.WEB.Properties.Resources.data_inicio</label>
                                    <input type="text" class="js-datepicker form-control" id="data_inicio" name="data_inicio" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value="@Model.data_inicio">
                                </div>
                            </div>

                        </div>

                        <div class="block-header block-mode-loading-repeat block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.ADM.WEB.Properties.Resources.logo</h3>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
                                <div class="col-12">
                                    <label>Logo tamanho: (250 x 120)</label>
                                    <div class="custom-file">
                                        <input type="file" class="custom-file-input" id="logoMin" name="logoMin" onchange="LogoMin();" accept="image/png,image/gif,image/jpeg">
                                        <label id="lblLogoMin" class="custom-file-label" for="logoMin">@PCM.ADM.WEB.Properties.Resources.selecione_arquivo</label>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-12">
                                    <label>Logo tamanho: (500 x 500)</label>
                                    <div class="custom-file">
                                        <input type="file" class="custom-file-input" id="logoMax" name="logoMax" onchange="LogoMax();" accept="image/png,image/gif,image/jpeg">
                                        <label id="lblLogoMax" class="custom-file-label" for="logoMax">@PCM.ADM.WEB.Properties.Resources.selecione_arquivo</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")

    <script>

        function LogoMin() {
            document.getElementById("lblLogoMin").textContent = document.getElementById("logoMin").files[0].name;
        }

        function LogoMax() {
            document.getElementById("lblLogoMax").textContent = document.getElementById("logoMax").files[0].name;
        }

        $(document).ready(function () {
            $("#cnpj").mask("99.999.999/9999-99");
            $("#cep").mask("99.999-999");
            $("#telefone").mask("(99) 99999-9999");
            $("#data").mask("99/99/9999");
            $("#valor").maskMoney({ prefix: 'R$ ', thousands: '.', decimal: ',', precision: 2, allowNegative: false, 'placeholder': '' });
        });

        jQuery.validator.addMethod("cnpj", function (cnpj, element) {

            cnpj = cnpj.replace(".", "");
            cnpj = cnpj.replace(".", "");
            cnpj = cnpj.replace("/", "");
            cnpj = cnpj.replace("-", "");

            var numeros, digitos, soma, resultado, pos, tamanho,
                digitos_iguais = true;

            if (cnpj.length < 14 && cnpj.length > 15)
                return false;

            for (var i = 0; i < cnpj.length - 1; i++)
                if (cnpj.charAt(i) != cnpj.charAt(i + 1)) {
                    digitos_iguais = false;
                    break;
                }

            if (!digitos_iguais) {
                tamanho = cnpj.length - 2
                numeros = cnpj.substring(0, tamanho);
                digitos = cnpj.substring(tamanho);
                soma = 0;
                pos = tamanho - 7;

                for (i = tamanho; i >= 1; i--) {
                    soma += numeros.charAt(tamanho - i) * pos--;
                    if (pos < 2)
                        pos = 9;
                }

                resultado = soma % 11 < 2 ? 0 : 11 - soma % 11;

                if (resultado != digitos.charAt(0))
                    return false;

                tamanho = tamanho + 1;
                numeros = cnpj.substring(0, tamanho);
                soma = 0;
                pos = tamanho - 7;

                for (i = tamanho; i >= 1; i--) {
                    soma += numeros.charAt(tamanho - i) * pos--;
                    if (pos < 2)
                        pos = 9;
                }

                resultado = soma % 11 < 2 ? 0 : 11 - soma % 11;

                if (resultado != digitos.charAt(1))
                    return false;

                return true;
            }

            return false;
        }, "Informe um CNPJ v&aacute;lido.");

        jQuery.validator.addMethod("cnpj_bd", function (value, element) {

            var dataString = {
                "cnpj": value,
                "codigo": @Model.codigo
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaEmpresa",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "Informe um CNPJ v&aacute;lido.");

        jQuery.validator.addMethod("validate_email_bd", function (value, element) {

            var dataString = {
                "email": value,
                "codigo": -1
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaUsuario",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "");

        function LoadCEP() {

            var cep = $('#cep').val();

            if (cep != "") {
                $.ajax({
                    type: 'POST',
                    url: 'CEPInfo',
                    data: { "cep": cep },
                    success: function (dados) {
                        if (dados.length > 0) {
                            $.each(dados, function (i, obj) {
                                $("#uf").val(obj.uf);
                                $("#municipio").val(obj.municipio);
                                $("#logradouro").val(obj.logradouro);
                                $("#bairro").val(obj.bairro);
                                $("#uf").select2({ disabled: true });
                                $("#municipio").prop('disabled', true);
                                $("#logradouro").prop('disabled', true);
                                $("#bairro").prop('disabled', true);
                            })
                        }
                        else {
                            $("#cep").val("");
                            $("#uf").val("");
                            $("#municipio").val("");
                            $("#logradouro").val("");
                            $("#bairro").val("");
                            $("#uf").select2({ disabled: false });
                            $("#municipio").prop('disabled', false);
                            $("#logradouro").prop('disabled', false);
                            $("#bairro").prop('disabled', false);
                        };
                    }
                });
            }
            else {
                $("#uf").val("");
                $("#municipio").val("");
                $("#logradouro").val("");
                $("#bairro").val("");
                $("#uf").select2({ disabled: false });
                $("#municipio").prop('disabled', false);
                $("#logradouro").prop('disabled', false);
                $("#bairro").prop('disabled', false);
            }
        }

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'tipo_empresa': {
                            required: true
                        },
                        'cnpj': {
                            required: true,
                            cnpj: true,
                            cnpj_bd: true,
                        },
                        'nome_fantasia': {
                            required: true
                        },
                        'razao_social': {
                            required: true
                        },
                        'cep': {
                            required: true
                        },
                        'uf': {
                            required: true
                        },
                        'municipio': {
                            required: true
                        }
                    },
                    messages: {
                        'tipo_empresa': {
                            required: '@PCM.ADM.WEB.Properties.Resources.campo_requerido'
                        },
                        'cnpj': {
                            required: '@PCM.ADM.WEB.Properties.Resources.campo_requerido',
                            cnpj: '@PCM.ADM.WEB.Properties.Resources.valida_cnpj_invalido',
                            cnpj_bd: '@PCM.ADM.WEB.Properties.Resources.valida_cnpj_bd',
                        },
                        'nome_fantasia': {
                            required: '@PCM.ADM.WEB.Properties.Resources.campo_requerido'
                        },
                        'razao_social': {
                            required: '@PCM.ADM.WEB.Properties.Resources.campo_requerido'
                        },
                        'cep': {
                            required: '@PCM.ADM.WEB.Properties.Resources.campo_requerido'
                        },
                        'uf': {
                            required: '@PCM.ADM.WEB.Properties.Resources.campo_requerido'
                        },
                        'municipio': {
                            required: '@PCM.ADM.WEB.Properties.Resources.campo_requerido'
                        }
                    },
                    submitHandler: function (form) {
                        $("#uf").select2({ disabled: false });
                        $("#municipio").prop('disabled', false);
                        $("#logradouro").prop('disabled', false);
                        $("#bairro").prop('disabled', false);
                        form.submit();
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
        });

    </script>

}