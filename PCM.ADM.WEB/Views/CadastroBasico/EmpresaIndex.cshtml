@model IEnumerable<PCM.WEB.MODELS.Empresa>

<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action("Index", "Home")">@PCM.ADM.WEB.Properties.Resources.sistema</a>
                <span class="breadcrumb-item">@PCM.ADM.WEB.Properties.Resources.cadastro_basico</span>
                <span class="breadcrumb-item active">@PCM.ADM.WEB.Properties.Resources.empresa</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">        

        <!-- Listagem -->
        <div class="block block-rounded border">

            <div class="block-header block-header-default bg-gd-default">
                <h3 class="block-title text-white font-w600">@PCM.ADM.WEB.Properties.Resources.listagem</h3>
                @if(ViewBag.inserir)
                {
                    <div class="block-options">
                        <a href="@Url.Action("EmpresaInsert", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                            <i class="fa fa-save mr-5"></i>@PCM.ADM.WEB.Properties.Resources.novo
                        </a>
                    </div>
                }
            </div>            
            
            <div class="block-content block-content-full">
                <!-- DataTables init on table by adding .js-dataTable-full-pagination class, functionality initialized in js/pages/be_tables_datatables.js -->
                <table class="table table-sm table-vcenter table-striped js-dataTable-list">

                    <thead>
                        <tr class="table-secondary">
                            <th class="d-none d-sm-table-cell text-center">@PCM.ADM.WEB.Properties.Resources.tipo</th>
                            <th class="d-none d-sm-table-cell text-center">@PCM.ADM.WEB.Properties.Resources.cnpj</th>
                            <th>@PCM.ADM.WEB.Properties.Resources.nome_fantasia</th>
                            <th class="d-none d-sm-table-cell text-center">@PCM.ADM.WEB.Properties.Resources.uf</th>
                            <th class="d-none d-sm-table-cell text-center">@PCM.ADM.WEB.Properties.Resources.municipio</th>
                            <th class="d-none d-sm-table-cell text-center" style="width: 100px;">@PCM.ADM.WEB.Properties.Resources.valor</th>
                            <th class="d-none d-sm-table-cell text-center" style="width: 80px;">@PCM.ADM.WEB.Properties.Resources.ativo</th>
                            <th class="text-center" style="width: 80px;" data-sortable="false"></th>
                        </tr>
                    </thead>

                    <tbody>                       
                        @foreach (var item in Model)
                        {
                        <tr>
                            <td class="d-none d-sm-table-cell text-center">@Html.DisplayFor(modelItem => item.tipo)</td>
                            <td class="d-none d-sm-table-cell text-center">@Html.DisplayFor(modelItem => item.cnpj)</td>
                            <td>@Html.DisplayFor(modelItem => item.nome_fantasia)</td>
                            <td class="d-none d-sm-table-cell text-center">@Html.DisplayFor(modelItem => item.uf)</td>
                            <td class="d-none d-sm-table-cell text-center">@Html.DisplayFor(modelItem => item.municipio)</td>
                            <td class="d-none d-sm-table-cell text-center" style="width: 100px;">@Html.DisplayFor(modelItem => item.valor)</td>
                            <td class="d-none d-sm-table-cell text-center" style="width: 80px;">
                                <label class="css-control-sm css-control-secondary css-checkbox">
                                    @Html.CheckBoxFor(modelItem => item.ativo, new { @class = "css-control-input", @disabled = "disabled" })
                                    <span class="css-control-indicator"></span>
                                </label>
                            </td>
                            <td class="text-center" style="width: 80px;">
                                <div class="btn-group">
                                    <a href="@Url.Action("EmpresaEdit", "CadastroBasico", new { codigo = item.codigo })" class="btn btn-sm btn-secondary"><i class="fa fa-pencil"></i></a>
                                    <a href="@Url.Action("EmpresaDelete", "CadastroBasico", new { codigo = item.codigo })" class="btn btn-sm btn-secondary"><i class="fa fa-times"></i></a>
                                </div>
                            </td>
                        </tr>
                        }
                    </tbody>

                </table>
            </div>
          
        </div>

    </div>
    <!-- END Page Content -->

</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/dataTables")
}

@section Scripts {
    @Scripts.Render("~/plugins/dataTables")

    <script type="text/javascript">

        var BeTableDatatables = function () {
            // Override a few DataTable defaults, for more examples you can check out https://www.datatables.net/
            var exDataTable = function () {
                jQuery.extend(jQuery.fn.dataTable.ext.classes, {
                    sWrapper: "dataTables_wrapper dt-bootstrap4"
                });
            };

            // Init simple DataTable, for more examples you can check out https://www.datatables.net/
            var initDataTableSimple = function () {
                jQuery('.js-dataTable-list').dataTable({
                    fixedHeader: true,
                    searching: true,
                    lengthChange: false,
                    pageLength: 15,
                    autoWidth: false,
                    scrollX: false,
                    scrollColapse: true,
                    dom: 'Bfrtip',
                    buttons: [
                        { extend: 'copy', text: 'Copiar' },
                        {
                            extend: 'print',
                            text: 'Imprimir'
                        },
                        { extend: 'excel' },
                        { extend: 'pdf', orientation: 'portrait' },
                    ],
                    language: {
                        "search": "Procurar:",
                        "lengthMenu": "Exibir _MENU_ ",
                        "zeroRecords": "Nenhum Registro Encontrado",
                        "info": "_MAX_ registro(s)",
                        "infoEmpty": "Nenhum Registro encontrado",
                        "infoFiltered": "(filtrado de _MAX_ registro(s))"
                    }
                });
            };

            return {
                init: function () {
                    // Override a few DataTable defaults
                    exDataTable();

                    // Init Datatables
                    initDataTableSimple();
                }
            };
        }();


        // Initialize when page loads
        jQuery(function () { BeTableDatatables.init(); });

    </script>
}
