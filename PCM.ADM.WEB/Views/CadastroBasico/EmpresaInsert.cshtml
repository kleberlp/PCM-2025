</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")

    <script>

        function LogoMin() {
            document.getElementById("lblLogoMin").textContent = document.getElementById("logoMin").files[0].name;
        }

        function LogoMax() {
            document.getElementById("lblLogoMax").textContent = document.getElementById("logoMax").files[0].name;
        }

        $(document).ready(function () {
            $("#cnpj").mask("99.999.999/9999-99");
            $("#cep").mask("99.999-999");
            $("#telefone").mask("(99) 99999-9999");
            $("#data").mask("99/99/9999");
            $("#valor").maskMoney({ prefix: 'R$ ', thousands: '.', decimal: ',', precision: 2, allowNegative: false, 'placeholder': '' });
            $("#email").attr("autocomplete", "off");
            $("#senha").attr("autocomplete", "off");
            $("#confirmar_senha").attr("autocomplete", "off");
            $("#url").attr("autocomplete", "off");
            $("#email").prop("readonly", false);
            $("#senha").prop("readonly", false);
            $("#confirmar_senha").prop("readonly", false);            
            $("#url").prop("readonly", false);
        });

        jQuery.validator.addMethod("cnpj", function (cnpj, element) {

            cnpj = cnpj.replace(".", "");
            cnpj = cnpj.replace(".", "");
            cnpj = cnpj.replace("/", "");
            cnpj = cnpj.replace("-", "");

            var numeros, digitos, soma, resultado, pos, tamanho,
                digitos_iguais = true;

            if (cnpj.length < 14 && cnpj.length > 15)
                return false;

            for (var i = 0; i < cnpj.length - 1; i++)
                if (cnpj.charAt(i) != cnpj.charAt(i + 1)) {
                    digitos_iguais = false;
                    break;
                }

            if (!digitos_iguais) {
                tamanho = cnpj.length - 2
                numeros = cnpj.substring(0, tamanho);
                digitos = cnpj.substring(tamanho);
                soma = 0;
                pos = tamanho - 7;

                for (i = tamanho; i >= 1; i--) {
                    soma += numeros.charAt(tamanho - i) * pos--;
                    if (pos < 2)
                        pos = 9;
                }

                resultado = soma % 11 < 2 ? 0 : 11 - soma % 11;

                if (resultado != digitos.charAt(0))
                    return false;

                tamanho = tamanho + 1;
                numeros = cnpj.substring(0, tamanho);
                soma = 0;
                pos = tamanho - 7;

                for (i = tamanho; i >= 1; i--) {
                    soma += numeros.charAt(tamanho - i) * pos--;
                    if (pos < 2)
                        pos = 9;
                }

                resultado = soma % 11 < 2 ? 0 : 11 - soma % 11;

                if (resultado != digitos.charAt(1))
                    return false;

                return true;
            }

            return false;
        }, "Informe um CNPJ v&aacute;lido.");

        jQuery.validator.addMethod("cnpj_bd", function (value, element) {

            var dataString = {
                "cnpj": value,
                "codigo": -1
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaEmpresa",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "Informe um CNPJ v&aacute;lido.");

        jQuery.validator.addMethod("validate_email_bd", function (value, element) {

            var dataString = {
                "email": value,
                "codigo": -1
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaUsuario",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "");

        function LoadCEP() {

            var cep = $('#cep').val();

            if (cep != "") {
                $.ajax({
                    type: 'POST',
                    url: 'CEPInfo',
                    data: { "cep": cep },
                    success: function (dados) {
                        if (dados.length > 0) {
                            $.each(dados, function (i, obj) {
                                $("#uf").val(obj.uf);
                                $("#municipio").val(obj.municipio);
                                $("#logradouro").val(obj.logradouro);
                                $("#bairro").val(obj.bairro);
                                $("#uf").select2({ disabled: true });
                                $("#municipio").prop('disabled', true);
                                $("#logradouro").prop('disabled', true);
                                $("#bairro").prop('disabled', true);
                            })
                        }
                        else {
                            $("#cep").val("");
                            $("#uf").val("");
                            $("#municipio").val("");
                            $("#logradouro").val("");
                            $("#bairro").val("");
                            $("#uf").select2({ disabled: false });                            
                            $("#municipio").prop('disabled', false);
                            $("#logradouro").prop('disabled', false);
                            $("#bairro").prop('disabled', false);
                        };
                    }
                });
            }
            else {
                $("#uf").val("");
                $("#municipio").val("");
                $("#logradouro").val("");
                $("#bairro").val("");
                $("#uf").select2({ disabled: false });
                $("#municipio").prop('disabled', false);
                $("#logradouro").prop('disabled', false);
                $("#bairro").prop('disabled', false);
            }
        }

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'tipo_empresa': {
                            required: true
                        },
                        'cnpj': {
                            required: true,
                            cnpj: true,
