<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action("Index", "Home")">@PCM.ADM.WEB.Properties.Resources.sistema</a>
                <span class="breadcrumb-item">@PCM.ADM.WEB.Properties.Resources.cadastro_basico</span>
                <a class="breadcrumb-item" href="@Url.Action("EmpresaIndex", "CadastroBasico")">@PCM.ADM.WEB.Properties.Resources.empresa</a>
                <span class="breadcrumb-item active">@PCM.ADM.WEB.Properties.Resources.inserir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->
    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">
                @using (Html.BeginForm("EmpresaInsert", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data", autocomplete = "off" }))
                {
                    @Html.AntiForgeryToken()

                <div class="block block-rounded border">

                    <div class="block-header block-header-default bg-gd-default">
                        <h3 class="block-title text-white font-w600">@PCM.ADM.WEB.Properties.Resources.cadastrar</h3>
                        <div class="block-options">
                            <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                <i class="fa fa-save mr-5"></i>@PCM.ADM.WEB.Properties.Resources.salvar
                            </button>
                            <a href="@Url.Action("EmpresaIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                <i class="si si-action-undo mr-5"></i>@PCM.ADM.WEB.Properties.Resources.voltar
                            </a>
                        </div>
                    </div>

                    <div class="block-content block-content-full">

                        <div class="form-group row">
                            <div class="col-md-3">
                                <label for="tipo_empresa">@PCM.ADM.WEB.Properties.Resources.tipo_empresa</label>
                                @Html.DropDownList("tipo_empresa", null, "", new { @class = "form-control" })
                            </div>
                            <div class="col-md-9">
                                <label for="nome_fantasia">@PCM.ADM.WEB.Properties.Resources.nome_fantasia</label>
                                <input type="text" class="form-control js-maxlength" id="nome_fantasia" name="nome_fantasia" maxlength="120" value="">
                            </div>
                        </div>

                        <div class="form-group row">
                            <div class="col-md-3">
                                <label for="cnpj">@PCM.ADM.WEB.Properties.Resources.cnpj</label>
                                <input type="text" class="form-control" id="cnpj" name="cnpj" value="">
                            </div>
                            <div class="col-md-3">
                                <label for="inscricao_estadual">@PCM.ADM.WEB.Properties.Resources.inscricao_estadual</label>
                                <input type="text" class="js-maxlength form-control" id="inscricao_estadual" name="inscricao_estadual" maxlength="20" value="">
                            </div>
                            <div class="col-md-3">
                                <label for="inscricao_municipal">@PCM.ADM.WEB.Properties.Resources.inscricao_municipal</label>
                                <input type="text" class="js-maxlength form-control" id="inscricao_municipal" name="inscricao_municipal" maxlength="20" value="">
                            </div>
                            <div class="col-md-3">
                                <label for="cep">@PCM.ADM.WEB.Properties.Resources.cep</label>
                                <input type="text" class="form-control" id="cep" name="cep" maxlength="10" onblur="LoadCEP();" value="">
                            </div>
                        </div>

                        <div class="form-group row">
                            <div class="col-md-2">
                                <label for="uf">@PCM.ADM.WEB.Properties.Resources.uf</label>
                                @Html.DropDownList("uf", null, "", new { @class = "form-control" })
                            </div>
                            <div class="col-md-4">
                                <label for="municipio">@PCM.ADM.WEB.Properties.Resources.municipio</label>
                                <input type="text" class="js-maxlength form-control" id="municipio" name="municipio" maxlength="100" value="">
                            </div>
                            <div class="col-md-4">
                                <label for="logradouro">@PCM.ADM.WEB.Properties.Resources.logradouro</label>
                                <input type="text" class="js-maxlength form-control" id="logradouro" name="logradouro" maxlength="100" value="">
                            </div>
                            <div class="col-md-2">
                                <label for="numero">@PCM.ADM.WEB.Properties.Resources.numero</label>
                                <input type="text" class="js-maxlength form-control" id="numero" name="numero" maxlength="60" value="">
                            </div>
                        </div>

                        <div class="form-group row">
                            <div class="col-md-3">
                                <label for="bairro">@PCM.ADM.WEB.Properties.Resources.bairro</label>
                                <input type="text" class="js-maxlength form-control" id="bairro" name="bairro" maxlength="100" value="">
                            </div>
                            <div class="col-md-6">
                                <label for="complemento">@PCM.ADM.WEB.Properties.Resources.complemento</label>
                                <input type="text" class="js-maxlength form-control" id="complemento" name="complemento" maxlength="100" value="">
                            </div>
                            <div class="col-md-3">
