                        <h3 class="block-title text-white font-w600">@PCM.ADM.WEB.Properties.Resources.financeiro</h3>
                    </div>

                    <div class="block-content block-content-full">

                        <div class="form-group row">
                            <div class="col-md-2">
                                <label for="valor">@PCM.ADM.WEB.Properties.Resources.valor</label>
                                <input type="text" id="valor" name="valor" class="form-control" />
                            </div>
                            <div class="col-md-2">
                                <label for="data_inicio">@PCM.ADM.WEB.Properties.Resources.data_inicio</label>
                                <input type="text" class="js-datepicker form-control" id="data_inicio" name="data_inicio" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="">
                            </div>
                        </div>

                    </div>

                    <div class="block-header block-header-default bg-gd-default">
                        <h3 class="block-title text-white font-w600">@PCM.ADM.WEB.Properties.Resources.usuario @PCM.ADM.WEB.Properties.Resources.administrador</h3>
                    </div>

                    <div class="block-content block-content-full">

                        <div class="form-group row">
                            <div class="col-md-4">
                                <label for="email">@PCM.ADM.WEB.Properties.Resources.email</label>
                                <input type="email" id="email" name="email" class="form-control js-maxlength" style="text-transform: lowercase" maxlength="150" required autocomplete="off" readonly />
                            </div>
                            <div class="col-md-2">
                                <label for="senha">@PCM.ADM.WEB.Properties.Resources.senha</label>
                                <input type="password" id="senha" name="senha" class="form-control js-maxlength" maxlength="20" required autocomplete="off" readonly />
                            </div>
                            <div class="col-md-2">
                                <label for="confirmar_senha">@PCM.ADM.WEB.Properties.Resources.confirmar_senha</label>
                                <input type="password" id="confirmar_senha" name="confirmar_senha" class="form-control js-maxlength" maxlength="20" required autocomplete="off" readonly />
                            </div>
