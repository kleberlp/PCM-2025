                    <div class="block-header block-header-default bg-gd-default">
                        <h3 class="block-title text-white font-w600">@PCM.ADM.WEB.Properties.Resources.usuario @PCM.ADM.WEB.Properties.Resources.acesso</h3>
                    </div>

                    <div class="block-content block-content-full">

                        <div class="form-group row">
                            <div class="col-md-4">
                                <label for="email">@PCM.ADM.WEB.Properties.Resources.url</label>
                                <input type="text" id="url" name="url" class="form-control js-maxlength" style="text-transform: lowercase" maxlength="50" required autocomplete="off" readonly />
                            </div>
                        </div>

                    </div>

                    <div class="block-header block-mode-loading-repeat block-header-default bg-gd-default">
                        <h3 class="block-title text-white font-w600">@PCM.ADM.WEB.Properties.Resources.logo</h3>
                    </div>
                    <div class="block-content block-content-full">
                        <div class="form-group row">
                            <div class="col-12">
                                <label>Logo tamanho: (250 x 120)</label>
                                <div class="custom-file">
                                    <input type="file" class="custom-file-input" id="logoMin" name="logoMin" onchange="LogoMin();" accept="image/png,image/gif,image/jpeg">
                                    <label id="lblLogoMin" class="custom-file-label" for="logoMin">@PCM.ADM.WEB.Properties.Resources.selecione_arquivo</label>
                                </div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <div class="col-12">
                                <label>Logo tamanho: (500 x 500)</label>
                                <div class="custom-file">
                                    <input type="file" class="custom-file-input" id="logoMax" name="logoMax" onchange="LogoMax();" accept="image/png,image/gif,image/jpeg">
                                    <label id="lblLogoMax" class="custom-file-label" for="logoMax">@PCM.ADM.WEB.Properties.Resources.selecione_arquivo</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="block-header block-header-default bg-gd-default">
                        <h3 class="block-title text-white font-w600">@PCM.ADM.WEB.Properties.Resources.usuario @PCM.ADM.WEB.Properties.Resources.modulo</h3>
                    </div>

                    <table class="table table-sm table-vcenter table-striped js-dataTable-list">

                        <tbody>
                            <tr>
                                <td class="d-none d-sm-table-cell text-center" style="width: 80px;">
                                    <label class="css-control-sm css-control-secondary css-checkbox">
                                        <input type="checkbox" class="css-control-input" id="auditoria" name="auditoria" checked value="true">
                                        <span class="css-control-indicator"></span>
                                    </label>
                                </td>
                                <td class="d-none d-sm-table-cell">@PCM.ADM.WEB.Properties.Resources.auditoria</td>
                            </tr>
                            <tr>
                                <td class="d-none d-sm-table-cell text-center" style="width: 80px;">
                                    <label class="css-control-sm css-control-secondary css-checkbox">
                                        <input type="checkbox" class="css-control-input" id="aeb" name="aeb" checked value="true">
                                        <span class="css-control-indicator"></span>
                                    </label>
                                </td>
                                <td class="d-none d-sm-table-cell">@PCM.ADM.WEB.Properties.Resources.aeb</td>
                            </tr>
                            <tr>
                                <td class="d-none d-sm-table-cell text-center" style="width: 80px;">
                                    <label class="css-control-sm css-control-secondary css-checkbox">
                                        <input type="checkbox" class="css-control-input" id="estoque" name="estoque" checked value="true">
                                        <span class="css-control-indicator"></span>
                                    </label>
                                </td>
                                <td class="d-none d-sm-table-cell">@PCM.ADM.WEB.Properties.Resources.estoque</td>
                            </tr>
                            <tr>
                                <td class="d-none d-sm-table-cell text-center" style="width: 80px;">
                                    <label class="css-control-sm css-control-secondary css-checkbox">
                                        <input type="checkbox" class="css-control-input" id="financas" name="financas" checked value="true">
                                        <span class="css-control-indicator"></span>
                                    </label>
                                </td>
                                <td class="d-none d-sm-table-cell">@PCM.ADM.WEB.Properties.Resources.financas</td>
                            </tr>
                            <tr>
                                <td class="d-none d-sm-table-cell text-center" style="width: 80px;">
                                    <label class="css-control-sm css-control-secondary css-checkbox">
                                        <input type="checkbox" class="css-control-input" id="governanca" name="governanca" checked value="true">
                                        <span class="css-control-indicator"></span>
                                    </label>
                                </td>
                                <td class="d-none d-sm-table-cell">@PCM.ADM.WEB.Properties.Resources.governanca</td>
                            </tr>
                            <tr>
                                <td class="d-none d-sm-table-cell text-center" style="width: 80px;">
                                    <label class="css-control-sm css-control-secondary css-checkbox">
                                        <input type="checkbox" class="css-control-input" id="green_planet" name="green_planet" checked value="true">
                                        <span class="css-control-indicator"></span>
                                    </label>
                                </td>
                                <td class="d-none d-sm-table-cell">@PCM.ADM.WEB.Properties.Resources.green_planet</td>
                            </tr>
                            <tr>
                                <td class="d-none d-sm-table-cell text-center" style="width: 80px;">
                                    <label class="css-control-sm css-control-secondary css-checkbox">
                                        <input type="checkbox" class="css-control-input" id="log_book" name="log_book" checked value="true">
                                        <span class="css-control-indicator"></span>
                                    </label>
                                </td>
                                <td class="d-none d-sm-table-cell">@PCM.ADM.WEB.Properties.Resources.log_book</td>
                            </tr>
                            <tr>
                                <td class="d-none d-sm-table-cell text-center" style="width: 80px;">
                                    <label class="css-control-sm css-control-secondary css-checkbox">
                                        <input type="checkbox" class="css-control-input" id="laudo" name="laudo" checked value="true">
                                        <span class="css-control-indicator"></span>
                                    </label>
                                </td>
                                <td class="d-none d-sm-table-cell">@PCM.ADM.WEB.Properties.Resources.pcm - @PCM.ADM.WEB.Properties.Resources.laudo</td>
                            </tr>
