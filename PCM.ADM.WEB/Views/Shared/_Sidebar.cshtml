<!-- Side Overlay-->
<aside id="side-overlay">
    <!-- Side Overlay Scroll Container -->
    <div id="side-overlay-scroll">
        <!-- Side Header -->
        <div class="content-header content-header-fullrow">
            <div class="content-header-section align-parent">
                <!-- Close Side Overlay -->
                <!-- Layout API, functionality initialized in Codebase() -> uiApiLayout() -->
                <button type="button" class="btn btn-circle btn-dual-secondary align-v-r" id="btnClose" data-toggle="layout" data-action="side_overlay_close">
                    <i class="fa fa-times text-danger"></i>
                </button>
                <!-- END Close Side Overlay -->
                <!-- User Info -->
                <div class="content-header-item">
                    <a class="align-middle link-effect text-primary-dark font-w600" href="#">@Session["nome"]</a>
                </div>
                <!-- END User Info -->
            </div>
        </div>
        <!-- END Side Header -->
        <!-- Side Content -->
        <div class="content-side">

            <form id="frmsidebar" class="border-r">
                <!-- Profile -->
                <div class="block pull-r-l">
                    <div class="block-header bg-body-light">
                        <h3 class="block-title">
                            <i class="fa fa-fw fa-pencil font-size-default mr-5"></i>Perfil
                        </h3>
                        <div class="block-options">
                            <button type="button" class="btn-block-option" data-toggle="block-option" data-action="content_toggle"></button>
                        </div>
                    </div>
                    <div class="block-content">
                        <div class="form-group mb-15">
                            <label for="side-overlay-profile-name">@PCM.ADM.WEB.Properties.Resources.nome</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="nome_perfil" name="nome_perfil" placeholder="Seu Nome.." value=@Session["nome"]>
                                <div class="input-group-append">
                                    <span class="input-group-text">
                                        <i class="fa fa-user"></i>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="form-group mb-15">
                            <label for="side-overlay-profile-email">@PCM.ADM.WEB.Properties.Resources.email</label>
                            <div class="input-group">
                                <input type="email" disabled class="form-control" id="email_perfil" name="email_perfil" placeholder="Seu E-mail.." value=@Session["email"]>
                                <div class="input-group-append">
                                    <span class="input-group-text">
                                        <i class="fa fa-envelope"></i>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="form-group mb-15">
                            <label for="side-overlay-profile-password">@PCM.ADM.WEB.Properties.Resources.senha</label>
                            <div class="input-group">
                                <input type="password" class="form-control" id="senha_perfil" name="senha_perfil" placeholder="Nova Senha..">
                                <div class="input-group-append">
                                    <span class="input-group-text">
                                        <i class="fa fa-asterisk"></i>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="form-group mb-15">
                            <label for="side-overlay-profile-password-confirm">@PCM.ADM.WEB.Properties.Resources.confirmar_senha</label>
                            <div class="input-group">
                                <input type="password" class="form-control" id="confirmar_senha_perfil" name="confirmar_senha_perfil" placeholder="Confirmar Nova Senha..">
                                <div class="input-group-append">
                                    <span class="input-group-text">
                                        <i class="fa fa-asterisk"></i>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <div class="col-6">
                                <button type="submit" id="salvar_usuario" name="salvar_usuario" class="btn btn-square btn-secondary min-width-100">
                                    <i class="fa fa-refresh mr-5"></i> @PCM.ADM.WEB.Properties.Resources.salvar
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END Profile -->
            </form>

        </div>
        <!-- END Side Content -->
    </div>
    <!-- END Side Overlay Scroll Container -->
</aside>
<!-- END Side Overlay -->
<!-- Sidebar -->
<!--
    Helper classes

    Adding .sidebar-mini-hide to an element will make it invisible (opacity: 0) when the sidebar is in mini mode
    Adding .sidebar-mini-show to an element will make it visible (opacity: 1) when the sidebar is in mini mode
        If you would like to disable the transition, just add the .sidebar-mini-notrans along with one of the previous 2 classes

    Adding .sidebar-mini-hidden to an element will hide it when the sidebar is in mini mode
    Adding .sidebar-mini-visible to an element will show it only when the sidebar is in mini mode
        - use .sidebar-mini-visible-b if you would like to be a block when visible (display: block)
-->
<nav id="sidebar">

    <!-- Sidebar Scroll Container -->
    <div id="sidebar-scroll">

        <!-- Sidebar Content -->
        <div class="sidebar-content">

            <!-- Side User -->
            <div class="content-side content-side-full content-side-user px-10 align-parent">

                <!-- Visible only in mini mode -->
                <div class="sidebar-mini-visible-b align-v animated fadeIn">
                    <img class="img-avatar img-avatar32" src="@Session["imagem_sidebar_min"]" alt="">
                </div>
                <!-- END Visible only in mini mode -->
                <!-- Visible only in normal mode -->
                <div class="sidebar-mini-hidden text-center">
                    <img class="img-avatar img-avatar128" src="@Session["imagem_sidebar"]" alt="">
                    <ul class="list-inline mt-10">
                        <li class="list-inline-item">
                            <a class="link-effect text-primary-dark font-size-xs font-w600 text-uppercase" href="#">@Session["nome"]</a>
                        </li>
                        <li class="list-inline-item">
                            <a class="link-effect text-dual-primary" href="@Url.Action("LogOff", "Account")">
                                <i class="si si-logout"></i>
                            </a>
                        </li>
                    </ul>
                </div>
                <!-- END Visible only in normal mode -->

            </div>
            <!-- END Side User -->
            <!-- Side Navigation -->
            <div class="content-side content-side-full">

                <ul class="nav-main">
                    
                    <li>
                        <a class="@Html.IsSelected(action: "Index", cssClass: "active") font-size-sm" href="@Url.Action("Index", "Home")"><i class="si si-graph"></i><span class="sidebar-mini-hide">@PCM.ADM.WEB.Properties.Resources.dashboard</span></a>
                    </li>                    
                    <li class="@Html.IsSelected(controller: "CadastroBasico", cssClass: "open")">
                        <a class="nav-submenu font-size-sm" data-toggle="nav-submenu" href="#"><i class="si si-note"></i><span class="sidebar-mini-hide">@PCM.ADM.WEB.Properties.Resources.cadastro_basico</span></a>
                        <ul>
                            <li>
                                <a class="@Html.IsSelected(action: "Empresa", cssClass: "active") font-size-sm" href="@Url.Action("EmpresaIndex", "CadastroBasico")"><span class="sidebar-mini-hide">@PCM.ADM.WEB.Properties.Resources.empresa</span></a>
                            </li>
                        </ul>
                    </li>

                </ul>
            </div>
            <!-- END Side Navigation -->
        </div>
        <!-- Sidebar Content -->
    </div>
    <!-- END Sidebar Scroll Container -->
</nav>
<!-- END Sidebar -->
