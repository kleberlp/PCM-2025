
<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-5 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@INTERACTI.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("EquipamentoIndex", "CadastroBasico")">@INTERACTI.WEB.Properties.Resources.equipamento</a>
                <span class="breadcrumb-item active">@INTERACTI.WEB.Properties.Resources.inserir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">                
                @using (Html.BeginForm("EquipamentoInsert", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="block block-rounded block-themed">
                        <div class="block-header bg-gd-primary">
                            <h3 class="block-title">@INTERACTI.WEB.Properties.Resources.informacoes</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-sm btn-alt-primary">
                                    <i class="fa fa-save mr-5"></i>@INTERACTI.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("EquipamentoIndex", "CadastroBasico")" class="btn btn-sm btn-alt-primary">
                                    <i class="si si-action-undo mr-5"></i>@INTERACTI.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full"> 
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.tag</label>
                                <div class="col-12"><input type="text" class="form-control" id="tag" name="tag" value="" maxlength="20"></div>
                            </div>                     
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.descricao</label>
                                <div class="col-12"><input type="text" class="form-control" id="descricao" name="descricao" value="" maxlength="200"></div>
                            </div>
                             <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.setor</label>
                                <div class="col-12">@Html.DropDownList("setor", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.fabricante</label>
                                <div class="col-12"><input type="text" class="form-control" id="fabricante" name="fabricante" value="" maxlength="100"></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.endereco_fabricante</label>
                                <div class="col-12"><input type="text" class="form-control" id="endereco_fabricante" name="endereco_fabricante" value="" maxlength="200"></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.contato_fabricante</label>
                                <div class="col-12"><input type="text" class="form-control" id="contato_fabricante" name="contato_fabricante" value="" maxlength="100"></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.modelo</label>
                                <div class="col-12"><input type="text" class="form-control" id="modelo" name="modelo" value="" maxlength="100"></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.numero_fabricacao</label>
                                <div class="col-12"><input type="text" class="form-control" id="numero_fabricacao" name="numero_fabricacao" value=""></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.ano_fabricacao</label>
                                <div class="col-12"><input type="text" class="form-control" id="ano_fabricacao" name="ano_fabricacao" value="" maxlength="50"></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.caracteristicas</label>
                                <div class="col-12"><textarea class="form-control" id="caracteristicas" name="caracteristicas" maxlength="500"></textarea></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.descricao_operacao</label>
                                <div class="col-12"><textarea class="form-control" id="descricao_operacao" name="descricao_operacao" maxlength="2000"></textarea></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.instrucao_utilizacao</label>
                                <div class="col-12"><textarea class="form-control" id="instrucao_utilizacao" name="instrucao_utilizacao" maxlength="2000"></textarea></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.procedimento_emergencia</label>
                                <div class="col-12"><textarea class="form-control" id="procedimento_emergencia" name="procedimento_emergencia" maxlength="2000"></textarea></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.treinamento_operador</label>
                                <div class="col-12"><textarea class="form-control" id="treinamento_operador" name="treinamento_operador" maxlength="2000"></textarea></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.condicao_seguranca</label>
                                <div class="col-12"><textarea class="form-control" id="condicao_seguranca" name="condicao_seguranca" maxlength="2000"></textarea></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.indicacao_conclusiva</label>
                                <div class="col-12"><textarea class="form-control" id="indicacao_conclusiva" name="indicacao_conclusiva" maxlength="2000"></textarea></div>
                            </div>
                            <div class="form-group row">
                            <label class="col-12">@INTERACTI.WEB.Properties.Resources.ativo</label>
                            <div class="col-12">
                                <label class="css-control css-control-success css-switch">
                                    <input type="checkbox" class="css-control-input" id="ativo" name="ativo" checked value ="true">
                                    <span class="css-control-indicator"></span>
                                </label>
                            </div>
                            </div>
                        </div>                        
                    </div>   
                }
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Scripts {
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/bundles/cookie")    
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/select")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/bundles/codebase")

    <script>

          jQuery.validator.addMethod("tag_bd", function (value, element) {

              var unidade = $("#unidade").val();

              var dataString = {
                  "unidade": unidade,
                  "tag": value,
                  "codigo": -1
              };

              var result = false;

              jQuery.ajax({
                  type: "POST",
                  url: "ValidaEquipamento",
                  async: false,
                  data: dataString,
                  dataType: "json",
                  success: function (return_data) {
                      if (return_data == false) {
                          result = false;
                      } else if (return_data == true) {
                          result = true;
                      }
                  }
              });

              return result;

          }, "");

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'tag': {
                            required: true,
                            tag_bd: true
                        },
                        'descricao': {
                            required: true
                        },
                        'setor': {
                            required: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'tag': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido',
                            tag_bd: '@INTERACTI.WEB.Properties.Resources.valida_tag_bd'
                        },
                        'descricao': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'setor': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        }
                    }
                });
            };
        
            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['datepicker', 'maxlength']);
        });

    </script>
}
