
<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-5 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@INTERACTI.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("ServicoIndex", "CadastroBasico")">@INTERACTI.WEB.Properties.Resources.servico</a>
                <span class="breadcrumb-item active">@INTERACTI.WEB.Properties.Resources.inserir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <h2 class="content-heading">@INTERACTI.WEB.Properties.Resources.cadastrar_servico</h2>
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">                
                @using (Html.BeginForm("ServicoInsert", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="block block-rounded block-themed">
                        <div class="block-header bg-gd-primary">
                            <h3 class="block-title">@INTERACTI.WEB.Properties.Resources.informacoes</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-sm btn-alt-primary">
                                    <i class="fa fa-save mr-5"></i>@INTERACTI.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("ServicoIndex", "CadastroBasico")" class="btn btn-sm btn-alt-primary">
                                    <i class="si si-action-undo mr-5"></i>@INTERACTI.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full"> 
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                            </div>   
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.equipamento</label>
                                <div class="col-12">@Html.DropDownList("equipamento", null, "", new { @class = "form-control" })</div>
                            </div>                           
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.servico</label>
                                <div class="col-12"><input type="text" class="form-control" id="servico" name="servico" value="" maxlength="500"></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.peridiocidade</label>
                                <div class="col-lg-4">@Html.DropDownList("peridiocidade", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.intervalo</label>
                                <div class="col-lg-2"><input type="text" class="form-control" id="intervalo" name="intervalo" value=""></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.data_inicio</label>
                                <div class="col-lg-2"><input type="text" class="js-datepicker form-control" id="data_inicio" name="data_inicio" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder=""></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.tipo_servico</label>
                                <div class="col-lg-4">@Html.DropDownList("tipo_servico", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="form-group row">
                            <label class="col-12">@INTERACTI.WEB.Properties.Resources.exige_laudo</label>
                            <div class="col-12">
                                <label class="css-control css-control-success css-switch">
                                    <input type="checkbox" class="css-control-input" id="exige_laudo" name="exige_laudo" checked value ="true">
                                    <span class="css-control-indicator"></span>
                                </label>
                            </div>
                            </div>
                            <div class="form-group row">
                            <label class="col-12">@INTERACTI.WEB.Properties.Resources.ativo</label>
                            <div class="col-12">
                                <label class="css-control css-control-success css-switch">
                                    <input type="checkbox" class="css-control-input" id="ativo" name="ativo" checked value ="true">
                                    <span class="css-control-indicator"></span>
                                </label>
                            </div>
                            </div>
                        </div>                        
                    </div>   
                }
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Scripts {
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/bundles/interacti")
    @Scripts.Render("~/bundles/cookie")    
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/select")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")

    <script>

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'servico': {
                            required: true
                        },
                        'peridiocidade': {
                            required: true
                        },
                        'tipo_servico': {
                            required: true
                        },
                        'intervalo': {
                            required: true
                        },
                        'data_inicio': {
                            required: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@INTERACTI.WEB.Properties.Resources.valida_unidade'
                        },
                        'servico': {
                            required: '@INTERACTI.WEB.Properties.Resources.valida_servico'
                        },
                        'peridiocidade': {
                            required: '@INTERACTI.WEB.Properties.Resources.valida_peridiocidade'
                        },
                        'tipo_servico': {
                            required: '@INTERACTI.WEB.Properties.Resources.valida_tipo_servico'
                        },
                        'intervalo': {
                            required: '@INTERACTI.WEB.Properties.Resources.valida_intervalo'
                        },
                        'data_inicio': {
                            required: '@INTERACTI.WEB.Properties.Resources.valida_data_inicio'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['datepicker', 'maxlength']);
        });

    </script>

}
