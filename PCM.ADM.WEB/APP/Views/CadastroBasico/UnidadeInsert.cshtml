
<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-5 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@INTERACTI.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("UnidadeIndex", "CadastroBasico")">@INTERACTI.WEB.Properties.Resources.unidade</a>
                <span class="breadcrumb-item active">@INTERACTI.WEB.Properties.Resources.inserir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">        
                @using (Html.BeginForm("UnidadeInsert", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data"  }))        
                {
                    @Html.AntiForgeryToken()

                    <div class="block block-rounded block-themed">
                        <div class="block-header bg-gd-primary">
                            <h3 class="block-title">@INTERACTI.WEB.Properties.Resources.informacoes</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-sm btn-alt-primary">
                                    <i class="fa fa-save mr-5"></i>@INTERACTI.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("UnidadeIndex", "CadastroBasico")" class="btn btn-sm btn-alt-primary">
                                    <i class="si si-action-undo mr-5"></i>@INTERACTI.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">                            
                            <div class="form-group row">
                                <label class="col-lg-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.cnpj</label>
                                <div class="col-4"><input type="text" class="form-control" id="cnpj" name="cnpj" value=""></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-lg-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.nome_fantasia</label>
                                <div class="col-12"><input type="text" class="js-maxlength form-control" id="nome_fantasia" name="nome_fantasia" maxlength="120" value=""></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-lg-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.razao_social</label>
                                <div class="col-12"><input type="text" class="js-maxlength form-control" id="razao_social" name="razao_social" maxlength="120" value=""></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-lg-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.inscricao_estadual</label>
                                <div class="col-4"><input type="text" class="js-maxlength form-control" id="inscricao_estadual" name="inscricao_estadual" maxlength="20" value=""></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-lg-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.inscricao_municipal</label>
                                <div class="col-4"><input type="text" class="js-maxlength form-control" id="inscricao_municipal" name="inscricao_municipal" maxlength="20" value=""></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-lg-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.cep</label>
                                <div class="col-3"><input type="text" class="form-control" id="cep" name="cep" value="" onblur="LoadCEP();"></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-lg-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.uf</label>
                                <div class="col-lg-3">@Html.DropDownList("uf", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.municipio</label>
                                <div class="col-lg-12">@Html.DropDownList("municipio", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.logradouro</label>
                                <div class="col-12"><input type="text" class="js-maxlength form-control" id="logradouro" name="logradouro" maxlength="100" value=""></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-lg-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.numero</label>
                                <div class="col-4"><input type="text" class="js-maxlength form-control" id="numero" name="numero" maxlength="60" value=""></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.bairro</label>
                                <div class="col-12"><input type="text" class="js-maxlength form-control" id="bairro" name="bairro" maxlength="100" value=""></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.complemento</label>
                                <div class="col-12"><input type="text" class="js-maxlength form-control" id="complemento" name="complemento" maxlength="100" value=""></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-lg-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.telefone</label>
                                <div class="col-4"><input type="text" class="form-control" id="telefone" name="telefone" value=""></div>
                            </div>
                            <div class="form-group row">
                            <label class="col-12">@INTERACTI.WEB.Properties.Resources.aponta_horas</label>
                            <div class="col-12">
                                <label class="css-control css-control-success css-switch">
                                    <input type="checkbox" class="css-control-input" id="aponta_horas" name="aponta_horas" checked value ="true">
                                    <span class="css-control-indicator"></span>
                                </label>
                            </div>                            
                            </div>
                            <div class="form-group row">
                            <label class="col-12">@INTERACTI.WEB.Properties.Resources.ativo</label>
                            <div class="col-12">
                                <label class="css-control css-control-success css-switch">
                                    <input type="checkbox" class="css-control-input" id="ativo" name="ativo" checked value ="true">
                                    <span class="css-control-indicator"></span>
                                </label>
                            </div>                            
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.logo</label>
                                <div class="col-12">
                                    <div class="custom-file">
                                        <input id="imagem" name="imagem" type="file" />
                                    </div>
                                </div>
                            </div>
                        </div>                        
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Scripts {
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/bundles/cookie")    
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/select")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/bundles/codebase")

    <script>

        $(document).ready(function () { $("#cnpj").mask("99.999.999/9999-99"); });
        $(document).ready(function () { $("#cep").mask("99.999-999"); });
        $(document).ready(function () { $("#telefone").mask("(99) 9999-9999"); });

        jQuery.validator.addMethod("cnpj", function (cnpj, element) {

            cnpj = cnpj.replace(".", "");
            cnpj = cnpj.replace(".", "");
            cnpj = cnpj.replace("/", "");
            cnpj = cnpj.replace("-", "");

            var numeros, digitos, soma, resultado, pos, tamanho,
                digitos_iguais = true;

            if (cnpj.length < 14 && cnpj.length > 15)
                return false;

            for (var i = 0; i < cnpj.length - 1; i++)
                if (cnpj.charAt(i) != cnpj.charAt(i + 1)) {
                    digitos_iguais = false;
                    break;
                }

            if (!digitos_iguais) {
                tamanho = cnpj.length - 2
                numeros = cnpj.substring(0, tamanho);
                digitos = cnpj.substring(tamanho);
                soma = 0;
                pos = tamanho - 7;

                for (i = tamanho; i >= 1; i--) {
                    soma += numeros.charAt(tamanho - i) * pos--;
                    if (pos < 2)
                        pos = 9;
                }

                resultado = soma % 11 < 2 ? 0 : 11 - soma % 11;

                if (resultado != digitos.charAt(0))
                    return false;

                tamanho = tamanho + 1;
                numeros = cnpj.substring(0, tamanho);
                soma = 0;
                pos = tamanho - 7;

                for (i = tamanho; i >= 1; i--) {
                    soma += numeros.charAt(tamanho - i) * pos--;
                    if (pos < 2)
                        pos = 9;
                }

                resultado = soma % 11 < 2 ? 0 : 11 - soma % 11;

                if (resultado != digitos.charAt(1))
                    return false;

                return true;
            }

            return false;
        }, "Informe um CNPJ v&aacute;lido.");

        jQuery.validator.addMethod("cnpj_bd", function (value, element) {

            var dataString = {
                "cnpj": value,
                "codigo": -1
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaUnidade",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "Informe um CNPJ v&aacute;lido.");

        $(function () {

            var uf = $("#uf");
            var cMunicipio = $("#municipio");

            uf.change(function () {
                var request = { "uf": uf.val() };
                $.post("LoadMunicipio", request, function (obj) {
                    cMunicipio.empty();
                    option = $("<option>", { "value": "" }).text("");
                    cMunicipio.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        cMunicipio.append(option);
                    });
                }, "json");
            });
        });

        function LoadCEP() {

            var cep = $('#cep').val();
            var cMunicipio = $('#municipio');

            if (cep != "") {
                $.ajax({
                    type: 'POST',
                    url: 'CEPInfo',
                    data: { "cep": cep },
                    success: function (dados) {
                        if (dados.length > 0) {
                            $.each(dados, function (i, obj) {
                                document.getElementById("uf").value = obj.uf;
                                document.getElementById("uf").readonly = true;
                                cMunicipio.empty();
                                option = $("<option>", { "value": obj.municipio }).text(obj.municipio);
                                cMunicipio.append(option);
                                cMunicipio.value = obj.codigo_municipio;
                                document.getElementById("municipio").readonly;
                                document.getElementById("logradouro").value = obj.logradouro;
                                document.getElementById("logradouro").readonly;
                                document.getElementById("bairro").value = obj.bairro;
                                document.getElementById("bairro").readonly = true;
                            })
                        }
                        else {
                            cep.value = "";
                            document.getElementById("uf").value = "";
                            document.getElementById("uf").readonly = false;
                            cMunicipio.value = "";
                            cMunicipio.readonly = false;
                            document.getElementById("logradouro").value = "";
                            document.getElementById("logradouro").readonly = false;
                            document.getElementById("bairro").value = "";
                            document.getElementById("bairro").readonly = false;
                        };
                    }
                });
            }
            else {
                document.getElementById("uf").value = "";
                document.getElementById("uf").readonly = false;
                cMunicipio.value = "";
                cMunicipio.readonly = false;
                document.getElementById("logradouro").value = "";
                document.getElementById("logradouro").readonly = false;
                document.getElementById("bairro").value = "";
                document.getElementById("bairro").readonly = false;
            }
        }

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'cnpj': {
                            required: true,
                            cnpj: true,
                            cnpj_bd: true,
                        },
                        'nome_fantasia': {
                            required: true
                        },
                        'razao_social': {
                            required: true
                        },
                        'cep': {
                            required: true
                        },
                        'uf': {
                            required: true
                        },
                        'municipio': {
                            required: true
                        }
                    },
                    messages: {
                        'cnpj': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido',
                            cnpj: '@INTERACTI.WEB.Properties.Resources.valida_cnpj_invalido',
                            cnpj_bd: '@INTERACTI.WEB.Properties.Resources.valida_cnpj_bd',
                        },
                        'nome_fantasia': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'razao_social': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'cep': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'uf': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'municipio': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['maxlength']);
        });

    </script>

}