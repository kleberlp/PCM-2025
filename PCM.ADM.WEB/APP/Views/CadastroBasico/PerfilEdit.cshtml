@model List<INTERACTI.WEB.MODELS.PerfilDireito>

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-5 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@INTERACTI.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("PerfilIndex", "CadastroBasico")">@INTERACTI.WEB.Properties.Resources.perfil</a>
                <span class="breadcrumb-item active">@INTERACTI.WEB.Properties.Resources.editar</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <h2 class="content-heading">@INTERACTI.WEB.Properties.Resources.editar_perfil</h2>
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">           
                @using (Html.BeginForm("PerfilEdit", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="codigo" name="codigo" value="@ViewBag.codigo">

                    <div class="block block-rounded block-themed">
                        <div class="block-header bg-gd-primary">
                            <h3 class="block-title">@INTERACTI.WEB.Properties.Resources.informacoes</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-sm btn-alt-primary">
                                    <i class="fa fa-save mr-5"></i>@INTERACTI.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("PerfilIndex", "CadastroBasico")" class="btn btn-sm btn-alt-primary">
                                    <i class="si si-action-undo mr-5"></i>@INTERACTI.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">                            
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.descricao</label>
                                <div class="col-12"><input type="text" class="form-control" id="descricao" name="descricao" value="@ViewBag.descricao" maxlength="50"></div>
                            </div>
                            <div class="form-group row">
                            <label class="col-12">@INTERACTI.WEB.Properties.Resources.ativo</label>
                            <div class="col-12">
                                <label class="css-control css-control-success css-switch">
                                    <input type="checkbox" class="css-control-input" id="ativo" name="ativo" checked value ="@ViewBag.ativo">
                                    <span class="css-control-indicator"></span>
                                </label>
                            </div>
                        </div>
                        </div>                        
                    </div>

                    <!-- Dynamic Table Full Pagination -->
                    <div class="block">
                        <div class="block-content block-content-full">
                            <!-- DataTables init on table by adding .js-dataTable-full-pagination class, functionality initialized in js/pages/be_tables_datatables.js -->
                            <table class="table table-bordered table-striped table-vcenter js-dataTable-full-pagination">
                                <thead>
                                    <tr>
                                        <th>@INTERACTI.WEB.Properties.Resources.descricao </th>
                                        <th class="d-none d-sm-table-cell text-center" style="width: 150px;">@INTERACTI.WEB.Properties.Resources.visualizar</th>
                                        <th class="d-none d-sm-table-cell text-center" style="width: 150px;">@INTERACTI.WEB.Properties.Resources.inserir </th>
                                        <th class="d-none d-sm-table-cell text-center" style="width: 150px;">@INTERACTI.WEB.Properties.Resources.editar</th>
                                        <th class="d-none d-sm-table-cell text-center" style="width: 150px;">@INTERACTI.WEB.Properties.Resources.excluir</th>
                                        <th class="d-none d-sm-table-cell text-center" style="width: 150px;">@INTERACTI.WEB.Properties.Resources.imprimir</th>
                                    </tr>
                                </thead>

                                <tbody>         
                                @for (int i = 0; i < Model.Count; i++)
                                    {
                                        @Html.HiddenFor(m => m[i].codigo_formulario)
                                        <tr>          
                                            <td class="font-w600">@Html.DisplayFor(m => m[i].formulario)</td>
                                            <td class="d-none d-sm-table-cell text-center">                                            
                                                <div class="col-12">
                                                    <label class="css-control css-control-success css-switch">
                                                        @Html.CheckBoxFor(m => m[i].visualizar, new { @class = "css-control-input"})
                                                        <span class="css-control-indicator"></span>
                                                    </label>
                                                </div>
                                            </td>
                                            <td class="d-none d-sm-table-cell text-center">                                            
                                                <div class="col-12">
                                                    <label class="css-control css-control-success css-switch">
                                                        @Html.CheckBoxFor(m => m[i].inserir, new { @class = "css-control-input"})
                                                        <span class="css-control-indicator"></span>
                                                    </label>
                                                </div>
                                            </td>
                                            <td class="d-none d-sm-table-cell text-center">                                            
                                                <div class="col-12">
                                                    <label class="css-control css-control-success css-switch">
                                                        @Html.CheckBoxFor(m => m[i].editar, new { @class = "css-control-input"})
                                                        <span class="css-control-indicator"></span>
                                                    </label>
                                                </div>
                                            </td>
                                            <td class="d-none d-sm-table-cell text-center">                                            
                                                <div class="col-12">
                                                    <label class="css-control css-control-success css-switch">
                                                        @Html.CheckBoxFor(m => m[i].excluir, new { @class = "css-control-input"})
                                                        <span class="css-control-indicator"></span>
                                                    </label>
                                                </div>
                                            </td>
                                            <td class="d-none d-sm-table-cell text-center">                                            
                                                <div class="col-12">
                                                    <label class="css-control css-control-success css-switch">
                                                        @Html.CheckBoxFor(m => m[i].imprimir, new { @class = "css-control-input"})
                                                        <span class="css-control-indicator"></span>
                                                    </label>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <!-- END Dynamic Table Full Pagination -->

                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Scripts {
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/bundles/interacti")
    @Scripts.Render("~/bundles/cookie")    
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/select")

    <script>

        jQuery.validator.addMethod("descricao_bd", function (value, element) {

            var codigo = $("#codigo").val();

            var dataString = {
                "descricao": value,
                "codigo": codigo
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaPerfil",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "");

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'descricao': {
                            required: true,
                            minlength: 5,
                            descricao_bd: true
                        }
                    },
                    messages: {
                        'descricao': {
                            required: '@INTERACTI.WEB.Properties.Resources.valida_descricao',
                            minlength: '@INTERACTI.WEB.Properties.Resources.valida_descricao_minimo_5',
                            descricao_bd: '@INTERACTI.WEB.Properties.Resources.valida_descricao_bd'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['maxlength']);
        });

    </script>

}