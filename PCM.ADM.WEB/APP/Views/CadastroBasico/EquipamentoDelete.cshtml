@model INTERACTI.WEB.MODELS.Equipamento

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-5 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@INTERACTI.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("ServicoIndex", "CadastroBasico")">@INTERACTI.WEB.Properties.Resources.equipamento</a>
                <span class="breadcrumb-item active">@INTERACTI.WEB.Properties.Resources.excluir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">                
                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.codigo)

                    <div class="block block-rounded block-themed">
                        <div class="block-header bg-gd-primary">
                            <h3 class="block-title">@INTERACTI.WEB.Properties.Resources.deseja_excluir</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-sm btn-alt-primary">
                                    <i class="si si-trash mr-5"></i>@INTERACTI.WEB.Properties.Resources.excluir
                                </button>
                                <a href="@Url.Action("ServicoIndex", "CadastroBasico")" class="btn btn-sm btn-alt-primary">
                                    <i class="si si-action-undo mr-5"></i>@INTERACTI.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">                            
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">
                                    @Html.DisplayFor(model => model.unidade)
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.descricao</label>
                                <div class="col-12">
                                    @Html.DisplayFor(model => model.descricao)
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.local_instalacao</label>
                                <div class="col-12">
                                    @Html.DisplayFor(model => model.local_instalacao)
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.fabricante</label>
                                <div class="col-12">
                                    @Html.DisplayFor(model => model.fabricante)
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.endereco_fabricante</label>
                                <div class="col-12">
                                    @Html.DisplayFor(model => model.endereco_fabricante)
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.contato_fabricante</label>
                                <div class="col-12">
                                    @Html.DisplayFor(model => model.contato_fabricante)
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.modelo</label>
                                <div class="col-12">
                                    @Html.DisplayFor(model => model.modelo)
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.numero_fabricacao</label>
                                <div class="col-12">
                                    @Html.DisplayFor(model => model.numero_fabricacao)
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.ano_fabricacao</label>
                                <div class="col-12">
                                    @Html.DisplayFor(model => model.ano_fabricacao)
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.caracteristicas</label>
                                <div class="col-12">
                                    @Html.DisplayFor(model => model.caracteristicas)
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.descricao_operacao</label>
                                <div class="col-12">
                                    @Html.DisplayFor(model => model.descricao_operacao)
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.instrucao_utilizacao</label>
                                <div class="col-12">
                                    @Html.DisplayFor(model => model.instrucao_utilizacao)
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.procedimento_emergencia</label>
                                <div class="col-12">
                                    @Html.DisplayFor(model => model.procedimento_emergencia)
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.treinamento_operador</label>
                                <div class="col-12">
                                    @Html.DisplayFor(model => model.treinamento_operador)
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.condicao_seguranca</label>
                                <div class="col-12">
                                    @Html.DisplayFor(model => model.condicao_seguranca)
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.indicacao_conclusiva</label>
                                <div class="col-12">
                                    @Html.DisplayFor(model => model.indicacao_conclusiva)
                                </div>
                            </div>
                            <div class="form-group row">
                            <label class="col-12">@INTERACTI.WEB.Properties.Resources.ativo</label>
                            <div class="col-12">
                                <label class="css-control css-control-success css-switch">                                    
                                    @Html.CheckBoxFor(model => model.ativo, new { @class = "css-control-input"})
                                    <span class="css-control-indicator"></span>
                                </label>
                            </div>
                            </div>
                        </div>                        
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Scripts {
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/bundles/cookie")    
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/bundles/codebase")
}
