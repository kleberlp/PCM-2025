@model IEnumerable<INTERACTI.WEB.MODELS.Agenda>


<!-- Main Container -->
<main id="main-container">

    <!-- Page Content -->
    <div class="content">
               
        @using (Html.BeginForm("Agenda", "PCM", new {ReturnUrl = ViewBag.ReturnUrl}, FormMethod.Post, new { @class = "js-validation-bootstrap", @name="form", @id="form", role = "form" }))
        {
            @Html.AntiForgeryToken()
                                     
        <!-- Tasks Content -->
        <div class="row">
    
            <div class="col-md-5 col-xl-3">
                <!-- Toggle Tasks Navigation on mobile -->
                <button type="button" class="btn btn-block btn-primary d-md-none mb-10" data-toggle="class-toggle" data-target=".js-tasks-nav" data-class="d-none d-md-block">@INTERACTI.WEB.Properties.Resources.filtros</button>

                <!-- Collapsible Tasks Navigation -->
                <div class="js-tasks-nav d-none d-md-block">
                    <!-- Tasks Info -->
                    <div class="block block-rounded">
                        <div class="block-header block-header-default">
                            <h3 class="block-title">@INTERACTI.WEB.Properties.Resources.filtro</h3>
                        </div>
                        <div class="block-content">
                            <ul class="list-group push">
                                <li class="list-group-item">
                                    <div class="input-daterange input-group" data-date-format="dd/mm/yyyy" data-week-start="1" data-autoclose="true" data-today-highlight="true">
                                        <input type="text" class="form-control" id="data_inicio" name="data_inicio" placeholder="De" data-week-start="1" data-autoclose="true" data-today-highlight="true" value="@ViewBag.data_inicio">
                                        <div class="input-group-prepend input-group-append">
                                            <span class="input-group-text font-w600">-</span>
                                        </div>
                                        <input type="text" class="form-control" id="data_termino" name="data_termino" placeholder="Até" data-week-start="1" data-autoclose="true" data-today-highlight="true" value="@ViewBag.data_termino">
                                    </div>
                                </li>   
                                <li class="list-group-item">
                                    <div>@Html.DropDownList("unidade", null, INTERACTI.WEB.Properties.Resources.unidade, new { @class = "form-control" })</div>                                    
                                </li>
                                <li class="list-group-item">
                                    <div>@Html.DropDownList("setor", null, INTERACTI.WEB.Properties.Resources.setor, new { @class = "form-control" })</div>                                    
                                </li>                                
                                <li class="list-group-item">                                                    
                                    <div>@Html.DropDownList("equipamento", null, INTERACTI.WEB.Properties.Resources.equipamento, new { @class = "form-control" })</div>                                    
                                </li>                             
                                <li class="list-group-item">                                                    
                                    <div>@Html.DropDownList("status", null, INTERACTI.WEB.Properties.Resources.status, new { @class = "form-control" })</div>                                    
                                </li>                          
                                <li class="list-group-item text-right">                                                    
                                    <button type="submit" class="btn btn-sm btn-alt-primary" name="filtrar" id="filtrar"><i class="si si-magnifier mr-5"></i>@INTERACTI.WEB.Properties.Resources.filtrar</button>
                                </li>
                            </ul>
                        </div>
                    </div>
                    <!-- END Tasks Info -->

                </div>
                <!-- END Collapsible Tasks Navigation -->
            </div>

            <div class="col-md-7 col-xl-9">
                <!-- Tasks -->
                <!-- Tasks functionality (initialized in js/pages/be_pages_generic_todo.js) -->
                <div class="js-tasks">
                    
                    <div class="block">
                        <div class="block-header block-header-default">
                            <h3 class="block-title">
                                Serviços
                            </h3>
                        </div>
                        <div class="block-content">
                          
                            <table class="js-table-sections table table-hover">
                                <thead>
                                    <tr>
                                        <th style="width: 30px;"></th>
                                        @if(ViewBag.inserir || ViewBag.excluir)
                                        {    
                                            <th style="width: 20px;"></th>                                                                                       
                                        }
                                        <th>@INTERACTI.WEB.Properties.Resources.servico</th>                                        
                                        <th class="text-center" style="width: 15%;">@INTERACTI.WEB.Properties.Resources.status</th>
                                        <th class="d-none d-sm-table-cell text-center" style="width: 120px;">@INTERACTI.WEB.Properties.Resources.data</th>
                                    </tr>
                                </thead>                      
                                @foreach (var item in Model)
                                {
                                    <tbody class="js-table-sections-header">
                                        <tr>
                                            <td class="text-center">
                                                <i class="fa fa-angle-right"></i>
                                            </td>
                                            @if(item.codigo_status == 1)
                                            {       
                                                if(ViewBag.inserir)
                                                {
                                                    <td class="text-center" style="width: 20px;">@Html.ActionLink(" ", "Apontamento", new { codigo_pcm_programada = item.codigo_pcm_programada, codigo_pcm_ordem_servico = item.codigo_pcm_ordem_servico}, new { @class = "si si-check" })</td>                  
                                                }
                                                <td class="font-w600">@Html.DisplayFor(modelItem => item.servico)</td>        
                                                <td class="text-center" style="width: 15%;"><span class="badge badge-warning">@Html.DisplayFor(modelItem => item.status)</span></td>
                                                <td class="d-none d-sm-table-cell text-center" style="width: 120px;">@Html.DisplayFor(modelItem => item.data)</td>
                                            }   
                                            @if(item.codigo_status == 2)
                                            {       
                                                if(ViewBag.excluir)
                                                {
                                                    <td class="text-center" style="width: 20px;">@Html.ActionLink(" ", "ApontamentoExcluir", new { codigo = item.codigo, codigo_unidade = item.codigo_unidade}, new { @class = "si si-trash" })</td>                  
                                                }
                                                <td class="font-w600"><del>@Html.DisplayFor(modelItem => item.servico)</del></td>    
                                                <td class="text-center" style="width: 15%;"><span class="badge badge-success"><del>@Html.DisplayFor(modelItem => item.status)</del></span></td>
                                                <td class="d-none d-sm-table-cell text-center" style="width: 120px;"><del>@Html.DisplayFor(modelItem => item.data)</del></td>
                                            }  
                                        </tr>
                                    </tbody>
                                    <tbody>
                                        <tr>
                                            <td class="text-center"></td>                        
                                            <td class="text-center"></td>
                                            <td>
                                                <strong>@INTERACTI.WEB.Properties.Resources.unidade: </strong> @Html.DisplayFor(modelItem => item.unidade)
                                            </td>
                                            <td class="font-size-sm"></td>
                                            <td class="d-none d-sm-table-cell"></td>
                                        </tr>
                                        @if (item.setor != "")
                                        {
                                            <tr>
                                                <td class="text-center"></td>                        
                                                <td class="text-center"></td>
                                                <td>
                                                    <strong>@INTERACTI.WEB.Properties.Resources.setor: </strong> @Html.DisplayFor(modelItem => item.setor)
                                                </td>
                                                <td class="font-size-sm"></td>
                                                <td class="d-none d-sm-table-cell"></td>
                                            </tr>
                                        }
                                        @if (item.equipamento != "")
                                        {
                                            <tr>
                                                <td class="text-center"></td>                        
                                                <td class="text-center"></td>
                                                <td>
                                                    <strong>@INTERACTI.WEB.Properties.Resources.equipamento: </strong> @Html.DisplayFor(modelItem => item.equipamento)
                                                </td>
                                                <td class="font-size-sm"></td>
                                                <td class="d-none d-sm-table-cell"></td>
                                            </tr>
                                        }
                                        @if (item.solicitante != "")
                                        {
                                            <tr>
                                                <td class="text-center"></td>                        
                                                <td class="text-center"></td>
                                                <td>
                                                    <strong>@INTERACTI.WEB.Properties.Resources.solicitante: </strong> @Html.DisplayFor(modelItem => item.solicitante)
                                                </td>
                                                <td class="font-size-sm"></td>
                                                <td class="d-none d-sm-table-cell"></td>
                                            </tr>
                                        }
                                        @if (item.data_inicio != "")
                                        {
                                            <tr>
                                                <td class="text-center"></td>                        
                                                <td class="text-center"></td>
                                                <td>
                                                    <strong>@INTERACTI.WEB.Properties.Resources.data_inicio: </strong> @Html.DisplayFor(modelItem => item.data_inicio) @Html.DisplayFor(modelItem => item.hora_inicio) 
                                                </td>
                                                <td class="font-size-sm"></td>
                                                <td class="d-none d-sm-table-cell"></td>
                                            </tr>
                                        }
                                        @if (item.data_inicio != "")
                                        {
                                            <tr>
                                                <td class="text-center"></td>                        
                                                <td class="text-center"></td>
                                                <td>
                                                    <strong>@INTERACTI.WEB.Properties.Resources.data_termino: </strong> @Html.DisplayFor(modelItem => item.data_termino) @Html.DisplayFor(modelItem => item.hora_termino) 
                                                </td>
                                                <td class="font-size-sm"></td>
                                                <td class="d-none d-sm-table-cell"></td>
                                            </tr>
                                        }
                                        @if (item.descricao_solucao != "")
                                        {
                                            <tr>
                                                <td class="text-center"></td>                        
                                                <td class="text-center"></td>
                                                <td>
                                                    <strong>@INTERACTI.WEB.Properties.Resources.solucao: </strong> @Html.DisplayFor(modelItem => item.descricao_solucao)
                                                </td>
                                                <td class="font-size-sm"></td>
                                                <td class="d-none d-sm-table-cell"></td>
                                            </tr>
                                        }
                                    </tbody>
                                }
                            </table>
                        </div>
                    </div>
            </div>
            </div>

        <!-- END Tasks Content -->
        </div>

        }

    </div>
    <!-- END Page Content -->

</main>
<!-- END Main Container -->


@section Scripts {
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")    
    @Scripts.Render("~/bundles/cookie")    
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/select")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/bundles/codebase")

    <script>

        $(function () {

            var unidade = $("#unidade");
            var setor = $("#setor");
            var equipamento = $("#equipamento");

            unidade.change(function () {
                var request = { "unidade": unidade.val() };
                $.post("LoadSetor", request, function (obj) {
                    setor.empty();
                    option = $("<option>", { "value": "" }).text("");
                    setor.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        setor.append(option);
                    });
                }, "json");

                $.post("LoadEquipamento", request, function (obj) {
                    equipamento.empty();
                    option = $("<option>", { "value": "" }).text("");
                    equipamento.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        equipamento.append(option);
                    });
                }, "json");
            });

        });

        $(function () {

            var unidade = $("#unidade");
            var setor = $("#setor");
            var equipamento = $("#equipamento");

            setor.change(function () {
                var request = { "unidade": unidade.val(), "setor": setor.val() };
                $.post("LoadEquipamentoSetor", request, function (obj) {
                    equipamento.empty();
                    option = $("<option>", { "value": "" }).text("");
                    equipamento.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        equipamento.append(option);
                    });
                }, "json");
            });

        });

        var BeTableDatatables = function () {
            // Override a few DataTable defaults, for more examples you can check out https://www.datatables.net/
            var exDataTable = function () {
                jQuery.extend(jQuery.fn.dataTable.ext.classes, {
                    sWrapper: "dataTables_wrapper dt-bootstrap4"
                });
            };

            // Init full extra DataTable, for more examples you can check out https://www.datatables.net/
            var initDataTableFullPagination = function () {
                jQuery('.js-dataTable-full-pagination').dataTable({
                    searching: false,
                    paginate: false,
                    odering: false,
                    lengthChange: false,
                    info: false,
                    @ViewBag.columnDefs,
                    language: {
                        "search": "Procurar:",
                        "lengthMenu": "Exibir _MENU_ ",
                        "zeroRecords": "Nenhum Registro Encontrado",
                        "info": "Exibir página _PAGE_ de _PAGES_",
                        "infoEmpty": "Nenhum Registro encontrado",
                        "infoFiltered": "(filtrado de _MAX_ registro(s))"
                    }
                });
            };

            return {
                init: function () {
                    // Override a few DataTable defaults
                    exDataTable();

                    // Init Datatables
                    initDataTableFullPagination();
                }
            };
        }();

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'data_inicio': {
                            required: true
                        },
                        'data_termino': {
                            required: true
                        }
                    },                        
                    messages: {
                        'data_inicio': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'data_termino': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        }
                    }                    
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();
        
        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['table-tools', 'datepicker', 'maxlength', 'select2']);
            BeTableDatatables.init();
            
        });

    </script>
}
