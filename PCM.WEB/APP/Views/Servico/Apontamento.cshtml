@model IEnumerable<INTERACTI.WEB.MODELS.Apontamento>

<!-- Main Container -->
<main id="main-container">

    <!-- Page Content -->
    <div class="content">
     
        <!-- Tasks Content -->
        <div class="row">

            <div class="col-md-5 col-xl-3">
            
                <!-- Collapsible Tasks Navigation -->
                <div class="js-tasks-nav d-none d-md-block">
                    <!-- Tasks Info -->
                    <div class="block block-rounded">
                        <div class="block-header block-header-default">
                            <h3 class="block-title">@INTERACTI.WEB.Properties.Resources.servicos</h3>
                        </div>
                        <div class="block-content">
                            <ul class="list-group push">
                                <li class="list-group-item">
                                    <span class="js-task-badge-starred badge badge-warning float-right animated bounceIn"></span>
                                    <i class="fa fa-fw fa-star mr-5"></i>@INTERACTI.WEB.Properties.Resources.pendente_prioridade
                                </li>
                                <li class="list-group-item">
                                    <span class="js-task-badge badge badge-primary float-right animated bounceIn"></span>
                                    <i class="fa fa-fw fa-tasks mr-5"></i>@INTERACTI.WEB.Properties.Resources.pendente
                                </li>
                                <li class="list-group-item">
                                    <span class="js-task-badge-completed badge badge-success float-right animated bounceIn"></span>
                                    <i class="fa fa-fw fa-check mr-5"></i>@INTERACTI.WEB.Properties.Resources.realizado
                                </li>
                            </ul>
                        </div>
                    </div>
                    <!-- END Tasks Info -->

                </div>
                <!-- END Collapsible Tasks Navigation -->
            </div>

            <div class="col-md-7 col-xl-9">
                <!-- Tasks -->
                <!-- Tasks functionality (initialized in js/pages/be_pages_generic_todo.js) -->
                <div class="js-tasks">                    
                    <!-- Starred Tasks List -->
                    <h2 class="content-heading mb-10">@INTERACTI.WEB.Properties.Resources.pendente_prioridade</h2>
                    <div class="js-task-list-starred">
                        <!-- Task -->                      
                        @foreach (var item in Model)
                        {
                            if(@item.tipo == "U")
                            {
                                <div class="js-task block block-rounded mb-5 animated fadeIn" data-task-id="@item.codigo" data-task-completed="false" data-task-starred="true">
                                    <table class="table table-borderless table-vcenter mb-0">
                                        <tr>
                                            <td class="text-center" style="width: 50px;">
                                                <button class="btn btn-sm btn-alt-warning" type="button" data-toggle="modal" data-target="#modal-popout" onclick="document.getElementById('codigo_servico').value=@item.codigo;document.getElementById('servico').value='@item.servico';">
                                                    <i class="si si-check"></i>
                                                </button>    
                                            </td>
                                            <td class="js-task-content font-w600" style="width: 70%;">@item.servico</td>
                                            @if(Session["unidade"] == "")
                                            {                                    
                                                <td class="text-center" style="width: 30%;">@item.unidade</td>
                                            }
                                        </tr>
                                    </table>
                                </div>
                            }
                        }
                        <!-- END Task -->

                    </div>
                    <!-- END Starred Tasks List -->

                    <!-- Tasks List -->
                    <h2 class="content-heading mb-10">@INTERACTI.WEB.Properties.Resources.pendente</h2>
                    <div class="js-task-list">
                        <!-- Task -->
                        @foreach (var item in Model)
                        {
                            if(@item.tipo == "P")
                            {
                                <div class="js-task block block-rounded mb-5 animated fadeIn" data-task-id="@item.codigo" data-task-completed="false" data-task-starred="false">
                                    <table class="table table-borderless table-vcenter mb-0">
                                        <tr>
                                            <td class="text-center" style="width: 50px;">
                                                <button class="btn btn-sm btn-alt-primary" type="button" data-toggle="modal" data-target="#modal-popout" onclick="document.getElementById('codigo_servico').value=@item.codigo;document.getElementById('servico').value='@item.servico';">
                                                    <i class="si si-check"></i>
                                                </button>    
                                            </td>
                                            <td class="js-task-content font-w600" style="width: 70%;">@item.servico</td>
                                            @if(Session["unidade"] == "")
                                            {                                    
                                                <td class="text-center" style="width: 30%;">@item.unidade</td>
                                            }
                                        </tr>
                                    </table>
                                </div>
                            }
                        }
                        <!-- END Task -->
                    </div>
                    <!-- END Tasks List -->

                    <!-- Tasks List Completed -->
                    <h2 class="content-heading mb-10">@INTERACTI.WEB.Properties.Resources.realizado</h2>
                    <div class="js-task-list-completed">
                        <!-- Task -->
                        @foreach (var item in Model)
                        {
                            if(@item.tipo == "R")
                            {
                                <div class="js-task block block-rounded mb-5 animated fadeIn" data-task-id="@item.codigo" data-task-completed="true" data-task-starred="false">
                                    <table class="table table-borderless table-vcenter mb-0">
                                        <tr>
                                            <td class="text-center" style="width: 50px;">
                                                <button class="btn btn-sm btn-alt-success" type="button" data-toggle="modal" data-target="#modal-popout-excluir" onclick="document.getElementById('codigo').value=@item.codigo;document.getElementById('servico_excluir').value='@item.servico';document.getElementById('executor_excluir').value='@item.executor';document.getElementById('valor_excluir').value='@item.valor';document.getElementById('comentario_excluir').value='@item.comentario';">
                                                    <i class="si si-close"></i>
                                                </button>    
                                            </td>
                                            <td class="js-task-content font-w600" style="width: 70%;">@item.servico</td>
                                            @if(Session["unidade"] == "")
                                            {                                    
                                                <td class="text-center" style="width: 30%;">@item.unidade</td>
                                            }
                                        </tr>
                                    </table>
                                </div>
                            }
                        }
                        <!-- END Task -->
                    </div>
                    <!-- END Tasks List Completed -->
                </div>
                <!-- END Tasks -->
            </div>

        </div>
        <!-- END Tasks Content -->

    </div>
    <!-- END Page Content -->

</main>
<!-- END Main Container -->

<!-- Pop Out Modal -->
<div class="modal fade" id="modal-popout" tabindex="-1" role="dialog" aria-labelledby="modal-popout" aria-hidden="true">
    <div class="modal-dialog modal-dialog-popout" role="document">
        <div class="modal-content">
        @using (Html.BeginForm("ApontamentoInsert", "Servico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data"  }))
                {
                    @Html.AntiForgeryToken()
                    <div class="block block-themed block-transparent mb-0">
                
                        <input type="hidden" name="codigo_servico" id="codigo_servico" value="0">
                    
                        <div class="block-header bg-primary-dark">
                            <h3 class="block-title">@INTERACTI.WEB.Properties.Resources.apontamento</h3>
                            <div class="block-options">
                                <button type="button" class="btn-block-option" data-dismiss="modal" aria-label="Close">
                                    <i class="si si-close"></i>
                                </button>
                            </div>
                        </div>
                        <div class="block-content">
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.servico</label>
                                <div class="col-12"><textarea class="form-control" id="servico" name="servico" disabled></textarea></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.data</label>
                                <div class="col-lg-6"><input type="text" class="js-datepicker form-control" id="data_inicio" name="data" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" value="@ViewBag.data" disabled></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.executor</label>
                                <div class="col-12">
                                    <input type="text" class="form-control" id="executor" name="executor" value="">
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.valor</label>
                                <div class="col-6">
                                    <input type="text" class="form-control" id="valor" name="valor" value="">
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.comentario</label>
                                <div class="col-12"><textarea class="form-control" id="comentario" name="comentario"></textarea></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.laudo</label>
                                <div class="col-12">
                                    <div class="custom-file">
                                        <input id="laudo" name="laudo" type="file" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-alt-secondary" data-dismiss="modal"><i class="si si-action-undo mr-5"></i>@INTERACTI.WEB.Properties.Resources.voltar</button>
                        <button type="submit" class="btn btn-alt-success"><i class="fa fa-save mr-5"></i>@INTERACTI.WEB.Properties.Resources.salvar</button>
                    </div>
            }
        </div>
    </div>
</div>
<!-- END Pop Out Modal -->


<!-- Pop Out Modal Excluir -->
<div class="modal fade" id="modal-popout-excluir" tabindex="-1" role="dialog" aria-labelledby="modal-popout-excluir" aria-hidden="true">
    <div class="modal-dialog modal-dialog-popout" role="document">
        <div class="modal-content">
        @using (Html.BeginForm("ApontamentoDelete", "Servico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap2", role = "form" }))
                {
                    @Html.AntiForgeryToken()
                    <div class="block block-themed block-transparent mb-0">
                
                        <input type="hidden" name="codigo" id="codigo" value="0">
                    
                        <div class="block-header bg-primary-dark">
                            <h3 class="block-title">@INTERACTI.WEB.Properties.Resources.excluir_apontamento</h3>
                            <div class="block-options">
                                <button type="button" class="btn-block-option" data-dismiss="modal" aria-label="Close">
                                    <i class="si si-close"></i>
                                </button>
                            </div>
                        </div>
                        <div class="block-content">
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.servico</label>
                                <div class="col-12"><textarea class="form-control" id="servico_excluir" name="servico_excluir" disabled></textarea></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.data</label>
                                <div class="col-lg-6"><input type="text" class="js-datepicker form-control" id="data_inicio" name="data" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" value="@ViewBag.data" disabled></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.executor</label>
                                <div class="col-12">
                                    <input type="text" class="form-control" id="executor_excluir" name="executor_excluir" value="" disabled>
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.valor</label>
                                <div class="col-6">
                                    <input type="text" class="form-control" id="valor_excluir" name="valor_excluir" value="" disabled>
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.comentario</label>
                                <div class="col-12"><textarea class="form-control" id="comentario_excluir" name="comentario_excluir" disabled></textarea></div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-alt-secondary" data-dismiss="modal"><i class="si si-action-undo mr-5"></i>@INTERACTI.WEB.Properties.Resources.voltar</button>
                        <button type="submit" class="btn btn-alt-danger"><i class="fa fa-save mr-5"></i>@INTERACTI.WEB.Properties.Resources.excluir</button>
                    </div>
            }
        </div>
    </div>
</div>
<!-- END Pop Out Modal -->

@section Scripts {
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/bundles/interacti")
    @Scripts.Render("~/bundles/cookie")    
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/select")
    @Scripts.Render("~/plugins/datepicker")

    <script>

        /*
 *  Document   : be_pages_generic_todo.js
 *  Author     : pixelcave
 *  Description: Custom JS code used in Todo Page in Backend
 */

        var BeTasks = function () {
            // Helper variables - set in initTasks()
            var taskIdNext, tasks, taskForm, taskInput, taskInputVal,
                taskList, taskListStarred, taskListCompleted,
                taskBadge, taskBadgeStarred, taskBadgeCompleted;

            // Set variables and default functionality
            var initTasks = function () {
                tasks = jQuery('.js-tasks');
                taskForm = jQuery('#js-task-form');
                taskInput = jQuery('#js-task-input');

                taskList = jQuery('.js-task-list');
                taskListStarred = jQuery('.js-task-list-starred');
                taskListCompleted = jQuery('.js-task-list-completed');

                taskBadge = jQuery('.js-task-badge');
                taskBadgeStarred = jQuery('.js-task-badge-starred');
                taskBadgeCompleted = jQuery('.js-task-badge-completed');

                // Set your own next new task id based on your database setup
                taskIdNext = 10;

                // Update badges
                badgesUpdate();

                // New task form submission
                taskForm.on('submit', function (e) {
                    e.preventDefault();

                    // Get input value
                    taskInputVal = taskInput.prop('value');

                    // Check if the user entered something
                    if (taskInputVal) {
                        // Add Task
                        taskAdd(taskInputVal);

                        // Clear and focus input field
                        taskInput.prop('value', '').focus();
                    }
                });

                // Task status update on checkbox click
                var stask, staskId;

                tasks.on('click', '.js-task-status', function (e) {
                    e.preventDefault();

                    stask = jQuery(this).closest('.js-task');
                    staskId = stask.attr('data-task-id');

                    // Check task status and toggle it
                    if (stask.attr('data-task-completed') === 'true') {
                        taskSetActive(staskId);
                    } else {
                        taskSetCompleted(staskId);
                    }
                });

                // Task starred status update on star click
                var ftask, ftaskId;

                tasks.on('click', '.js-task-star', function () {
                    ftask = jQuery(this).closest('.js-task');
                    ftaskId = ftask.attr('data-task-id');

                    // Check task starred status and toggle it
                    if (ftask.attr('data-task-starred') === 'true') {
                        taskStarRemove(ftaskId);
                    } else {
                        taskStarAdd(ftaskId);
                    }
                });

                // Remove task on remove button click
                tasks.on('click', '.js-task-remove', function () {
                    ftask = jQuery(this).closest('.js-task');
                    ftaskId = ftask.attr('data-task-id');

                    // Remove task
                    taskRemove(ftaskId);
                });
            };

            // Update badges
            var badgesUpdate = function () {
                taskBadge.text(taskList.children().length || '');
                taskBadgeStarred.text(taskListStarred.children().length || '');
                taskBadgeCompleted.text(taskListCompleted.children().length || '');
            };

            // Add a task
            var taskAdd = function (taskContent) {
                // Add it to the task list
                taskList
                    .prepend(
                    '<div class="js-task block block-rounded mb-5 animated fadeIn" data-task-id="' +
                        taskIdNext +
                        '" data-task-completed="false" data-task-starred="false">' +
                        '<table class="table table-borderless table-vcenter mb-0">' +
                            '<tr>' +
                                '<td class="text-center" style="width: 50px;">' +
                                    '<label class="js-task-status css-control css-control-primary css-checkbox py-0">' +
                                        '<input type="checkbox" class="css-control-input">' +
                                        '<span class="css-control-indicator"></span>' +
                                    '</label>' +
                                '</td>' +
                                '<td class="js-task-content font-w600">' +
                                    jQuery('<span />').text(taskContent).html() +
                                '</td>' +
                                '<td class="text-right" style="width: 100px;">' +
                                    '<button class="js-task-star btn btn-sm btn-alt-warning" type="button">' +
                                        '<i class="fa fa-star-o"></i>' +
                                    '</button> ' +
                                    '<button class="js-task-remove btn btn-sm btn-alt-danger" type="button">' +
                                        '<i class="fa fa-times"></i>' +
                                    '</button>' +
                                '</td>' +
                            '</tr>' +
                        '</table>' +
                    '</div>'
                    );

                // Update badges
                badgesUpdate();

                // Save the task based on your database setup
                // ..

                // Update task next id
                taskIdNext++;
            };

            // Remove a task
            var taskRemove = function (taskId) {
                jQuery('.js-task[data-task-id="' + taskId + '"]').remove();

                // Update badges
                badgesUpdate();

                // Remove the task based on your database setup
                // ..
            };

            // Star a task
            var taskStarAdd = function (taskId) {
                var task = jQuery('.js-task[data-task-id="' + taskId + '"]');

                // Check if exists and update accordignly the markup
                if (task.length > 0) {
                    task.attr('data-task-starred', true);
                    task.find('.js-task-star > i').toggleClass('fa-star fa-star-o');

                    if (task.attr('data-task-completed') === 'false') {
                        task.prependTo(taskListStarred);
                    }

                    // Update badges
                    badgesUpdate();

                    // Star the task based on your database setup
                    // ..
                }
            };

            // Unstar a task
            var taskStarRemove = function (taskId) {
                var task = jQuery('.js-task[data-task-id="' + taskId + '"]');

                // Check if exists and update accordignly the markup
                if (task.length > 0) {
                    task.attr('data-task-starred', false);
                    task.find('.js-task-star > i').toggleClass('fa-star fa-star-o');

                    if (task.attr('data-task-completed') === 'false') {
                        task.prependTo(taskList);
                    }

                    // Update badges
                    badgesUpdate();

                    // Unstar the task based on your database setup
                    // ..
                }
            };

            // Set a task to active
            var taskSetActive = function (taskId) {
                var task = jQuery('.js-task[data-task-id="' + taskId + '"]');

                // Check if exists and update accordignly
                if (task.length > 0) {
                    task.attr('data-task-completed', false);
                    task.find('.table').toggleClass('bg-body-light');
                    task.find('.js-task-status > input').prop('checked', false);
                    task.find('.js-task-content > del').contents().unwrap();

                    if (task.attr('data-task-starred') === 'true') {
                        task.prependTo(taskListStarred);
                    } else {
                        task.prependTo(taskList);
                    }

                    // Update badges
                    badgesUpdate();

                    // Update task status based on your database setup
                    // ..
                }
            };

            // Set a task to completed
            var taskSetCompleted = function (taskId) {
                var task = jQuery('.js-task[data-task-id="' + taskId + '"]');

                // Check if exists and update accordignly
                if (task.length > 0) {
                    task.attr('data-task-completed', true);
                    task.find('.table').toggleClass('bg-body-light');
                    task.find('.js-task-status > input').prop('checked', true);
                    task.find('.js-task-content').wrapInner('<del></del>');
                    task.prependTo(taskListCompleted);

                    // Update badges
                    badgesUpdate();

                    // Update task status based on your database setup
                    // ..
                }
            };

            return {
                init: function () {
                    // Init Tasks
                    initTasks();
                }
            };
        }();

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'data': {
                            required: true
                        },
                        'executor': {
                            required: true
                        },
                        'valor': {
                            required: true
                        },
                        'laudo': {
                            required: true
                        }
                    },
                    messages: {
                        'data': {
                            required: '@INTERACTI.WEB.Properties.Resources.valida_data'
                        },
                        'executor': {
                            required: '@INTERACTI.WEB.Properties.Resources.valida_executor'
                        },
                        'valor': {
                            required: '@INTERACTI.WEB.Properties.Resources.valida_valor'
                        },
                        'laudo': {
                            required: '@INTERACTI.WEB.Properties.Resources.valida_laudo'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {

            BeTasks.init();

            //Datepicker
            Codebase.helpers(['datepicker']);
            
            //Validation
            FormValidation.init();
        });

    </script>
}
