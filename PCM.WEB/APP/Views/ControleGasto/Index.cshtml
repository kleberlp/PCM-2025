                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.previsao_gasto_novembro, new { @class = "form-control text-center"})</td>
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.gasto_novembro, new { @class = "form-control text-center"})</td>
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.saldo_novembro, new { @class = "form-control text-center"})</td>
                                                </tr>
                                            } 
                                            @if(ViewBag.mes <= 12)
                                            {
                                                <tr>     
