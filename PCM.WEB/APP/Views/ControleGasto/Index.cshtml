                        <div class="block-header bg-gd-primary">
                            <h3 class="block-title">@INTERACTI.WEB.Properties.Resources.informacoes</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-sm btn-alt-primary">
                                    <i class="si si-magnifier mr-5"></i>@INTERACTI.WEB.Properties.Resources.filtrar
                                </button>
                                <a href="@Url.Action("Index", "Home")" class="btn btn-sm btn-alt-primary">
                                    <i class="si si-action-undo mr-5"></i>@INTERACTI.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">                                                        
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@Html.DropDownList("unidade", null, "", new { @class = "form-control"})</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.ano</label>
                                <div class="col-2">@Html.DropDownList("ano", null, "", new { @class = "form-control"})</div>
                            </div>
                        </div>
                        
                    </div>

                        <div class="block">
                            <div class="block-content block-content-full">
                                <table class="table table-bordered table-striped table-vcenter js-dataTable-full-pagination">
                                    <thead>                                    
                                        <tr>
                                            <th class="text-center" style="width: 25%;">@INTERACTI.WEB.Properties.Resources.periodo</th>
                                            <th class="text-center" style="width: 25%;">@INTERACTI.WEB.Properties.Resources.previsao_gasto</th>
                                            <th class="text-center" style="width: 25%;">@INTERACTI.WEB.Properties.Resources.gasto_real</th>
                                            <th class="text-center" style="width: 25%;">@INTERACTI.WEB.Properties.Resources.saldo</th>
                                        </tr>
                                    </thead>

                                        <tbody> 
                                            @if(ViewBag.mes == 1)
                                            {
                                                <tr>     
                                                    <td class="text-center" style="width: 25%;">@INTERACTI.WEB.Properties.Resources.janeiro</td>                  
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.previsao_gasto_janeiro, new { @class = "form-control text-center"})</td>
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.gasto_janeiro, new { @class = "form-control text-center"})</td>
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.saldo_janeiro, new { @class = "form-control text-center"})</td>
                                                </tr>
                                            }
                                            @if(ViewBag.mes <= 2)
                                            {
                                                <tr>     
                                                    <td class="text-center" style="width: 25%;">@INTERACTI.WEB.Properties.Resources.fevereiro</td>                  
