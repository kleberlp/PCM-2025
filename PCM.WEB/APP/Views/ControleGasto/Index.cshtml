                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.previsao_gasto_outubro, new { @class = "form-control text-center"})</td>
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.gasto_outubro, new { @class = "form-control text-center"})</td>
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.saldo_outubro, new { @class = "form-control text-center"})</td>
                                                </tr>
                                            } 
