@model INTERACTI.WEB.MODELS.NormasProcedimentos

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-5 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@INTERACTI.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("NormasProcedimentosIndex", "Auditoria")">@INTERACTI.WEB.Properties.Resources.normas_procedimentos</a>
                <span class="breadcrumb-item active">@INTERACTI.WEB.Properties.Resources.editar</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">           
                @using (Html.BeginForm("NormasProcedimentosEdit", "Auditoria", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()
                    
                    <input type="hidden" name="codigo" id="codigo" value="@ViewBag.apontamento.codigo">

                    <div class="block block-rounded block-themed">
                        <div class="block-header bg-gd-primary">
                            <h3 class="block-title">@INTERACTI.WEB.Properties.Resources.informacoes</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-sm btn-alt-primary">
                                    <i class="fa fa-save mr-5"></i>@INTERACTI.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("NormasProcedimentosIndex", "Auditoria")" class="btn btn-sm btn-alt-primary">
                                    <i class="si si-action-undo mr-5"></i>@INTERACTI.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">                            
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.descricao</label>
                                <div class="col-12">@Html.TextBoxFor(model => model.descricao, new { @class = "form-control", @maxlength="100"})</div>                                    
                            </div>  
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.comentario</label>
                                <div class="col-12">@Html.TextAreaFor(model => model.comentario, new { @class = "form-control", @maxlenght = "5000", @rows=10})</div>   
                            </div>  
                            <div class="form-group row">
                            <label class="col-12">@INTERACTI.WEB.Properties.Resources.ativo</label>
                            <div class="col-12">
                                <label class="css-control css-control-success css-switch">
                                    @Html.CheckBoxFor(model => model.ativo, new { @class = "css-control-input"})
                                    <span class="css-control-indicator"></span>
                                </label>
                            </div>
                            </div>
                        </div>                        
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Scripts {
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/bundles/cookie")    
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/select")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/bundles/codebase")

    <script>

        jQuery.validator.addMethod("descricao_bd", function (value, element) {

            var codigo = $("#codigo").val();
            var unidade = $("#unidade").val();

            var dataString = {
                "descricao": value,
                "codigo": codigo,
                "unidade": unidade
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaNormasProcedimentos",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "");

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'descricao': {
                            required: true,
                            descricao_bd: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'descricao': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido',
                            descricao_bd: '@INTERACTI.WEB.Properties.Resources.valida_descricao_bd'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['maxlength']);
        });

    </script>

}
