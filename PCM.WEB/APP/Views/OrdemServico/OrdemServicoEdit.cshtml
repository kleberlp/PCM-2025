@model INTERACTI.WEB.MODELS.OrdemServico

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-5 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@INTERACTI.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("OrdemServicoIndex", "OrdemServico")">@INTERACTI.WEB.Properties.Resources.solicitar_manutencao</a>
                <span class="breadcrumb-item active">@INTERACTI.WEB.Properties.Resources.inserir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">                
                @using (Html.BeginForm("OrdemServicoEdit", "OrdemServico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data"  }))        
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.codigo)
                    <input type="hidden" name="unidade_old" id="unidade_old" value="@ViewBag.codigo_unidade">

                    <div class="block block-rounded block-themed">
                        <div class="block-header bg-gd-primary">
                            <h3 class="block-title">@INTERACTI.WEB.Properties.Resources.informacoes</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-sm btn-alt-primary">
                                    <i class="fa fa-save mr-5"></i>@INTERACTI.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("OrdemServicoIndex", "OrdemServico")" class="btn btn-sm btn-alt-primary">
                                    <i class="si si-action-undo mr-5"></i>@INTERACTI.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full"> 
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.categoria</label>
                                <div class="col-12">@Html.DropDownList("categoria", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.setor</label>
                                <div class="col-12">@Html.DropDownList("setor", null, "", new { @class = "form-control" })</div>
                            </div>                
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.equipamento</label>
                                <div class="col-12">@Html.DropDownList("equipamento", null, "", new { @class = "form-control" })</div>
                            </div>                
                            <div class="form-group row">                                
                                <div class="col-3">
                                    <label for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.data</label>
                                    <div><input type="text" class="js-datepicker form-control" id="data" name="data" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value="@ViewBag.data"></div>
                                </div>
                                <div class="col-3">
                                    <label for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.prioridade</label>
                                    <div>@Html.DropDownList("prioridade", null, "", new { @class = "form-control" })</div>
                                </div>
                                <div class="col-3">
                                    <label for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.tipo_ordem_servico</label>
                                    <div>@Html.DropDownList("tipo_ordem_servico", null, "", new { @class = "form-control" })</div>
                                </div>
                                <div class="col-3">
                                    <label for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.tipo_servico</label>
                                    <div>@Html.DropDownList("tipo_servico", null, "", new { @class = "form-control" })</div>
                                </div>
                            </div> 
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.descricao</label>
                                <div class="col-12">@Html.TextAreaFor(model => model.descricao, new { @class = "form-control", @maxlength="5000",  @rows="6" })</div>                                    
                            </div>                
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.imagem</label>
                                <div class="col-12">
                                    <div class="custom-file">
                                        <input id="imagem" name="imagem" type="file" />
                                    </div>
                                </div>
                            </div>
                        </div>                        
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Scripts {
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/bundles/cookie")    
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/select")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/bundles/codebase")

    <script>

        $(function () {

            var unidade = $("#unidade");
            var setor = $("#setor");
            var equipamento = $("#equipamento");

            unidade.change(function () {
                var request = { "unidade": unidade.val() };
                $.post("LoadSetor", request, function (obj) {
                    setor.empty();
                    option = $("<option>", { "value": "" }).text("");
                    setor.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        setor.append(option);
                    });
                }, "json");

                $.post("LoadEquipamento", request, function (obj) {
                    equipamento.empty();
                    option = $("<option>", { "value": "" }).text("");
                    equipamento.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        equipamento.append(option);
                    });
                }, "json");
            });

        });

        $(function () {

            var unidade = $("#unidade");
            var setor = $("#setor");
            var equipamento = $("#equipamento");

            setor.change(function () {
                var request = { "unidade": unidade.val(), "setor": setor.val() };
                $.post("LoadEquipamentoSetor", request, function (obj) {
                    equipamento.empty();
                    option = $("<option>", { "value": "" }).text("");
                    equipamento.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        equipamento.append(option);
                    });
                }, "json");
            });

        });

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'categoria': {
                            required: true
                        },
                        'data': {
                            required: true
                        },
                        'prioridade': {
                            required: true
                        },
                        'tipo_ordem_servico': {
                            required: true
                        },
                        'tipo_servico': {
                            required: true
                        },
                        'descricao': {
                            required: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'categoria': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'data': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'prioridade': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'tipo_ordem_servico': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'tipo_servico': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'descricao': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        }
                    }
                });
            };
        
            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['datepicker', 'maxlength']);
        });

    </script>
}
