
<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-5 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@INTERACTI.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("UsuarioIndex", "Administracao")">@INTERACTI.WEB.Properties.Resources.usuario</a>
                <span class="breadcrumb-item active">@INTERACTI.WEB.Properties.Resources.inserir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">                
                @using (Html.BeginForm("UsuarioInsert", "Administracao", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="block block-rounded block-themed">
                        <div class="block-header bg-gd-primary">
                            <h3 class="block-title">@INTERACTI.WEB.Properties.Resources.informacoes</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-sm btn-alt-primary">
                                    <i class="fa fa-save mr-5"></i>@INTERACTI.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("UsuarioIndex", "Administracao")" class="btn btn-sm btn-alt-primary">
                                    <i class="si si-action-undo mr-5"></i>@INTERACTI.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full"> 
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.email</label>
                                <div class="col-12"><input type="text" class="form-control" id="email" name="email" value="" maxlength="150"></div>
                            </div>                    
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.nome</label>
                                <div class="col-12"><input type="text" class="form-control" id="nome" name="nome" value="" maxlength="50"></div>
                            </div>    
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.perfil</label>
                                <div class="col-12">@Html.DropDownList("perfil", null, "", new { @class = "form-control" })</div>
                            </div>                       
                            <div class="form-group row">
                                <div class="col-4">
                                    <label for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.senha</label>
                                    <div><input type="password" class="form-control" id="senha" name="senha" value="" maxlength="20"></div>
                                </div>                  
                                <div class="col-4">              
                                    <label for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.confirmar_senha</label>
                                    <div ><input type="password" class="form-control" id="confirmar_senha" name="confirmar_senha" value="" maxlength="20"></div>
                                </div>                                              
                            </div>                            
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.celular</label>
                                <div class="col-4"><input type="text" class="form-control" id="telefone" name="telefone" value=""></div>
                            </div>     
                            <div class="form-group row">
                            <label class="col-12">@INTERACTI.WEB.Properties.Resources.ativo</label>
                            <div class="col-12">
                                <label class="css-control css-control-success css-switch">
                                    <input type="checkbox" class="css-control-input" id="ativo" name="ativo" checked value ="true">
                                    <span class="css-control-indicator"></span>
                                </label>
                            </div>
                        </div>
                        </div>                        
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Scripts {
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/bundles/cookie")    
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/select")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/bundles/codebase")

    <script>

        $(document).ready(function () { $("#telefone").mask("(99) 99999-9999"); });

        jQuery.validator.addMethod("email_bd", function (value, element) {

            var dataString = {
                "email": value,
                "codigo": -1
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaUsuario",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "");

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'email': {
                            required: true,
                            email: true,
                            email_bd: true
                        },
                        'perfil': {
                            required: true
                        },
                        'nome': {
                            required: true
                        },
                        'senha': {
                            required: true
                        },
                        'confirmar_senha': {
                            required: true,
                            equalTo: '#senha'
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'email': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido',
                            email: '@INTERACTI.WEB.Properties.Resources.valida_email_valido',
                            email_bd: '@INTERACTI.WEB.Properties.Resources.valida_email_valido_bd'
                        },
                        'perfil': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'nome': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'senha': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido',
                        },
                        'confirmar_senha': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido',
                            equalTo: '@INTERACTI.WEB.Properties.Resources.erro_confirmacao_senha',
                        }
                    }
                });
            };
        
            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['maxlength']);
        });

    </script>
}
