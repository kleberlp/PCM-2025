@model List<INTERACTI.WEB.MODELS.LancamentoMedicao>

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-5 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@INTERACTI.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("LancamentoIndex", "GreenPlanet")">@INTERACTI.WEB.Properties.Resources.green_planet</a>
                <span class="breadcrumb-item active">@INTERACTI.WEB.Properties.Resources.medicao</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">
                            
        @using (Html.BeginForm("LancamentoIndex", "GreenPlanet", new {ReturnUrl = ViewBag.ReturnUrl}, FormMethod.Post, new { @class = "js-validation-bootstrap", @name = "form", @id = "form", role = "form" }))
        {
            @Html.AntiForgeryToken()
                    
            <div class="row">

                <div class="col-md-5 col-xl-3">
                    <!-- Toggle Tasks Navigation on mobile -->
                    <button type="button" class="btn btn-block btn-primary d-md-none mb-10" data-toggle="class-toggle" data-target=".js-tasks-nav" data-class="d-none d-md-block">@INTERACTI.WEB.Properties.Resources.filtros</button>

                    <!-- Collapsible Tasks Navigation -->
                    <div class="js-tasks-nav d-none d-md-block">
                        <!-- Tasks Info -->
                        <div class="block block-rounded">
                            <div class="block-header block-header-default">
                                <h3 class="block-title">@INTERACTI.WEB.Properties.Resources.filtro</h3>
                            </div>
                            <div class="block-content">
                                <ul class="list-group push">
                                    <li class="list-group-item">
                                        <div>@Html.DropDownList("unidade", null, INTERACTI.WEB.Properties.Resources.unidade, new { @class = "form-control" })</div>                                    
                                    </li>
                                    <li class="list-group-item">
                                        <div><input type="text" class="js-datepicker form-control" id="data" name="data" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value="@ViewBag.data"></div>
                                    </li>                                
                                    <li class="list-group-item text-right">                                                    
                                        <button type="button" class="btn btn-sm btn-alt-primary" name="filtrar" id="filtrar" onclick="Load(); submit();"><i class="si si-magnifier mr-5"></i>@INTERACTI.WEB.Properties.Resources.filtrar</button>
                                    </li>
                                </ul>
                            </div>
                        </div>
                        <!-- END Tasks Info -->

                    </div>
                    <!-- END Collapsible Tasks Navigation -->
                </div>
    
                <div class="col-md-7 col-xl-9">
                    
                    <div class="js-tasks">
                    
                        <div class="block">
                            <div class="block-header block-header-default">
                                <h3 class="block-title">
                                    @INTERACTI.WEB.Properties.Resources.medicao
                                </h3>
                                <div class="block-options">
                                    <button type="button" class="btn btn-sm btn-alt-primary" onclick="Insert(); submit();">
                                        <i class="fa fa-save mr-5"></i>@INTERACTI.WEB.Properties.Resources.salvar
                                    </button>
                                </div>
                            </div>
                        
                            <div class="block-content"> 
                                
                                <table class="js-table-sections table table-hover">
                                    <thead>
                                        <tr>
                                            <th>@INTERACTI.WEB.Properties.Resources.item_medicao</th>
                                            <th class="text-center" style="width: 150px;">@INTERACTI.WEB.Properties.Resources.valor</th>                                
                                        </tr>
                                    </thead>

                                    <tbody>             
                                        @for (int i = 0; i < Model.Count; i++)
                                        {                                    
                                            <tr>     
                                                @Html.HiddenFor(m => m[i].codigo_item_medicao)
                                                <td>@Html.DisplayFor(m => m[i].item_medicao)</td>
                                                <td class="text-center" style="width: 150px;">@Html.TextBoxFor(m => m[i].valor, new { @class = "form-control text-center"})</td>                                                                
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                 
                    </div>

                </div>
                      
            </div>
                      
        }
            
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Scripts {
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/bundles/cookie")    
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/select")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/bundles/codebase")

    <script>

        function Load() {
            $('#form').attr('action', 'LancamentoIndex');
        }

        function Insert() {
            $('#form').attr('action', 'LancamentoInsert');
        }

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'data': {
                            required: true
                        },
                        messages: {
                            'unidade': {
                                required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                            },
                            'data': {
                                required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                            }
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['datepicker', 'maxlength']);
        });

    </script>
}
