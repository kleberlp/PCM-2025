
<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-5 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@INTERACTI.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("FuncionarioIndex", "CadastroBasico")">@INTERACTI.WEB.Properties.Resources.funcionario</a>
                <span class="breadcrumb-item active">@INTERACTI.WEB.Properties.Resources.inserir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">        
                @using (Html.BeginForm("FuncionarioInsert", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data"  }))        
                {
                    @Html.AntiForgeryToken()

                    <div class="block block-rounded block-themed">
                        <div class="block-header bg-gd-primary">
                            <h3 class="block-title">@INTERACTI.WEB.Properties.Resources.informacoes</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-sm btn-alt-primary">
                                    <i class="fa fa-save mr-5"></i>@INTERACTI.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("FuncionarioIndex", "CadastroBasico")" class="btn btn-sm btn-alt-primary">
                                    <i class="si si-action-undo mr-5"></i>@INTERACTI.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">    
                            <div class="form-group row">
                                <label class="col-lg-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.unidade</label>
                                <div class="col-lg-12">@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                            </div>                        
                            <div class="form-group row">
                                <label class="col-lg-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.cpf</label>
                                <div class="col-4"><input type="text" class="form-control" id="cpf" name="cpf" value=""></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-lg-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.nome</label>
                                <div class="col-12"><input type="text" class="js-maxlength form-control" id="nome" name="nome" maxlength="120" value=""></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.funcao</label>
                                <div class="col-lg-12">@Html.DropDownList("funcao", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-lg-12" for="ecom-product-name">@INTERACTI.WEB.Properties.Resources.telefone</label>
                                <div class="col-4"><input type="text" class="form-control" id="telefone" name="telefone" value=""></div>
                            </div>
                            <div class="form-group row">
                            <label class="col-12">@INTERACTI.WEB.Properties.Resources.ativo</label>
                            <div class="col-12">
                                <label class="css-control css-control-success css-switch">
                                    <input type="checkbox" class="css-control-input" id="ativo" name="ativo" checked value ="true">
                                    <span class="css-control-indicator"></span>
                                </label>
                            </div>                            
                            </div>
                        </div>                        
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Scripts {
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/bundles/cookie")    
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/select")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/bundles/codebase")

    <script>

        $(document).ready(function () { $("#cpf").mask("999.999.999-99"); });
        $(document).ready(function () { $("#telefone").mask("(99) 99999-9999"); });

        jQuery.validator.addMethod("cpf", function (cpf, element) {

            cpf = cpf.replace(".", "");
            cpf = cpf.replace(".", "");
            cpf = cpf.replace(".", "");
            cpf = cpf.replace("-", "");

            var Soma;
            var Resto;
            Soma = 0;
            if (cpf == "00000000000") return false;

            for (i = 1; i <= 9; i++) Soma = Soma + parseInt(cpf.substring(i - 1, i)) * (11 - i);
            Resto = (Soma * 10) % 11;

            if ((Resto == 10) || (Resto == 11)) Resto = 0;
            if (Resto != parseInt(cpf.substring(9, 10))) return false;

            Soma = 0;
            for (i = 1; i <= 10; i++) Soma = Soma + parseInt(cpf.substring(i - 1, i)) * (12 - i);
            Resto = (Soma * 10) % 11;

            if ((Resto == 10) || (Resto == 11)) Resto = 0;
            if (Resto != parseInt(cpf.substring(10, 11))) return false;
            return true;

        }, "Informe um CPF v&aacute;lido.");

        jQuery.validator.addMethod("cpf_bd", function (value, element) {

            var unidade = $("#unidade").val();

            var dataString = {
                "cpf": value,
                "codigo": -1,
                "unidade": unidade
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaFuncionario",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "Informe um CPF v&aacute;lido.");

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'cpf': {
                            required: true,
                            cpf: true,
                            cpf_bd: true,
                        },
                        'nome': {
                            required: true
                        },
                        'funcao': {
                            required: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'cpf': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido',
                            cpf: '@INTERACTI.WEB.Properties.Resources.valida_cpf_invalido',
                            cpf_bd: '@INTERACTI.WEB.Properties.Resources.valida_cpf_bd',
                        },
                        'nome': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        },
                        'funcao': {
                            required: '@INTERACTI.WEB.Properties.Resources.campo_requerido'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['maxlength']);
        });

    </script>

}