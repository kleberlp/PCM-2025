                    datasets: [{
                        data: @ViewBag.ChartCategoria.valor,
                        backgroundColor: [
                            'rgba(160,82,45, 1)',
                            'rgba(210,105,30, 1)',
                            'rgba(205,133,63, 1)',
                            'rgba(244,164,96, 1)',
                            'rgba(222,184,135, 1)',
                            'rgba(210,180,140, 1)',
                            'rgba(188,143,143, 1)',
                            'rgba(255,228,181, 1)',
                            'rgba(255,222,173, 1)',
                            'rgba(255,218,185, 1)',
                            'rgba(255,228,225, 1)',
                            'rgba(255,240,245, 1)',
                            'rgba(250,240,230, 1)',
                            'rgba(253,245,230, 1)',
                            'rgba(255,239,213, 1)',
                            'rgba(255,245,238, 1)',
                            'rgba(245,255,250, 1)',
                            'rgba(112,128,144, 1)',
                            'rgba(119,136,153, 1)',
                            'rgba(176,196,222, 1)',
                            'rgba(230,230,250, 1)',
                            'rgba(255,250,240, 1)',
                            'rgba(240,248,255, 1)',
                            'rgba(248,248,255, 1)',
                            'rgba(240,255,240, 1)',
                            'rgba(255,255,240, 1)',
                            'rgba(240,255,255, 1)',
                            'rgba(255,250,250, 1)'
                        ],
                        hoverBackgroundColor: [
                            'rgba(160,82,45, .5)',
                            'rgba(210,105,30, .5)',
                            'rgba(205,133,63, .5)',
                            'rgba(244,164,96, .5)',
                            'rgba(222,184,135, .5)',
                            'rgba(210,180,140, .5)',
                            'rgba(188,143,143, .5)',
                            'rgba(255,228,181, .5)',
                            'rgba(255,222,173, .5)',
                            'rgba(255,218,185, .5)',
                            'rgba(255,228,225, .5)',
                            'rgba(255,240,245, .5)',
                            'rgba(250,240,230, .5)',
                            'rgba(253,245,230, .5)',
                            'rgba(255,239,213, .5)',
                            'rgba(255,245,238, .5)',
                            'rgba(245,255,250, .5)',
                            'rgba(112,128,144, .5)',
                            'rgba(119,136,153, .5)',
                            'rgba(176,196,222, .5)',
                            'rgba(230,230,250, .5)',
                            'rgba(255,250,240, .5)',
                            'rgba(240,248,255, .5)',
                            'rgba(248,248,255, .5)',
                            'rgba(240,255,240, .5)',
                            'rgba(255,255,240, .5)',
                            'rgba(240,255,255, .5)',
                            'rgba(255,250,250, .5)'
                        ]
                    }]
                };

                if (chartManutencaoCategoriaCon.length) {
                    chartManutencaoCategoria = new Chart(chartManutencaoCategoriaCon, { type: 'pie', data: chartManutencaoCategoria });
                }
            };

            return {
                init: function () {

                    // Init Chart.js Charts
                    initChart();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            chartManutencaoPendenteRealizado.init();
            chartManutencaoTipoOrdemServico.init();
            chartManutencaoCategoria.init();
        });

    </script>
}
