@section Scripts {
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/bundles/cookie")    
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/chart")
    @Scripts.Render("~/bundles/codebase")

    <!-- Page JS Code -->
    <script>

        var dados_tipo_ordem_servico = [];
        var label_tipo_ordem_servico = [];
        var dados_categoria = [];
        var label_categoria = [];

        var chartManutencaoPendenteRealizado = function () {

            var initChartJS = function () {

                // Get Chart Containers
                var chartManutencaoPendenteRealizadoCon = jQuery('.manutencao_pendente_realizado');

                // Set Chart and Chart Data variables
                var chartManutencaoPendenteRealizado;

                // Lines/Bar/Radar Chart Data
                var chartManutencaoPendenteRealizado = {
                    labels: ["Jan", "Fev", "Mar", "Abr", "Mai", "Jun", "Jul", "Ago", "Set", "Out", "Nov", "Dez"],
                    datasets: [
                        {
                            label: 'Pendente',
                            fill: true,
                            fillColor: "rgba(220,220,220,0.5)",
                            strokeColor: "rgba(220,220,220,1)",
                            pointColor: "rgba(220,220,220,1)",
                            pointStrokeColor: "#fff",
                            pointHighlightFill: "#fff",
                            pointHighlightStroke: "rgba(220,220,220,1)",
                            data: @ViewBag.ChartPendenteRealizado.pendente
                        },
                        {
                            label: 'Realizado',
                            fill: true,
                            backgroundColor: 'rgba(111,171,88,.25)',
                            borderColor: 'rgba(94,145,66,1)',
                            pointBackgroundColor: 'rgba(94,145,66,1)',
                            pointBorderColor: '#fff',
                            pointHoverBackgroundColor: '#fff',
                            pointHoverBorderColor: 'rgba(66,165,245,1)',
                            data: @ViewBag.ChartPendenteRealizado.realizado
                        }
                    ]
                };

                var lineOptions = {
                    scaleShowGridLines: true,
                    scaleGridLineColor: "rgba(0,0,0,.05)",
                    scaleGridLineWidth: 1,
                    bezierCurve: true,
                    bezierCurveTension: 0.4,
                    pointDot: true,
                    pointDotRadius: 4,
                    pointDotStrokeWidth: 1,
                    pointHitDetectionRadius: 20,
                    datasetStroke: true,
                    datasetStrokeWidth: 2,
                    datasetFill: true,
                    responsive: true,
                };


                // Init Charts
                if (chartManutencaoPendenteRealizadoCon.length) {
                    chartManutencaoPendenteRealizado = new Chart(chartManutencaoPendenteRealizadoCon, { type: 'line', data: chartManutencaoPendenteRealizado, options: lineOptions});
                }
            };

            return {
                init: function () {

                    initChartJS();
                }
            };
        }();

        var chartManutencaoTipoOrdemServico = function () {

            var initChartJS = function () {

                // Get Chart Containers
                var chartManutencaoTipoOrdemServicoCon = jQuery('.manutencao_tipo_ordem_servico');

                // Set Chart and Chart Data variables
                var chartManutencaoTipoOrdemServico;

                // Donut Data
                var chartManutencaoTipoOrdemServico = {
                    labels: ["CHECKLIST", "CORRETIVA", "MELHORIA", "PREDITIVA", "PREVENTIVA"],
                    datasets: [{
                        data: @ViewBag.ChartTipoOrdemServico.valor,
                        backgroundColor: [
                            'rgba(156,204,101,1)',
                            'rgba(255,202,40,1)',
                            'rgba(255,240,245,1)',
                            'rgba(239,83,80,1)'
                        ],
                        hoverBackgroundColor: [
                            'rgba(156,204,101,.5)',
                            'rgba(255,202,40,.5)',
                            'rgba(255,240,245,.5)',
                            'rgba(239,83,80,.5)'
                        ]
                    }]
                };

                if (chartManutencaoTipoOrdemServicoCon.length) {
                    chartManutencaoTipoOrdemServico = new Chart(chartManutencaoTipoOrdemServicoCon, { type: 'doughnut', data: chartManutencaoTipoOrdemServico });
                }
            };

            return {
                init: function () {

                    initChartJS();
                }
            };
        }();

        var chartManutencaoCategoria = function () {

            var initChart = function () {

                // Get Chart Containers
                var chartManutencaoCategoriaCon = jQuery('.manutencao_categoria');
                
