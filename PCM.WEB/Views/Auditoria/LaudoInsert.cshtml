
<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-md-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("LaudoIndex", "Auditoria")">@PCM.WEB.Properties.Resources.laudo</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.inserir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">                
                @using (Html.BeginForm("LaudoInsert", "Auditoria", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data"  }))
                {
                    @Html.AntiForgeryToken()

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.cadastrar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("LaudoIndex", "Auditoria")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full"> 
                            <div class="form-group row">
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.unidade</label>
                                    <div>@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.modulo</label>
                                    <div>@Html.DropDownList("modulo", null, @PCM.WEB.Properties.Resources.modulo, new { @class = "js-select form-control" })</div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.laudo</label>
                                <div class="col-12">@Html.DropDownList("programada", null, "", new { @class = "form-control js-select2" })</div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.data</label>
                                    <div><input type="text" class="js-datepicker form-control" id="data" name="data" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value="@ViewBag.data"></div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.data_validade</label>
                                    <div><input type="text" class="js-datepicker form-control" id="data_validade" name="data_validade" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value="@ViewBag.data_validade"></div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.fornecedor</label>
                                <div class="col-12">@Html.DropDownList("fornecedor", null, "", new { @class = "form-control js-select2" })</div>
                            </div>      
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.equipamento</label>
                                <div class="col-12">@Html.DropDownList("equipamento", null, "", new { @class = "form-control js-select2", @multiple="multiple" })</div>
                            </div>      
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.valor</label>
                                <div class="col-md-4"><input type="text" class="form-control" id="valor" name="valor" value=""></div>
                            </div>                       
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.arquivo</label>
                                <div class="col-12">
                                    <div class="custom-file">                                        
                                        <input type="file" class="custom-file-input" id="arquivo" name="arquivo" onchange="Arquivo();" accept="application/pdf">
                                        <label id="lblArquivo" class="custom-file-label" for="arquivo">@PCM.WEB.Properties.Resources.selecione_arquivo</label>
                                    </div>
                                </div>
                            </div>
                        </div>                        
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")

<script>

    $(document).ready(function () { $("#data").mask("99/99/9999"); });
    $(document).ready(function () { $("#data_validade").mask("99/99/9999"); });
    $(document).ready(function () { $("#valor").maskMoney({ prefix: 'R$ ', thousands: '.', decimal: ',', precision: 2, allowNegative: false, 'placeholder': '' }); });

    $(function () {

        $.ajaxSetup({ async: false });
        var unidade = $("#unidade")
        var programada = $("#programada");
        var fornecedor = $("#fornecedor");
        var equipamento = $("#equipamento");

        equipamento.prop("disabled", true);
        programada.select2({ placeholder: '', allowClear: true });
        fornecedor.select2({ placeholder: '', allowClear: true });
        equipamento.select2({ placeholder: '', allowClear: true });

        if (unidade.val() == "" || unidade.val() == "-1") {
            programada.prop("disabled", true);
            fornecedor.prop("disabled", true);
            equipamento.prop("disabled", true);
            programada.select2({ placeholder: '', allowClear: true });
            fornecedor.select2({ placeholder: '', allowClear: true });
            equipamento.select2({ placeholder: '', allowClear: true });
        }

        unidade.change(function () {

            if (unidade.val() == "") {
                programada.prop("disabled", true);
                fornecedor.prop("disabled", true);
                equipamento.prop("disabled", true);
                programada.select2({ placeholder: '', allowClear: true });
                fornecedor.select2({ placeholder: '', allowClear: true });
                equipamento.select2({ placeholder: '', allowClear: true });
            } else {

                var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val() };

                $.post("LoadFornecedor", request, function (obj) {
                    fornecedor.empty();
                    option = $("<option>", { "value": "" }).text("");
                    fornecedor.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        fornecedor.append(option);
                    });
                }, "json");

                var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val(), "tipo_ordem_servico": 6 };

                $.post("LoadProgramada", request, function (obj) {
                    programada.empty();
                    option = $("<option>", { "value": "" }).text("");
                    programada.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        programada.append(option);
                    });
                }, "json");

                fornecedor.prop("disabled", false);
                programada.prop("disabled", false);
                fornecedor.select2({ placeholder: '', allowClear: true });
                programada.select2({ placeholder: '', allowClear: true });
            }

        });

        programada.change(function () {

            if (programada.val() == "") {
                equipamento.prop("disabled", true);
                equipamento.select2({ placeholder: '', allowClear: true });
            } else {

                var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val(), "programada": programada.val() };

                $.post("LoadEquipamentoLaudo", request, function (obj) {
                    equipamento.empty();
                    option = $("<option>", { "value": "" }).text("");
                    equipamento.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        equipamento.append(option);
                    });
                }, "json");

                equipamento.prop("disabled", false);
                equipamento.select2({ placeholder: '', allowClear: true });
            }

        });

    });

    function Arquivo() {

        //const file = document.getElementById("arquivo").files[0];
        //if (!file) return;

        //const sanitized = sanitizeFileName(file.name);

        //if (sanitized !== file.name) {
        //    const dt = new DataTransfer();
        //    dt.items.add(new File([file], sanitized, { type: file.type }));
        //    this.files = dt.files;
        //}

        document.getElementById("lblArquivo").textContent = document.getElementById("arquivo").files[0].name;
    }

    jQuery.validator.addMethod("maxDate", function (value, element) {

        var curDate = new Date();
        curDate.setHours(0, 0, 0, 0);
        var from = value.split("/");
        var inputDate = new Date(from[2], from[1] - 1, from[0]);
        if (inputDate > curDate) {
            return this.optional(element) || false;
        }
        else {
            return this.optional(element) || true;
        }

    }, '');

    jQuery.validator.addMethod("maxFileSize", function (value, element, param) {
        if (element.files.length === 0) return true; // sem arquivo
        const maxSizeBytes = param;
        return element.files[0].size <= maxSizeBytes;
    }, "O arquivo excede o tamanho máximo permitido.");

    function sanitizeFileName(fileName) {
        return fileName
            .normalize("NFD").replace(/[\u0300-\u036f]/g, "")
            .replace(/[^a-zA-Z0-9_.-]/g, "_");
    }

    var FormValidation = function () {
        // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
        var initValidationBootstrap = function () {
            jQuery('.js-validation-bootstrap').validate({
                ignore: [],
                errorClass: 'invalid-feedback animated fadeInDown',
                errorElement: 'div',
                errorPlacement: function (error, e) {
                    jQuery(e).parents('.form-group > div').append(error);
                },
                highlight: function (e) {
                    jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                },
                success: function (e) {
                    jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                    jQuery(e).remove();
                },
                rules: {
                    'unidade': {
                        required: true
                    },
                    'modulo': {
                        required: true
                    },
                    'programada': {
                        required: true
                    },
                    'data': {
                        required: true,
                        maxDate: true
                    },
                    'data_validade': {
                        required: true
                    },
                    'fornecedor': {
                        required: true
                    },
                    'arquivo': {
                        required: true,
                        maxFileSize: 10 * 1024 * 1024 // 5MB
                    }
                },
                messages: {
                    'unidade': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'modulo': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'programada': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'data': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido',
                        maxDate: '@PCM.WEB.Properties.Resources.data_maior_corrente'
                    },
                    'data_validade': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'fornecedor': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'arquivo': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido',
                        maxFileSize: 'Tamanho do arquivo excedeu o máximo permitido (10 Mb).'
                    }
                }
            });
        };

        return {
            init: function () {
                // Init Bootstrap Forms Validation
                initValidationBootstrap();
            }
        };
    }();

    // Initialize when page loads
    jQuery(function () {
        FormValidation.init();
        Codebase.helpers(['datepicker', 'maxlength', 'select2']);
    });

</script>
}
