@using Microsoft.AspNet.Identity

<!-- URLs para o codebase.js usar — padrão do sistema -->
<script>
    var urlHeaderCombos = '@Url.Action("HeaderCombos", "Home")';
    var urlHeaderPost   = '@Url.Action("Index", "Home")';
    var urlSetUnidade   = '@Url.Action("SetUnidade", "Home")';
</script>

<!-- Header -->
<header id="page-header">

    <div class="content-header border-b">

        <!-- Left: toggle sidebar -->
        <div class="content-header-section">
            <button type="button" class="btn btn-circle btn-dual-secondary" data-toggle="layout" data-action="sidebar_toggle">
                <i class="fa fa-navicon"></i>
            </button>
        </div>

        <!-- Center: logo + selects de unidade/módulo -->
        <div class="content-header-section header-center-section flex-fill px-3">
            <div class="d-flex align-items-center" style="gap:12px;">

                <img src="@Session["imagem_header"]" style="height:22px; flex-shrink:0;" alt="" />

                @using (Html.BeginForm("Index", "Home", FormMethod.Post, new { id = "form-header-filter", @class = "header-filter-form" }))
                {
                    @Html.AntiForgeryToken()
                    <select id="header-unidade" name="unidade" class="header-select">
                        <option>Carregando...</option>
                    </select>
                    <select id="header-modulo" name="modulo" class="header-select">
                        <option>Carregando...</option>
                    </select>
                    if (ViewBag.ShowDateFilter != null && (bool)ViewBag.ShowDateFilter == true)
                    {
                        @Html.DropDownList("data", null, null, new { @class = "header-select", id = "filtro-data" })
                    }
                }

            </div>
        </div>

        <!-- Right: notificações + sair -->
        <div class="content-header-section">

            <div class="btn-group" role="group">
                <button type="button" class="btn btn-rounded btn-dual-secondary"
                        id="page-header-notifications" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    <i class="fa fa-flag"></i>
                    <span class="badge badge-primary badge-pill" id="quantidade_notificacao"></span>
                </button>
                <div class="dropdown-menu dropdown-menu-right min-width-300" aria-labelledby="page-header-notifications">
                    <h5 class="h6 text-center py-10 mb-0 border-b text-uppercase">Notificações</h5>
                    <ul class="list-unstyled my-20" id="header_notificacao" name="header_notificacao"></ul>
                </div>
            </div>

            <button type="button" class="btn btn-circle btn-dual-secondary" data-toggle="layout" data-action="side_overlay_toggle">
                <i class="fa fa-tasks"></i>
            </button>

            <a class="btn btn-circle btn-dual-secondary" href="@Url.Action("LogOff", "Account")">SAIR</a>

        </div>

    </div>

    <!-- Header Search -->
    <div id="page-header-search" class="overlay-header">
        <div class="content-header content-header-fullrow">
            <form action="be_pages_generic_search.html" method="post">
                <div class="input-group">
                    <div class="input-group-prepend">
                        <button type="button" class="btn btn-secondary" data-toggle="layout" data-action="header_search_off">
                            <i class="fa fa-times"></i>
                        </button>
                    </div>
                    <input type="text" class="form-control" placeholder="Search or hit ESC.." id="page-header-search-input" name="page-header-search-input">
                    <div class="input-group-append">
                        <button type="submit" class="btn btn-secondary"><i class="fa fa-search"></i></button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Header Loader -->
    <div id="page-header-loader" class="overlay-header bg-primary">
        <div class="content-header content-header-fullrow text-center">
            <div class="content-header-item">
                <i class="fa fa-sun-o fa-spin text-white"></i>
            </div>
        </div>
    </div>

</header>
<!-- END Header -->
