@model PCM.WEB.MODELS.interfaceOpera

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-md-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item">@PCM.WEB.Properties.Resources.configuracao </a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.interface_opera </span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product se -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">           
                @using (Html.BeginForm("InterfaceOpera", "Configuracao", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()
                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.interface_opera </h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                            </div>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.unidade</label>
                                    <div>@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                                </div>
                                <div class="col-md-4">
                                    <label>Hostname</label>
                                    <div>@Html.TextBoxFor(model => model.hostname, new { @class = "form-control", @maxlength = "250" })</div>
                                </div>
                                <div class="col-md-2">
                                    <label>Username</label>
                                    <div>@Html.TextBoxFor(model => model.username, new { @class = "form-control", @maxlength = "50" })</div>
                                </div>
                                <div class="col-md-2">
                                    <label>Password</label>
                                    <div>@Html.PasswordFor(model => model.password, new { @class = "form-control", @maxlength = "50", @value = Model.password })</div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-4">
                                    <label>App Key</label>
                                    <div>@Html.TextBoxFor(model => model.appKey, new { @class = "form-control", @maxlength = "250" })</div>
                                </div>
                                <div class="col-md-3">
                                    <label>Client ID</label>
                                    <div>@Html.TextBoxFor(model => model.clientId, new { @class = "form-control", @maxlength = "50" })</div>
                                </div>
                                <div class="col-md-3">
                                    <label>Client Secret</label>
                                    <div>@Html.TextBoxFor(model => model.clientSecret, new { @class = "form-control", @maxlength = "50" })</div>
                                </div>
                                <div class="col-md-2">
                                    <label>Frequência (minutos)</label>
                                    <div>@Html.TextBoxFor(model => model.intervalo, new { @class = "form-control", @maxlength = "2" })</div>
                                </div>
                            </div>

                        </div>                        
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")
    
<script>

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'hostname': {
                            required: true
                        },
                        'username': {
                            required: true
                        },
                        'password': {
                            required: true
                        },
                        'appKey': {
                            required: true
                        },
                        'clientId': {
                            required: true
                        },
                        'clientSecret': {
                            required: true
                        },
                        'intervalo': {
                            required: true
                        }
                    },
                    messages: {
                        'hostname': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'username': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'password': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'appKey': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'clientId': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'clientSecret': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'intervalo': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
        });

        $(function () {

            var unidade = $("#unidade");

            unidade.change(function () {

                $("#hostname").val("");
                $("#username").val("");
                $("#password").val("");
                $("#appKey").val("");
                $("#clientId").val("");
                $("#clientSecret").val("");
                $("#intervalo").val("");

                var dataString = { "codigoEmpresa": @ViewBag.codigoEmpresa, "codigoUnidade": (unidade.val() == "") ? "-1" : unidade.val() };

                jQuery.ajax({
                    type: "POST",
                    url: "LoadInterfaceOpera",
                    async: false,
                    data: dataString,
                    dataType: "json",
                    success: function (result) {
                        $("#hostname").val(result.hostname);
                        $("#username").val(result.username);
                        $("#password").val(result.password);
                        $("#appKey").val(result.appKey);
                        $("#clientId").val(result.clientId);
                        $("#clientSecret").val(result.clientSecret);
                        $("#intervalo").val(result.intervalo);
                    }
                });

            });

        });

</script>

}
