@model List<PCM.WEB.MODELS.Treinamento>

<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.treinamento</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->
    <!-- Page Content -->
    <div class="content">

        @using (Html.BeginForm("TreinamentoIndex", "Treinamento", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data", name = "form", id = "form" }))
        {
            @Html.AntiForgeryToken()

            <!-- Toggle Tasks Navigation on mobile -->
            <button type="button" class="btn btn-block btn-square btn-primary d-md-none mb-10" data-toggle="class-toggle" data-target=".js-tasks-nav" data-class="d-none d-md-block">@PCM.WEB.Properties.Resources.filtros</button>

            <div class="js-tasks-nav d-none d-md-block">
                <div class="block block-rounded border">
                    <div class="block-header block-header-default bg-gd-default">
                        <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.treinamento</h3>
                    </div>
                    <div class="block-content">
                        <ul class="list-group push">
                            <li class="list-group-item">
                                <div class="row">
                                    <div class="col-md-4">@Html.DropDownList("unidade", null, PCM.WEB.Properties.Resources.unidade.ToUpper(), new { @class = "js-select2 form-control" })</div>
                                    <div class="col-md-4"><div>@Html.DropDownList("modulo", null, PCM.WEB.Properties.Resources.modulo.ToUpper(), new { @class = "js-select2 form-control" })</div></div>
                                </div>
                            </li>
                            <li class="list-group-item text-right">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75" name="filtrar" id="filtrar"><i class="si si-magnifier mr-5"></i>@PCM.WEB.Properties.Resources.filtrar</button>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <!-- END Collapsible Tasks Navigation -->


            if (Model.Count > 0)
            {
                <div class="block block-rounded border">
                    <div class="block-content">

                        @for (int i = 0; i < Model.Count; i++)
                        {
                            if (i == 0)
                            {
                                <div class="content-block font-size-h2 border-b mb-15">@Model[i].unidade</div>
                            }
                            else if (Model[i].codigo_unidade != Model[i - 1].codigo_unidade)
                            {
                                <div class="content-block font-size-h2 border-b mb-15">@Model[i].unidade</div>
                            }

                            <div class="row mt-15">
                                <div class="col-md-12">
                                    <a class="block block-rounded block-bordered block-link-shadow" target="_blank" href="@Url.Content(Model[i].path_arquivo)">
                                        <div class="block-content block-content-full clearfix">
                                            <div class="float-right mt-15 d-none d-sm-block text-danger"><i class="fa fa-file-pdf-o fa-3x"></i></div>
                                            <div class="font-size-h3 font-w600 text-uppercase">@Model[i].descricao</div>
                                            <div class="font-size-md font-w600 text-secundary">@Model[i].comentario</div>
                                        </div>
                                    </a>
                                </div>
                            </div>
                        }

                    </div>
                </div>

            }
        }
    </div>

</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/dataTables")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")

    <script type="text/javascript">

        $(function () {
           
            $.ajaxSetup({async: false});

            var unidade = $("#unidade");
            var auditoria = $("#auditoria");
            var status = $("#status");
            var departamento = $("#departamento");
            var prioridade = $("#prioridade");
            var solicitante = $("#solicitante");

            unidade.select2({ placeholder: '@PCM.WEB.Properties.Resources.unidade.ToUpper()', allowClear: true });
            auditoria.select2({ placeholder: '@PCM.WEB.Properties.Resources.auditoria.ToUpper()', allowClear: true });
            status.select2({ placeholder: '@PCM.WEB.Properties.Resources.status.ToUpper()', allowClear: true });
            departamento.select2({ placeholder: '@PCM.WEB.Properties.Resources.departamento.ToUpper()', allowClear: true });
            prioridade.select2({ placeholder: '@PCM.WEB.Properties.Resources.prioridade.ToUpper()', allowClear: true });
            solicitante.select2({ placeholder: '@PCM.WEB.Properties.Resources.solicitante.ToUpper()', allowClear: true });

            if (unidade.val() == "" || unidade.val() == "-1") {
                auditoria.prop( "disabled", true );
                solicitante.prop("disabled", true);
            }

            unidade.change(function () {

                if (unidade.val() == "") {

                    auditoria.empty();
                    prioridade.empty();
                    solicitante.empty();
                    auditoria.prop( "disabled", true );
                    prioridade.prop( "disabled", true );
                    solicitante.prop( "disabled", true );
                    unidade.select2({ placeholder: '@PCM.WEB.Properties.Resources.unidade.ToUpper()', allowClear: true });
                    auditoria.select2({ placeholder: '@PCM.WEB.Properties.Resources.auditoria.ToUpper()', allowClear: true });
                    status.select2({ placeholder: '@PCM.WEB.Properties.Resources.status.ToUpper()', allowClear: true });
                    prioridade.select2({ placeholder: '@PCM.WEB.Properties.Resources.prioridade.ToUpper()', allowClear: true });
                    solicitante.select2({ placeholder: '@PCM.WEB.Properties.Resources.solicitante.ToUpper()', allowClear: true });

                } else {

                    var request = { "unidade": unidade.val() };
                    
                    $.post("LoadAuditoriaQualidade", request, function (obj) {
                        auditoria.empty();
                        option = $("<option>", { "value": "" }).text("");
                        auditoria.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            auditoria.append(option);
                        });
                    }, "json");
                    
                    $.post("LoadPrioridade", request, function (obj) {
                        prioridade.empty();
                        option = $("<option>", { "value": "" }).text("");
                        prioridade.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            prioridade.append(option);
                        });
                    }, "json");

                    $.post("LoadSolicitante", request, function (obj) {
                        solicitante.empty();
                        option = $("<option>", { "value": "" }).text("");
                        solicitante.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            solicitante.append(option);
                        });
                    }, "json");

                    auditoria.prop("disabled", false);
                    prioridade.prop("disabled", false);
                    solicitante.prop("disabled", false);

                    unidade.select2({ placeholder: '@PCM.WEB.Properties.Resources.unidade.ToUpper()', allowClear: true });
                    auditoria.select2({ placeholder: '@PCM.WEB.Properties.Resources.auditoria.ToUpper()', allowClear: true });
                    status.select2({ placeholder: '@PCM.WEB.Properties.Resources.status.ToUpper()', allowClear: true });
                    prioridade.select2({ placeholder: '@PCM.WEB.Properties.Resources.prioridade.ToUpper()', allowClear: true });
                    solicitante.select2({ placeholder: '@PCM.WEB.Properties.Resources.solicitante.ToUpper()', allowClear: true });

                }

            });

        });
        
        function UpdateDataOrdemServico(codigo, unidade, data){

            
            //Seta Váriaveis
            $("#codigo_ordem_servico").val(codigo);
            $("#codigo_unidade").val(unidade);
            $("#data_os").val(data);
            $("#data_ordem_servico").val(data);
            
            //Abre Formulário
            jQuery('#modalDataOrdemServico').modal('show');

        }

        $('#form_data').validate({
            ignore: [],
            errorClass: 'invalid-feedback animated fadeInDown',
            errorElement: 'div',
            errorPlacement: function (error, e) {
                jQuery(e).parents('.form-group > div').append(error);
            },
            highlight: function (e) {
                jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
            },
            success: function (e) {
                jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                jQuery(e).remove();
            },
            rules: {
                'data_ordem_servico': {
                    required: true
                }
            },
            messages: {
                'data_ordem_servico': {
                    required: '@PCM.WEB.Properties.Resources.campo_requerido'
                }
            },
            submitHandler: function (form) {

                var data = $("#data_ordem_servico").val().toString();
                var codigo = $("#codigo_ordem_servico").val();
                var unidade = $("#codigo_unidade").val();
                
                var dataString = {
                    "codigo": codigo,
                    "unidade": unidade,
                    "data": data
                };

                $.post("UpdateDataOrdemServico", dataString,
                    function (result) {
                        $("#form").submit();
                    });

                $('#modalFuncionario').modal('hide');
            }
        });

        // Initialize when page loads
        jQuery(function () {
            $.fn.dataTable.moment('DD/MM/YYYY HH:mm');
            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
        });

    </script>
}
