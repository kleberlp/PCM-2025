@model List<PCM.WEB.MODELS.OrdemServico>

<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <span class="breadcrumb-item">@PCM.WEB.Properties.Resources.qualidade</span>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.plano_acao</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->
    <!-- Page Content -->
    <div class="content">

        @using (Html.BeginForm("OrdemServicoIndex", "Qualidade", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data", name = "form", id = "form" }))
        {
            @Html.AntiForgeryToken()

            <!-- Toggle Tasks Navigation on mobile -->
            <button type="button" class="btn btn-block btn-square btn-primary d-md-none mb-10" data-toggle="class-toggle" data-target=".js-tasks-nav" data-class="d-none d-md-block">@PCM.WEB.Properties.Resources.filtros</button>

            <div class="js-tasks-nav d-none d-md-block">
                <div class="block block-rounded border">
                    <div class="block-header block-header-default bg-gd-default">
                        <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.plano_acao</h3>
                    </div>
                    <div class="block-content">
                        <ul class="list-group push">
                            @if (Session["unidade"] == "")
                            {
                                <li class="list-group-item">
                                    <div class="row">
                                        <div class="col-md-4">@Html.DropDownList("unidade", null, PCM.WEB.Properties.Resources.unidade.ToUpper(), new { @class = "js-select2 form-control" })</div>
                                    </div>
                                </li>
                            }
                            @if (Session["unidade"] != "")
                            {
                                <input type="hidden" name="unidade" id="unidade" value="@ViewBag.codigo_unidade">
                            }
                            <li class="list-group-item">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="input-daterange input-group" data-date-format="dd/mm/yyyy" data-week-start="1" data-autoclose="true" data-today-highlight="true">
                                            <input type="text" class="form-control" id="data_inicio" name="data_inicio" placeholder="De" data-week-start="1" data-autoclose="true" data-today-highlight="true" value="@ViewBag.data_inicio">
                                            <div class="input-group-prepend input-group-append">
                                                <span class="input-group-text font-w600">-</span>
                                            </div>
                                            <input type="text" class="form-control" id="data_termino" name="data_termino" placeholder="Até" data-week-start="1" data-autoclose="true" data-today-highlight="true" value="@ViewBag.data_termino">
                                        </div>
                                    </div>
                                    <div class="col-md-2"><div><input type="text" id="ordem_servico" name="ordem_servico" value="@ViewBag.ordem_servico" placeholder="@PCM.WEB.Properties.Resources.plano_acao" class="form-control"></div></div>
                                    <div class="col-md-4"><div>@Html.DropDownList("auditoria", null, PCM.WEB.Properties.Resources.auditoria.ToUpper(), new { @class = "js-select2 form-control" })</div></div>
                                    <div class="col-md-2"><div>@Html.DropDownList("status", null, PCM.WEB.Properties.Resources.status.ToUpper(), new { @class = "js-select2 form-control" })</div></div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="row">
                                    <div class="col-md-4"><div>@Html.DropDownList("departamento", null, PCM.WEB.Properties.Resources.departamento.ToUpper(), new { @class = "js-select2 form-control" })</div></div>
                                    <div class="col-md-2"><div>@Html.DropDownList("prioridade", null, PCM.WEB.Properties.Resources.prioridade.ToUpper(), new { @class = "js-select2 form-control" })</div></div>
                                    <div class="col-md-6"><div>@Html.DropDownList("solicitante", null, PCM.WEB.Properties.Resources.solicitante.ToUpper(), new { @class = "js-select2 form-control" })</div></div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="row">
                                    <div class="col-md-6"><div><input type="text" id="executor" name="executor" value="@ViewBag.executor" placeholder="@PCM.WEB.Properties.Resources.executor" class="form-control"></div></div>
                                    <div class="col-md-6"><div>@Html.DropDownList("justificativa_apontamento", null, PCM.WEB.Properties.Resources.justificativa_apontamento.ToUpper(), new { @class = "js-select2 form-control" })</div></div>
                                </div>
                            </li>
                            <li class="list-group-item text-right">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75" name="filtrar" id="filtrar"><i class="si si-magnifier mr-5"></i>@PCM.WEB.Properties.Resources.filtrar</button>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <!-- END Collapsible Tasks Navigation -->


    <div class="row">

        <div class="col-3 col-sm-12 col-md-3 col-xl-3">
            <a class="block block-rounded block-bordered block-link-shadow" onclick="$('#status').select2('val', '3'); $('#form').submit()">
                <div class="block-content block-content-full clearfix">
                    <div class="float-right mt-15 d-none d-sm-block"><i class="fa fa-area-chart fa-2x text-danger"></i></div>
                    <div class="font-size-h5 font-w600 text-danger" data-speed="1000" data-to="@ViewBag.plano_acao_status.atrasado" id="quantidade_atrasado" name="quantidade_atrasado">@ViewBag.plano_acao_status.atrasado</div>
                    <div class="font-size-sm font-w600 text-uppercase text-muted">@PCM.WEB.Properties.Resources.plano_acao @PCM.WEB.Properties.Resources.atrasado</div>
                </div>
            </a>
        </div>

        <div class="col-3 col-sm-12 col-md-3 col-xl-3">
            <a class="block block-rounded block-bordered block-link-shadow" onclick="$('#status').select2('val', '1'); $('#form').submit()">
                <div class="block-content block-content-full clearfix">
                    <div class="float-right mt-15 d-none d-sm-block"><i class="fa fa-area-chart fa-2x text-warning"></i></div>
                    <div class="font-size-h5 font-w600 text-warning"><span data-speed="1000" data-to="@ViewBag.plano_acao_status.pendente" id="quantidade_pendente" name="quantidade_pendente">@ViewBag.plano_acao_status.pendente</span></div>
                    <div class="font-size-sm font-w600 text-uppercase text-muted">@PCM.WEB.Properties.Resources.plano_acao @PCM.WEB.Properties.Resources.pendente</div>
                </div>
            </a>
        </div>

        <div class="col-3 col-sm-12 col-md-3 col-xl-3">
            <a class="block block-rounded block-bordered block-link-shadow" onclick="$('#status').select2('val', '2'); $('#form').submit()">
                <div class="block-content block-content-full clearfix">
                    <div class="float-right mt-15 d-none d-sm-block"><i class="fa fa-area-chart fa-2x text-success"></i></div>
                    <div class="font-size-h5 font-w600 text-success"><span data-speed="1000" data-to="@ViewBag.plano_acao_status.concluido" id="quantidade_concluido" name="quantidade_concluido">@ViewBag.plano_acao_status.concluido</span></div>
                    <div class="font-size-sm font-w600 text-uppercase text-muted">@PCM.WEB.Properties.Resources.plano_acao @PCM.WEB.Properties.Resources.concluido</div>
                </div>
            </a>
        </div>

        <div class="col-3 col-sm-12 col-md-3 col-xl-3">
            <a class="block block-rounded block-bordered block-link-shadow" onclick="$('#status').select2('val', '4'); $('#form').submit()">
                <div class="block-content block-content-full clearfix">
                    <div class="float-right mt-15 d-none d-sm-block"><i class="fa fa-area-chart fa-2x text-primary"></i></div>
                    <div class="font-size-h5 font-w600 text-primary"><span data-speed="1000" data-to="@ViewBag.plano_acao_status.em_andamento" id="quantidade_andamento" name="quantidade_andamento">@ViewBag.plano_acao_status.em_andamento</span></div>
                    <div class="font-size-sm font-w600 text-uppercase text-muted">@PCM.WEB.Properties.Resources.plano_acao @PCM.WEB.Properties.Resources.em_andamento</div>
                </div>
            </a>
        </div>

    </div>

            if(Model.Count > 0)
            {
                <div class="block block-rounded border">
                    <div class="block-content block-content-full border">

                        <table class="table table-vcenter js-dataTable-list">

                            <tbody>

                                @for (int i = 0; i < Model.Count; i++)
                                {
                                    if (i == 0 || Model[i].unidade != Model[i - 1].unidade)
                                    {
                                        <tr class="mt-50">
                                            <td class="font-size-h2 font-w600 text-success" colspan="9">@Html.DisplayFor(m => m[i].unidade)</td>
                                        </tr>

                                    }

                                    if (i == 0 || Model[i].unidade != Model[i - 1].unidade || Model[i].auditoria != Model[i - 1].auditoria)
                                    {
                                        <tr class="mb-15">
                                            <td class="font-size-h4 font-w600 text-primary" colspan="9">@Html.DisplayFor(m => m[i].auditoria)</td>
                                        </tr>
                                        <tr class="table-secondary">
                                            <th class="text-center d-md-table-cell">@PCM.WEB.Properties.Resources.plano_acao</th>
                                            <th class="text-center d-md-table-cell">@PCM.WEB.Properties.Resources.departamento</th>
                                            <th class="text-center d-md-table-cell">@PCM.WEB.Properties.Resources.data</th>
                                            <th class="d-none d-lg-table-cell">@PCM.WEB.Properties.Resources.descricao</th>
                                            <th class="d-none d-md-table-cell text-center" style="width: 120px;">@PCM.WEB.Properties.Resources.data_execucao</th>
                                            <th class="d-none d-md-table-cell text-center" style="width: 120px;">@PCM.WEB.Properties.Resources.prioridade</th>
                                            <th class="text-center d-md-table-cell">@PCM.WEB.Properties.Resources.prazo</th>
                                            <th class="d-none d-md-table-cell text-center" style="width: 120px;">@PCM.WEB.Properties.Resources.status</th>
                                            <th data-sortable="false" class="text-center" style="width: 100px;" data-sortable="false"></th>
                                        </tr>
                                    }

                            <tr>
                                <td class="text-center d-md-table-cell">@Html.DisplayFor(modelItem => Model[i].numero_documento)</td>
                                <td class="text-center d-md-table-cell">@Html.DisplayFor(modelItem => Model[i].departamento)</td>
                                <td class="text-center d-md-table-cell">@Html.DisplayFor(modelItem => Model[i].data)</td>
                                <td class="d-none d-lg-table-cell">@Html.DisplayFor(modelItem => Model[i].descricao)</td>
                                <td class="d-none d-md-table-cell text-center">@Html.DisplayFor(modelItem => Model[i].data_execucao)</td>
                                <td class="d-none d-md-table-cell text-center">@Html.DisplayFor(modelItem => Model[i].prioridade)</td>
                                @if (Model[i].status == 1)
                                {
                                    <td class="text-center d-md-table-cell">@Html.DisplayFor(modelItem => Model[i].data_necessidade) <span class="badge badge-warning">(@Html.DisplayFor(modelItem => Model[i].dias))</span></td>
                                    <td class="d-none d-md-table-cell text-center" id="td.Model[i].codigo"><span class="badge badge-warning">@Model[i].status_descricao</span></td>
                                    <td class="text-center">
                                        <div class="btn-group">
                                            @if ((ViewBag.administrador_vincular) || Session["funcionario"] != "")
                                            {<button type="button" class="btn btn-sm btn-secondary" id="btn.Model[i].codigo" onclick="UpdateStatus(Model[i].codigo, Model[i].codigo_unidade, '@Model[i].data_necessidade', 5);"><i class="si si-call-in" id="i.Model[i].codigo" title="@PCM.WEB.Properties.Resources.vincular_desvincular_os" data-toggle="tooltip"></i></button>}
                                            @if (ViewBag.inserir)
                                            {
                                                <a href="@Url.Action("ApontamentoOS", "Qualidade", new { codigo_pcm_ordem_servico = Model[i].codigo, codigo_unidade = Model[i].codigo_unidade, model = "Qualidade", page = "OrdemServicoIndex" })" class="btn btn-sm btn-secondary"><i class="fa fa-crosshairs"></i></a>
                                            }
                                            @if (ViewBag.editar)
                                            {
                                        <button type="button" class="btn btn-sm btn-secondary" onclick="UpdateDataOrdemServico(@Model[i].codigo, @Model[i].codigo_unidade, '@Model[i].data_necessidade');"><i class="si si-calendar" title="@PCM.WEB.Properties.Resources.alterar_data_plano_acao" data-toggle="tooltip"></i></button>
                                            }
                                            <a href="@Url.Action("OrdemServicoView", "Qualidade", new { codigo = Model[i].codigo, unidade = Model[i].codigo_unidade })" class="btn btn-sm btn-secondary" target="_blank"><i class="fa fa-navicon"></i></a>
                                        </div>
                                    </td>
                                }
                                @if (Model[i].status == 2)
                                {
                                    <td class="text-center d-md-table-cell">@Html.DisplayFor(modelItem => Model[i].data_necessidade) <span class="badge badge-success">(@Html.DisplayFor(modelItem => Model[i].dias))</span></td>
                                    <td class="d-none d-md-table-cell text-center" id="td.Model[i].codigo"><span class="badge badge-success">@Model[i].status_descricao</span></td>
                                    <td class="text-center">
                                        <div class="btn-group">
                                            <a href="@Url.Action("OrdemServicoView", "Qualidade", new { codigo = Model[i].codigo, unidade = Model[i].codigo_unidade })" class="btn btn-sm btn-secondary" target="_blank"><i class="fa fa-navicon"></i></a>
                                        </div>
                                    </td>
                                }
                                @if (Model[i].status == 3)
                                {
                                    <td class="text-center d-md-table-cell">@Html.DisplayFor(modelItem => Model[i].data_necessidade) <span class="badge badge-danger">(@Html.DisplayFor(modelItem => Model[i].dias))</span></td>
                                    <td class="d-none d-md-table-cell text-center" id="td.Model[i].codigo"><span class="badge badge-danger">@Model[i].status_descricao</span></td>
                                    <td class="text-center">
                                        <div class="btn-group">
                                            @if ((ViewBag.administrador_vincular) || Session["funcionario"] != "")
                                            {<button type="button" class="btn btn-sm btn-secondary" id="btn.Model[i].codigo" onclick="UpdateStatus(@Model[i].codigo, @Model[i].codigo_unidade, '@Model[i].data', 5);"><i class="si si-call-in" id="i.Model[i].codigo" title="@PCM.WEB.Properties.Resources.vincular_desvincular_os" data-toggle="tooltip"></i></button>}
                                            @if (ViewBag.inserir)
                                            {<a href="@Url.Action("ApontamentoOS", "Qualidade", new { codigo_pcm_ordem_servico = Model[i].codigo, codigo_unidade = Model[i].codigo_unidade, model = "Qualidade", page = "OrdemServicoIndex" })" class="btn btn-sm btn-secondary"><i class="fa fa-crosshairs"></i></a>}
                                            @if (ViewBag.editar)
                                            {
                                                <button type="button" class="btn btn-sm btn-secondary" onclick="UpdateDataOrdemServico(@Model[i].codigo, @Model[i].codigo_unidade, '@Model[i].data_necessidade');"><i class="si si-calendar" title="@PCM.WEB.Properties.Resources.alterar_data_plano_acao" data-toggle="tooltip"></i></button>
                                            }
                                            <a href="@Url.Action("OrdemServicoView", "Qualidade", new { codigo = Model[i].codigo, unidade = Model[i].codigo_unidade })" class="btn btn-sm btn-secondary" target="_blank"><i class="fa fa-navicon"></i></a>
                                        </div>
                                    </td>
                                }
                                @if (Model[i].status == 4)
                                {
                                    <td class="text-center d-md-table-cell">@Html.DisplayFor(modelItem => Model[i].data_necessidade) <span class="badge @((Model[i].dias.Contains("-"))? Html.Raw("badge-danger") : Html.Raw("badge-primary"))">(@Html.DisplayFor(modelItem => Model[i].dias))</span></td>
                                    <td class="d-none d-md-table-cell text-center" id="td.Model[i].codigo"><span class="badge badge-primary">@Model[i].status_descricao</span></td>
                                    <td class="text-center">
                                        <div class="btn-group">
                                            @if (ViewBag.inserir)
                                            {<a href="@Url.Action("ApontamentoOS", "Qualidade", new { codigo_pcm_ordem_servico = Model[i].codigo, codigo_unidade = Model[i].codigo_unidade, model = "Qualidade", page = "OrdemServicoIndex" })" class="btn btn-sm btn-secondary"><i class="fa fa-crosshairs"></i></a>}

                                            @if (ViewBag.editar)
                                            {
                                        <button type="button" class="btn btn-sm btn-secondary" onclick="UpdateDataOrdemServico(@Model[i].codigo, @Model[i].codigo_unidade, '@Model[i].data_necessidade');"><i class="si si-calendar" title="@PCM.WEB.Properties.Resources.alterar_data_plano_acao" data-toggle="tooltip"></i></button>
                                            }
                                            <a href="@Url.Action("OrdemServicoView", "Qualidade", new { codigo = Model[i].codigo, unidade = Model[i].codigo_unidade })" class="btn btn-sm btn-secondary" target="_blank"><i class="fa fa-navicon"></i></a>
                                        </div>
                                    </td>
                                }
                                @if (Model[i].status == 5)
                                {
                                    <td class="d-none d-md-table-cell text-center" id="td.Model[i].codigo"><span class="badge badge-info">@Model[i].status_descricao</span></td>
                                    <td class="text-center">
                                        <div class="btn-group">
                                            @if (ViewBag.inserir)
                                            {<button type="button" class="btn btn-sm btn-danger" id="btn.Model[i].codigo" onclick="UpdateStatus(@Model[i].codigo, @Model[i].codigo_unidade, 'Model[i].data', 1);"><i class="si si-call-in" id="i.Model[i].codigo" title="@PCM.WEB.Properties.Resources.vincular_desvincular_os" data-toggle="tooltip"></i></button>}
                                            @if (ViewBag.inserir)
                                            {<a href="@Url.Action("ApontamentoOS", "Qualidade", new { codigo_pcm_ordem_servico = Model[i].codigo, codigo_unidade = Model[i].codigo_unidade, model = "Qualidade", page = "OrdemServicoIndex" })" class="btn btn-sm btn-secondary"><i class="fa fa-crosshairs"></i></a>}

                                            @if (ViewBag.editar)
                                            {
                                        <button type="button" class="btn btn-sm btn-secondary" onclick="UpdateDataOrdemServico(@Model[i].codigo, @Model[i].codigo_unidade, '@Model[i].data_necessidade');"><i class="si si-calendar" title="@PCM.WEB.Properties.Resources.alterar_data_plano_acao" data-toggle="tooltip"></i></button>
                                            }
                                            <a href="@Url.Action("OrdemServicoView", "Qualidade", new { codigo = Model[i].codigo, unidade = Model[i].codigo_unidade })" class="btn btn-sm btn-secondary" target="_blank"><i class="fa fa-navicon"></i></a>
                                        </div>
                                    </td>
                                }
                            </tr>
                                }
                            </tbody>

                        </table>

                    </div>
                </div>
            }
        }
    </div>

    <!-- From Right Modal -->
    <div class="modal fade" id="modalDataOrdemServico" tabindex="-1" role="dialog" aria-labelledby="modalDataOrdemServico" aria-hidden="true">
        @using (Html.BeginForm("OrdemServicoIndex", "Qualidade", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", @name = "form_data", @id = "form_data", enctype = "multipart/form-data" }))
        {
            <input type="hidden" name="codigo_ordem_servico" id="codigo_ordem_servico" value="0">
            <input type="hidden" name="codigo_unidade" id="codigo_unidade" value="0">
            <input type="hidden" name="data_os" id="data_os" value="">
            <div class="modal-dialog modal-dialog-fromright" role="document">
                <div class="modal-content">
                    <div class="block block-themed block-transparent mb-15">
                        <div class="block-header bg-secondary">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.novo_prazo_plano_acao</h3>
                        </div>
                        <div class="block-content">
                            <label class="col-12">@PCM.WEB.Properties.Resources.prazo</label>
                            <div class="col-md-6"><input type="text" class="js-datepicker form-control" id="data_ordem_servico" name="data_ordem_servico" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value=""></div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-square btn-secondary min-width-100 h-75" name="close" id="close" data-bs-dismiss="modal"><i class="fa fa-close mr-5"></i>@PCM.WEB.Properties.Resources.sair</button>
                        <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75" name="salvar" id="salvar"><i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar </button>
                    </div>
                </div>
            </div>
        }
    </div>
    <!-- END From Right Modal -->

</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/dataTables")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")

<script type="text/javascript">

        $(function () {

            $.ajaxSetup({async: false});

            var unidade = $("#unidade");
            var auditoria = $("#auditoria");
            var status = $("#status");
            var departamento = $("#departamento");
            var prioridade = $("#prioridade");
            var solicitante = $("#solicitante");
            var justificativa_apontamento = $("#justificativa_apontamento");

            if ("@Session["unidade"]" == "") {
                $("#unidade").select2({ placeholder: '@PCM.WEB.Properties.Resources.unidade.ToUpper()', allowClear: true });
            }
            auditoria.select2({ placeholder: '@PCM.WEB.Properties.Resources.auditoria.ToUpper()', allowClear: true });
            status.select2({ placeholder: '@PCM.WEB.Properties.Resources.status.ToUpper()', allowClear: true });
            departamento.select2({ placeholder: '@PCM.WEB.Properties.Resources.departamento.ToUpper()', allowClear: true });
            prioridade.select2({ placeholder: '@PCM.WEB.Properties.Resources.prioridade.ToUpper()', allowClear: true });
            solicitante.select2({ placeholder: '@PCM.WEB.Properties.Resources.solicitante.ToUpper()', allowClear: true });
            justificativa_apontamento.select2({ placeholder: '@PCM.WEB.Properties.Resources.justificativa_apontamento.ToUpper()', allowClear: true });

            if (unidade.val() == "" || unidade.val() == "-1") {
                auditoria.prop( "disabled", true );
                solicitante.prop("disabled", true);
            }

            unidade.change(function () {

                if (unidade.val() == "") {

                    auditoria.empty();
                    prioridade.empty();
                    solicitante.empty();
                    justificativa_apontamento.empty();
                    auditoria.prop( "disabled", true );
                    prioridade.prop( "disabled", true );
                    solicitante.prop("disabled", true);
                    justificativa_apontamento.prop("disabled", true);
                    unidade.select2({ placeholder: '@PCM.WEB.Properties.Resources.unidade.ToUpper()', allowClear: true });
                    auditoria.select2({ placeholder: '@PCM.WEB.Properties.Resources.auditoria.ToUpper()', allowClear: true });
                    status.select2({ placeholder: '@PCM.WEB.Properties.Resources.status.ToUpper()', allowClear: true });
                    prioridade.select2({ placeholder: '@PCM.WEB.Properties.Resources.prioridade.ToUpper()', allowClear: true });
                    solicitante.select2({ placeholder: '@PCM.WEB.Properties.Resources.solicitante.ToUpper()', allowClear: true });
                    justificativa_apontamento.select2({ placeholder: '@PCM.WEB.Properties.Resources.justificativa_apontamento.ToUpper()', allowClear: true });

                } else {

                    var request = { "unidade": unidade.val() };

                    $.post("LoadAuditoriaQualidade", request, function (obj) {
                        auditoria.empty();
                        option = $("<option>", { "value": "" }).text("");
                        auditoria.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            auditoria.append(option);
                        });
                    }, "json");

                    $.post("LoadPrioridade", request, function (obj) {
                        prioridade.empty();
                        option = $("<option>", { "value": "" }).text("");
                        prioridade.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            prioridade.append(option);
                        });
                    }, "json");

                    $.post("LoadSolicitante", request, function (obj) {
                        solicitante.empty();
                        option = $("<option>", { "value": "" }).text("");
                        solicitante.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            solicitante.append(option);
                        });
                    }, "json");

                    $.post("LoadJustificativaApontamento", request, function (obj) {
                        justificativa_apontamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        justificativa_apontamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            justificativa_apontamento.append(option);
                        });
                    }, "json");

                    auditoria.prop("disabled", false);
                    prioridade.prop("disabled", false);
                    solicitante.prop("disabled", false);
                    justificativa_apontamento.prop("disabled", false);

                    unidade.select2({ placeholder: '@PCM.WEB.Properties.Resources.unidade.ToUpper()', allowClear: true });
                    auditoria.select2({ placeholder: '@PCM.WEB.Properties.Resources.auditoria.ToUpper()', allowClear: true });
                    status.select2({ placeholder: '@PCM.WEB.Properties.Resources.status.ToUpper()', allowClear: true });
                    prioridade.select2({ placeholder: '@PCM.WEB.Properties.Resources.prioridade.ToUpper()', allowClear: true });
                    solicitante.select2({ placeholder: '@PCM.WEB.Properties.Resources.solicitante.ToUpper()', allowClear: true });
                    justificativa_apontamento.select2({ placeholder: '@PCM.WEB.Properties.Resources.justificativa_apontamento.ToUpper()', allowClear: true });

                }

            });

        });

        function UpdateDataOrdemServico(codigo, unidade, data){


            //Seta Váriaveis
            $("#codigo_ordem_servico").val(codigo);
            $("#codigo_unidade").val(unidade);
            $("#data_os").val(data);
            $("#data_ordem_servico").val(data);

            //Abre Formulário
            jQuery('#modalDataOrdemServico').modal('show');

        }

        $('#form_data').validate({
            ignore: [],
            errorClass: 'invalid-feedback animated fadeInDown',
            errorElement: 'div',
            errorPlacement: function (error, e) {
                jQuery(e).parents('.form-group > div').append(error);
            },
            highlight: function (e) {
                jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
            },
            success: function (e) {
                jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                jQuery(e).remove();
            },
            rules: {
                'data_ordem_servico': {
                    required: true
                }
            },
            messages: {
                'data_ordem_servico': {
                    required: '@PCM.WEB.Properties.Resources.campo_requerido'
                }
            },
            submitHandler: function (form) {

                var data = $("#data_ordem_servico").val().toString();
                var codigo = $("#codigo_ordem_servico").val();
                var unidade = $("#codigo_unidade").val();

                var dataString = {
                    "codigo": codigo,
                    "unidade": unidade,
                    "data": data
                };

                $.post("UpdateDataOrdemServico", dataString,
                    function (result) {
                        $("#form").submit();
                    });

                $('#modalFuncionario').modal('hide');
            }
        });

        // Initialize when page loads
        jQuery(function () {
            $.fn.dataTable.moment('DD/MM/YYYY HH:mm');
            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
        });

</script>
