@model PCM.WEB.MODELS.ControleGasto

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("LancamentoIndex", "GreenPlanet")">@PCM.WEB.Properties.Resources.financas</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.controle_gasto</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">
                                     
        @using (Html.BeginForm("Index", "ControleGasto", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", @name="form", @id="form", role = "form" }))
        {
            @Html.AntiForgeryToken()
                
            <div class="row">

                <div class="col-md-5 col-xl-3">
                    <!-- Toggle Tasks Navigation on mobile -->
                    <button type="button" class="btn btn-block btn-primary d-md-none mb-10" data-toggle="class-toggle" data-target=".js-tasks-nav" data-class="d-none d-md-block">@PCM.WEB.Properties.Resources.filtros</button>

                    <!-- Collapsible Tasks Navigation -->
                    <div class="js-tasks-nav d-none d-md-block">
                        <!-- Tasks Info -->
                        <div class="block block-rounded border">
                            <div class="block-header block-header-default bg-gd-default">
                                <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.filtro</h3>
                            </div>
                            <div class="block-content">
                                <ul class="list-group push">
                                    <li class="list-group-item">
                                        <div>@Html.DropDownList("unidade", null, PCM.WEB.Properties.Resources.unidade, new { @class = "form-control" })</div>                                    
                                    </li>
                                    <li class="list-group-item">
                                        <div>@Html.DropDownList("ano", null, PCM.WEB.Properties.Resources.ano, new { @class = "form-control"})</div>                                 
                                    </li>                                
                                    <li class="list-group-item text-right">                                                    
                                        <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75" name="filtrar" id="filtrar" onclick="Load();"><i class="si si-magnifier mr-5"></i>@PCM.WEB.Properties.Resources.filtrar</button>
                                    </li>
                                </ul>
                            </div>
                        </div>
                        <!-- END Tasks Info -->

                    </div>
                    <!-- END Collapsible Tasks Navigation -->
                </div>
                
                <div class="col-md-7 col-xl-9">
                    
                    <div class="js-tasks">
                    
                        <div class="block">
                            <div class="block-header block-header-default bg-gd-default">
                                <h3 class="block-title text-white font-w600">
                                    @PCM.WEB.Properties.Resources.controle_gasto
                                </h3>
                                @if(ViewBag.inserir)
                                {
                                    <div class="block-options">
                                        <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75" onclick="Insert();"><i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar</button>
                                    </div>
                                }                                
                            </div>
                        
                            <div class="block-content"> 
                                
                                <table class="js-table-sections table table-hover">
                                    <thead>                                    
                                        <tr>
                                            <th class="text-center font-w600" style="width: 25%;">@PCM.WEB.Properties.Resources.periodo</th>
                                            <th class="text-center" style="width: 25%;">@PCM.WEB.Properties.Resources.previsao_gasto</th>
                                            <th class="text-center" style="width: 25%;">@PCM.WEB.Properties.Resources.gasto_real</th>
                                            <th class="text-center" style="width: 25%;">@PCM.WEB.Properties.Resources.saldo</th>
                                        </tr>
                                    </thead>

                                        <tbody> 
                                            @if(ViewBag.mes == 1)
                                            {
                                                <tr>     
                                                    <td class="text-center font-w600 table-warning" style="width: 25%;">@PCM.WEB.Properties.Resources.janeiro</td>                  
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.previsao_gasto_janeiro, new { @class = "form-control text-center"})</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.gasto_janeiro)</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.saldo_janeiro)</td>
                                                </tr>
                                            }
                                            @if(ViewBag.mes <= 2)
                                            {
                                                <tr>     
                                                    <td class="text-center font-w600 table-warning" style="width: 25%;">@PCM.WEB.Properties.Resources.fevereiro</td>                  
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.previsao_gasto_fevereiro, new { @class = "form-control text-center"})</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.gasto_fevereiro)</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.saldo_fevereiro)</td>
                                                </tr>
                                            } 
                                            @if(ViewBag.mes <= 3)
                                            {
                                                <tr>     
                                                    <td class="text-center font-w600 table-warning"  style="width: 25%;">@PCM.WEB.Properties.Resources.marco</td>                  
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.previsao_gasto_marco, new { @class = "form-control text-center"})</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.gasto_marco)</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.saldo_marco)</td>
                                                </tr>
                                            } 
                                            @if(ViewBag.mes <= 4)
                                            {
                                                <tr>     
                                                    <td class="text-center font-w600 table-warning" style="width: 25%;">@PCM.WEB.Properties.Resources.abril</td>                  
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.previsao_gasto_abril, new { @class = "form-control text-center"})</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.gasto_abril)</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.saldo_abril)</td>
                                                </tr>
                                            } 
                                            @if(ViewBag.mes <= 5)
                                            {
                                                <tr>     
                                                    <td class="text-center table-warning font-w600" style="width: 25%;">@PCM.WEB.Properties.Resources.maio</td>                  
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.previsao_gasto_maio, new { @class = "form-control text-center"})</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.gasto_maio)</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.saldo_maio)</td>
                                                </tr>
                                            } 
                                            @if(ViewBag.mes <= 6)
                                            {
                                                <tr>     
                                                    <td class="text-center table-warning font-w600" style="width: 25%;">@PCM.WEB.Properties.Resources.junho</td>                  
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.previsao_gasto_junho, new { @class = "form-control text-center"})</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.gasto_junho)</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.saldo_junho)</td>
                                                </tr>
                                            } 
                                            @if(ViewBag.mes <= 7)
                                            {
                                                <tr>     
                                                    <td class="text-center table-warning font-w600" style="width: 25%;">@PCM.WEB.Properties.Resources.julho</td>                  
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.previsao_gasto_julho, new { @class = "form-control text-center"})</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.gasto_julho)</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.saldo_julho)</td>
                                                </tr>
                                            } 
                                            @if(ViewBag.mes <= 8)
                                            {
                                                <tr>     
                                                    <td class="text-center table-warning font-w600" style="width: 25%;">@PCM.WEB.Properties.Resources.agosto</td>                  
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.previsao_gasto_agosto, new { @class = "form-control text-center"})</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.gasto_agosto)</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.saldo_agosto)</td>
                                                </tr>
                                            } 
                                            @if(ViewBag.mes <= 9)
                                            {
                                                <tr>     
                                                    <td class="text-center table-warning font-w600" style="width: 25%;">@PCM.WEB.Properties.Resources.setembro</td>                  
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.previsao_gasto_setembro, new { @class = "form-control text-center"})</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.gasto_setembro)</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.saldo_setembro)</td>
                                                </tr>
                                            } 
                                            @if(ViewBag.mes <= 10)
                                            {
                                                <tr>     
                                                    <td class="text-center table-warning font-w600" style="width: 25%;">@PCM.WEB.Properties.Resources.outubro</td>                  
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.previsao_gasto_outubro, new { @class = "form-control text-center"})</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.gasto_outubro)</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.saldo_outubro)</td>
                                                </tr>
                                            } 
                                            @if(ViewBag.mes <= 11)
                                            {
                                                <tr>     
                                                    <td class="text-center table-warning font-w600" style="width: 25%;">@PCM.WEB.Properties.Resources.novembro</td>                  
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.previsao_gasto_novembro, new { @class = "form-control text-center"})</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.gasto_novembro)</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.saldo_novembro)</td>
                                                </tr>
                                            } 
                                            @if(ViewBag.mes <= 12)
                                            {
                                                <tr>     
                                                    <td class="text-center table-warning font-w600" style="width: 25%;">@PCM.WEB.Properties.Resources.dezembro</td>                  
                                                    <td class="text-center" style="width: 25%;">@Html.TextBoxFor(model => model.previsao_gasto_dezembro, new { @class = "form-control text-center"})</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.gasto_dezembro)</td>
                                                    <td class="text-center" style="width: 25%;">@Html.DisplayFor(model => model.saldo_dezembro)</td>
                                                </tr>
                                            }
                                        </tbody>
                                </table>

                            </div>
                        </div>
                    </div>
                </div>

            </div>
        }

    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->


@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/maskedinput")
    
    <script>

        $(document).ready(function ($) { $("#previsao_gasto_janeiro").maskMoney({ decimal: ",", thousands: "." }); });
        $(document).ready(function ($) { $("#previsao_gasto_fevereiro").maskMoney({ decimal: ",", thousands: "." }); });
        $(document).ready(function ($) { $("#previsao_gasto_marco").maskMoney({ decimal: ",", thousands: "." }); });
        $(document).ready(function ($) { $("#previsao_gasto_abril").maskMoney({ decimal: ",", thousands: "." }); });
        $(document).ready(function ($) { $("#previsao_gasto_maio").maskMoney({ decimal: ",", thousands: "." }); });
        $(document).ready(function ($) { $("#previsao_gasto_junho").maskMoney({ decimal: ",", thousands: "." }); });
        $(document).ready(function ($) { $("#previsao_gasto_julho").maskMoney({ decimal: ",", thousands: "." }); });
        $(document).ready(function ($) { $("#previsao_gasto_agosto").maskMoney({ decimal: ",", thousands: "." }); });
        $(document).ready(function ($) { $("#previsao_gasto_setembro").maskMoney({ decimal: ",", thousands: "." }); });
        $(document).ready(function ($) { $("#previsao_gasto_outubro").maskMoney({ decimal: ",", thousands: "." }); });
        $(document).ready(function ($) { $("#previsao_gasto_novembro").maskMoney({ decimal: ",", thousands: "." }); });
        $(document).ready(function ($) { $("#previsao_gasto_dezembro").maskMoney({ decimal: ",", thousands: "." }); });

        function Load() {
            $('#form').attr('action', 'ControleGastoIndex');
        }

        function Insert() {
            $('#form').attr('action', 'ControleGastoInsert');
        }

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.list-group-item > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.list-group-item').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.list-group-item').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'ano': {
                            required: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'ano': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['maxlength']);
        });

    </script>
}