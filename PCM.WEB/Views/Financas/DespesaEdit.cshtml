@model PCM.WEB.MODELS.Despesa

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("DespesaIndex", "Financas")">@PCM.WEB.Properties.Resources.input_despesa</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.editar</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">           
                @using (Html.BeginForm("DespesaEdit", "Financas", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data"  }))        
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.codigo)
                    @Html.HiddenFor(model => model.codigo_unidade)

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.editar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("DespesaIndex", "Financas")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.numero_documento</label>
                                <div class="col-4"><input type="text" class="form-control" id="numero_documento" name="numero_documento" value="@Model.numero_documento" maxlength="20"></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.tipo_despesa</label>
                                <div class="col-12">@Html.DropDownList("tipo_despesa", null, "", new { @class = "js-select2 form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.fornecedor</label>
                                <div class="col-12">@Html.DropDownList("fornecedor", null, "", new { @class = "js-select2 form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.descricao</label>
                                <div class="col-12"><input type="text" class="form-control" id="descricao" name="descricao" value="@Model.descricao" maxlength="250"></div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.valor</label>
                                    <div><input type="text" class="form-control" id="valor" name="valor" value="@Model.valor" maxlength="10"></div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.data_competencia</label>
                                    <div><input type="text" class="js-datepicker form-control" id="data_competencia" name="data_competencia" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value="@Model.data_competencia"></div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.data_pagamento</label>
                                    <div><input type="text" class="js-datepicker form-control" id="data_pagamento" name="data_pagamento" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value="@Model.data_pagamento"></div>
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.arquivo</label>
                                <div class="col-12">
                                    <div class="custom-file">
                                        <input type="file" class="custom-file-input" id="arquivo" name="arquivo" onchange="Arquivo();" accept="application/pdf">
                                        <label id="lblArquivo" class="custom-file-label" for="arquivo">@PCM.WEB.Properties.Resources.selecione_arquivo</label>
                                    </div>
                                </div>
                            </div>
                        </div>                                  
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/select")
    
    <script>
        
        function Arquivo() {
            document.getElementById("lblArquivo").textContent = document.getElementById("arquivo").files[0].name;
        }
        
        $(document).ready(function ($) { $("#valor").maskMoney({ decimal: ",", thousands: "." }); });

        $(function () {

            var unidade = $("#unidade");
            var tipo_despesa = $("#tipo_despesa");
            var fornecedor = $("#fornecedor");
            $.ajaxSetup({ async: false });


            if (unidade.val() == "" || unidade.val() == "-1") {
                tipo_despesa.prop("disabled", true);
                tipo_despesa.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.tipo_despesa)', allowClear: true });
                fornecedor.prop("disabled", true);
                fornecedor.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.fornecedor)', allowClear: true });
            }

            unidade.change(function () {

                if (unidade.val() == "") {
                    tipo_despesa.empty();
                    tipo_despesa.prop("disabled", true);
                    tipo_despesa.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.tipo_despesa)', allowClear: true });
                    fornecedor.empty();
                    fornecedor.prop("disabled", true);
                    fornecedor.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.fornecedor)', allowClear: true });

                } else {

                    var request = { "unidade": unidade.val() };

                    $.post("LoadTipoDespesa", request, function (obj) {
                        tipo_despesa.empty();
                        option = $("<option>", { "value": "" }).text("");
                        tipo_despesa.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            tipo_despesa.append(option);
                        });
                    }, "json");

                    $.post("LoadFornecedor", request, function (obj) {
                        fornecedor.empty();
                        option = $("<option>", { "value": "" }).text("");
                        fornecedor.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            fornecedor.append(option);
                        });
                    }, "json");

                    tipo_despesa.prop("disabled", false);
                    tipo_despesa.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.tipo_despesa)', allowClear: true });
                    fornecedor.prop("disabled", false);
                    fornecedor.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.fornecedor)', allowClear: true });

                }

            });

        });

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'numero_documento': {
                            required: true
                        },
                        'tipo_despesa': {
                            required: true
                        },
                        'fornecedor': {
                            required: true
                        },
                        'data_competencia': {
                            required: true
                        },
                        'valor': {
                            required: true
                        },
                        'descricao': {
                            required: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'numero_documento': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'tipo_despesa': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'fornecedor': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'data_competencia': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'valor': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'descricao': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
        });

    </script>

}
