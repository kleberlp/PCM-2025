@model PCM.WEB.MODELS.Contrato

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("ContratoIndex", "Financas")">@PCM.WEB.Properties.Resources.contrato</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.editar</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">           
                @using (Html.BeginForm("ContratoEdit", "Financas", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data"  }))        
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.codigo)
                    @Html.HiddenFor(model => model.codigo_unidade)
                    <input type="hidden" name="change_arquivo" id="change_arquivo" value="">

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.editar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("ContratoIndex", "Financas")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
                                <label class="col-12" for="unidade">@PCM.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@Html.DisplayFor(model => model.unidade)</div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-3">
                                    <label>@PCM.WEB.Properties.Resources.data_inicio</label>
                                    <div><input type="text" class="js-datepicker form-control" id="data_inicio" name="data_inicio" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value="@Model.data_inicio"></div>
                                </div>
                                <div class="col-md-3">
                                    <label>@PCM.WEB.Properties.Resources.data_termino</label>
                                    <div><input type="text" class="js-datepicker form-control" id="data_termino" name="data_termino" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value="@Model.data_termino"></div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.descricao</label>
                                <div class="col-12">@Html.TextBoxFor(model => model.descricao, new { @class = "form-control", @maxlength = "100" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.comentario</label>
                                <div class="col-12">@Html.TextAreaFor(model => model.comentario, new { @class = "form-control", @maxlenght = "5000", @rows = 10 })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.arquivo</label>
                                <div class="col-12">
                                    <div class="custom-file">
                                        <input type="file" class="custom-file-input" id="arquivo" name="arquivo" onchange="Arquivo();" accept="application/pdf">
                                        <label id="lblArquivo" class="custom-file-label" for="arquivo">@PCM.WEB.Properties.Resources.selecione_arquivo</label>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.envia_email</label>
                                <div class="col-12">
                                    <label class="css-control css-control-success css-switch">
                                        @if (Model.envia_email)
                                        {
                                            <input type="checkbox" class="css-control-input" id="envia_email" name="envia_email" value="true" checked onchange="verificaEnviaEmail();">
                                        }
                                        else
                                        {
                                            <input type="checkbox" class="css-control-input" id="envia_email" name="envia_email" value="true" onchange="verificaEnviaEmail();">
                                        }
                                        <span class="css-control-indicator"></span>
                                    </label>
                                </div>
                            </div>
                            <div id="div_email" style="display:none">
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.dias_alerta</label>
                                    <div class="col-md-2">@Html.TextBoxFor(model => model.dias_alerta, new { @class = "form-control", @maxlength = "4" })</div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.lista_email</label>
                                    <div class="col-12">@Html.TextAreaFor(model => model.email, new { @class = "form-control", @maxlenght = "2000", @rows = 6 })</div>
                                </div>

                            </div>
                        </div>
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    
    <script>
        
        function verificaEnviaEmail() {

            if (document.getElementById("envia_email").checked == true)
                $("#div_email").show();
            else
                $("#div_email").hide();
        }

        function Arquivo() {
            document.getElementById("lblArquivo").textContent = document.getElementById("arquivo").files[0].name;
            document.getElementById("change_arquivo").value = "change";
        }

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'data_inicio': {
                            required: true
                        },
                        'descricao': {
                            required: true
                        }
                    },
                    messages: {
                        'data_inicio': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'descricao': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['datepicker', 'maxlength']);
            verificaEnviaEmail();
        });

    </script>

}
