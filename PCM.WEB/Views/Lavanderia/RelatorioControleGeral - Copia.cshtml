        $(function () {

            var unidade = $("#unidade");
            var cliente = $("#cliente");
            var equipamento = $("#equipamento");
            var funcionario = $("#funcionario");
            var mes = $("#mes");

            unidade.change(function () {

                var request = { "unidade": unidade.val() };

                $.post("LoadComboCliente", request, function (obj) {
                    cliente.empty();
                    option = $("<option>", { "value": "" }).text("");
                    cliente.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        cliente.append(option);
                    });
                }, "json");

                $.post("LoadComboEquipamento", request, function (obj) {
                    equipamento.empty();
                    option = $("<option>", { "value": "" }).text("");
                    equipamento.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        equipamento.append(option);
                    });
                }, "json");

                $.post("LoadComboFuncionario", request, function (obj) {
                    funcionario.empty();
                    option = $("<option>", { "value": "" }).text("");
                    funcionario.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        funcionario.append(option);
                    });
                }, "json");

                $.post("LoadComboMes", request, function (obj) {
                    mes.empty();
                    option = $("<option>", { "value": "" }).text("");
                    mes.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        mes.append(option);
                    });
                }, "json");

            });

            $("#filtrar").on('click', function (e) {
                $("#form").submit();
            });


        $('#form').validate({
            ignore: [],
            errorClass: 'invalid-feedback animated fadeInDown',
            errorElement: 'div',
            errorPlacement: function (error, e) {
                jQuery(e).parents('.form-group > div').append(error);
            },
            highlight: function (e) {
                jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
            },
            success: function (e) {
                jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                jQuery(e).remove();
            },
            rules: {
                'unidade': {
                    required: true
                },
                'mes': {
                    required: true
                },
                'agrupadoPor': {
                    required: true
                }
            },
            messages: {
                'unidade': {
                    required: '@PCM.WEB.Properties.Resources.campo_requerido'
                },
                'mes': {
                    required: '@PCM.WEB.Properties.Resources.campo_requerido'
                },
                'agrupadoPor': {
                    required: '@PCM.WEB.Properties.Resources.campo_requerido'
                }
            },
            submitHandler: function (form) {
                table.ajax.reload(null, false);
                table.columns.adjust().draw(true);
                return false;
            }
        });


            var table = $('#tableMain').DataTable({
                searching: false,
                lengthChange: false,
                paging: false,
                processing: true,
                serverSide: false,
                scrollCollapse: true,
                fixedHeader: false,
