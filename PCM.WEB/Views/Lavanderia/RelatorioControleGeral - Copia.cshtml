                        d.unidade = ($('#unidade').val() == "") ? "-1" : $("#unidade").val(),
                            d.cliente = ($('#cliente').val() == "") ? "-1" : $("#cliente").val(),
                            d.equipamento = ($('#equipamento').val() == "") ? "-1" : $("#equipamento").val(),
                            d.funcionario = ($('#funcionario').val() == "") ? "-1" : $("#funcionario").val(),
                            d.mes = ($('#mes').val() == "") ? "-1" : $("#mes").val(),
                            d.agrupadoPor = ($('#agrupadoPor').val() == "") ? "" : $("#agrupadoPor").val()
                    },
