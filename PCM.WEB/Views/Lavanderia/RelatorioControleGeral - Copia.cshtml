<!-- Main Container -->
<main id="main-container">


    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <span class="breadcrumb-item">@PCM.WEB.Properties.Resources.relatorio </span>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.controleLavagem</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->
    <!-- Page Content -->
    <div class="content">

        @using (Html.BeginForm("FuncionarioHorasTrabalhadasGovernanca", "Relatorio", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", @name = "form", @id = "form", role = "form" }))
        {
            @Html.AntiForgeryToken()

        <div>

                <!-- Toggle Tasks Navigation on mobile -->
                <button type="button" class="btn btn-block btn-square btn-primary d-md-none mb-10" data-toggle="class-toggle" data-target=".js-tasks-nav" data-class="d-none d-md-block">@PCM.WEB.Properties.Resources.filtros</button>

                <div class="js-tasks-nav d-none d-md-block">
                    <div class="block block-rounded border">
                            <div class="block-header block-header-default bg-gd-default">
                                <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.historico</h3>
                            </div>
                            <div class="block-content">
                                <ul class="list-group push">
                                    <li class="list-group-item">
                                        <div class="form-group row">
                                            <div class="col-md-4">
                                                <label>@PCM.WEB.Properties.Resources.unidade</label>
                                                @Html.DropDownList("unidade", null, "", new { @class = "form-control" })
                                            </div>
                                            <div class="col-md-4">
                                                <label>@PCM.WEB.Properties.Resources.cliente</label>
                                                @Html.DropDownList("cliente", null, "", new { @class = "js-select2 form-control" })
                                            </div>
                                            <div class="col-md-4">
                                                <label>@PCM.WEB.Properties.Resources.equipamento</label>
                                                @Html.DropDownList("equipamento", null, "", new { @class = "js-select2 form-control" })
                                            </div>
                                        </div>
                                        <div class="form-group row">
                                            <div class="col-md-4">
                                                <label>@PCM.WEB.Properties.Resources.funcionario</label>
                                                @Html.DropDownList("funcionario", null, "", new { @class = "form-control" })
                                            </div>
                                            <div class="col-md-2">
                                                <label>@PCM.WEB.Properties.Resources.mes</label>
                                                @Html.DropDownList("mes", null, "", new { @class = "form-control" })
                                            </div>
                                            <div class="col-md-4">
                                                <label>@PCM.WEB.Properties.Resources.agrupado_por</label>
                                                @Html.DropDownList("agrupadoPor", null, "", new { @class = "form-control" })
                                            </div>
                                        </div>
                                    </li>
                                    <li class="list-group-item text-right">
                                        <button type="button" class="btn btn-square btn-secondary min-width-100 h-75" name="filtrar" id="filtrar"><i class="si si-magnifier mr-5"></i>@PCM.WEB.Properties.Resources.filtrar</button>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>


                <div class="block block-rounded border">
                    <div class="block-header block-header-default bg-gd-default">
                        <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.controleLavagem</h3>
                        <div class="block-options">
                            <button type="button" class="btn-block-option text-dark font-w600" data-toggle="block-option" data-action="fullscreen_toggle"></button>
                        </div>
                    </div>

                    <div class="block-content">

                        <!-- Table -->
                        <div class="table-responsive table-sm push">

                            <table class="table table-bordered nowrap" id="tableMain" name="tableMain">
                                <thead>
                                    <tr class="table-secondary font-size-sm">
                                        <th rowspan="2" class="border text-center"></th>
                                        <th rowspan="2" class="border table-secondary">@PCM.WEB.Properties.Resources.descricao</th>
                                        @for (int i = 1; i <= 31; i++)
                                        {
                                            <th colspan="2" class="border text-center">@i.ToString()</th>
                                        }
                                        <th colspan="2" class="border text-center">TOTAL</th>
                                    </tr>
                                    <tr class="table-secondary font-size-sm">
                                        @for (int i = 1; i <= 32; i++)
                                        {
                                            <th class="border text-center">Kg Lav</th>
                                            <th class="border text-center">Kg Rel</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody class="font-size-sm">
                                </tbody>
                            </table>

                        </div>

                    </div>

                </div>

            </div>
            }

        </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->


@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/dataTables")
    @Styles.Render("~/Content/select")
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/fixedcolumns/4.2.2/css/fixedColumns.dataTables.min.css">
}

