@model PCM.WEB.MODELS.Tarefa

<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <span class="breadcrumb-item">@PCM.WEB.Properties.Resources.cadastro_basico</span>
                <a class="breadcrumb-item" href="@Url.Action("TarefaIndex", "CadastroBasico")">@PCM.WEB.Properties.Resources.tarefa</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.editar</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->
    <!-- Page Content -->
    <div class="content">

        <!-- Update Product se -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">
                @using (Html.BeginForm("TarefaEdit", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data", @name = "form", @id = "form" }))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="codigo" id="codigo" value="@Model.codigo">
                    <input type="hidden" name="codigo_unidade" id="codigo_unidade" value="@Model.codigo_unidade">
                    <input type="hidden" name="unidade_old" id="unidade_old" value="@Model.codigo_unidade">

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.editar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("TarefaIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
                                <label class="col-12" for="unidade">@PCM.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@Model.unidade</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.descricao</label>
                                <div class="col-12">@Html.TextAreaFor(model => model.descricao, new { @class = "form-control", @maxlength = "500", @rows = "6" })</div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.checklist</label>
                                    <div>@Html.DropDownList("checklist", null, "", new { @class = "form-control js-select2" })</div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.periodicidade</label>
                                    <div>@Html.DropDownList("periodicidade", null, "", new { @class = "form-control js-select2" })</div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.intervalo</label>
                                    <div>@Html.TextBoxFor(model => model.intervalo, new { @class = "form-control", @maxlength = "3" })</div>
                                </div>

                            </div>

                            <div class="block block-rounded border border text-center mb-15" id="div_diario" style="display:none">
                                <div class="block-header block-header-default bg-secondary text-left">
                                    <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.dias_uteis</h3>
                                </div>
                                <div class="form-group row mt-15">
                                    <div class="col-md-1">
                                        <label>@PCM.WEB.Properties.Resources.segunda</label>
                                        <div>
                                            <label class="css-control css-control-success css-checkbox">
                                                @Html.CheckBoxFor(model => model.segunda, new { @class = "css-control-input" })
                                                <span class="css-control-indicator"></span>
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-1">
                                        <label>@PCM.WEB.Properties.Resources.terca</label>
                                        <div>
                                            <label class="css-control css-control-success css-checkbox">
                                                @Html.CheckBoxFor(model => model.terca, new { @class = "css-control-input" })
                                                <span class="css-control-indicator"></span>
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-1">
                                        <label>@PCM.WEB.Properties.Resources.quarta</label>
                                        <div>
                                            <label class="css-control css-control-success css-checkbox">
                                                @Html.CheckBoxFor(model => model.quarta, new { @class = "css-control-input" })
                                                <span class="css-control-indicator"></span>
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-1">
                                        <label>@PCM.WEB.Properties.Resources.quinta</label>
                                        <div>
                                            <label class="css-control css-control-success css-checkbox">
                                                @Html.CheckBoxFor(model => model.quinta, new { @class = "css-control-input" })
                                                <span class="css-control-indicator"></span>
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-1">
                                        <label>@PCM.WEB.Properties.Resources.sexta</label>
                                        <div>
                                            <label class="css-control css-control-success css-checkbox">
                                                @Html.CheckBoxFor(model => model.sexta, new { @class = "css-control-input" })
                                                <span class="css-control-indicator"></span>
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-1">
                                        <label>@PCM.WEB.Properties.Resources.sabado</label>
                                        <div>
                                            <label class="css-control css-control-success css-checkbox">
                                                @Html.CheckBoxFor(model => model.sabado, new { @class = "css-control-input" })
                                                <span class="css-control-indicator"></span>
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-md-1">
                                        <label>@PCM.WEB.Properties.Resources.domingo</label>
                                        <div>
                                            <label class="css-control css-control-success css-checkbox">
                                                @Html.CheckBoxFor(model => model.domingo, new { @class = "css-control-input" })
                                                <span class="css-control-indicator"></span>
                                            </label>
                                        </div>
                                    </div>

                                </div>
                            </div>

                            <div class="form-group row">
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.ativo</label>
                                    <div>
                                        <label class="css-control css-control-success css-switch">
                                            @Html.CheckBoxFor(model => model.ativo, new { @class = "css-control-input" })
                                            <span class="css-control-indicator"></span>
                                        </label>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->

</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/ckeditor")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")

<script>

    function verificaPeriodicidade() {

        if ($("#periodicidade").val() == "0") {
            $("#div_checklist").show();
            $("#div_intervalo").hide();
        } else if ($("#periodicidade").val() == "") {
            $("#div_checklist").hide();
            $("#div_intervalo").hide();
        } else {
            $("#div_checklist").hide();
            $("#div_intervalo").show();
        }

        if ($("#periodicidade").val() == 1 && $("#intervalo").val() == "1") {
            $("#div_diario").show();
        } else {
            $("#div_diario").hide();
        }
    }

    $(function () {

        var periodicidade = $("#periodicidade");
        var intervalo = $("#intervalo");

        periodicidade.change(function () {
            verificaPeriodicidade();
        });

        intervalo.change(function () {
            verificaPeriodicidade();
        });

    });

    jQuery.validator.addMethod("checklist", function (value, element) {

        if ($("#periodicidade").val() == "0") {
            if (value == "") {
                return false
            } else {
                return true
            }
        } else {
            return true
        }

    }, "");

    jQuery.validator.addMethod("intervalo", function (value, element) {

        if ($("#periodicidade").val() != "0") {
            if (value == "") {
                return false
            } else {
                return true
            }
        } else {
            return true
        }

    }, "");

    var FormValidation = function () {
        // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
        var initValidationBootstrap = function () {
            jQuery('.js-validation-bootstrap').validate({
                ignore: [],
                errorClass: 'invalid-feedback animated fadeInDown',
                errorElement: 'div',
                errorPlacement: function (error, e) {
                    jQuery(e).parents('.form-group > div').append(error);
                },
                highlight: function (e) {
                    jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                },
                success: function (e) {
                    jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                    jQuery(e).remove();
                },
                rules: {
                    'descricao': {
                        required: true
                    },
                    'periodicidade': {
                        required: true
                    },
                    'intervalo': {
                        intervalo: true
                    }
                },
                messages: {
                    'descricao': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'periodicidade': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'intervalo': {
                        intervalo: '@PCM.WEB.Properties.Resources.campo_requerido'
                    }
                }
            });
        };

        return {
            init: function () {
                // Init Bootstrap Forms Validation
                initValidationBootstrap();
            }
        };
    }();

    // Initialize when page loads
    jQuery(function () {
        FormValidation.init();
        Codebase.helpers(['datepicker', 'maxlength', 'select2', 'ckeditor']);
        $("#intervalo").maskMoney({ thousands: ".", precision: 0, allowNegative: false });
        verificaPeriodicidade();
    });

</script>

}