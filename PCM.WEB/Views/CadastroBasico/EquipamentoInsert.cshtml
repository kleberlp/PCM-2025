
<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-md-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("EquipamentoIndex", "CadastroBasico")">@PCM.WEB.Properties.Resources.equipamento</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.inserir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">                
                @using (Html.BeginForm("EquipamentoInsert", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.cadastrar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("EquipamentoIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.unidade</label>
                                    <div>@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                                </div>
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.familia_equipamento </label>
                                    <div>@Html.DropDownList("familia", null, "", new { @class = "form-control" })</div>
                                </div>
                            </div>
                                <div class="form-group row">
                                    <div class="col-md-2">
                                        <label>@PCM.WEB.Properties.Resources.tag</label>
                                        <div><input type="text" class="form-control" id="tag" name="tag" value="" maxlength="20"></div>
                                    </div>
                                    <div class="col-md-10">
                                        <label>@PCM.WEB.Properties.Resources.descricao</label>
                                        <div><input type="text" class="form-control" id="descricao" name="descricao" value="" maxlength="200"></div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <div class="col-md-4">
                                        <label>@PCM.WEB.Properties.Resources.departamento_responsavel</label>
                                        <div>@Html.DropDownList("departamento", null, "", new { @class = "form-control" })</div>
                                    </div>
                                    <div class="col-md-4">
                                        <label>@PCM.WEB.Properties.Resources.setor</label>
                                        <div>@Html.DropDownList("setor", null, "", new { @class = "form-control" })</div>
                                    </div>
                                    <div class="col-md-4">
                                        <label>@PCM.WEB.Properties.Resources.apartamento</label>
                                        <div>@Html.DropDownList("apartamento", null, "", new { @class = "form-control" })</div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.fabricante</label>
                                    <div class="col-12"><input type="text" class="form-control" id="fabricante" name="fabricante" value="" maxlength="100"></div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.endereco_fabricante</label>
                                    <div class="col-12"><input type="text" class="form-control" id="endereco_fabricante" name="endereco_fabricante" value="" maxlength="200"></div>
                                </div>
                                <div class="form-group row">
                                    <div class="col-md-3">
                                        <label>@PCM.WEB.Properties.Resources.contato_fabricante</label>
                                        <div><input type="text" class="form-control" id="contato_fabricante" name="contato_fabricante" value="" maxlength="100"></div>
                                    </div>
                                    <div class="col-md-3">
                                        <label>@PCM.WEB.Properties.Resources.modelo</label>
                                        <div><input type="text" class="form-control" id="modelo" name="modelo" value="" maxlength="100"></div>
                                    </div>
                                    <div class="col-md-3">
                                        <label>@PCM.WEB.Properties.Resources.numero_fabricacao</label>
                                        <div><input type="text" class="form-control" id="numero_fabricacao" name="numero_fabricacao" value="" maxlength="100"></div>
                                    </div>
                                    <div class="col-md-3">
                                        <label>@PCM.WEB.Properties.Resources.ano_fabricacao</label>
                                        <div><input type="text" class="form-control" id="ano_fabricacao" name="ano_fabricacao" value="" maxlength="100"></div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.caracteristicas</label>
                                    <div class="col-12"><textarea class="form-control" id="caracteristicas" name="caracteristicas" maxlength="500" rows="4"></textarea></div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.laudo</label>
                                    <div class="col-12">@Html.DropDownList("laudo", null, "", new { @class = "form-control js-select2", @multiple = "multiple" })</div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.descricao_operacao</label>
                                    <div class="col-12"><textarea class="form-control" id="descricao_operacao" name="descricao_operacao" maxlength="500" rows="4"></textarea></div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.instrucao_utilizacao</label>
                                    <div class="col-12"><textarea class="form-control" id="instrucao_utilizacao" name="instrucao_utilizacao" maxlength="500" rows="4"></textarea></div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.procedimento_emergencia</label>
                                    <div class="col-12"><textarea class="form-control" id="procedimento_emergencia" name="procedimento_emergencia" maxlength="500" rows="4"></textarea></div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.treinamento_operador</label>
                                    <div class="col-12"><textarea class="form-control" id="treinamento_operador" name="treinamento_operador" maxlength="500" rows="4"></textarea></div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.condicao_seguranca</label>
                                    <div class="col-12"><textarea class="form-control" id="condicao_seguranca" name="condicao_seguranca" maxlength="500" rows="4"></textarea></div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.indicacao_conclusiva</label>
                                    <div class="col-12"><textarea class="form-control" id="indicacao_conclusiva" name="indicacao_conclusiva" maxlength="500" rows="4"></textarea></div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.arquivo</label>
                                    <div class="col-12">
                                        <div class="custom-file">
                                            <input type="file" class="custom-file-input" id="arquivo" name="arquivo" onchange="Arquivo();" accept="image/*,application/pdf">
                                            <label id="lblArquivo" class="custom-file-label" for="imagem">@PCM.WEB.Properties.Resources.selecione_arquivo</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.ativo</label>
                                    <div class="col-12">
                                        <label class="css-control css-control-success css-switch">
                                            <input type="checkbox" class="css-control-input" id="ativo" name="ativo" checked value="true">
                                            <span class="css-control-indicator"></span>
                                        </label>
                                    </div>
                                </div>
                            </div>                        
                    </div>   
                }
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")
    
<script>

        function Arquivo() {
            document.getElementById("lblArquivo").textContent = document.getElementById("arquivo").files[0].name;
        }

        $(function () {

            var unidade = $("#unidade")
            var familia = $("#familia")
            var departamento = $("#departamento");
            var setor = $("#setor");
            var apartamento = $("#apartamento");
            var laudo = $("#laudo");

            familia.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.familia_equipamento)', allowClear: true });
            departamento.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.departamento)', allowClear: true });
            setor.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.setor)', allowClear: true });
            apartamento.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.apartamento)', allowClear: true });
            laudo.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.laudo)', allowClear: true });

            if (unidade.val() == "" || unidade.val() == "-1") {
                familia.prop("disabled", true);
                setor.prop("disabled", true);
                apartamento.prop("disabled", true);
                laudo.prop("disabled", true);
                familia.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.familia_equipamento)', allowClear: true });
                setor.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.setor)', allowClear: true });
                apartamento.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.apartamento)', allowClear: true });
                laudo.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.laudo)', allowClear: true });
            }

            if (setor.val() == "") {
                apartamento.prop("disabled", true);
                apartamento.select2({ placeholder: '@PCM.WEB.Properties.Resources.apartamento', allowClear: true });
            }

            unidade.change(function () {

                if (unidade.val() == "") {
                    familia.empty();
                    setor.empty();
                    apartamento.empty();
                    laudo.empty();
                    familia.prop("disabled", true);
                    setor.prop("disabled", true);
                    apartamento.prop("disabled", true);
                    laudo.prop("disabled", true);
                    familia.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.familia_equipamento)', allowClear: true });
                    setor.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.setor)', allowClear: true });
                    apartamento.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.apartamento)', allowClear: true });
                    laudo.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.laudo)', allowClear: true });
                } else {

                    var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val() };

                    $.post("LoadFamiliaEquipamento", request, function (obj) {
                        familia.empty();
                        option = $("<option>", { "value": "" }).text("");
                        familia.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            familia.append(option);
                        });
                    }, "json");

                    $.post("LoadSetor", request, function (obj) {
                        setor.empty();
                        option = $("<option>", { "value": "" }).text("");
                        setor.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            setor.append(option);
                        });
                    }, "json");

                    $.post("LoadApartamento", request, function (obj) {
                        apartamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        apartamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            apartamento.append(option);
                        });
                    }, "json");

                    var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val(), "tipo_ordem_servico": 6 };

                    $.post("LoadProgramada", request, function (obj) {
                        laudo.empty();
                        option = $("<option>", { "value": "" }).text("");
                        laudo.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            laudo.append(option);
                        });
                    }, "json");

                    familia.prop("disabled", false);
                    setor.prop("disabled", false);
                    apartamento.prop("disabled", false);
                    laudo.prop("disabled", false);
                    familia.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.familia_equipamento)', allowClear: true });
                    setor.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.setor)', allowClear: true });
                    apartamento.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.apartamento)', allowClear: true });
                    laudo.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.laudo)', allowClear: true });
                }

            });

            setor.change(function () {

                if (setor.val() == "") {
                    apartamento.empty();
                    apartamento.prop("disabled", true);
                    apartamento.select2({ placeholder: '@PCM.WEB.Properties.Resources.apartamento', allowClear: true });
                }
                else {

                    var request = { "unidade": unidade.val(), "setor": setor.val() };

                    $.post("LoadApartamento", request, function (obj) {
                        apartamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        apartamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            apartamento.append(option);
                        });
                    }, "json");

                    apartamento.prop("disabled", false);
                    apartamento.select2({ placeholder: '@PCM.WEB.Properties.Resources.apartamento', allowClear: true });
                }

            });

        });

        jQuery.validator.addMethod("tag_bd", function (value, element) {

            var unidade = ($("#unidade").val() == "") ? "-1" : $("#unidade").val();

            var dataString = {
                "unidade": unidade,
                "tag": value,
                "codigo": -1
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaEquipamento",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "");

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'departamento': {
                            required: true
                        },
                        'tag': {
                            tag_bd: true
                        },
                        'descricao': {
                            required: true
                        },
                        'setor': {
                            required: true
                        },
                        'ano_fabricacao': {
                            number: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'departamento': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'tag': {
                            tag_bd: '@PCM.WEB.Properties.Resources.validacao'
                        },
                        'descricao': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'setor': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'ano_fabricacao': {
                            number: '@PCM.WEB.Properties.Resources.campo_numerico'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
        });

</script>
}
