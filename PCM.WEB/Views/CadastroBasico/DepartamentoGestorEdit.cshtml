@model PCM.WEB.MODELS.DepartamentoGestor

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-md-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item">@PCM.WEB.Properties.Resources.cadastro_basico</a>
                <a class="breadcrumb-item" href="@Url.Action("DepartamentoGestorIndex", "CadastroBasico")">@PCM.WEB.Properties.Resources.departamento_gestor</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.editar</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">           
                @using (Html.BeginForm("DepartamentoGestorEdit", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.codigo)
                    @Html.HiddenFor(model => model.codigo_unidade)

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.editar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("DepartamentoGestorIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.departamento</label>
                                <div class="col-12">@Html.DropDownList("departamento", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.gestor</label>
                                <div class="col-12">@Html.DropDownList("usuario", null, "", new { @class = "form-control" })</div>
                            </div>
                        </div>                        
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    
<script>

        $(function () {

            var unidade = $("#unidade");
            var usuario = $("#usuario");

            if (unidade.val() == "") {
                usuario.empty();
                usuario.prop("disabled", true);
            }

            unidade.change(function () {

                if (unidade.val() == "") {
                    usuario.empty();
                    usuario.prop("disabled", true);
                }
                else
                {
                    var request = { "unidade": unidade.val()};

                    $.post("LoadUsuario", request, function (obj) {
                        usuario.empty();
                        option = $("<option>", { "value": "" }).text("");
                        usuario.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            usuario.append(option);
                        });
                    }, "json");

                    usuario.prop("disabled", false);
                }

            });

        });

        jQuery.validator.addMethod("valida_gestor", function (value, element) {

            var unidade = ($("#unidade").val() == "") ? "-1" : $("#unidade").val();
            var departamento = ($("#departamento").val() == "") ? "-1" : $("#departamento").val();
            var usuario = ($("#usuario").val() == "") ? "-1" : $("#usuario").val();

            var dataString = {
                "codigo": @Model.codigo,
                "unidade": unidade,
                "departamento": departamento,
                "usuario": usuario
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaDepartamentoGestor",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "");

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'departamento': {
                            required: true
                        },
                        'usuario': {
                            required: true,
                            valida_gestor: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'departamento': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'usuario': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            validate_bd: '@PCM.WEB.Properties.Resources.valida_gestor'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['maxlength']);
        });

</script>

}
