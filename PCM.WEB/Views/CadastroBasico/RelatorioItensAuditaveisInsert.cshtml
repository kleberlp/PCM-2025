@model List<PCM.WEB.MODELS.RelatorioItensAuditaveisDetais>

<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-md-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item">@PCM.WEB.Properties.Resources.administracao</a>
                <a class="breadcrumb-item" href="@Url.Action("RelatorioItensAuditaveisIndex", "CadastroBasico")">@PCM.WEB.Properties.Resources.cad_relatorio_itens_auditaveis</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.inserir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->
    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">

                @using (Html.BeginForm("RelatorioItensAuditaveisInsert", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.cadastrar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("RelatorioItensAuditaveisIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.unidade</label>
                                    <div>@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.descricao</label>
                                <div class="col-12"><input type="text" class="form-control" id="descricao" name="descricao" value="" maxlength="200" autocomplete="off"></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.ativo</label>
                                <div class="col-12">
                                    <label class="css-control css-control-success css-switch">
                                        <input type="checkbox" class="css-control-input" id="ativo" name="ativo" checked value="true">
                                        <span class="css-control-indicator"></span>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>


                    <!-- Dynamic Table Full Pagination -->
                    <div class="block">
                        <div class="block-content block-content-full">
                            <!-- DataTables init on table by adding .js-dataTable-full-pagination class, functionality initialized in js/pages/be_tables_datatables.js -->
                            <table class="table table-sm table-bordered table-striped table-vcenter js-dataTable-full-pagination">
                                <thead>
                                    <tr class="table-secondary">
                                        <th class="text-center" style="width: 20px;"></th>
                                        <th>Itens Auditáveis</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @for (int i = 0; i < Model.Count; i++)
                                    {
                                        @Html.HiddenFor(m => m[i].codigo_checklist)
                                        @Html.HiddenFor(m => m[i].codigo)
                                        <tr>
                                            <td class="d-table-cell text-center" style="width: 20px">
                                                <div class="col-12">
                                                    <label class="css-control css-control-success css-switch">
                                                        @Html.CheckBoxFor(m => m[i].selecionado, new { @class = "css-control-input" })
                                                        <span class="css-control-indicator"></span>
                                                    </label>
                                                </div>
                                            </td>
                                            <td class="font-w600">@Html.DisplayFor(m => m[i].descricao)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->


@section Styles {
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/select")

    <script>

        //VÁRIAVEIS
        var unidade = $("#unidade");

        //AJAX
        $.ajaxSetup({ async: false });

        jQuery.validator.addMethod("valida_descricao_bd", function (value, element) {

            var dataString = {
                "unidade": $("#unidade").val,
                "descricao": value,
                "codigo": -1
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaRelatorioItensAuditaveis",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "");


        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'descricao': {
                            required: true,
                            valida_descricao_bd: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'descricao': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            valida_descricao_bd: '@PCM.WEB.Properties.Resources.valida_descricao_bd'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['maxlength', 'select2']);
        });

    </script>
}
