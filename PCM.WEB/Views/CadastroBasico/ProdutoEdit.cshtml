@model PCM.WEB.MODELS.Produto 

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action("Index", "Home")">@PCM.WEB.Properties.Resources.pcm</a>
                <span class="breadcrumb-item">@PCM.WEB.Properties.Resources.cadastro_basico</span>
                <a class="breadcrumb-item" href="@Url.Action("ProdutoIndex", "CadastroBasico")">@PCM.WEB.Properties.Resources.grupo_produto</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.editar</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">
                @using (Html.BeginForm("ProdutoEdit", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()

                    <input id="codigo" name="codigo" type="hidden" value="@Model.codigo" />
                    <input id="unidade" name="unidade" type="hidden" value="@Model.codigoUnidade" />

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-primary">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.grupo_produto</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("ProdutoIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.unidade</label>
                                    <div>@Model.unidade</div>
                                </div>
                                <div class="col-md-3">
                                    <label>@PCM.WEB.Properties.Resources.grupo_produto</label>
                                    <div>@Html.DropDownList("grupoProduto", null, "", new { @class = "form-control" })</div>
                                </div>
                                <div class="col-md-2">
                                    <div><label>@PCM.WEB.Properties.Resources.codigo</label></div>
                                    <div><input type="text" class="form-control" id="codigoProduto" name="codigoProduto" value="@Model.codigoProduto" maxlength="20"></div>
                                </div>
                                <div class="col-md-5">
                                    <div><label>@PCM.WEB.Properties.Resources.descricao</label></div>
                                    <div><input type="text" class="form-control" id="descricao" name="descricao" value="@Model.descricao" maxlength="150"></div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-2">
                                    <div><label>@PCM.WEB.Properties.Resources.unidade_medida</label></div>
                                    <div><input type="text" class="form-control" id="unidadeMedida" name="unidadeMedida" value="@Model.unidadeMedida" maxlength="5"></div>
                                </div>
                                <div class="col-md-2">
                                    <div><label>@PCM.WEB.Properties.Resources.ponto_reposicao</label></div>
                                    <div><input type="text" class="form-control" id="pontoReposicao" name="pontoReposicao" value="@Model.pontoReposicao" maxlength="5"></div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.controla_lote</label>
                                    <div>
                                        <label class="css-control css-control-success css-switch">
                                            @Html.CheckBoxFor(model => model.controlaLote, new { @class = "css-control-input" })
                                            <span class="css-control-indicator"></span>
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.controla_data_validade </label>
                                    <div>
                                        <label class="css-control css-control-success css-switch">
                                            @Html.CheckBoxFor(model => model.controlaDataValidade, new { @class = "css-control-input" })
                                            <span class="css-control-indicator"></span>
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.ativo</label>
                                    <div>
                                        <label class="css-control css-control-success css-switch">
                                            @Html.CheckBoxFor(model => model.ativo, new { @class = "css-control-input" })
                                            <span class="css-control-indicator"></span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    
<script>

        jQuery.validator.addMethod("validation_record", function (value, element) {

            var dataString = {
                "unidade": @Model.codigoUnidade,
                "codigoProduto": value,
                "codigo": @Model.codigo
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaProduto",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    result = return_data;
                }
            });

            return result;

        }, "");

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'grupoProduto': {
                            required: true
                        },
                        'codigoProduto': {
                            required: true,
                            validation_record: true
                        },
                        'descricao': {
                            required: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'grupoProduto': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'codigoProduto': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            validation_record: '@PCM.WEB.Properties.Resources.valida_bd'
                        },
                        'descricao': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['maxlength']);
        });

</script>

}
