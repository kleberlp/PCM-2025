
<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("UHChecklistIndex", "CadastroBasico")">@PCM.WEB.Properties.Resources.checklist</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.inserir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">                
                @using (Html.BeginForm("UHChecklistInsert", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.cadastrar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("UHChecklistIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full"> 
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.grupo_checklist</label>
                                <div class="col-12">@Html.DropDownList("grupo_checklist", null, "", new { @class = "js-select2 form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.codigo_checklist</label>
                                <div class="col-12"><input type="text" class="form-control" id="codigo_checklist" name="codigo_checklist" value="" maxlength="20"></div>
                            </div>      
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.descricao</label>
                                <div class="col-12"><input type="text" class="form-control" id="descricao" name="descricao" value="" maxlength="100"></div>
                            </div>                    
                            <div class="form-group row">
                            <label class="col-12">@PCM.WEB.Properties.Resources.ativo</label>
                            <div class="col-12">
                                <label class="css-control css-control-success css-switch">
                                    <input type="checkbox" class="css-control-input" id="ativo" name="ativo" checked value ="true">
                                    <span class="css-control-indicator"></span>
                                </label>
                            </div>
                        </div>
                        </div>                        
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/select")
}
@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/select")
    
    <script>

        $(function () {

            var unidade = $("#unidade");
            var grupo_checklist = $("#grupo_checklist");
            $.ajaxSetup({ async: false });

            if (unidade.val() == "" || unidade.val() == "-1") {
                grupo_checklist.prop("disabled", true);
                grupo_checklist.select2({ placeholder: '@PCM.WEB.Properties.Resources.grupo_checklist', allowClear: true });
            }

            unidade.change(function () {

                var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val() };

                $.post("LoadGrupoChecklist", request, function (obj) {
                    grupo_checklist.empty();
                    option = $("<option>", { "value": "" }).text("");
                    grupo_checklist.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        grupo_checklist.append(option);
                    });
                }, "json");

                grupo_checklist.prop("disabled", false);
                grupo_checklist.select2({ placeholder: '@PCM.WEB.Properties.Resources.grupo_checklist', allowClear: true });

            });

        });

        jQuery.validator.addMethod("codigo_checklist_bd", function (value, element) {

            var unidade = ($("#unidade").val() == "") ? "-1" : $("#unidade").val();

            var dataString = {
                "codigo_checklist": value,
                "codigo": -1,
                "unidade": unidade
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaChecklist",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "");

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'grupo_checklist': {
                            required: true
                        },
                        'codigo_checklist': {
                            required: true,
                            codigo_checklist_bd: true
                        },
                        'descricao': {
                            required: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'grupo_checklist': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'codigo_checklist': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            codigo_checklist_bd: '@PCM.WEB.Properties.Resources.valida_bd'
                        },
                        'descricao': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        }
                    }
                });
            };
        
            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['maxlength', 'select2']);
        });

    </script>
}
