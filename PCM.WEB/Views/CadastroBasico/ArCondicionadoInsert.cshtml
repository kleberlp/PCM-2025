<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-md-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("ArCondicionadoIndex", "CadastroBasico")">@PCM.WEB.Properties.Resources.ar_condicionado</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.inserir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->
    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">
                @using (Html.BeginForm("ArCondicionadoInsert", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()

                    <input type="hidden" id="empresa_pmoc" name="empresa_pmoc" value='@Session["codigo_empresa_pmoc"].ToString()' />

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.cadastrar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("ArCondicionadoIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.tipo_ar_condicionado</label>
                                    <div>@Html.DropDownList("tipo_ar_condicionado", null, "", new { @class = "form-control" })</div>
                                </div>
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.departamento_responsavel</label>
                                    <div>@Html.DropDownList("departamento", null, "", new { @class = "form-control" })</div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.tag</label>
                                    <div><input type="text" class="form-control" id="tag" name="tag" value="" maxlength="20"></div>
                                </div>
                                <div class="col-md-10">
                                    <label>@PCM.WEB.Properties.Resources.descricao</label>
                                    <div><input type="text" class="form-control" id="descricao" name="descricao" value="" maxlength="200"></div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-5">
                                    <label>@PCM.WEB.Properties.Resources.setor</label>
                                    <div>@Html.DropDownList("setor", null, "", new { @class = "form-control" })</div>
                                </div>
                                <div class="col-md-5">
                                    <label>@PCM.WEB.Properties.Resources.apartamento</label>
                                    <div>@Html.DropDownList("apartamento", null, "", new { @class = "form-control" })</div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.andar</label>
                                    <div><input type="text" class="form-control" id="andar" name="andar" value="" maxlength="2"></div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.fabricante</label>
                                <div class="col-12"><input type="text" class="form-control" id="fabricante" name="fabricante" value="" maxlength="100"></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.endereco_fabricante</label>
                                <div class="col-12"><input type="text" class="form-control" id="endereco_fabricante" name="endereco_fabricante" value="" maxlength="200"></div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-3">
                                    <label>@PCM.WEB.Properties.Resources.contato_fabricante</label>
                                    <div><input type="text" class="form-control" id="contato_fabricante" name="contato_fabricante" value="" maxlength="100"></div>
                                </div>
                                <div class="col-md-3">
                                    <label>@PCM.WEB.Properties.Resources.modelo</label>
                                    <div><input type="text" class="form-control" id="modelo" name="modelo" value="" maxlength="100"></div>
                                </div>
                                <div class="col-md-3">
                                    <label>@PCM.WEB.Properties.Resources.numero_fabricacao</label>
                                    <div><input type="text" class="form-control" id="numero_fabricacao" name="numero_fabricacao" value="" maxlength="100"></div>
                                </div>
                                <div class="col-md-3">
                                    <label>@PCM.WEB.Properties.Resources.ano_fabricacao</label>
                                    <div><input type="text" class="form-control" id="ano_fabricacao" name="ano_fabricacao" value="" maxlength="100"></div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.caracteristicas</label>
                                <div class="col-12"><textarea class="form-control" id="caracteristicas" name="caracteristicas" maxlength="500"></textarea></div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-3">
                                    <label>@PCM.WEB.Properties.Resources.potencia</label>
                                    <div>
                                        <div class="input-group">
                                            <input type="text" class="form-control" id="potencia" name="potencia" value="" maxlength="10">
                                            @Html.DropDownList("potencia_ar_condicionado", null, "", new { @class = "form-control" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <label>@PCM.WEB.Properties.Resources.data_proxima_manutencao</label>
                                    <div><input type="text" class="js-datepicker form-control" id="data_proxima_manutencao" name="data_proxima_manutencao" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value=""></div>
                                </div>
                                <div class="col-md-3">
                                    <label>@PCM.WEB.Properties.Resources.ativo</label>
                                    <div>
                                        <label class="css-control css-control-success css-switch">
                                            <input type="checkbox" class="css-control-input" id="ativo" name="ativo" checked value="true">
                                            <span class="css-control-indicator"></span>
                                        </label>
                                    </div>
                                </div>
                            </div>                            
                        </div>
                    </div>
                }
                <!-- END Basic Info -->
            </div>
            <!-- END Update Product -->
        </div>
        <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")

<script>

    $(document).ready(function () { $("#potencia").maskMoney({ prefix: '', thousands: '', precision: 0, allowNegative: false, 'placeholder': '' }); });
    $(document).ready(function () { $("#andar").maskMoney({ prefix: '', thousands: '', precision: 0, allowNegative: true, 'placeholder': '' }); });

        var pmoc = 0;

        $(function () {

            var unidade = $("#unidade");
            var tipo_ar_condicionado = $("#tipo_ar_condicionado");
            var setor = $("#setor");
            var apartamento = $("#apartamento");

            setor.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.setor)', allowClear: true });
            apartamento.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.apartamento)', allowClear: true });
            
            if (setor.val() == "") {
                apartamento.prop("disabled", true);
                apartamento.select2({ placeholder: '@PCM.WEB.Properties.Resources.apartamento', allowClear: true });
            }

            unidade.change(function () {

                if (unidade.val() == "") {
                    tipo_ar_condicionado.empty();
                    setor.empty();
                    apartamento.empty();
                    tipo_ar_condicionado.prop("disabled", true);
                    setor.prop("disabled", true);
                    apartamento.prop("disabled", true);
                    tipo_ar_condicionado.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.tipo_ar_condicionado)', allowClear: true });
                    setor.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.setor)', allowClear: true });
                    apartamento.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.apartamento)', allowClear: true });
                } else {

                    var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val() };

                    $.post("LoadTipoArCondicionado", request, function (obj) {
                        tipo_ar_condicionado.empty();
                        option = $("<option>", { "value": "" }).text("");
                        tipo_ar_condicionado.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            tipo_ar_condicionado.append(option);
                        });
                    }, "json");

                    $.post("LoadSetor", request, function (obj) {
                        setor.empty();
                        option = $("<option>", { "value": "" }).text("");
                        setor.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            setor.append(option);
                        });
                    }, "json");

                    $.post("LoadApartamento", request, function (obj) {
                        apartamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        apartamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            apartamento.append(option);
                        });
                    }, "json");

                    tipo_ar_condicionado.prop("disabled", false);
                    setor.prop("disabled", false);
                    apartamento.prop("disabled", false);
                    tipo_ar_condicionado.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.tipo_ar_condicionado)', allowClear: true });
                    setor.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.setor)', allowClear: true });
                    apartamento.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.apartamento)', allowClear: true });
                }

            });

            setor.change(function () {

                if (setor.val() == "") {
                    apartamento.empty();
                    apartamento.prop("disabled", true);
                    apartamento.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.apartamento)', allowClear: true });
                }
                else {

                    var request = { "unidade": unidade.val(), "setor": setor.val() };

                    $.post("LoadApartamento", request, function (obj) {
                        apartamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        apartamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            apartamento.append(option);
                        });
                    }, "json");

                    apartamento.prop("disabled", false);
                    apartamento.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.apartamento)', allowClear: true });
                }

            });

        });

        jQuery.validator.addMethod("tag_bd", function (value, element) {

            var unidade = $("#unidade").val();

            var dataString = {
                "unidade": unidade,
                "tag": value,
                "codigo": -1
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaArCondicionado",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "");

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    onkeyup: false,
                    onclick: false,
                    onfocusout: false,
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'tipo_ar_condicionado': {
                            required: true
                        },
                        'departamento': {
                            required: true
                        },
                        'tag': {
                            required: true,
                            tag_bd: true
                        },
                        'descricao': {
                            required: true
                        },
                        'setor': {
                            required: true
                        },
                        'ano_fabricacao': {
                            number: true
                        },
                        'potencia': {
                            required: true,
                            number: true
                        },
                        'potencia_ar_condicionado': {
                            required: true
                        },
                        'data_proxima_manutencao': {
                            required: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'tipo_ar_condicionado': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'departamento': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'tag': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            tag_bd: '@PCM.WEB.Properties.Resources.valida_tag_bd'
                        },
                        'descricao': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'setor': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'ano_fabricacao': {
                            number: '@PCM.WEB.Properties.Resources.campo_numerico'
                        },
                        'potencia': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            number: '@PCM.WEB.Properties.Resources.campo_numerico'
                        },
                        'potencia_ar_condicionado': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'data_proxima_manutencao': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
        });

</script>
}
