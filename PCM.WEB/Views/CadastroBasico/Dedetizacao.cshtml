@model List<PCM.WEB.MODELS.DedetizacaoApartamento>

<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <span class="breadcrumb-item">@PCM.WEB.Properties.Resources.cadastro_basico</span>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.dedetizacao </span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->
    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">
                @using (Html.BeginForm("Dedetizacao", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()

                    <input id="codigo_empresa" name="codigo_empresa" type="hidden" value="@Session["codigo_empresa"]" />

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-primary">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.dedetizacao </h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                            </div>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.unidade</label>
                                    <div>@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.periodicidade</label>
                                    <div><input type="number" class="form-control" id="periodicidade" name="periodicidade" value="@ViewBag.dedetizacao.periodicidade" maxlength="3"></div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.dias_alerta</label>
                                    <div><input type="number" class="form-control" id="alerta" name="alerta" maxlength="3" value="@ViewBag.dedetizacao.alerta"></div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.tipo_servico </label>
                                    <div>@Html.DropDownList("tipo_servico", null, "", new { @class = "form-control" })</div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.data_inicio</label>
                                    <div><input type="text" class="js-datepicker form-control" id="data_inicio" name="data_inicio" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value="@ViewBag.dedetizacao.data_inicio"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Dynamic Table Full Pagination -->
                    <div class="block" id="block_row">
                        <div class="block-content block-content-full">
                            <table class="table table-hover table-striped table-sm js-table-checkable">
                                <thead>
                                    <tr class="table-secondary">
                                        <th class="text-center" style="width:100px">@PCM.WEB.Properties.Resources.apartamento</th>
                                        <th>@PCM.WEB.Properties.Resources.tipo_apartamento</th>
                                        <th>@PCM.WEB.Properties.Resources.setor</th>
                                        <th class="text-center" style="width:100px">@PCM.WEB.Properties.Resources.bloco</th>
                                        <th class="text-center" style="width:100px">@PCM.WEB.Properties.Resources.andar</th>
                                        <th class="text-md-center" style="width: 50px;" data-sortable="false">
                                            <label class="css-control-sm css-control-secondary css-switch">
                                                <input type="checkbox" class="css-control-input" id="check-all" name="check-all" value="0">
                                                <span class="css-control-indicator"></span>
                                            </label>
                                        </th>
                                    </tr>
                                </thead>

                                <tbody id="table_body" name="table_body">
                                    @for (int i = 0; i < Model.Count; i++)
                                    {
                                        @Html.HiddenFor(m => m[i].codigo_apartamento)
                                        <tr>
                                            <td class="font-w600 text-center" style="width:100px">@Html.DisplayFor(m => m[i].apartamento)</td>
                                            <td>@Html.DisplayFor(m => m[i].tipo_apartamento)</td>
                                            <td>@Html.DisplayFor(m => m[i].setor)</td>
                                            <td class="text-center" style="width:100px">@Html.DisplayFor(m => m[i].bloco)</td>
                                            <td class="text-center" style="width:100px">@Html.DisplayFor(m => m[i].andar)</td>
                                            <td class="d-none d-sm-table-cell text-center">
                                                <div class="col-12">
                                                    <label class="css-control-sm css-control-success css-switch">
                                                        @Html.CheckBoxFor(m => m[i].selected, new { @class = "css-control-input" })
                                                        <span class="css-control-indicator"></span>
                                                    </label>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

    @section Styles {
        @Styles.Render("~/Content/datepicker")
        @Styles.Render("~/Content/dataTables")
        @Styles.Render("~/Content/select")
    }

    @section Scripts {
        @Scripts.Render("~/plugins/dataTables")
        @Scripts.Render("~/plugins/validation")
        @Scripts.Render("~/plugins/maxlenght")
        @Scripts.Render("~/plugins/maskedinput")
        @Scripts.Render("~/plugins/datepicker")
        @Scripts.Render("~/plugins/select")

<script>

    var FormValidation = function () {
        // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
        var initValidationBootstrap = function () {
            jQuery('.js-validation-bootstrap').validate({
                ignore: [],
                errorClass: 'invalid-feedback animated fadeInDown',
                errorElement: 'div',
                errorPlacement: function (error, e) {
                    jQuery(e).parents('.form-group > div').append(error);
                },
                highlight: function (e) {
                    jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                },
                success: function (e) {
                    jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                    jQuery(e).remove();
                },
                rules: {
                    'unidade': {
                        required: true
                    },
                    'periodicidade': {
                        required: true
                    },
                    'alerta': {
                        required: true
                    },
                    'data_inicio': {
                        required: true
                    }
                },
                messages: {
                    'unidade': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'periodicidade': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'alerta': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'data_inicio': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    }
                }
            });
        };

        return {
            init: function () {
                // Init Bootstrap Forms Validation
                initValidationBootstrap();
            }
        };
    }();

    function LoadDedetizacaoInfo() {

        jQuery.ajax({
            type: "POST",
            url: "LoadDedetizacaoInfo",
            async: false,
            data: {
                "unidade": $("#unidade").val(),
            },
            dataType: "json",
            success: function (data) {
                $("#periodicidade").val(data.periodicidade);
                $("#alerta").val(data.alerta);
                $("#tipo_servico").val(data.codigo_tipo_servico);
                $("#data_inicio").val(data.data_inicio);
            }
        });

    };

    function LoadDedetizacaoApartamento() {

        Codebase.layout("header_loader_on");

        jQuery.ajax({
            type: "POST",
            url: "LoadDedetizacaoApartamento",
            async: false,
            data: {
                "unidade": $("#unidade").val(),
            },
            dataType: "json",
            success: function (data) {

                $("#table_body tr").remove();

                $.each(data, function (i, result) {

                    var rowsItem = $("<tr id='linha'>");

                    var colsItem = '<input name="[' + i + '].codigo_apartamento" type="hidden" value="' + result.codigo_apartamento + '" />';
                    rowsItem.append(colsItem);

                    colsItem = '<td class="font-w600 text-center" style = "width:100px" >' + result.apartamento + '</td>';
                    colsItem += '<td>' + result.tipo_apartamento + '</td>';
                    colsItem += '<td>' + result.setor + '</td>';
                    colsItem += '<td class="text-center" style="width:100px">' + result.bloco + '</td>';
                    colsItem += '<td class="text-center" style="width:100px">' + result.andar + '</td>';
                    colsItem += '<td class="d-none d-sm-table-cell text-center">';
                    colsItem += '<div class="col-12">';
                    colsItem += '<label class="css-control-sm css-control-success css-switch">';
                    if (result.selected) {
                        colsItem += '<input checked="checked" class="css-control-input" data-val="true" data-val-required="The selected field is required." name="[' + i + '].selected" type="checkbox" value="true"/>';
                    } else {
                        colsItem += '<input class="css-control-input" data-val="true" data-val-required="The selected field is required." name="[' + i + '].selected" type="checkbox" value="true"/>';
                    }
                    colsItem += '<input name="[' + i + '].selected" type="hidden" value="true"/>';
                    colsItem += '<span class="css-control-indicator"></span>';
                    colsItem += '</label>';
                    colsItem += '</div> ';
                    colsItem += '</td>';
                    rowsItem.append(colsItem);
                    $("#table_body").append(rowsItem);
                });

                Codebase.layout("header_loader_off");
            },
            error: function (error) {
                Codebase.layout("header_loader_off");
            }
        });

    };

    var BeTableDatatables = function () {
        // Override a few DataTable defaults, for more examples you can check out https://www.datatables.net/
        var exDataTable = function () {
            jQuery.extend(jQuery.fn.dataTable.ext.classes, {
                sWrapper: "dataTables_wrapper dt-bootstrap4"
            });
        };

        // Init simple DataTable, for more examples you can check out https://www.datatables.net/
        var initDataTableSimple = function () {
            jQuery('.js-table-checkable').dataTable({
                columnDefs: [
                    { orderable: false, targets: [0] },
                    { type: 'date-br', targets: [2] }
                ],
                order: [[1, "desc"]],
                fixedHeader: true,
                searching: true,
                paging: false,
                lengthChange: false,
                pageLength: 15,
                autoWidth: false,
                scrollX: false,
                scrollColapse: true,
                columnDefs: [{ orderable: false, targets: [0] }],
                dom: 'Bfrtip',
                buttons: [
                    { extend: 'copy', text: 'Copiar' },
                    {
                        extend: 'print',
                        text: 'Imprimir'
                    },
                    { extend: 'excel' },
                    { extend: 'pdf', orientation: 'portrait' },
                ],
                language: {
                    "search": "Procurar:",
                    "lengthMenu": "Exibir _MENU_ ",
                    "zeroRecords": "Nenhum Registro Encontrado",
                    "info": "_MAX_ registro(s)",
                    "infoEmpty": "Nenhum Registro encontrado",
                    "infoFiltered": "(filtrado de _MAX_ registro(s))"
                }
            });
        };

        return {
            init: function () {
                // Override a few DataTable defaults
                exDataTable();

                // Init Datatables
                initDataTableSimple();
            }
        };
    }();

    // Initialize when page loads
    jQuery(function () {

        FormValidation.init();
        //BeTableDatatables.init();

        Codebase.helpers(['datepicker', 'maxlength', 'select2', 'table-tools']);

        $("#data_inicio").mask("99/99/9999");
        var unidade = $("#unidade");

        unidade.change(function () {
            LoadDedetizacaoInfo();
            LoadDedetizacaoApartamento();
        });

    });

        </script>

    }
