@model IEnumerable<PCM.WEB.MODELS.Fornecedor>

<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-md-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.fornecedor</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->
    <!-- Page Content -->
    <div class="content">

        @using (Html.BeginForm("FornecedorIndex", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()

            if (Session["unidade"] != "")
            {
                <input type="hidden" name="unidade" id="unidade" value='@Session["codigo_unidade"]'>
            }

            <!-- Toggle Tasks Navigation on mobile -->
            <button type="button" class="btn btn-block btn-square btn-primary d-md-none mb-10" data-toggle="class-toggle" data-target=".js-tasks-nav" data-class="d-none d-md-block">@PCM.WEB.Properties.Resources.filtros</button>
            <div class="js-tasks-nav d-none d-md-block">
                <div class="block block-rounded border">
                    <div class="block-header block-header-default bg-gd-default">
                        <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.fornecedor</h3>
                        <div class="block-options">

                            @if (ViewBag.inserir)
                            {
                                <a href="@Url.Action("FornecedorInsert", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.novo
                                </a>
                            }
                        </div>
                    </div>
                    <div class="block-content">
                        <ul class="list-group push">
                            <li class="list-group-item">
                                <div class="row">
                                    <div class="col-md-4">@Html.DropDownList("unidade", null, PCM.WEB.Properties.Resources.unidade, new { @class = "js-select2 form-control" })</div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="row">
                                    <div class="col-md-2"><input type="text" id="cnpj" name="cnpj" value="@ViewBag.cnpj" placeholder="@PCM.WEB.Properties.Resources.cnpj" class="form-control"></div>
                                    <div class="col-md-3"><input type="text" id="nome_fantasia" name="nome_fantasia" value="@ViewBag.nome_fantasia" placeholder="@PCM.WEB.Properties.Resources.nome_fantasia" class="form-control"></div>
                                    <div class="col-md-3">@Html.DropDownList("categoria", null, PCM.WEB.Properties.Resources.categoria, new { @class = "js-select2 form-control" })</div>
                                    <div class="col-md-2">@Html.DropDownList("uf", null, PCM.WEB.Properties.Resources.uf, new { @class = "js-select2 form-control" })</div>
                                    <div class="col-md-2">@Html.DropDownList("ativo", null, PCM.WEB.Properties.Resources.ativo, new { @class = "js-select2 form-control" })</div>
                                </div>
                            </li>
                            <li class="list-group-item text-right">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75" name="filtrar" id="filtrar"><i class="si si-magnifier mr-5"></i>@PCM.WEB.Properties.Resources.filtrar</button>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <!-- END Collapsible Tasks Navigation -->

            <!-- Listagem -->
            <div class="block block-rounded border">

                <div class="block-content block-content-full">
                    <!-- DataTables init on table by adding .js-dataTable-full-pagination class, functionality initialized in js/pages/be_tables_datatables.js -->
                    <table class="table table-sm table-vcenter table-striped js-dataTable-list">
                        <thead>
                            <tr class="table-secondary">
                                @if (Session["unidade"] == "")
                                {
                                    <th class="d-none d-sm-table-cell">@PCM.WEB.Properties.Resources.unidade </th>
                                }
                                <th class="d-none d-sm-table-cell">@PCM.WEB.Properties.Resources.categoria</th>
                                <th class="d-none d-sm-table-cell text-md-center">@PCM.WEB.Properties.Resources.cnpj</th>
                                <th>@PCM.WEB.Properties.Resources.nome_fantasia</th>
                                <th class="d-none d-sm-table-cell text-md-center">@PCM.WEB.Properties.Resources.telefone</th>
                                <th class="d-none d-sm-table-cell text-md-center">@PCM.WEB.Properties.Resources.email</th>
                                <th class="d-none d-sm-table-cell text-md-center" style="width: 80px;">@PCM.WEB.Properties.Resources.ativo</th>
                                @if (ViewBag.editar || ViewBag.excluir)
                                {
                                    <th class="text-md-center" style="width: 80px;" data-sortable="false"></th>
                                }
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    @if (Session["unidade"] == "")
                                    {
                                        <td class="d-none d-sm-table-cell">@Html.DisplayFor(modelItem => item.unidade)</td>
                                    }
                                    <td class="d-none d-sm-table-cell">@Html.DisplayFor(modelItem => item.categoria)</td>
                                    <td class="d-none d-sm-table-cell text-md-center">@Html.DisplayFor(modelItem => item.cnpj)</td>
                                    <td>@Html.DisplayFor(modelItem => item.nome_fantasia)</td>
                                    <td class="d-none d-sm-table-cell text-md-center">@Html.DisplayFor(modelItem => item.telefone)</td>
                                    <td class="d-none d-sm-table-cell text-md-center">@Html.DisplayFor(modelItem => item.email)</td>
                                    <td class="d-none d-sm-table-cell text-md-center" style="width: 80px;">
                                        <label class="css-control-sm css-control-secondary css-checkbox">
                                            @Html.CheckBoxFor(modelItem => item.ativo, new { @class = "css-control-input", @disabled = "disabled" })
                                            <span class="css-control-indicator"></span>
                                        </label>
                                    </td>
                                    @if (ViewBag.editar || ViewBag.excluir)
                                    {
                                        <td class="text-md-center" style="width: 80px;">
                                            <div class="btn-group">
                                                @if (ViewBag.editar)
                                                {<a href="@Url.Action("FornecedorEdit", "CadastroBasico", new { codigo = item.codigo })" class="btn btn-sm btn-secondary"><i class="fa fa-pencil"></i></a>}
                                                @if (ViewBag.excluir)
                                                {<a href="@Url.Action("FornecedorDelete", "CadastroBasico", new { codigo = item.codigo })" class="btn btn-sm btn-secondary"><i class="fa fa-times"></i></a>}
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
            <!-- END Fornecedor -->

        }

    </div>
    <!-- END Page Content -->

</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/dataTables")
}

@section Scripts {
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/plugins/maskedinput")

    <script type="text/javascript">

        $(document).ready(function () { $("#cnpj").mask("99.999.999/9999-99"); });

        $(function () {

            var unidade = $("#unidade");
            var categoria = $("#categoria");

            unidade.change(function () {
                var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val() };

                $.post("LoadCategoria", request, function (obj) {
                    categoria.empty();
                    option = $("<option>", { "value": "" }).text("");
                    categoria.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        categoria.append(option);
                    });
                }, "json");
            });

        });

        var BeTableDatatables = function () {
            // Override a few DataTable defaults, for more examples you can check out https://www.datatables.net/
            var exDataTable = function () {
                jQuery.extend(jQuery.fn.dataTable.ext.classes, {
                    sWrapper: "dataTables_wrapper dt-bootstrap4"
                });
            };

            // Init simple DataTable, for more examples you can check out https://www.datatables.net/
            var initDataTableSimple = function () {
                jQuery('.js-dataTable-list').dataTable({
                    fixedHeader: true,
                    searching: true,
                    lengthChange: false,
                    pageLength: 15,
                    autoWidth: false,
                    scrollX: false,
                    scrollColapse: true,
                    dom: 'Bfrtip',
                    buttons: [
                        { extend: 'copy', text: 'Copiar' },
                        {
                            extend: 'print',
                            text: 'Imprimir'
                        },
                        { extend: 'excel' },
                        { extend: 'pdf', orientation: 'portrait' },
                    ],
                    language: {
                        "search": "Procurar:",
                        "lengthMenu": "Exibir _MENU_ ",
                        "zeroRecords": "Nenhum Registro Encontrado",
                        "info": "_MAX_ registro(s)",
                        "infoEmpty": "Nenhum Registro encontrado",
                        "infoFiltered": "(filtrado de _MAX_ registro(s))"
                    }
                });
            };

            return {
                init: function () {
                    // Override a few DataTable defaults
                    exDataTable();

                    // Init Datatables
                    initDataTableSimple();
                }
            };
        }();


        // Initialize when page loads
        jQuery(function () { $.fn.dataTable.moment('DD/MM/YYYY HH:mm'); BeTableDatatables.init(); });

    </script>
}
