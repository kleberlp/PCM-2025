@model PCM.WEB.MODELS.Atividade

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-md-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("ProgramadaIndex", "CadastroBasico")">@PCM.WEB.Properties.Resources.atividade</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.excluir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">                
                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.codigo)

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.deseja_excluir</h3>
                            <div class="block-options">
                                @if(ViewBag.erro == "")
                                {
                                    <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                        <i class="si si-trash mr-5"></i>@PCM.WEB.Properties.Resources.excluir
                                    </button>
                                }
                                <a href="@Url.Action("ProgramadaIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">     
                            @if(ViewBag.erro != "")
                            {
                                <div class="form-group row">
                                    <i><label class="col-12 font-w600 text-danger">** @ViewBag.erro</label></i>
                                </div>
                            }   
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.unidade: <span class="font-w400">@Html.DisplayFor(model => model.unidade)</span></label> 
                            </div>    
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.categoria: <span class="font-w400">@Html.DisplayFor(model => model.categoria)</span></label> 
                            </div>    
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.itens_gerais: <span class="font-w400">@Html.DisplayFor(model => model.equipamento)</span></label> 
                            </div>    
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.titulo: <span class="font-w400">@Html.DisplayFor(model => model.titulo)</span></label> 
                            </div>    
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.descricao: <span class="font-w400">@Html.DisplayFor(model => model.descricao)</span></label> 
                            </div>    
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.data_previsao_termino: <span class="font-w400">@Html.DisplayFor(model => model.data_previsao_termino)</span></label> 
                            </div>   
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.tipo_servico: <span class="font-w400">@Html.DisplayFor(model => model.tipo_servico)</span></label> 
                            </div> 
                        </div>                        
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->
