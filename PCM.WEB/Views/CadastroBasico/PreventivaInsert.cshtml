<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <span class="breadcrumb-item">@PCM.WEB.Properties.Resources.cadastro_basico</span>
                <a class="breadcrumb-item" href="@Url.Action("PreventivaIndex", "CadastroBasico")">@PCM.WEB.Properties.Resources.preventiva</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.inserir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->
    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">

                @using (Html.BeginForm("PreventivaInsert", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()

                    <input type="hidden" id="tipo_ordem_servico" name="tipo_ordem_servico" value="5" />

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.cadastrar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("PreventivaIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@Html.DropDownList("unidade", null, "", new { @class = "js-select2 form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.categoria</label>
                                    <div>@Html.DropDownList("categoria", null, "", new { @class = "js-select2 form-control" })</div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.modulo</label>
                                    <div>@Html.DropDownList("modulo", null, "", new { @class = "js-select2 form-control" })</div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.forma_lancamento_preventiva</label>
                                    <div>@Html.DropDownList("forma_lancamento", null, "", new { @class = "js-select2 form-control" })</div>
                                </div>
                            </div>
                            <div class="form-group row" id="div_forma_lancamento" style="display:none">
                                <div class="col-md-12" id="div_setor">
                                    <label>@PCM.WEB.Properties.Resources.setor</label>
                                    <div>@Html.DropDownList("setor", null, "", new { @class = "js-select2 form-control" })</div>
                                </div>
                                <div class="col-md-12" id="div_familia">
                                    <label>@PCM.WEB.Properties.Resources.familia_equipamento</label>
                                    <div>@Html.DropDownList("familia", null, "", new { @class = "js-select2 form-control" })</div>
                                </div>
                                <div class="col-md-12" id="div_equipamento">
                                    <label>@PCM.WEB.Properties.Resources.equipamento</label>
                                    <div>@Html.DropDownList("equipamento", null, "", new { @class = "js-select2 form-control" })</div>
                                </div>
                            </div>
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.descricao</label>
                                    <div class="col-12"><textarea class="form-control" id="descricao" name="descricao" maxlength="500" rows="6"></textarea></div>
                                </div>
                                <div class="form-group row">
                                    <div class="col-md-3">
                                        <label>@PCM.WEB.Properties.Resources.valor_previsto</label>
                                        <div><input type="text" class="form-control" id="valor_previsto" name="valor_previsto" value="" maxlength="9"></div>
                                    </div>
                                    <div class="col-md-3">
                                        <label>@PCM.WEB.Properties.Resources.quantidade_equipamento</label>
                                        <div><input type="text" class="form-control" id="quantidade_equipamento" name="quantidade_equipamento" value="" maxlength="5"></div>
                                    </div>
                                    <div class="col-md-3">
                                        <label>@PCM.WEB.Properties.Resources.periodicidade</label>
                                        <div>@Html.DropDownList("periodicidade", null, "", new { @class = "form-control js-select2" })</div>
                                    </div>
                                    <div class="col-md-3">
                                        <label>@PCM.WEB.Properties.Resources.intervalo</label>
                                        <div><input type="text" class="form-control" id="intervalo" name="intervalo" maxlength="3"></div>
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <div class="col-md-6">
                                        <label>@PCM.WEB.Properties.Resources.tipo_servico</label>
                                        <div>@Html.DropDownList("tipo_servico", null, "", new { @class = "js-select2 form-control" })</div>
                                    </div>
                                    <div class="col-md-6">
                                        <label>@PCM.WEB.Properties.Resources.checklist</label>
                                        <div>@Html.DropDownList("checklist", null, "", new { @class = "form-control js-select2" })</div>
                                    </div>
                                </div>

                                <div class="form-group row">
                                    <div class="col-md-2">
                                        <label>@PCM.WEB.Properties.Resources.ativo</label>
                                        <div>
                                            <label class="css-control css-control-success css-switch">
                                                <input type="checkbox" class="css-control-input" id="ativo" name="ativo" checked value="true">
                                                <span class="css-control-indicator"></span>
                                            </label>
                                        </div>
                                    </div>
                                </div>

                            </div>
                    </div>
                }
                <!-- END Basic Info -->
            </div>
            <!-- END Update Product -->
        </div>
        <!-- END Page Content -->

    </div>

</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/ckeditor")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")

<script>

    $(document).ready(function () {
        $("#valor_previsto").maskMoney({ decimal: ",", thousands: "." });
        $("#quantidade_equipamento").maskMoney({ prefix: '', thousands: '.', precision: 0, allowNegative: false, 'placeholder': '' });
        $("#intervalo").maskMoney({ thousands: ".", precision: 0, allowNegative: false });
    });

    $(function () {

        var unidade = $("#unidade");
        var familia = $("#familia");
        var categoria = $("#categoria");
        var forma_lancamento = $("#forma_lancamento");
        var setor = $("#setor");
        var equipamento = $("#equipamento");

        forma_lancamento.change(function () {

            if(forma_lancamento.val() == "") {
                $("#div_forma_lancamento").hide();
            } else if(forma_lancamento.val() == "1") {
                $("#div_setor").show();
                $("#div_familia").hide();
                $("#div_equipamento").hide();
                $("#div_forma_lancamento").show();
            } else if (forma_lancamento.val() == "2") {
                $("#div_setor").hide();
                $("#div_familia").show();
                $("#div_equipamento").hide();
                $("#div_forma_lancamento").show();
            } else if (forma_lancamento.val() == "3") {
                $("#div_setor").hide();
                $("#div_familia").hide();
                $("#div_equipamento").show();
                $("#div_forma_lancamento").show();
            }

        });

        unidade.change(function () {
            var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val() };

            $.post("LoadCategoria", request, function (obj) {
                categoria.empty();
                option = $("<option>", { "value": "" }).text("");
                categoria.append(option);
                $.each(obj, function (indice, result) {
                    option = $("<option>", { "value": result.codigo }).text(result.descricao);
                    categoria.append(option);
                });
            }, "json");

            $.post("LoadFamiliaEquipamento", request, function (obj) {
                familia.empty();
                option = $("<option>", { "value": "" }).text("");
                familia.append(option);
                $.each(obj, function (indice, result) {
                    option = $("<option>", { "value": result.codigo }).text(result.descricao);
                    familia.append(option);
                });
            }, "json");

            $.post("LoadSetor", request, function (obj) {
                setor.empty();
                option = $("<option>", { "value": "" }).text("");
                setor.append(option);
                $.each(obj, function (indice, result) {
                    option = $("<option>", { "value": result.codigo }).text(result.descricao);
                    setor.append(option);
                });
            }, "json");

        });

        setor.change(function () {
            var request = { "unidade": unidade.val(), "setor": (setor.val() == "") ? "-1" : setor.val(), "familia": (familia.val() == "") ? "-1" : familia.val() };
            $.post("LoadEquipamentoFamiliaSetor", request, function (obj) {
                equipamento.empty();
                option = $("<option>", { "value": "" }).text("");
                equipamento.append(option);
                $.each(obj, function (indice, result) {
                    option = $("<option>", { "value": result.codigo }).text(result.descricao);
                    equipamento.append(option);
                })
            }, "json");
        });

        familia.change(function () {
            var request = { "unidade": unidade.val(), "setor": (setor.val() == "") ? "-1" : setor.val(), "familia": (familia.val() == "") ? "-1" : familia.val() };
            $.post("LoadEquipamentoFamiliaSetor", request, function (obj) {
                equipamento.empty();
                option = $("<option>", { "value": "" }).text("");
                equipamento.append(option);
                $.each(obj, function (indice, result) {
                    option = $("<option>", { "value": result.codigo }).text(result.descricao);
                    equipamento.append(option);
                })
            }, "json");
        });

    });

    jQuery.validator.addMethod("valida_setor", function (value, element) {

        if ($("#forma_lancamento").val() != "1")
            return true;
        else if (value != "")
            return true;
        else
            return false;

    }, "");

    jQuery.validator.addMethod("valida_familia", function (value, element) {

        if ($("#forma_lancamento").val() != "2")
            return true;
        else if (value != "")
            return true;
        else
            return false;

    }, "");

    jQuery.validator.addMethod("valida_equipamento", function (value, element) {

        if ($("#forma_lancamento").val() != "3")
            return true;
        else if (value != "")
            return true;
        else
            return false;

    }, "");

    var FormValidation = function () {
        // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
        var initValidationBootstrap = function () {
            jQuery('.js-validation-bootstrap').validate({
                ignore: [],
                errorClass: 'invalid-feedback animated fadeInDown',
                errorElement: 'div',
                errorPlacement: function (error, e) {
                    jQuery(e).parents('.form-group > div').append(error);
                },
                highlight: function (e) {
                    jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                },
                success: function (e) {
                    jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                    jQuery(e).remove();
                },
                rules: {
                    'unidade': {
                        required: true
                    },
                    'modulo': {
                        required: true
                    },
                    'categoria': {
                        required: true
                    },
                    'forma_lancamento': {
                        required: true
                    },
                    'setor': {
                        valida_setor: true
                    },
                    'familia': {
                        valida_familia: true
                    },
                    'equipamento': {
                        valida_equipamento: true
                    },
                    'descricao': {
                        required: true
                    },
                    'valor_previsto': {
                        required: false
                    },
                    'quantidade_equipamento': {
                        required: true
                    },
                    'periodicidade': {
                        required: true
                    },
                    'intervalo': {
                        required: true
                    },
                    'tipo_servico': {
                        required: true
                    }
                },
                messages: {
                    'unidade': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'modulo': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'categoria': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'setor': {
                        valida_setor: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'familia': {
                        valida_familia: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'equipamento': {
                        valida_equipamento: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'descricao': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'valor_previsto': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'quantidade_equipamento': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'periodicidade': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'intervalo': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'tipo_servico': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    }
                }
            });
        };

        return {
            init: function () {
                // Init Bootstrap Forms Validation
                initValidationBootstrap();
            }
        };
    }();

    // Initialize when page loads
    jQuery(function () {
        FormValidation.init();
        Codebase.helpers(['datepicker', 'maxlength', 'select2', 'ckeditor']);
    });

</script>

    }
