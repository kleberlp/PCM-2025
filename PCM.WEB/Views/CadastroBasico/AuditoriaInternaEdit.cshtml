@model PCM.WEB.MODELS.AuditoriaInterna

<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-md-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <span class="breadcrumb-item">@PCM.WEB.Properties.Resources.cadastro_basico</span>
                <a class="breadcrumb-item" href="@Url.Action("AuditoriaInternaIndex", "CadastroBasico")">@PCM.WEB.Properties.Resources.auditoria_interna</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.editar</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->
    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">
                @using (Html.BeginForm("AuditoriaInternaEdit", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.codigo)
                    @Html.HiddenFor(model => model.codigo_unidade)

                <div class="block block-rounded border">
                    <div class="block-header block-header-default bg-gd-default">
                        <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.cadastrar</h3>
                        <div class="block-options">
                            <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                            </button>
                            <a href="@Url.Action("AuditoriaInternaIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                            </a>
                        </div>
                    </div>
                    <div class="block-content block-content-full">
                        <div class="form-group row">
                            <label class="col-12">@PCM.WEB.Properties.Resources.unidade</label>
                            <div class="col-12">@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                        </div>
                        <div class="form-group row">
                            <div class="col-md-6">
                                <label>@PCM.WEB.Properties.Resources.descricao</label>
                                <div><input type="text" class="form-control" id="descricao" name="descricao" value="@Model.descricao" maxlength="100"></div>
                            </div>
                            <div class="col-md-6">
                                <label>@PCM.WEB.Properties.Resources.modulo</label>
                                <div>@Html.DropDownList("modulo", null, "", new { @class = "js-select2 form-control" })</div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <div class="col-md-6">
                                <label>@PCM.WEB.Properties.Resources.checklist</label>
                                <div>@Html.DropDownList("checklist", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="col-md-4">
                                <label>@PCM.WEB.Properties.Resources.periodicidade</label>
                                <div>@Html.DropDownList("periodicidade", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="col-md-2">
                                <label>@PCM.WEB.Properties.Resources.intervalo </label>
                                <div><input type="text" class="form-control" id="intervalo" name="intervalo" value="@Model.intervalo " maxlength="3"></div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <div class="col-md-3">
                                <label>@PCM.WEB.Properties.Resources.ativo</label>
                                <div>
                                    <label class="css-control css-control-success css-switch">
                                        <input type="checkbox" class="css-control-input" id="ativo" name="ativo" @ViewBag.ativo value="true">
                                        <span class="css-control-indicator"></span>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")

    <script>

    $(function () {

        $.ajaxSetup({ async: false });
        var unidade = $("#unidade")
        var fornecedor = $("#checklist");

        if (unidade.val() == "" || unidade.val() == "-1") {
            checklist.prop("disabled", true);
            checklist.select2({ placeholder: '', allowClear: true });
        }

        unidade.change(function () {

            if (unidade.val() == "") {
                checklist.prop("disabled", true);
                checklist.select2({ placeholder: '', allowClear: true });
            } else {

                var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val(), "codigo_tipo_checklist" : 5};

                $.post("LoadChecklist", request, function (obj) {
                    checklist.empty();
                    option = $("<option>", { "value": "" }).text("");
                    checklist.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        checklist.append(option);
                    });
                }, "json");

                checklist.prop("disabled", false);
                checklist.select2({ placeholder: '', allowClear: true });
            }

        });
    });

    var FormValidation = function () {
        // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
        var initValidationBootstrap = function () {
            jQuery('.js-validation-bootstrap').validate({
                ignore: [],
                errorClass: 'invalid-feedback animated fadeInDown',
                errorElement: 'div',
                errorPlacement: function (error, e) {
                    jQuery(e).parents('.form-group > div').append(error);
                },
                highlight: function (e) {
                    jQuery(e).closest('.form-group').removeClass('is-invalid').addClass('is-invalid');
                },
                success: function (e) {
                    jQuery(e).closest('.form-group').removeClass('is-invalid');
                    jQuery(e).remove();
                },
                rules: {
                    'unidade': {
                        required: true
                    },
                    'descricao': {
                        required: true
                    },
                    'checklist': {
                        required: true
                    }
                },
                messages: {
                    'unidade': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'descricao': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'checklist': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    }
                }
            });
        };

        return {
            init: function () {
                // Init Bootstrap Forms Validation
                initValidationBootstrap();
            }
        };
    }();

    // Initialize when page loads
    jQuery(function () {
        FormValidation.init();
        Codebase.helpers(['datepicker', 'maxlength', 'select2']);
    });

    </script>
}
