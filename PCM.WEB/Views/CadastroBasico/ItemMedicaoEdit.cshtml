@model PCM.WEB.MODELS.ItemMedicao

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-md-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("ItemMedicaoIndex", "CadastroBasico")">@PCM.WEB.Properties.Resources.item_medicao</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.editar</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">           
                @using (Html.BeginForm("ItemMedicaoEdit", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.codigo)
                    @Html.HiddenFor(model => model.codigo_unidade)

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.editar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("ItemMedicaoIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">                            
                            <div class="form-group row">
                                <label class="col-12" for="unidade">@PCM.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@Html.DisplayFor(model => model.unidade)</div>
                            </div>                               
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.grupo_item_medicao</label>
                                <div class="col-12">@Html.DropDownList("grupo_item_medicao", null, "", new { @class = "js-select2 form-control" })</div>
                            </div> 
                            <div class="form-group row">
                                <div class="col-10">
                                    <label>@PCM.WEB.Properties.Resources.descricao</label>
                                    <div>@Html.TextBoxFor(model => model.descricao, new { @class = "form-control", @maxlength = "100" })</div>
                                </div>
                                <div class="col-2">
                                    <label>@PCM.WEB.Properties.Resources.unidade_medida</label>
                                    <div>@Html.TextBoxFor(model => model.unidade_medida, new { @class = "form-control", @maxlength = "5" })</div>
                                </div>
                            </div>  
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.meta_consumo</label>
                                <div class="col-12">@Html.TextBoxFor(model => model.meta_consumo, new { @class = "form-control", @maxlength="20"})</div>                                    
                            </div>                                          
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.forma_leitura</label>
                                <div class="col-12">@Html.DropDownList("forma_leitura", null, "", new { @class = "form-control", @onChange="verificaFormaLeitura();" })</div>
                            </div> 
                            <div class="form-group row" id="div_numero_digitos">
                                <div class="col-md-6">
                                    <div><label>@PCM.WEB.Properties.Resources.numero_digitos_leitor</label></div>
                                    <div>@Html.TextBoxFor(model => model.numero_digitos, new { @class = "form-control", @maxlength="2"})</div>   
                                </div>
                                <div class="col-md-6">
                                    <div><label>@PCM.WEB.Properties.Resources.numero_casas_decimais</label></div>
                                    <div>@Html.TextBoxFor(model => model.numero_casas_decimais, new { @class = "form-control", @maxlength="2"})</div>   
                                </div>
                            </div>                
                            <div class="form-group row">
                            <label class="col-12">@PCM.WEB.Properties.Resources.ativo</label>
                            <div class="col-12">
                                <label class="css-control css-control-success css-switch">
                                    @Html.CheckBoxFor(model => model.ativo, new { @class = "css-control-input"})
                                    <span class="css-control-indicator"></span>
                                </label>
                            </div>
                            </div>
                        </div>                        
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/select")

    <script>

        function verificaFormaLeitura() {

            var tipo = $("#forma_leitura").val();
            if (tipo == 2)
                document.getElementById("div_numero_digitos").style.display = "block";
            else
                document.getElementById("div_numero_digitos").style.display = "none";
        }

        jQuery.validator.addMethod("descricao_bd", function (value, element) {

            var codigo = $("#codigo").val();
            var unidade = $("#codigo_unidade").val();

            var dataString = {
                "descricao": value,
                "codigo": codigo,
                "unidade": unidade
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaItemMedicao",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, '@PCM.WEB.Properties.Resources.campo_requerido');

        jQuery.validator.addMethod("numero_digitos", function (value, element) {

            var forma_leitura = $("#forma_leitura").val();

            if (forma_leitura == 1) {
                return true;
            }
            else {
                if (value == "") {
                    return false;
                }
                else {
                    return true;
                }
            }
            return result;

        }, '@PCM.WEB.Properties.Resources.campo_requerido');

        jQuery.validator.addMethod("numero_casas_decimais", function (value, element) {

            var forma_leitura = $("#forma_leitura").val();

            if (forma_leitura == 1) {
                return true;
            }
            else {
                if (value == "") {
                    return false;
                }
                else {
                    return true;
                }
            }
            return result;

        }, '@PCM.WEB.Properties.Resources.campo_requerido');

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'grupo_item_medicao': {
                            required: true
                        },
                        'descricao': {
                            required: true,
                            descricao_bd: true
                        },
                        'meta_consumo': {
                            required: true,
                            number: true
                        },
                        'forma_leitura': {
                            required: true
                        },
                        'numero_digitos': {
                            numero_digitos: true,
                            number: true
                        },
                        'numero_casas_decimais': {
                            numero_casas_decimais: true,
                            number: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'grupo_item_medicao': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'descricao': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            descricao_bd: '@PCM.WEB.Properties.Resources.valida_descricao_bd'
                        },
                        'meta_consumo': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            number: '@PCM.WEB.Properties.Resources.campo_numerico'
                        },
                        'forma_leitura': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'numero_digitos': {
                            numero_digitos: '@PCM.WEB.Properties.Resources.campo_requerido',
                            number: '@PCM.WEB.Properties.Resources.campo_numerico'
                        },
                        'numero_casas_decimais': {
                            numero_casas_decimais: '@PCM.WEB.Properties.Resources.campo_requerido',
                            number: '@PCM.WEB.Properties.Resources.campo_numerico'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['maxlength']);
            verificaFormaLeitura();
        });

    </script>

}
