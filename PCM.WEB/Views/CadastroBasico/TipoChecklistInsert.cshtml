<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("TipoChecklistIndex", "CadastroBasico")">@PCM.WEB.Properties.Resources.tipo_checklist</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.inserir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">                
                @using (Html.BeginForm("TipoChecklistInsert", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.cadastrar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("TipoChecklistIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">        
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                            </div>  
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.descricao</label>
                                <div class="col-12"><input type="text" class="form-control" id="descricao" name="descricao" value="" maxlength="50"></div>
                            </div>
                            <div class="form-group row">
                            <label class="col-12">@PCM.WEB.Properties.Resources.ativo</label>
                            <div class="col-12">
                                <label class="css-control css-control-success css-switch">
                                    <input type="checkbox" class="css-control-input" id="ativo" name="ativo" checked value ="true">
                                    <span class="css-control-indicator"></span>
                                </label>
                            </div>
                        </div>
                        </div>                        
                    </div>

                    <!-- Dynamic Table Full Pagination -->
                    <div class="block" id="list_checklist">
                        <div class="block-content block-content-full">
                            <!-- DataTables init on table by adding .js-dataTable-full-pagination class, functionality initialized in js/pages/be_tables_datatables.js -->
                            <table class="table table-sm table-bordered table-striped table-vcenter js-dataTable-list" id="checklist-table" name="checklist-table">
                                <thead>
                                    <tr class="table-secondary">
                                        <th class="text-center" style="width:100px">X</th>
                                        <th class="text-center" style="width:100px">@PCM.WEB.Properties.Resources.codigo </th>
                                        <th>@PCM.WEB.Properties.Resources.descricao </th>
                                    </tr>
                                </thead>
                                <tbody id="checklist_row">  
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <!-- END Dynamic Table Full Pagination -->

                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->


@section Styles {
    @Styles.Render("~/Content/dataTables")
}

@section Scripts {
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/plugins/validation")
    
    <script>

        $(function () {

            var unidade = $("#unidade");
            var table = $('#checklist-table');

            $('#list_checklist').hide();

            var codigo = 0;

            unidade.change(function () {
                var request = { "unidade": unidade.val()};
                $.post("LoadChecklist", request, function (obj) {

                    $("#checklist_row").empty();
                    $('#list_checklist').hide();

                    $.each(obj, function (indice, result) {

                        var newRowItem = $("<tr id='linha'>");
                        var colsItem = "";
                        colsItem = '<input data-val="true" name="[' + codigo + '].codigo" type="hidden" value="' + result.codigo + '" />';
                        newRowItem.append(colsItem);
                        colsItem = '<td class="text-center" style="width:100px"><label class="css-control css-control-success css-checkbox"><input class="css-control-input" data-val="true" name="[' + codigo + '].selecionado" type="checkbox" value="true" /><span class="css-control-indicator"></span></label></td>';
                        newRowItem.append(colsItem);
                        colsItem = '<td class="text-center">' + result.codigo_checklist + '</td>';
                        newRowItem.append(colsItem);
                        colsItem = '<td>' + result.checklist + '</td>';
                        newRowItem.append(colsItem);

                        $("#checklist-table").append(newRowItem);

                        codigo = codigo + 1;
                        $('#list_checklist').show();

                    });
                }, "json");

            });

        });

        jQuery.validator.addMethod("descricao_bd", function (value, element) {

            var dataString = {
                "descricao": value,
                "codigo": -1,
                "unidade": (unidade == "") ? "-1": unidade
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaTipoChecklist",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "");

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'descricao': {
                            required: true,
                            descricao_bd: true
                        }
                    },
                    messages: {
                        'descricao': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            descricao_bd: '@PCM.WEB.Properties.Resources.valida_descricao_bd'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['maxlength']);
        });

    </script>

}