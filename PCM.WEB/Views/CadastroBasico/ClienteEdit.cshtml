@model PCM.WEB.MODELS.Cliente 

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action("Index", "Home")">@PCM.WEB.Properties.Resources.pcm</a>
                <span class="breadcrumb-item">@PCM.WEB.Properties.Resources.cadastro_basico</span>
                <a class="breadcrumb-item" href="@Url.Action("ClienteIndex", "CadastroBasico")">@PCM.WEB.Properties.Resources.cliente</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.editar</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">
                @using (Html.BeginForm("ClienteEdit", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()

                    <input id="codigo" name="codigo" type="hidden" value="@Model.codigo" />
                    <input id="unidade" name="unidade" type="hidden" value="@Model.codigoUnidade" />

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-primary">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.cliente</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("ClienteIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.unidade</label>
                                    <div>@Html.DisplayFor(model => model.unidade)</div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.cnpj</label>
                                    <div><input type="text" class="form-control" id="cnpj" name="cnpj" value="@Model.cnpj"></div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.inscricao_estadual</label>
                                    <div><input type="text" class="js-maxlength form-control" id="inscricaoEstadual" name="inscricaoEstadual" maxlength="20" value="@Model.inscricaoEstadual"></div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.inscricao_municipal</label>
                                    <div><input type="text" class="js-maxlength form-control" id="inscricaoMunicipal" name="inscricaoMunicipal" maxlength="20" value="@Model.inscricaoMunicipal "></div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.nome_fantasia</label>
                                    <div><input type="text" class="js-maxlength form-control" id="nomeFantasia" name="nomeFantasia" maxlength="120" value="@Model.nomeFantasia "></div>
                                </div>
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.razao_social</label>
                                    <div><input type="text" class="js-maxlength form-control" id="razaoSocial" name="razaoSocial" maxlength="120" value="@Model.razaoSocial"></div>
                                </div>
                            </div>

                            <div class="form-group row">
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.cep</label>
                                    <div><input type="text" class="form-control" id="cep" name="cep" value="@Model.cep" onblur="LoadCEP();"></div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.uf</label>
                                    <div>@Html.DropDownList("uf", null, "", new { @class = "form-control" })</div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.municipio</label>
                                    <div>@Html.DropDownList("municipio", null, "", new { @class = "form-control" })</div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.logradouro</label>
                                    <div><input type="text" class="js-maxlength form-control" id="logradouro" name="logradouro" maxlength="100" value="@Model.logradouro"></div>
                                </div>
                            </div>

                            <div class="form-group row">
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.numero</label>
                                    <div><input type="text" class="js-maxlength form-control" id="numero" name="numero" maxlength="60" value="@Model.numero"></div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.bairro</label>
                                    <div><input type="text" class="js-maxlength form-control" id="bairro" name="bairro" maxlength="100" value="@Model.bairro "></div>
                                </div>
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.complemento</label>
                                    <div><input type="text" class="js-maxlength form-control" id="complemento" name="complemento" maxlength="100" value="@Model.complemento"></div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.telefone</label>
                                    <div><input type="text" class="form-control" id="telefone" name="telefone" value="@Model.telefone "></div>
                                </div>
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.email</label>
                                    <div><input type="text" class="form-control" id="email" name="email" value="@Model.email" maxlength="100"></div>
                                </div>
                                <div class="col-md-2">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.ativo</label>
                                    <div class="col-12">
                                        <label class="css-control css-control-success css-switch">
                                            @Html.CheckBoxFor(model => model.ativo, new { @class = "css-control-input" })
                                            <span class="css-control-indicator"></span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    
<script>

        $(document).ready(function () { $("#cnpj").mask("99.999.999/9999-99"); });
        $(document).ready(function () { $("#cep").mask("99.999-999"); });
        $(document).ready(function () { $("#telefone").mask("(99) 99999-9999"); });

        jQuery.validator.addMethod("cnpj", function (cnpj, element) {

            cnpj = cnpj.replace(".", "");
            cnpj = cnpj.replace(".", "");
            cnpj = cnpj.replace("/", "");
            cnpj = cnpj.replace("-", "");

            var numeros, digitos, soma, resultado, pos, tamanho,
                digitos_iguais = true;

            if (cnpj.length < 14 && cnpj.length > 15)
                return false;

            for (var i = 0; i < cnpj.length - 1; i++)
                if (cnpj.charAt(i) != cnpj.charAt(i + 1)) {
                    digitos_iguais = false;
                    break;
                }

            if (!digitos_iguais) {
                tamanho = cnpj.length - 2
                numeros = cnpj.substring(0, tamanho);
                digitos = cnpj.substring(tamanho);
                soma = 0;
                pos = tamanho - 7;

                for (i = tamanho; i >= 1; i--) {
                    soma += numeros.charAt(tamanho - i) * pos--;
                    if (pos < 2)
                        pos = 9;
                }

                resultado = soma % 11 < 2 ? 0 : 11 - soma % 11;

                if (resultado != digitos.charAt(0))
                    return false;

                tamanho = tamanho + 1;
                numeros = cnpj.substring(0, tamanho);
                soma = 0;
                pos = tamanho - 7;

                for (i = tamanho; i >= 1; i--) {
                    soma += numeros.charAt(tamanho - i) * pos--;
                    if (pos < 2)
                        pos = 9;
                }

                resultado = soma % 11 < 2 ? 0 : 11 - soma % 11;

                if (resultado != digitos.charAt(1))
                    return false;

                return true;
            }

            return false;
        }, "Informe um CNPJ v&aacute;lido.");

        jQuery.validator.addMethod("cnpj_bd", function (value, element) {

            var unidade = ($("#unidade").val() == "") ? "-1" : $("#unidade").val();

            var dataString = {
                "cnpj": value,
                "codigo": @Model.codigo,
                "unidade": @Model.codigoUnidade
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaCliente",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "Informe um CNPJ v&aacute;lido.");

        $(function () {

            var uf = $("#uf");
            var municipio = $("#municipio");
            var unidade = $("#unidade");

            uf.change(function () {
                var request = { "uf": uf.val() };
                $.post("LoadMunicipio", request, function (obj) {
                    municipio.empty();
                    option = $("<option>", { "value": "" }).text("");
                    municipio.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        municipio.append(option);
                    });
                }, "json");
            });

        });

        function LoadCEP() {

            var cep = $('#cep').val();
            var cMunicipio = $('#municipio');

            if (cep != "") {
                $.ajax({
                    type: 'POST',
                    url: 'CEPInfo',
                    data: { "cep": cep },
                    success: function (dados) {
                        if (dados.length > 0) {
                            $.each(dados, function (i, obj) {
                                document.getElementById("uf").value = obj.uf;
                                document.getElementById("uf").readonly = true;
                                cMunicipio.empty();
                                option = $("<option>", { "value": obj.municipio }).text(obj.municipio);
                                cMunicipio.append(option);
                                cMunicipio.value = obj.codigo_municipio;
                                document.getElementById("municipio").readonly;
                                document.getElementById("logradouro").value = obj.logradouro;
                                document.getElementById("logradouro").readonly;
                                document.getElementById("bairro").value = obj.bairro;
                                document.getElementById("bairro").readonly = true;
                            })
                        }
                        else {
                            cep.value = "";
                            document.getElementById("uf").value = "";
                            document.getElementById("uf").readonly = false;
                            cMunicipio.value = "";
                            cMunicipio.readonly = false;
                            document.getElementById("logradouro").value = "";
                            document.getElementById("logradouro").readonly = false;
                            document.getElementById("bairro").value = "";
                            document.getElementById("bairro").readonly = false;
                        };
                    }
                });
            }
            else {
                document.getElementById("uf").value = "";
                document.getElementById("uf").readonly = false;
                cMunicipio.value = "";
                cMunicipio.readonly = false;
                document.getElementById("logradouro").value = "";
                document.getElementById("logradouro").readonly = false;
                document.getElementById("bairro").value = "";
                document.getElementById("bairro").readonly = false;
            }
        }

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'cnpj': {
                            required: true,
                            cnpj: true,
                            cnpj_bd: true,
                        },
                        'nome_fantasia': {
                            required: true
                        },
                        'razao_social': {
                            required: true
                        },
                        'email': {
                            email: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'cnpj': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            cnpj: '@PCM.WEB.Properties.Resources.valida_cnpj_invalido',
                            cnpj_bd: '@PCM.WEB.Properties.Resources.valida_cnpj_bd',
                        },
                        'nome_fantasia': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'razao_social': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'email': {
                            email: '@PCM.WEB.Properties.Resources.valida_email_valido'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['maxlength']);
        });

</script>

}
