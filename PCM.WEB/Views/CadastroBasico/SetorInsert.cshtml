@model List<PCM.WEB.MODELS.SetorLocal>

<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("SetorIndex", "CadastroBasico")">@PCM.WEB.Properties.Resources.setor</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.inserir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->
    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">
                @using (Html.BeginForm("SetorInsert", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="update" id="update" value="0" />

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.cadastrar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("SetorIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.descricao</label>
                                <div class="col-12"><input type="text" class="form-control" id="descricao" name="descricao" value="" maxlength="50"></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.observacao</label>
                                <div class="col-12"><textarea class="form-control" id="observacao" name="observacao" maxlength="2000"></textarea></div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-3">
                                    <label>@PCM.WEB.Properties.Resources.metragem</label>
                                    <div><input type="text" class="form-control" id="metragem" name="metragem" value="" maxlength="10"></div>
                                </div>

                                <div class="col-md-3">
                                    <label>@PCM.WEB.Properties.Resources.carga_termica</label>
                                    <div><input type="text" class="form-control" id="carga_termica" name="carga_termica" value="" maxlength="10"></div>
                                </div>
                                <div class="col-md-3">
                                    <label>@PCM.WEB.Properties.Resources.numero_pessoas_fixas</label>
                                    <div><input type="text" class="form-control" id="numero_pessoas_fixas" name="numero_pessoas_fixas" value="" maxlength="10"></div>
                                </div>
                                <div class="col-md-3">
                                    <label>@PCM.WEB.Properties.Resources.numero_pessoas_volantes</label>
                                    <div><input type="text" class="form-control" id="numero_pessoas_volantes" name="numero_pessoas_volantes" value="" maxlength="10"></div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-9">
                                    <label>@PCM.WEB.Properties.Resources.descricao_atividade</label>
                                    <div><input type="text" class="form-control" id="descricao_atividade" name="descricao_atividade" value="" maxlength="150"></div>
                                </div>
                                <div class="col-md-3">
                                    <label>@PCM.WEB.Properties.Resources.ativo</label>
                                    <div>
                                        <label class="css-control css-control-success css-switch">
                                            <input type="checkbox" class="css-control-input" id="ativo" name="ativo" checked value="true">
                                            <span class="css-control-indicator"></span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>


                    <div class="block block-rounded" id="registros" style="display:block">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.local</h3>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
                                <div class="col-md-8">
                                    <label>@PCM.WEB.Properties.Resources.local</label>
                                    <div class="input-group">
                                        <input type="text" class="form-control" style="text-transform: uppercase;" id="local" name="local" autocomplete="off" placeholder="" value="" onkeypress="if(event.keyCode == 13){event.preventDefault(); adicionarLocal(); return false; }">
                                        <div class="input-group-append">
                                            <button type="button" class="btn btn-square btn-secondary min-width-40 fa fa-plus mr-5" onclick="adicionarLocal();"></button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <table class="table table-bordered table-sm table-striped table-vcenter" id="table" name="table">
                                <thead>
                                    <tr class="table-secondary">
                                        <th>@PCM.WEB.Properties.Resources.local</th>
                                        <th class="text-center" style="width:80px" data-sortable="false"></th>
                                    </tr>
                                </thead>
                                <tbody id="table_linha" name="table_linha">
                                    @for (int i = 0; i < Model.Count; i++)
                                    {
                                        <tr id='linha' style="display:none">
                                            @Html.HiddenFor(m => m[i].local)
                                            @Html.HiddenFor(m => m[i].excluido)
                                            @Html.HiddenFor(m => m[i].codigo)
                                            <td id="text_@i">@Html.DisplayFor(m => m[i].local)</td>
                                            <td class="text-center">
                                                <div class="btn-group">
                                                    <a href="#" onclick="remove(this, ' + codigo + ');" class="btn btn-sm btn-secondary"><i class="fa fa-times"></i></a>
                                                    <a href="#" onclick="edit(this, @i);" class="btn btn-sm btn-secondary"><i class="fa fa-pencil"></i></a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>

                        </div>

                    </div>

                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")

    <script>
    
        var registros = [];
        var codigo = 1;

        $(document).ready(function () { $("#metragem").maskMoney({ prefix: '', thousands: '.', decimal: ",", precision: 2, allowNegative: false, 'placeholder': '' }); });
        $(document).ready(function () { $("#carga_termica").maskMoney({ prefix: '', thousands: '.', decimal: ",", precision: 2, allowNegative: false, 'placeholder': '' }); });
        $(document).ready(function () { $("#numero_pessoas_fixas").maskMoney({ prefix: '', thousands: '', decimal: ",", precision: 0, allowNegative: false, 'placeholder': '' }); });
        $(document).ready(function () { $("#numero_pessoas_volantes").maskMoney({ prefix: '', thousands: '', decimal: ",", precision: 0, allowNegative: false, 'placeholder': '' }); });
        
        function adicionarLocal() {

            var local = $("#local").val().toUpperCase().trim();

            if (local != "") {

                if (registros.indexOf(local) >= 0) {

                    //Alerta para o problema encontrado
                    document.getElementById("local").disabled = true;
                    swal({
                        title: 'Atenção',
                        text: 'Registro já inserido!',
                        type: 'error',
                        allowEscapeKey: false,
                        allowEnterKey: false
                    }).then(function (result) {
                        document.getElementById("local").disabled = false;
                        document.getElementById("local").value = "";
                        document.getElementById("local").focus();
                    });

                }
                else {
                    
                    id = $("#update").val();

                    if (parseInt(id) == 0) {

                        registros.push(local);

                        //Adiciona linha a Grid
                        var newRowItem = $("<tr id='linha'>");
                        var colsItem = "";
                        colsItem = '<input data-val="true" name="[' + codigo + '].local" type="hidden" value="' + local + '" />';
                        newRowItem.append(colsItem);
                        colsItem = '<input data-val="true" name="[' + codigo + '].excluido" type="hidden" value="0" />';
                        newRowItem.append(colsItem);
                        colsItem = '<input data-val="true" name="[' + codigo + '].codigo" type="hidden" value="0" />';
                        newRowItem.append(colsItem);
                        colsItem = '<td id="text_' + codigo + '">' + local + '</td>';
                        newRowItem.append(colsItem);
                        colsItem = '<td class="text-center"><div class="btn-group">';
                        colsItem += '<a href="#" onclick="remove(this, ' + codigo + ');" class="btn btn-sm btn-secondary"><i class="fa fa-times"></i></a>';
                        colsItem += '<a href="#" onclick="edit(this, ' + codigo + ');" class="btn btn-sm btn-secondary"><i class="fa fa-pencil"></i></a>';
                        colsItem += '</div></td>';
                        newRowItem.append(colsItem);
                        $("#table").append(newRowItem);

                        codigo = codigo + 1;
                    }
                    else {                        
                        registros[id] = local;
                        $("input[name$='[" + id + "].local']").val(local);
                        $("#text_" + id).html(local);
                    }

                    document.getElementById("local").value = "";
                    document.getElementById("local").focus();

                }
            }
        };

        function remove(item, id) {
            $("#update").val("0");
            $("#local").val("");
            var tr = $(item).closest('tr');
            tr.fadeOut(400, function () {
                tr.hide();                
                $("input[name$='[" + id + "].excluido']").val("1");
                delete registros[id];
            });
            return false;
        };
        
        function edit(item, id) {
            $("#local").val($("input[name$='[" + id + "].local']").val());
            $("#update").val(id);
            $("#local").focus();
        };

        jQuery.validator.addMethod("descricao_bd", function (value, element) {

            var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val() };

            var dataString = {
                "descricao": value,
                "codigo": -1,
                "unidade": unidade
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaSetor",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "");

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'descricao': {
                            required: true,
                            descricao_bd: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'descricao': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            descricao_bd: '@PCM.WEB.Properties.Resources.valida_descricao_bd'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['maxlength']);
        });

    </script>
}
