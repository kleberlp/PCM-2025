<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <span class="breadcrumb-item">@PCM.WEB.Properties.Resources.cadastro_basico</span>
                <a class="breadcrumb-item" href="@Url.Action("RotinaIndex", "CadastroBasico")">@PCM.WEB.Properties.Resources.rotina</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.inserir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">                
                @using (Html.BeginForm("RotinaInsert", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data", @name= "form", @id="form"  }))    
                {
                    @Html.AntiForgeryToken()

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.cadastrar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("RotinaIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@Html.DropDownList("unidade", null, "", new { @class = "js-select2 form-control" })</div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.categoria</label>
                                    <div>@Html.DropDownList("categoria", null, "", new { @class = "js-select2 form-control" })</div>
                                </div>
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.modulo</label>
                                    <div>@Html.DropDownList("modulo", null, "", new { @class = "js-select2 form-control" })</div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.setor</label>
                                    <div>@Html.DropDownList("setor", null, "", new { @class = "js-select2 form-control" })</div>
                                </div>
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.equipamento</label>
                                    <div>@Html.DropDownList("equipamento", null, "", new { @class = "js-select2 form-control" })</div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.descricao</label>
                                <div class="col-12"><textarea class="form-control" id="descricao" name="descricao" maxlength="500" rows="6"></textarea></div>
                            </div>
                            @if (Convert.ToBoolean(Session["rotina_prioridade"]))
                            {

                        <div class="form-group row">
                            <div class="col-md-3">
                                <label>@PCM.WEB.Properties.Resources.prioridade</label>
                                <div>@Html.DropDownList("prioridade", null, "", new { @class = "form-control js-select2" })</div>
                            </div>
                            <div class="col-md-2">
                                <label>@PCM.WEB.Properties.Resources.tempo_estimado</label>
                                <div><input type="text" class="form-control" id="tempo_estimado" name="tempo_estimado" maxlength="5"></div>
                            </div>
                        </div>
                                    }
                                    <div class="form-group row">
                                        <div class="col-md-3">
                                            <label>@PCM.WEB.Properties.Resources.tipo_servico</label>
                                            <div>@Html.DropDownList("tipo_servico", null, "", new { @class = "js-select2 form-control" })</div>
                                        </div>
                                        <div class="col-md-4">
                                            <label>@PCM.WEB.Properties.Resources.checklist</label>
                                            <div>@Html.DropDownList("checklist", null, "", new { @class = "form-control js-select2" })</div>
                                        </div>
                                        <div class="col-md-3">
                                            <label>@PCM.WEB.Properties.Resources.periodicidade</label>
                                            <div>@Html.DropDownList("periodicidade", null, "", new { @class = "form-control js-select2" })</div>
                                        </div>
                                        <div class="col-md-2">
                                            <label>@PCM.WEB.Properties.Resources.intervalo</label>
                                            <div><input type="text" class="form-control" id="intervalo" name="intervalo" maxlength="3"></div>
                                        </div>
                                    </div>

                                    <div class="block block-rounded border border text-center mb-15" id="div_diario" style="display:none">
                                        <div class="block-header block-header-default bg-secondary text-left">
                                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.dias_uteis</h3>
                                        </div>
                                        <div class="form-group row mt-15">
                                            <div class="col-md-1">
                                                <label>@PCM.WEB.Properties.Resources.segunda</label>
                                                <div>
                                                    <label class="css-control css-control-success css-checkbox">
                                                        <input type="checkbox" class="css-control-input" id="segunda" name="segunda" checked value="true">
                                                        <span class="css-control-indicator"></span>
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-md-1">
                                                <label>@PCM.WEB.Properties.Resources.terca</label>
                                                <div>
                                                    <label class="css-control css-control-success css-checkbox">
                                                        <input type="checkbox" class="css-control-input" id="terca" name="terca" checked value="true">
                                                        <span class="css-control-indicator"></span>
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-md-1">
                                                <label>@PCM.WEB.Properties.Resources.quarta</label>
                                                <div>
                                                    <label class="css-control css-control-success css-checkbox">
                                                        <input type="checkbox" class="css-control-input" id="quarta" name="quarta" checked value="true">
                                                        <span class="css-control-indicator"></span>
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-md-1">
                                                <label>@PCM.WEB.Properties.Resources.quinta</label>
                                                <div>
                                                    <label class="css-control css-control-success css-checkbox">
                                                        <input type="checkbox" class="css-control-input" id="quinta" name="quinta" checked value="true">
                                                        <span class="css-control-indicator"></span>
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-md-1">
                                                <label>@PCM.WEB.Properties.Resources.sexta</label>
                                                <div>
                                                    <label class="css-control css-control-success css-checkbox">
                                                        <input type="checkbox" class="css-control-input" id="sexta" name="sexta" checked value="true">
                                                        <span class="css-control-indicator"></span>
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-md-1">
                                                <label>@PCM.WEB.Properties.Resources.sabado</label>
                                                <div>
                                                    <label class="css-control css-control-success css-checkbox">
                                                        <input type="checkbox" class="css-control-input" id="sabado" name="sabado" checked value="true">
                                                        <span class="css-control-indicator"></span>
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-md-1">
                                                <label>@PCM.WEB.Properties.Resources.domingo</label>
                                                <div>
                                                    <label class="css-control css-control-success css-checkbox">
                                                        <input type="checkbox" class="css-control-input" id="domingo" name="domingo" checked value="true">
                                                        <span class="css-control-indicator"></span>
                                                    </label>
                                                </div>
                                            </div>

                                        </div>
                                    </div>

                                    <div class="form-group row">
                                        <div class="col-md-2">
                                            <label>@PCM.WEB.Properties.Resources.ativo</label>
                                            <div>
                                                <label class="css-control css-control-success css-switch">
                                                    <input type="checkbox" class="css-control-input" id="ativo" name="ativo" checked value="true">
                                                    <span class="css-control-indicator"></span>
                                                </label>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>   
                }
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->

</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")
        
<script>

        var codigo = 1;

        $(document).ready(function () {
            $("#valor_previsto").maskMoney({ decimal: ",", thousands: "." });
            $("#quantidade_equipamento").maskMoney({ prefix: '', thousands: '.', precision: 0, allowNegative: false, 'placeholder': '' });
            $("#intervalo").maskMoney({ thousands: ".", precision: 0, allowNegative: false });
            $("#tempo_estimado").maskMoney({ prefix: '', thousands: '.', precision: 2, decimal: ",", allowNegative: false, 'placeholder': '' });
        });

        var change_equipamento = false;

        $(function () {

            var unidade = $("#unidade");
            var categoria = $("#categoria");
            var setor = $("#setor");
            var equipamento = $("#equipamento");
            var periodicidade = $("#periodicidade");
            var intervalo = $("#intervalo");

            unidade.change(function () {
                var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val() };

                $.post("LoadCategoria", request, function (obj) {
                    categoria.empty();
                    option = $("<option>", { "value": "" }).text("");
                    categoria.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        categoria.append(option);
                    });
                }, "json");

                $.post("LoadSetor", request, function (obj) {
                    setor.empty();
                    option = $("<option>", { "value": "" }).text("");
                    setor.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        setor.append(option);
                    });
                }, "json");

            });

            setor.change(function () {
                var request = { "unidade": unidade.val(), "setor": (setor.val() == "") ? "-1" : setor.val() };
                $.post("LoadEquipamentoSetor", request, function (obj) {
                    if (change_equipamento == false) {
                        equipamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        equipamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            equipamento.append(option);
                        })
                    }
                    change_equipamento = false;
                }, "json");
            });

            periodicidade.change(function () {
                if (periodicidade.val() == 1 && intervalo.val() == "1") {
                    $("#div_diario").show();
                } else {
                    $("#div_diario").hide();
                }
            });

            intervalo.change(function () {
                if (periodicidade.val() == 1 && intervalo.val() == "1") {
                    $("#div_diario").show();
                } else {
                    $("#div_diario").hide();
                }
            });

        });

        jQuery.validator.addMethod("checklist", function (value, element) {

            if ($("#periodicidade").val() == "0") {
                if (value == "") {
                    return false
                } else {
                    return true
                }
            } else {
                return true
            }

        }, "");

        jQuery.validator.addMethod("intervalo", function (value, element) {

            if ($("#periodicidade").val() != "0") {
                if (value == "") {
                    return false
                } else {
                    return true
                }
            } else {
                return true
            }

        }, "");

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'categoria': {
                            required: true
                        },
                        'modulo': {
                            required: true
                        },
                        'setor': {
                            required: false
                        },
                        'descricao': {
                            required: true
                        },
                        'periodicidade': {
                            required: true
                        },
                        'intervalo': {
                            required: true
                        },
                        'tipo_servico': {
                            required: true
                        },
                        'prioridade': {
                            required: ("@Session["rotina_prioridade"]" == "True")? true: false
                        },
                        'tempo_estimado': {
                            required: ("@Session["rotina_prioridade"]" == "True")? true: false
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'categoria': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'modulo': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'setor': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'descricao': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'periodicidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'intervalo': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'tipo_servico': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'prioridade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'tempo_estimado': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
        });

</script>

}
