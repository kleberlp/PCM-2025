
<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-md-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("AtividadeIndex", "CadastroBasico")">@PCM.WEB.Properties.Resources.atividade</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.inserir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">                
                @using (Html.BeginForm("AtividadeInsert", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.cadastrar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("AtividadeIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full"> 
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@Html.DropDownList("unidade", null, "", new { @class = "js-select2 form-control" })</div>
                            </div>   
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.categoria</label>
                                <div class="col-12">@Html.DropDownList("categoria", null, "", new { @class = "js-select2 form-control" })</div>
                            </div>           
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.itens_gerais</label>
                                <div class="col-12">@Html.DropDownList("equipamento", null, "", new { @class = "js-select2 form-control" })</div>
                            </div>                           
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.titulo</label>
                                <div class="col-12"><input type="text" class="form-control" id="titulo" name="titulo" value="" maxlength="200"></div>
                            </div>             
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.descricao</label>
                                <div class="col-12"><textarea class="form-control" id="descricao" name="descricao" maxlength="500" rows="6" ></textarea></div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.data_previsao_termino</label>
                                    <div><input type="text" class="js-datepicker form-control" id="data_previsao_termino" name="data_previsao_termino" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder=""></div>
                                </div>
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.tipo_servico</label>
                                    <div>@Html.DropDownList("tipo_servico", null, "", new { @class = "js-select2 form-control" })</div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.bloco</label>
                                    <div>@Html.DropDownList("bloco", null, "", new { @class = "js-select2 form-control", @multiple="multiple" })</div>
                                </div>
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.andar</label>
                                    <div>@Html.DropDownList("andar", null, "", new { @class = "js-select2 form-control", @multiple="multiple" })</div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.ativo</label>
                                <div class="col-12">
                                    <label class="css-control css-control-success css-switch">
                                        <input type="checkbox" class="css-control-input" id="ativo" name="ativo" checked value ="true">
                                        <span class="css-control-indicator"></span>
                                    </label>
                                </div>
                            </div>
                        </div>                        
                    </div>   
                }
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
        </div>
        <!-- END Page Content -->
    </div>
</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")
        
    <script>

        $(function () {

            $.ajaxSetup({ async: false });

            var unidade = $("#unidade");
            var categoria = $("#categoria");
            var equipamento = $("#equipamento");
            var bloco = $("#bloco");
            var andar = $("#andar");

            unidade.change(function () {

                var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val() };

                $.post("LoadCategoria", request, function (obj) {
                    categoria.empty();
                    option = $("<option>", { "value": "" }).text("");
                    categoria.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        categoria.append(option);
                    });
                }, "json");

                $.post("LoadItensGerais", request, function (obj) {
                    equipamento.empty();
                    option = $("<option>", { "value": "" }).text("");
                    equipamento.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        equipamento.append(option);
                    });
                }, "json");

                $.post("LoadBlocoApartamento", request, function (obj) {
                    bloco.empty();
                    option = $("<option>", { "value": "" }).text("");
                    bloco.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        bloco.append(option);
                    });
                }, "json");

                $.post("LoadAndarApartamento", request, function (obj) {
                    andar.empty();
                    option = $("<option>", { "value": "" }).text("");
                    andar.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        andar.append(option);
                    });
                }, "json");

            });

            bloco.change(function () {

                var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val(), "bloco": (bloco.val().toString() == "") ? "": bloco.val().toString() };

                $.post("LoadAndarApartamento", request, function (obj) {
                    andar.empty();
                    option = $("<option>", { "value": "" }).text("");
                    andar.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        andar.append(option);
                    });
                }, "json");

            });

        });

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'categoria': {
                            required: true
                        },
                        'titulo': {
                            required: true
                        },
                        'descricao': {
                            required: true
                        },
                        'data_previsao_termino': {
                            required: true
                        },
                        'tipo_servico': {
                            required: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'categoria': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'setor': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'titulo': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'descricao': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'data_previsao_termino': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'tipo_servico': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
        });

    </script>

}
