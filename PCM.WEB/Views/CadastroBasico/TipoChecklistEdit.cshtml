@model List<PCM.WEB.MODELS.TipoChecklistItem>

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("TipoChecklistIndex", "CadastroBasico")">@PCM.WEB.Properties.Resources.perfil</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.editar</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">           
                @using (Html.BeginForm("TipoChecklistEdit", "CadastroBasico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()
                    
                    <input type="hidden" id="codigo" name="codigo" value="@ViewBag.tipo_checklist.codigo">
                    <input type="hidden" id="unidade" name="unidade" value="@ViewBag.tipo_checklist.codigo_unidade">

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.editar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("TipoChecklistIndex", "CadastroBasico")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">                        
                            <div class="form-group row">
                                <label class="col-12" for="unidade">@PCM.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@ViewBag.tipo_checklist.unidade</div>
                            </div>             
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.descricao</label>
                                <div class="col-12"><input type="text" class="form-control" id="descricao" name="descricao" value="@ViewBag.tipo_checklist.descricao" maxlength="50"></div>
                            </div>
                            <div class="form-group row">
                            <label class="col-12">@PCM.WEB.Properties.Resources.ativo</label>
                            <div class="col-12">
                                <label class="css-control css-control-success css-switch">
                                    <input type="checkbox" class="css-control-input" id="ativo" name="ativo" checked value ="@ViewBag.tipo_checklist.ativo">
                                    <span class="css-control-indicator"></span>
                                </label>
                            </div>
                        </div>
                        </div>                        
                    </div>

                    <!-- Dynamic Table Full Pagination -->
                    <div class="block">
                        <div class="block-content block-content-full">
                            <!-- DataTables init on table by adding .js-dataTable-full-pagination class, functionality initialized in js/pages/be_tables_datatables.js -->
                            <table class="table table-sm table-bordered table-striped table-vcenter js-dataTable-full-pagination">
                                <thead>
                                    <tr class="table-secondary">
                                        <th class="text-center" style="width:100px">X</th>
                                        <th class="text-center" style="width:100px">@PCM.WEB.Properties.Resources.codigo</th>
                                        <th>@PCM.WEB.Properties.Resources.descricao </th>
                                    </tr>
                                </thead>

                                <tbody>         
                                @for (int i = 0; i < Model.Count; i++)
                                    {
                                        @Html.HiddenFor(m => m[i].codigo)
                                        <tr>          
                                            <td class="text-center" style="width:100px">
                                                <label class="css-control css-control-success css-checkbox">
                                                    @Html.CheckBoxFor(m => m[i].selecionado, new { @class = "css-control-input"})
                                                    <span class="css-control-indicator"></span>                    
                                                </label>
                                             </td>
                                            <td class="text-center">@Html.DisplayFor(m => m[i].codigo_checklist)</td>               
                                            <td>@Html.DisplayFor(m => m[i].checklist)</td>                                            
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <!-- END Dynamic Table Full Pagination -->

                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    
    <script>

        jQuery.validator.addMethod("descricao_bd", function (value, element) {

            var codigo = $("#codigo").val();
            var unidade = $("#unidade").val();
            
            var dataString = {
                "descricao": value,
                "codigo": codigo,
                "unidade": (unidade == "") ? "-1" : unidade
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaTipoChecklist",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "");

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'descricao': {
                            required: true,
                            descricao_bd: true
                        }
                    },
                    messages: {
                        'descricao': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            descricao_bd: '@PCM.WEB.Properties.Resources.valida_descricao_bd'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['maxlength']);
        });

    </script>

}