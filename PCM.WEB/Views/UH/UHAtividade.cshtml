@model IEnumerable<PCM.WEB.MODELS.UHAtividadeBloco>

<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b d-print-none">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item">@PCM.WEB.Properties.Resources.uh_em_dia</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.atividade</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        @using (Html.BeginForm("UHAtividade", "UH", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", @name = "form", @id = "form" }))
        {
            @Html.AntiForgeryToken()

            <div class="col-md-12 col-xl-12">
                <!-- Toggle Tasks Navigation on mobile -->
                <button type="button" class="btn btn-block btn-square btn-primary d-md-none mb-10" data-toggle="class-toggle" data-target=".js-tasks-nav" data-class="d-none d-md-block">@PCM.WEB.Properties.Resources.filtros</button>

                <!-- Collapsible Tasks Navigation -->
                <div class="js-tasks-nav d-none d-md-block">
                    <!-- Tasks Info -->
                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.filtro</h3>
                        </div>
                        <div class="block-content">
                            <ul class="list-group push">
                                <li class="list-group-item">
                                    <div class="row">
                                        <div class="col-md-5">@Html.DropDownList("unidade", null, PCM.WEB.Properties.Resources.unidade, new { @class = "js-select2 form-control" })</div>
                                    </div>
                                </li>
                                <li class="list-group-item">
                                    <div class="row">
                                        <div class="col-md-5">@Html.DropDownList("atividade", null, PCM.WEB.Properties.Resources.atividade, new { @class = "js-select2 form-control" })</div>
                                        <div class="col-md-3">@Html.DropDownList("apartamento", null, PCM.WEB.Properties.Resources.apartamento, new { @class = "js-select2 form-control" })</div>
                                        <div class="col-md-2">@Html.DropDownList("status", null, PCM.WEB.Properties.Resources.status, new { @class = "js-select2 form-control" })</div>
                                        <div class="col-md-2">@Html.DropDownList("status_uh", null, PCM.WEB.Properties.Resources.status_uh, new { @class = "js-select2 form-control" })</div>
                                    </div>
                                </li>
                                <li class="list-group-item text-right">
                                    <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75" name="filtrar" id="filtrar"><i class="si si-magnifier mr-5"></i>@PCM.WEB.Properties.Resources.filtrar</button>
                                </li>
                            </ul>
                        </div>
                    </div>
                    <!-- END Tasks Info -->
                </div>
                <!-- END Collapsible Tasks Navigation -->

                <div class="row">
                    <div class="col-4 col-sm-12 col-md-4 col-xl-4">
                        <a class="block block-rounded block-bordered block-link-shadow" onclick="$('#status').select2('val', '3'); $('#form').submit()">
                            <div class="block-content block-content-full clearfix">
                                <div class="float-right mt-15 d-none d-sm-block"><i class="fa fa-hotel fa-2x text-pulse"></i></div>
                                <div class="font-size-h5 font-w600 text-pulse" data-speed="1000" data-to="@ViewBag.quantidade_atrasado" id="quantidade_atrasado" name="quantidade_atrasado">@ViewBag.quantidade_atrasado</div>
                                <div class="font-size-sm font-w600 text-uppercase text-muted">@PCM.WEB.Properties.Resources.atrasado</div>
                            </div>
                        </a>
                    </div>
                    <div class="col-4 col-sm-12 col-md-4 col-xl-4">
                        <a class="block block-rounded block-bordered block-link-shadow" onclick="$('#status').select2('val', '1'); $('#form').submit()">
                            <div class="block-content block-content-full clearfix">
                                <div class="float-right mt-15 d-none d-sm-block"><i class="fa fa-hotel fa-2x text-warning"></i></div>
                                <div class="font-size-h5 font-w600 text-warning" data-speed="1000" data-to="@ViewBag.quantidade_pendente" id="quantidade_pendente" name="quantidade_pendente">@ViewBag.quantidade_pendente</div>
                                <div class="font-size-sm font-w600 text-uppercase text-muted">@PCM.WEB.Properties.Resources.pendente</div>
                            </div>
                        </a>
                    </div>
                    <div class="col-4 col-sm-12 col-md-4 col-xl-4">
                        <a class="block block-rounded block-bordered block-link-shadow" onclick="$('#status').select2('val', '2'); $('#form').submit()">
                            <div class="block-content block-content-full clearfix">
                                <div class="float-right mt-15 d-none d-sm-block"><i class="fa fa-hotel fa-2x text-earth-light"></i></div>
                                <div class="font-size-h5 font-w600 text-earth"><span data-speed="1000" data-to="@ViewBag.quantidade_realizada" id="quantidade_realizada" name="quantidade_realizada">@ViewBag.quantidade_realizada</span></div>
                                <div class="font-size-sm font-w600 text-uppercase text-muted">@PCM.WEB.Properties.Resources.concluido</div>
                            </div>
                        </a>
                    </div>
                </div>

                <div class="block">


                    <div class="block-header block-header-default bg-gd-default">
                        <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.atividade - @ViewBag.lastUpdate</h3>
                        <div class="block-options">
                            <button type="button" class="si si-grid btn-block-option text-white" onclick="$('#div_grid').show(); $('#div_list').hide()"></button>
                            <button type="button" class="si si-list btn-block-option text-white" onclick="$('#div_list').show(); $('#div_grid').hide()"></button>
                            <button type="button" class="si si-printer btn-block-option text-white" onclick="Codebase.helpers('print-page');"></button>
                            <button type="button" class="btn-block-option text-white" data-toggle="block-option" data-action="fullscreen_toggle"></button>
                        </div>
                    </div>


                    <div class="block-content block-content-full" id="div_grid">

                        @foreach (var bloco in Model)
                        {
                            <div class="content-block"><b>@PCM.WEB.Properties.Resources.bloco:</b> @Html.DisplayFor(modelItem => bloco.descricao)</div>

                            foreach (var andar in bloco.andar)
                            {
                                <hr />
                                <div class="content-block"><b>@PCM.WEB.Properties.Resources.andar:</b> @Html.DisplayFor(modelItem => andar.descricao)</div>
                                <hr />

                                <div class="row">
                                    @foreach (var uh in andar.uh)
                                    {
                                        if (uh.status == 2)
                                        {
                                            <div class="col-md-2 col-xl-1">
                                                <a class="block block-rounded block-bordered block-link-shadow" href="@Url.Action("UHAtividadeApontamentoExcluir", "UH", new { codigo_apartamento = @uh.codigo_apartamento, codigo_unidade = @uh.codigo_unidade, codigo_atividade = @uh.codigo_atividade, color = @uh.color, status = @uh.status })">
                                                    <div class="text-center">
                                                        <i class="fa fa-hotel fa-2x @uh.color"></i>
                                                        <h6 class="font-w700 mb-5">@uh.apartamento</h6>
                                                        <h6 class="mb-5 font-w600"><small class="font-w600 text-danger">@uh.room_status</small></h6>
                                                    </div>
                                                </a>
                                            </div>

                                        }
                                        else
                                        {
                                            <div class="col-md-2 col-xl-1">
                                                <a class="block block-rounded block-bordered block-link-shadow" href="@Url.Action("UHAtividadeApontamento", "UH", new { codigo_apartamento = @uh.codigo_apartamento, codigo_unidade = @uh.codigo_unidade, codigo_atividade = @uh.codigo_atividade, color = @uh.color, status = @uh.status })">
                                                    <div class="text-center">
                                                        <i class="fa fa-hotel fa-2x @uh.color"></i>
                                                        <h6 class="font-w700 mb-5">@uh.apartamento</h6>
                                                        <h6 class="mb-5 font-w600"><small class="font-w600 text-danger">@uh.room_status</small></h6>
                                                    </div>
                                                </a>
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        }
                    </div>



                    <div class="col-md-12 col-xl-12" id="div_list" style="display:none">

                        <div class="block-content block-content-full">

                            <table class="table table-vcenter table-sm table-bordered table-hover js-dataTable-list">
                                <thead class="thead-pcm">
                                    <tr>
                                        <th class="text-center">@PCM.WEB.Properties.Resources.bloco</th>
                                        <th class="text-center">@PCM.WEB.Properties.Resources.andar</th>
                                        <th class="text-center">@PCM.WEB.Properties.Resources.apartamento</th>
                                        <th class="text-center">@PCM.WEB.Properties.Resources.status</th>
                                        <th class="text-center">@PCM.WEB.Properties.Resources.status_uh</th>
                                        <th data-sortable="false" class="text-center d-print-none" style="width: 80px;"></th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        foreach (var andar in item.andar)
                                        {

                                            foreach (var uh in andar.uh)
                                            {
                                    <tr>
                                        <td class="text-center">@Html.DisplayFor(modelItem => item.descricao)</td>
                                        <td class="text-center">@Html.DisplayFor(modelItem => andar.descricao)</td>
                                        <td class="text-center">@Html.DisplayFor(modelItem => uh.apartamento)</td>
                                        <td class="text-center"><span class="badge @uh.color.ToString().Replace("text", "bg")">@Html.DisplayFor(modelItem => uh.descricao_status)</span></td>
                                        <td class="text-center">@Html.DisplayFor(modelItem => uh.room_status)</td>
                                        <td class="text-center d-print-none" style="width: 80px;">
                                            <div class="btn-group">
                                                @if (uh.status == 2)
                                                {
                                                    <a href="@Url.Action("UHAtividadeApontamentoExcluir", "UH", new { codigo_apartamento = @uh.codigo_apartamento, codigo_unidade = @uh.codigo_unidade, codigo_atividade = @uh.codigo_atividade, color = @uh.color, status = @uh.status })" class="btn btn-sm btn-secondary"><i class="fa fa-hotel"></i></a>
                                                }
                                                else
                                                {
                                                    <a href="@Url.Action("UHAtividadeApontamento", "UH", new { codigo_apartamento = @uh.codigo_apartamento, codigo_unidade = @uh.codigo_unidade, codigo_atividade = @uh.codigo_atividade, color = @uh.color, status = @uh.status })" class="btn btn-sm btn-secondary"><i class="fa fa-hotel"></i></a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                            }
                                        }
                                    }

                                </tbody>
                            </table>
                        </div>

                    </div>


                </div>

            </div>

        }

    </div>
    <!-- END Page Content -->

</main>
<!-- END Main Container -->


@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/dataTables")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")

    <script type="text/javascript">

        $.ajaxSetup({ async: false });

        $(function () {

            var unidade = $("#unidade");
            var atividade = $("#atividade");
            var apartamento = $("#apartamento");
            var status = $("#status");

            unidade.select2({placeholder: '@PCM.WEB.Properties.Resources.unidade', allowClear: true});
            atividade.select2({placeholder: 'Mapa de Manutenção', allowClear: true});
            apartamento.select2({placeholder: '@PCM.WEB.Properties.Resources.apartamento', allowClear: true});
            status.select2({placeholder: '@PCM.WEB.Properties.Resources.status', allowClear: true});

            if (unidade.val() == "" || unidade.val() == "-1") {                    
                atividade.prop( "disabled", true );
                apartamento.prop( "disabled", true );
                atividade.select2({ placeholder: 'Mapa de Manutenção', allowClear: true });
                apartamento.select2({placeholder: '@PCM.WEB.Properties.Resources.apartamento', allowClear: true});               
            }

            unidade.change(function () {

                if (unidade.val() == "") {
                    
                    atividade.empty();
                    apartamento.empty();
                    atividade.prop( "disabled", true );
                    apartamento.prop( "disabled", true );
                    atividade.select2({ placeholder: 'Mapa de Manutenção', allowClear: true });
                    apartamento.select2({placeholder: '@PCM.WEB.Properties.Resources.apartamento', allowClear: true});

                } else {

                    var request = { "unidade": unidade.val() };

                    $.post("LoadAtividade", request, function (obj) {
                        atividade.empty();
                        option = $("<option>", { "value": "" }).text("");
                        atividade.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            atividade.append(option);
                        });
                    }, "json");

                    $.post("LoadApartamento", request, function (obj) {
                        apartamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        apartamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            apartamento.append(option);
                        });
                    }, "json");

                    atividade.prop( "disabled", false );
                    apartamento.prop( "disabled", false );                    
                    atividade.select2({ placeholder: 'Mapa de Manutenção', allowClear: true });
                    apartamento.select2({placeholder: '@PCM.WEB.Properties.Resources.apartamento',allowClear: true});
                }

            });

            atividade.change(function () {

                if (atividade.val() == "") {

                    var request = { "unidade": unidade.val()};

                    $.post("LoadApartamento", request, function (obj) {
                        apartamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        apartamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            apartamento.append(option);
                        });
                    }, "json");                    

                }

                else {

                    var request = { "unidade": unidade.val(), "atividade": atividade.val() };

                    $.post("LoadApartamentoAtividade", request, function (obj) {
                        atividade.empty();
                        option = $("<option>", { "value": "" }).text("");
                        atividade.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            atividade.append(option);
                        });
                    }, "json");

                }

                atividade.prop( "disabled", false );
                apartamento.select2({placeholder: '@PCM.WEB.Properties.Resources.apartamento' ,allowClear: true});

            });

        });

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('#form').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.row > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.row').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.row').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'atividade': {
                            required: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'atividade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();


        var BeTableDatatables = function () {
            // Override a few DataTable defaults, for more examples you can check out https://www.datatables.net/
            var exDataTable = function () {
                jQuery.extend(jQuery.fn.dataTable.ext.classes, {
                    sWrapper: "dataTables_wrapper dt-bootstrap4"
                });
            };

            // Init simple DataTable, for more examples you can check out https://www.datatables.net/
            var initDataTableSimple = function () {
                jQuery('.js-dataTable-list').dataTable({
                    fixedHeader: false,
                    searching: true,
                    lengthChange: false,
                    pageLength: 15,
                    autoWidth: true,
                    dom: 'Bfrtip',
                    buttons: [
                        { extend: 'copy', text: 'Copiar' },
                        {
                            extend: 'print',

                            text: 'Imprimir'
                        },
                        { extend: 'excel' },
                        { extend: 'pdf', orientation: 'landscape' },
                    ],
                    language: {
                        "search": "Procurar:",
                        "lengthMenu": "Exibir _MENU_ ",
                        "zeroRecords": "Nenhum Registro Encontrado",
                        "info": "_MAX_ registro(s)",
                        "infoEmpty": "Nenhum Registro encontrado",
                        "infoFiltered": "(filtrado de _MAX_ registro(s))"
                    }
                });
            };

            return {
                init: function () {
                    // Override a few DataTable defaults
                    exDataTable();

                    // Init Datatables
                    initDataTableSimple();
                }
            };
        }();


        // Initialize when page loads
        jQuery(function () {
            $.fn.dataTable.moment('DD/MM/YYYY HH:mm'); BeTableDatatables.init(); 
            FormValidation.init();
            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
        });

    </script>
}
