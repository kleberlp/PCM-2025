<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item">@PCM.WEB.Properties.Resources.uh</a>
                <span class="breadcrumb-item" href="@Url.Action("Dedetizacao", "UH")">@PCM.WEB.Properties.Resources.dedetizacao</span>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.apontamento</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">
                @using (Html.BeginForm("DedetizacaoApontamento", "UH", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="codigo_uh_atividade" id="codigo_uh_atividade" value="@ViewBag.apontamento.codigo_uh_atividade">
                    <input type="hidden" name="codigo_unidade" id="codigo_unidade" value="@ViewBag.apontamento.codigo_unidade">
                    <input type="hidden" name="codigo_tipo_servico" id="codigo_tipo_servico" value="@ViewBag.apontamento.codigo_tipo_servico">
                    <input type="hidden" name="codigo_apartamento" id="codigo_apartamento" value="@ViewBag.apontamento.codigo_apartamento">
                    <input type="hidden" name="codigo" id="codigo" value="@ViewBag.apontamento.codigo">

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.apontamento_atividade</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("Dedetizacao", "UH")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
                                <div class="col-md-2 col-xl-1">
                                    <a class="block block-rounded block-bordered block-link-shadow">
                                        <div class="text-center">
                                            <i class="@Html.Raw(ViewBag.apontamento.icon) @ViewBag.color mt-10"></i>
                                            <h6 class="font-w700 mb-10">@ViewBag.apontamento.uh_local</h6>
                                        </div>
                                    </a>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-12"><strong>@PCM.WEB.Properties.Resources.unidade: </strong>@ViewBag.apontamento.unidade</div>
                            </div>
                            <div class="form-group row">
                                <div class="col-12"><strong>@PCM.WEB.Properties.Resources.descricao: </strong>@ViewBag.apontamento.descricao</div>
                            </div>
                            <hr></hr>
                            <div class="form-group row" id="div_funcionario">
                                <label class="col-12">@PCM.WEB.Properties.Resources.funcionario</label>
                                <div class="col-12">@Html.DropDownList("funcionario", null, "", new { @class = "form-control js-select2", @multiple = "multiple" })</div>
                            </div>
                            <div class="form-group row" id="div_fornecedor">
                                <label class="col-12">@PCM.WEB.Properties.Resources.fornecedor</label>
                                <div class="col-12">@Html.DropDownList("fornecedor", null, "", new { @class = "form-control js-select2" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.observacao</label>
                                <div class="col-12"><textarea class="form-control" id="observacao" name="observacao" maxlength="500" rows="6" value="">@ViewBag.apontamento.observacao</textarea></div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.data</label>
                                    <div><input type="text" class="js-datepicker form-control" id="data" name="data" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value="@ViewBag.apontamento.data"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                }
                <!-- END Basic Info -->
            </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/clockpicker")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/clockpicker")
    @Scripts.Render("~/plugins/select")

    <script>

        $(document).ready(function () { $("#data").mask("99/99/9999"); });
                
        function verificaTipoServico() {

            var funcionario = $("#div_funcionario");
            var fornecedor = $("#div_fornecedor");

            var codigo_tipo_servico = $("#codigo_tipo_servico").val();
            if (codigo_tipo_servico == 1) {
                fornecedor.hide();
                funcionario.show();
            }
            else if (codigo_tipo_servico == 2) {
                fornecedor.show();
                funcionario.hide();
            }
        }

        jQuery.validator.addMethod("funcionario", function (funcionario, element) {

            var tipo = $("#codigo_tipo_servico").val();
            var funcionario = $("#funcionario").val();
            if (tipo == 1) {
                if(funcionario != "")
                    return true;
                else
                    return false;
            }
            else if (tipo == 2) {
                return true;
            }
        }, '@PCM.WEB.Properties.Resources.campo_requerido');

        jQuery.validator.addMethod("fornecedor", function (funcionario, element) {

            var tipo = $("#codigo_tipo_servico").val();
            var fornecedor = $("#fornecedor").val();
            if (tipo == 2) {
                if (fornecedor != "")
                    return true;
                else
                    return false;
            }
            else if (tipo == 1) {
                return true;
            }
        }, '@PCM.WEB.Properties.Resources.campo_requerido');

        jQuery.validator.addMethod("maxDate", function (value, element) {

            var curDate = new Date();
            curDate.setHours(0, 0, 0, 0);
            var from = value.split("/");
            var inputDate = new Date(from[2], from[1] - 1, from[0]);
            if (inputDate > curDate) {
                return this.optional(element) || false;
            }
            else {
                return this.optional(element) || true;
            }

        }, '');

        jQuery.validator.addMethod("minDate", function (value, element) {

            var curDate = new Date();
            curDate.setDate(curDate.getDate() - 2);
            curDate.setHours(0, 0, 0, 0);
            var from = value.split("/");
            var inputDate = new Date(from[2], from[1] - 1, from[0]);
            if (inputDate > curDate) {
                return this.optional(element) || true;
            }
            else {
                return this.optional(element) || false;
            }
        }, '');

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'funcionario': {
                            funcionario: true
                        },
                        'fornecedor': {
                            fornecedor: true
                        },
                        'data': {
                            required: true,
                            minDate:  ('@ViewBag.administrador' == 'True')? false: true,
                            maxDate: { maxDate: true }
                        }
                    },
                    messages: {
                        'funcionario': {
                            funcionario: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'fornecedor': {
                            fornecedor: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'data_inicio': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            minDate: '@PCM.WEB.Properties.Resources.data_menor_permitida',
                            maxDate: '@PCM.WEB.Properties.Resources.data_maior_corrente'
                        }
                    }
                });
            };
        
            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            verificaTipoServico();
            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
        });

    </script>
}
