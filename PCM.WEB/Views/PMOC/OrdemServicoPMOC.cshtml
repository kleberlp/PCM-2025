@model List<PCM.WEB.MODELS.PMOCOrdemServicoChecklist>

<script>

    function setResultado(id, value) {
        $("input[name$='[" + id + "].resultado']").val(value);
    };

</script>

<!-- Main Container -->
<main id="main-container">
    <main id="main-container">

        <!-- Breadcrumb -->
        <div class="bg-body-light border-b">
            <div class="content py-0 text-center">
                <nav class="breadcrumb bg-body-light mb-0">
                    <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                    <a class="breadcrumb-item" href="@Url.Action(@ViewBag.view, "PMOC")">@PCM.WEB.Properties.Resources.pmoc</a>
                    <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.salvar</span>
                </nav>
            </div>
        </div>
        <!-- END Breadcrumb -->
        <!-- Page Content -->
        <div class="content">

            @using (Html.BeginForm("OrdemServicoPMOC", "PMOC", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()

                <div class="row gutters-tiny">
                    <!-- Basic Info -->
                    <div class="col-md-12">

                        <input type="hidden" name="codigo_pmoc_ordem_servico" id="codigo_pmoc_ordem_servico" value="@ViewBag.ordem_servico.codigo_pmoc_ordem_servico">
                        <input type="hidden" name="codigo_equipamento" id="codigo_equipamento" value="@ViewBag.ordem_servico.codigo_equipamento">
                        <input type="hidden" name="codigo_unidade" id="codigo_unidade" value="@ViewBag.ordem_servico.codigo_unidade">
                        <input type="hidden" name="view" id="view" value="@ViewBag.view">

                        <div class="block block-rounded border">
                            <div class="block-header block-header-default bg-gd-default">
                                <h3 class="block-title text-white font-w600">@ViewBag.resource_name</h3>
                                <div class="block-options">
                                    @if (ViewBag.administrador && ViewBag.ordem_servico.status == 2)
                                    {
                                        <a href="@Url.Action("ReabrirPMOC", "PMOC", new { codigo_pmoc_ordem_servico = ViewBag.ordem_servico.codigo_pmoc_ordem_servico, codigo_unidade = ViewBag.ordem_servico.codigo_unidade, view = ViewBag.view })" class="btn btn-square btn-secondary min-width-200 h-75"><i class="fa fa-unlock mr-5"></i>@PCM.WEB.Properties.Resources.reabrir_ordem_servico</a>
                                    }
                                    @if (ViewBag.administrador && ViewBag.ordem_servico.status != 2 && ViewBag.ordem_servico.apontamento != null)
                                    {
                                        <a href="@Url.Action("ConcluirPMOC", "PMOC", new { codigo_pmoc_ordem_servico = ViewBag.ordem_servico.codigo_pmoc_ordem_servico, codigo_unidade = ViewBag.ordem_servico.codigo_unidade, view = ViewBag.view })" class="btn btn-square btn-secondary min-width-200 h-75"><i class="fa fa-lock mr-5"></i>@PCM.WEB.Properties.Resources.concluir_ordem_servico</a>
                                    }
                                    @if (ViewBag.editar && ViewBag.ordem_servico.status != 2)
                                    {
                                        <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75"><i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar</button>
                                    }
                                    @if (ViewBag.excluir)
                                    {
                                        <a href="@Url.Action("DeleteOrdemServicoPMOC", "PMOC", new { codigo_pmoc_ordem_servico = ViewBag.ordem_servico.codigo_pmoc_ordem_servico, codigo_unidade = ViewBag.ordem_servico.codigo_unidade, view = ViewBag.view })" class="btn btn-square btn-secondary min-width-100 h-75"><i class="fa fa-times mr-5"></i>@PCM.WEB.Properties.Resources.excluir</a>
                                    }
                                    <a href="@Url.Action(@ViewBag.view, "PMOC")" class="btn btn-square btn-secondary min-width-100 h-75"><i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar</a>
                                </div>
                            </div>
                            <div class="block-content">
                                @if (Session["unidade"] == "")
                                {
                                    <div class="form-group row font-w600"><div class="col-12">@PCM.WEB.Properties.Resources.unidade: <span class="text-primary">@ViewBag.ordem_servico.unidade</span></div></div>
                                }
                                @if (@ViewBag.ordem_servico.setor != "")
                                {
                                    <div class="form-group row font-w600"><div class="col-12">@PCM.WEB.Properties.Resources.setor: <span class="text-primary">@ViewBag.ordem_servico.setor</span></div></div>
                                }
                                @if (@ViewBag.ordem_servico.equipamento != "")
                                {
                                    <div class="form-group row font-w600"><div class="col-12">@PCM.WEB.Properties.Resources.equipamento_pmoc: <span class="text-primary">@ViewBag.ordem_servico.equipamento</span></div></div>
                                }
                                @if (@ViewBag.ordem_servico.tipo_ar_condicionado != "")
                                {
                                    <div class="form-group row font-w600"><div class="col-12">@PCM.WEB.Properties.Resources.tipo_ar_condicionado: <span class="text-primary">@ViewBag.ordem_servico.tipo_ar_condicionado</span></div></div>
                                }
                                @if (@ViewBag.ordem_servico.apartamento != "")
                                {
                                    <div class="form-group row font-w600"><div class="col-12">@PCM.WEB.Properties.Resources.apartamento: <span class="text-primary">@ViewBag.ordem_servico.apartamento</span></div></div>
                                }
                            </div>
                        </div>

                        @if (@ViewBag.ordem_servico.apontamento != null && @ViewBag.ordem_servico.apontamento.Count > 0)
                        {
                            <div class="block block-rounded border">
                                <div class="block-header block-header-default bg-gd-default">
                                    <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.apontamento</h3>
                                    <div class="block-options">
                                        @if (ViewBag.ordem_servico.status != 2 && ViewBag.inserir)
                                        {
                                            <a href="@Url.Action("ApontamentoPMOCInsert", "PMOC", new { codigo_pmoc_ordem_servico = ViewBag.ordem_servico.codigo_pmoc_ordem_servico, codigo_unidade = ViewBag.ordem_servico.codigo_unidade, codigo_equipamento = ViewBag.ordem_servico.codigo_equipamento, view = @ViewBag.view })" class="btn btn-square btn-secondary min-width-100 h-75"><i class="fa fa-crosshairs mr-5"></i>@PCM.WEB.Properties.Resources.apontamento</a>
                                        }
                                    </div>
                                </div>
                                <div class="block-content">
                                    <!-- DataTables init on table by adding .js-dataTable-full-pagination class, functionality initialized in js/pages/be_tables_datatables.js -->
                                    <table class="table table-bordered table-sm table-striped table-vcenter">
                                        <thead>
                                            <tr class="table-secondary">
                                                <th>@PCM.WEB.Properties.Resources.executor</th>
                                                <th class="d-none d-sm-table-cell text-center" style="width: 150px;">@PCM.WEB.Properties.Resources.data_inicio</th>
                                                <th class="d-none d-sm-table-cell text-center" style="width: 150px;">@PCM.WEB.Properties.Resources.data_termino</th>
                                                @if ((ViewBag.editar || ViewBag.excluir) && ViewBag.ordem_servico.status != 2)
                                                {
                                                    <th class="text-center" style="width: 80px;"></th>

                                                }
                                            </tr>
                                        </thead>

                                        <tbody>
                                            @foreach (var apto in ViewBag.ordem_servico.apontamento)
                                            {
                                                <tr>
                                                    <td>@apto.executor</td>
                                                    <td class="d-none d-sm-table-cell text-center" style="width: 150px;">@apto.data_inicio</td>
                                                    <td class="d-none d-sm-table-cell text-center" style="width: 150px;">@apto.data_termino</td>
                                                    @if ((ViewBag.editar || ViewBag.excluir) && ViewBag.ordem_servico.status != 2)
                                                    {
                                                        <td class="text-center" style="width: 80px;">
                                                            <div class="btn-group">
                                                                @if (ViewBag.editar)
                                                                {<a href="@Url.Action("ApontamentoPMOCEdit", "PMOC", new { codigo_apontamento = apto.codigo, codigo_unidade = apto.codigo_unidade, codigo_pmoc_ordem_servico = @ViewBag.ordem_servico.codigo_pmoc_ordem_servico, view = @ViewBag.view})" class="btn btn-sm btn-secondary"><i class="fa fa-pencil"></i></a>}
                                                                @if (ViewBag.excluir)
                                                                {<button type="button" class="btn btn-sm btn-secondary" onclick="deleteApontamento(@apto.codigo, @apto.codigo_unidade, codigo_pmoc_ordem_servico = @ViewBag.ordem_servico.codigo_pmoc_ordem_servico, this);"><i class="fa fa-times"></i></button>}
                                                            </div>
                                                        </td>

                                                    }
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }


                        @if (@ViewBag.ordem_servico.checklist != null && @ViewBag.ordem_servico.checklist.Count > 0)
                        {

                            <div class="block-header block-header-default bg-gd-default">
                                <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.checklist</h3>
                            </div>
                            <div class="block block-content block-content-full border">
                                <table class="table table-sm table-hover table-vcenter js-dataTable-list">

                                    <tbody>

                                        @for (int i = 0; i < ViewBag.ordem_servico.checklist.Count; i++)
                                        {
                                            if (i == 0 || Model[i].grupo != Model[i - 1].grupo)
                                            {
                                                <tr class="table-secondary">
                                                    <th colspan="4">@Model[i].grupo</th>
                                                    <th>@PCM.WEB.Properties.Resources.observacao.ToUpper()</th>
                                                </tr>

                                            }
                                            if ((i == 0 || Model[i].subgrupo != Model[i - 1].subgrupo) && Model[i].subgrupo != "")
                                            {
                                                <tr class="table-primary">
                                                    <th colspan="5">@Model[i].subgrupo</th>
                                                </tr>
                                            }

                                            <tr>
                                                @Html.HiddenFor(m => m[i].codigo)
                                                @Html.HiddenFor(m => m[i].codigo_tipo_item_checklist)
                                                @Html.HiddenFor(m => m[i].descricao)
                                                @Html.HiddenFor(m => m[i].unidade_medida)
                                                @Html.HiddenFor(m => m[i].valor_minimo)
                                                @Html.HiddenFor(m => m[i].valor_maximo)
                                                @Html.HiddenFor(m => m[i].resultado)
                                                <td>@Html.DisplayFor(m => m[i].checklist) - @Html.DisplayFor(m => m[i].descricao)</td>
                                                @if (Model[i].codigo_tipo_item_checklist == 1)
                                                {
                                                    <td class="text-center" style="width:50px">
                                                        <span class="text-center font-w600">SIM</span>
                                                        <label class="css-control css-control-success css-checkbox">
                                                            @if (Model[i].resultado == "SIM")
                                                            {
                                                                @Html.RadioButtonFor(m => m[i].sim_nao, "SIM", new { @class = "css-control-input", @onChange = "setResultado(" + i + ", 'SIM');", @checked = true })
                                                            }
                                                            else
                                                            {
                                                                @Html.RadioButtonFor(m => m[i].sim_nao, "SIM", new { @class = "css-control-input", @onChange = "setResultado(" + i + ", 'SIM');" })
                                                            }
                                                            <span class="css-control-indicator"></span>
                                                        </label>
                                                    </td>
                                                    <td class="text-center" style="width:50px"></td>
                                                    <td class="text-center" style="width:50px">
                                                        <span class="text-center font-w600">NÃO</span>
                                                        <label class="css-control css-control-danger css-checkbox">
                                                            @if (Model[i].resultado == "NÃO")
                                                            {
                                                                @Html.RadioButtonFor(m => m[i].sim_nao, "NÃO", new { @class = "css-control-input", @onChange = "setResultado(" + i + ", 'NÃO');", @checked = true })
                                                            }
                                                            else
                                                            {
                                                                @Html.RadioButtonFor(m => m[i].sim_nao, "NÃO", new { @class = "css-control-input", @onChange = "setResultado(" + i + ", 'NÃO');" })
                                                            }
                                                            <span class="css-control-indicator"></span>
                                                        </label>
                                                    </td>
                                                }
                                                else if (Model[i].codigo_tipo_item_checklist == 2)
                                                {
                                                    <td class="text-center" style="width:150px" colspan="3">
                                                        <div class="input-group">
                                                            @Html.TextBoxFor(m => m[i].numero, new { @class = "js-masked-number form-control", @onChange = "setResultado(" + i + ", this.value);", @value = Model[i].resultado })
                                                            <div class="input-group-append min-width-50 text-center">
                                                                <span class="input-group-text font-w600 min-width-50 text-center">@Model[i].unidade_medida</span>
                                                            </div>
                                                        </div>
                                                    </td>
                                                }
                                                else if (Model[i].codigo_tipo_item_checklist == 3)
                                                {
                                                    <td class="text-center" style="width:150px" colspan="3">
                                                        <div>@Html.TextBoxFor(m => m[i].texto, new { @class = "form-control", @onChange = "setResultado(" + i + ", this.value);", @value = Model[i].resultado })</div>
                                                    </td>
                                                }
                                                else if (Model[i].codigo_tipo_item_checklist == 4)
                                                {
                                                    <td class="text-center" style="width:150px" colspan="3">
                                                        <div>@Html.TextBoxFor(m => m[i].data, new { @class = "form-control", @onChange = "setResultado(" + i + ", this.value);", @value = Model[i].resultado })</div>
                                                    </td>
                                                }
                                                else if (Model[i].codigo_tipo_item_checklist == 5)
                                                {
                                                    <td class="text-center" style="width:150px" colspan="3">
                                                        <div>@Html.TextBoxFor(m => m[i].hora, new { @class = "form-control", @onChange = "setResultado(" + i + ", this.value);", @value = Model[i].resultado })</div>
                                                    </td>
                                                }
                                                else if (Model[i].codigo_tipo_item_checklist == 8)
                                                {
                                                    <td class="text-center" style="width:50px">
                                                        <span class="text-center font-w600">SIM</span>
                                                        <label class="css-control css-control-success css-checkbox">
                                                            @if (Model[i].resultado == "SIM")
                                                            {
                                                                @Html.RadioButtonFor(m => m[i].sim_nao, "SIM", new { @class = "css-control-input", @onChange = "setResultado(" + i + ", 'SIM');", @checked = true })
                                                            }
                                                            else
                                                            {
                                                                @Html.RadioButtonFor(m => m[i].sim_nao, "SIM", new { @class = "css-control-input", @onChange = "setResultado(" + i + ", 'SIM');" })
                                                            }
                                                            <span class="css-control-indicator"></span>
                                                        </label>
                                                    </td>
                                                    <td class="text-center" style="width:50px">
                                                        <span class="text-center font-w600">NÃO</span>
                                                        <label class="css-control css-control-danger css-checkbox">
                                                            @if (Model[i].resultado == "NÃO")
                                                            {
                                                                @Html.RadioButtonFor(m => m[i].sim_nao, "NÃO", new { @class = "css-control-input", @onChange = "setResultado(" + i + ", 'NÃO');", @checked = true })
                                                            }
                                                            else
                                                            {
                                                                @Html.RadioButtonFor(m => m[i].sim_nao, "NÃO", new { @class = "css-control-input", @onChange = "setResultado(" + i + ", 'NÃO');" })
                                                            }
                                                            <span class="css-control-indicator"></span>
                                                        </label>
                                                    </td>
                                                    <td class="text-center" style="width:50px">
                                                        <span class="text-center font-w600">N/A</span>
                                                        <label class="css-control css-control-secondary css-checkbox">
                                                            @if (Model[i].resultado == "NÃO")
                                                            {
                                                                @Html.RadioButtonFor(m => m[i].sim_nao, "NÃO", new { @class = "css-control-input", @onChange = "setResultado(" + i + ", 'NÃO');", @checked = true })
                                                            }
                                                            else
                                                            {
                                                                @Html.RadioButtonFor(m => m[i].sim_nao, "NÃO", new { @class = "css-control-input", @onChange = "setResultado(" + i + ", 'NÃO');" })
                                                            }
                                                            <span class="css-control-indicator"></span>
                                                        </label>
                                                    </td>
                                                }
                                                <td><div>@Html.TextBoxFor(m => m[i].observacao, new { @class = "form-control", @maxlength = 200 })</div></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <!-- END Dynamic Table Full Pagination -->
                        }
                        <!-- END Basic Info -->
                    </div>
                    <!-- END Update Product -->
                </div>

            }
            <!-- END Page Content -->

    </main>
    <!-- END Main Container -->

    @section Styles {
        @Styles.Render("~/Content/datepicker")
        @Styles.Render("~/Content/clockpicker")
    }

    @section Scripts {
        @Scripts.Render("~/plugins/validation")
        @Scripts.Render("~/plugins/maskedinput")
        @Scripts.Render("~/plugins/maxlenght")
        @Scripts.Render("~/plugins/datepicker")
        @Scripts.Render("~/plugins/clockpicker")

        <script>

        $(document).ready(function () { $("#data_inicio").mask("99/99/9999"); });
        $(document).ready(function () { $("#data_termino").mask("99/99/9999"); });
        $(document).ready(function () { $("#hora_inicio").mask("99:99"); });
        $(document).ready(function () { $("#hora_termino").mask("99:99"); });

        jQuery.validator.addMethod("funcionario", function (funcionario, element) {

            var tipo = $("#tipo_servico").val();
            var funcionario = $("#funcionario").val();
            if (tipo == 1) {
                if(funcionario != "")
                    return true;
                else
                    return false;
            }
            else if (tipo == 2) {
                return true;
            }
        }, '@PCM.WEB.Properties.Resources.campo_requerido');

        jQuery.validator.addMethod("fornecedor", function (funcionario, element) {

            var tipo = $("#tipo_servico").val();
            var fornecedor = $("#fornecedor").val();
            if (tipo == 2) {
                if (fornecedor != "")
                    return true;
                else
                    return false;
            }
            else if (tipo == 1) {
                return true;
            }
        }, '@PCM.WEB.Properties.Resources.campo_requerido');

        jQuery.validator.addMethod("maxDate", function (value, element) {

            var curDate = new Date();
            curDate.setHours(0, 0, 0, 0);
            var from = value.split("/");
            var inputDate = new Date(from[2], from[1] - 1, from[0]);
            if (inputDate > curDate) {
                return this.optional(element) || false;
            }
            else {
                return this.optional(element) || true;
            }

        }, '');

        jQuery.validator.addMethod("minDate", function (value, element) {

            var curDate = new Date();
            curDate.setDate(curDate.getDate() - 2);
            curDate.setHours(0, 0, 0, 0);
            var from = value.split("/");
            var inputDate = new Date(from[2], from[1] - 1, from[0]);
            if (inputDate > curDate) {
                return this.optional(element) || true;
            }
            else {
                return this.optional(element) || false;
            }
        }, '');

        jQuery.validator.addMethod("lessThan", function (value, element, params) {

            var fromCurDate = $(params).val().split("/");
            var curDate = new Date(fromCurDate[2], fromCurDate[1] - 1, fromCurDate[0]);
            var fromMinDate = value.split("/");
            var minDate = new Date(fromMinDate[2], fromMinDate[1] - 1, fromMinDate[0]);
            if (curDate < minDate) {
                return this.optional(element) || false;
            }
            else {
                return this.optional(element) || true;
            }
        }, '');

        jQuery.validator.addMethod("greaterThan", function (value, element, params) {

            var fromCurDate = $(params).val().split("/");
            var curDate = new Date(fromCurDate[2], fromCurDate[1] - 1, fromCurDate[0]);
            var fromMaxDate = value.split("/");
            var maxDate = new Date(fromMaxDate[2], fromMaxDate[1] - 1, fromMaxDate[0]);
            if (curDate > maxDate) {
                return this.optional(element) || false;
            }
            else {
                return this.optional(element) || true;
            }
        }, '');

        jQuery.validator.addMethod("apontamentoHoras", function (value, element, params) {

            //Data e Hora - Início
            var fromDataInicio = $(params[0]).val().split("/");
            var fromHoraInicio = $(params[1]).val().split(":");
            var dataInicio = new Date(fromDataInicio[2], fromDataInicio[1] - 1, fromDataInicio[0], fromHoraInicio[0], fromHoraInicio[1], 0, 0);

            //Data e Hora - Término
            var fromDataTermino = $(params[2]).val().split("/");
            var fromHoraTermino = value.split(":");
            var dataTermino = new Date(fromDataTermino[2], fromDataTermino[1] - 1, fromDataTermino[0], fromHoraTermino[0], fromHoraTermino[1], 0, 0);
            var difference = dataTermino - dataInicio;

            if (((difference) / 3600000) > 10) {
                return this.optional(element) || false;
            }
            else {
                return this.optional(element) || true;
            }
        }, '');

        $.validator.addMethod('time', function (value, element, param) {
            return value == '' || value.match(/^([01][0-9]|2[0-3]):[0-5][0-9]$/);
        }, '@PCM.WEB.Properties.Resources.valida_hora');

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'funcionario': {
                            required: true
                        },
                        'data_inicio': {
                            required: true,
                            maxDate: { maxDate: true },
                            lessThan: "#data_termino"
                        },
                        'hora_inicio': {
                            required: true,
                            time: true
                        },
                        'data_termino': {
                            required: true,
                            maxDate: { maxDate: true },
                            greaterThan: "#data_inicio"
                        },
                        'hora_termino': {
                            required: true,
                            time: true,
                            apontamentoHoras: ["#data_inicio", "#hora_inicio", "#data_termino"]
                        }
                    },
                    messages: {
                        'funcionario': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'data_inicio': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            maxDate: '@PCM.WEB.Properties.Resources.data_maior_corrente',
                            lessDate: '@PCM.WEB.Properties.Resources.data_maior_termino'
                        },
                        'data_termino': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            maxDate: '@PCM.WEB.Properties.Resources.data_maior_corrente',
                            greaterThan: '@PCM.WEB.Properties.Resources.data_menor_inicio'
                        },
                        'hora_inicio': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'hora_termino': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            apontamentoHoras: '@PCM.WEB.Properties.Resources.diferenca_maior_10'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Init an example confirm alert on button click
        function deleteApontamento (codigo_apontamento, codigo_unidade, codigo_pmoc_ordem_servico, item) {
            swal({
                title: 'Deseja excluir o Apontamento?',
                text: 'Este apontamento não poderá ser recuperado!',
                type: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d26a5c',
                confirmButtonText: 'Sim',
                html: false,
                preConfirm: function () {
                    return new Promise(function (resolve) {
                        setTimeout(function () {
                            resolve();
                        }, 50);
                    });
                }
            }).then(function (result) {
                if (result.value) {
                    $.post("ApontamentoPMOCExcluir", { "codigo_unidade": codigo_unidade, "codigo_apontamento": codigo_apontamento, "codigo_pmoc_ordem_servico": codigo_pmoc_ordem_servico },
                    function (result) {
                        if (result) {
                            swal('Apontamento Excluido!', '', 'success');
                            var tr = $(item).closest('tr');
                            tr.fadeOut(400, function () { tr.remove(); });
                            return false;
                        }
                    });
                }
            });
        };

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['datepicker', 'maxlength', 'select2', 'masked-inputs']);
        });

        </script>
    }
