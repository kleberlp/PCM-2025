@model IEnumerable<PCM.WEB.MODELS.PMOCCadastro>

<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <span class="breadcrumb-item">@PCM.WEB.Properties.Resources.pmoc</span>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.cadastro_pmoc</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">        

        <!-- Listagem -->
        <div class="block block-rounded border">

            <div class="block-header block-header-default bg-gd-default">
                <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.cadastro_pmoc </h3>
                @if(ViewBag.inserir)
                {
                    <div class="block-options">
                        <a href="@Url.Action("PMOCInsert", "PMOC")" class="btn btn-square btn-secondary min-width-100 h-75">
                            <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.novo
                        </a>
                    </div>
                }
            </div>
            

            <div class="block-content block-content-full">
                <!-- DataTables init on table by adding .js-dataTable-full-pagination class, functionality initialized in js/pages/be_tables_datatables.js -->
                <table class="table table-sm table-vcenter table-striped js-dataTable-list">
                    <thead>
                        <tr class="table-secondary">
                            @if (Session["unidade"] == "")
                            {
                                <th class="d-none d-sm-table-cell">@PCM.WEB.Properties.Resources.unidade</th>
                            }
                            <th class="text-center">@PCM.WEB.Properties.Resources.numero_art</th>
                            <th class="text-center">@PCM.WEB.Properties.Resources.data_inicio_vigencia</th>
                            <th class="text-center">@PCM.WEB.Properties.Resources.data_termino_vigencia</th>
                            @if (ViewBag.editar || ViewBag.excluir)
                            {
                                <th class="text-center" style="width: 80px;" data-sortable="false"></th>
                            }
                        </tr>
                    </thead>

                    <tbody>                       
                        @foreach (var item in Model)
                        {
                        <tr>
                            @if (Session["unidade"] == "")
                            {
                                <td class="d-none d-sm-table-cell">@Html.DisplayFor(modelItem => item.unidade)</td>
                            }
                                <td class="text-center">@Html.DisplayFor(modelItem => item.numero_art_pmoc)</td>
                                <td class="text-center">@Html.DisplayFor(modelItem => item.data_inicio_vigencia_art_pmoc)</td>
                                <td class="text-center">@Html.DisplayFor(modelItem => item.data_termino_vigencia_art_pmoc)</td>
                            @if (ViewBag.editar || ViewBag.excluir)
                            {
                                <td class="text-center" style="width: 80px;">
                                    <div class="btn-group">
                                        @if (ViewBag.editar){<a href="@Url.Action("PMOCEdit", "PMOC", new { codigo = item.codigo, unidade = item.codigo_unidade })" class="btn btn-sm btn-secondary"><i class="fa fa-pencil"></i></a>}
                                        @if (ViewBag.excluir){<a href="@Url.Action("PMOCDelete", "PMOC", new { codigo = item.codigo, unidade = item.codigo_unidade })" class="btn btn-sm btn-secondary"><i class="fa fa-times"></i></a>}
                                        <a href="@Url.Action("PrintPMOCImplantacao", "PMOC", new { unidade = item.codigo_unidade})" target="_blank" class="btn btn-sm btn-secondary"><i class="si si-printer"></i></a>
                                    </div>
                                </td>
                            }
                        </tr>
                        }
                    </tbody>
                </table>

            </div>

        </div>

    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/dataTables")
}

@section Scripts {
    @Scripts.Render("~/plugins/dataTables")

    <script type="text/javascript">

        function ImprimirRelatorio(unidade) {            
            window.open('PrintPMOCImplantacao' + '?unidade=' + unidade, '_blank');
        }

        var BeTableDatatables = function () {
            // Override a few DataTable defaults, for more examples you can check out https://www.datatables.net/
            var exDataTable = function () {
                jQuery.extend(jQuery.fn.dataTable.ext.classes, {
                    sWrapper: "dataTables_wrapper dt-bootstrap4"
                });
            };

            // Init simple DataTable, for more examples you can check out https://www.datatables.net/
            var initDataTableSimple = function () {
                jQuery('.js-dataTable-list').dataTable({
                    fixedHeader: true,
                    searching: true,
                    lengthChange: false,
                    pageLength: 15,
                    autoWidth: false,
                    scrollX: false,
                    scrollColapse: true,
                    dom: 'Bfrtip',
                    buttons: [
                        { extend: 'copy', text: 'Copiar' },
                        {
                            extend: 'print',
                            text: 'Imprimir'
                        },
                        { extend: 'excel' },
                        { extend: 'pdf', orientation: 'portrait' },
                    ],
                    language: {
                        "search": "Procurar:",
                        "lengthMenu": "Exibir _MENU_ ",
                        "zeroRecords": "Nenhum Registro Encontrado",
                        "info": "_MAX_ registro(s)",
                        "infoEmpty": "Nenhum Registro encontrado",
                        "infoFiltered": "(filtrado de _MAX_ registro(s))"
                    }
                });
            };

            return {
                init: function () {
                    // Override a few DataTable defaults
                    exDataTable();

                    // Init Datatables
                    initDataTableSimple();
                }
            };
        }();


        // Initialize when page loads
        jQuery(function () { $.fn.dataTable.moment('DD/MM/YYYY HH:mm'); BeTableDatatables.init(); });

    </script>
}
