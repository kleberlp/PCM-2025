                                    <th class="text-center" colspan="2">2º Bimestre</th>
                                    <th class="text-center" colspan="2">3º Bimestre</th>
                                    <th class="text-center" colspan="2">4º Bimestre</th>
                                    <th class="text-center" colspan="2">5º Bimestre</th>
                                    <th class="text-center" colspan="2">6º Bimestre</th>
                                </tr>
