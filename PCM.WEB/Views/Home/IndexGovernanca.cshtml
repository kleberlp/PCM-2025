@using PCM.WEB.Properties
@using Newtonsoft.Json

<main id="main-container">
    <div class="content">

        @using (Html.BeginForm("IndexGovernanca", "Home", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", id = "form", enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()

            <input type="hidden" id="empresa" name="empresa" value="@Session["empresa"]" />
            <input type="hidden" id="codigo_unidade" name="codigo_unidade" value="@Session["codigo_unidade"]" />

            <!-- ================= FILTROS ================= -->
            <div class="dashboard-section">
                <div class="row invisible" data-toggle="appear">
                    <div class="col-md-2">
                        @Html.DropDownList("data", null, null, new { @class = "form-control font-w600" })
                    </div>
                </div>
            </div>

            <!-- ================= KPIs – ORDEM DE SERVIÇO ================= -->
            <div class="dashboard-section">

                @if ((int)ViewBag.codigo_tipo_unidade == 2)
                {
                    <div class="row invisible" data-toggle="appear">

                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("OrdemServicoInsert", "OrdemServico")" class="block block-rounded block-link-shadow dashboard-card kpi-card">
                                <div class="kpi-header">
                                    <i class="si si-wrench kpi-icon text-primary"></i>
                                    <div class="kpi-title">@Resources.ordem_servico</div>
                                </div>
                                <div class="kpi-value">@Resources.nova</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 3, responsavel_apartamento = 1 })" class="block dashboard-card kpi-card">
                                <div class="kpi-header">
                                    <i class="fa fa-gear kpi-icon text-danger"></i>
                                    <div class="kpi-title">@Resources.quantidade_atrasada</div>
                                </div>
                                <div class="kpi-value" id="quantidade_atrasada_condo">@ViewBag.InfoOrdemServico.quantidade_atrasada_condo</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 1, responsavel_apartamento = 1 })" class="block dashboard-card kpi-card">
                                <div class="kpi-header">
                                    <i class="fa fa-gear kpi-icon text-warning"></i>
                                    <div class="kpi-title">@Resources.quantidade_pendente</div>
                                </div>
                                <div class="kpi-value" id="quantidade_pendente_condo">@ViewBag.InfoOrdemServico.quantidade_pendente_condo</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 5, responsavel_apartamento = 1 })" class="block dashboard-card kpi-card">
                                <div class="kpi-header">
                                    <i class="fa fa-gear kpi-icon text-info"></i>
                                    <div class="kpi-title">@Resources.quantidade_vinculada</div>
                                </div>
                                <div class="kpi-value" id="quantidade_pendente_condo">@ViewBag.InfoOrdemServico.quantidade_vinculada_condo</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 4, responsavel_apartamento = 1 })" class="block dashboard-card kpi-card">
                                <div class="kpi-header">
                                    <i class="fa fa-gear kpi-icon text-primary-light"></i>
                                    <div class="kpi-title">@Resources.quantidade_andamento</div>
                                </div>
                                <div class="kpi-value" id="quantidade_andamento_condo">@ViewBag.InfoOrdemServico.quantidade_andamento_condo</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 2, responsavel_apartamento = 1 })" class="block dashboard-card kpi-card">
                                <div class="kpi-header">
                                    <i class="fa fa-gear kpi-icon text-earth-light"></i>
                                    <div class="kpi-title">@Resources.quantidade_realizada</div>
                                </div>
                                <div class="kpi-value" id="quantidade_realizada_condo">@ViewBag.InfoOrdemServico.quantidade_concluida_condo</div>
                            </a>
                        </div>

                    </div>

                    <div class="row invisible" data-toggle="appear">

                        <div class="col-xl-2 col-md-4 col-6">
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 3, responsavel_apartamento = 2 })" class="block dashboard-card kpi-card">
                                <div class="kpi-header">
                                    <i class="fa fa-gear kpi-icon text-danger"></i>
                                    <div class="kpi-title">@Resources.quantidade_atrasada POOL</div>
                                </div>
                                <div class="kpi-value" id="quantidade_atrasada_pool">@ViewBag.InfoOrdemServico.quantidade_atrasada_pool</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 1, responsavel_apartamento = 2 })" class="block dashboard-card kpi-card">
                                <div class="kpi-header">
                                    <i class="fa fa-gear kpi-icon text-warning"></i>
                                    <div class="kpi-title">@Resources.quantidade_pendente POOL</div>
                                </div>
                                <div class="kpi-value" id="quantidade_pendente_pool">@ViewBag.InfoOrdemServico.quantidade_pendente_pool</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 5, responsavel_apartamento = 2 })" class="block dashboard-card kpi-card">
                                <div class="kpi-header">
                                    <i class="fa fa-gear kpi-icon text-info"></i>
                                    <div class="kpi-title">@Resources.quantidade_vinculada POOL</div>
                                </div>
                                <div class="kpi-value" id="quantidade_pendente_pool">@ViewBag.InfoOrdemServico.quantidade_vinculada_pool</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 4, responsavel_apartamento = 2 })" class="block dashboard-card kpi-card">
                                <div class="kpi-header">
                                    <i class="fa fa-gear kpi-icon text-primary-light"></i>
                                    <div class="kpi-title">@Resources.quantidade_andamento POOL</div>
                                </div>
                                <div class="kpi-value" id="quantidade_andamento_pool">@ViewBag.InfoOrdemServico.quantidade_andamento_pool</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 2, responsavel_apartamento = 2 })" class="block dashboard-card kpi-card">
                                <div class="kpi-header">
                                    <i class="fa fa-gear kpi-icon text-earth-light"></i>
                                    <div class="kpi-title">@Resources.quantidade_realizada POOL</div>
                                </div>
                                <div class="kpi-value" id="quantidade_realizada_pool">@ViewBag.InfoOrdemServico.quantidade_concluida_pool</div>
                            </a>
                        </div>

                    </div>

                }
                else
                {
                    <div class="row invisible" data-toggle="appear">

                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("OrdemServicoInsert", "OrdemServico")" class="block block-rounded block-link-shadow dashboard-card kpi-card">
                                <div class="kpi-header">
                                    <i class="si si-wrench kpi-icon text-primary"></i>
                                    <div class="kpi-title">@Resources.ordem_servico</div>
                                </div>
                                <div class="kpi-value">@Resources.nova</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 3, responsavel_apartamento = 2 })" class="block dashboard-card kpi-card">
                                <div class="kpi-header">
                                    <i class="fa fa-gear kpi-icon text-danger"></i>
                                    <div class="kpi-title">@Resources.quantidade_atrasada</div>
                                </div>
                                <div class="kpi-value" id="quantidade_atrasada_pool">@ViewBag.InfoOrdemServico.quantidade_atrasada_pool</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 1, responsavel_apartamento = 2 })" class="block dashboard-card kpi-card">
                                <div class="kpi-header">
                                    <i class="fa fa-gear kpi-icon text-warning"></i>
                                    <div class="kpi-title">@Resources.quantidade_pendente</div>
                                </div>
                                <div class="kpi-value" id="quantidade_pendente_pool">@ViewBag.InfoOrdemServico.quantidade_pendente_pool</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 5, responsavel_apartamento = 2 })" class="block dashboard-card kpi-card">
                                <div class="kpi-header">
                                    <i class="fa fa-gear kpi-icon text-info"></i>
                                    <div class="kpi-title">@Resources.quantidade_vinculada</div>
                                </div>
                                <div class="kpi-value" id="quantidade_pendente_pool">@ViewBag.InfoOrdemServico.quantidade_vinculada_pool</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 4, responsavel_apartamento = 2 })" class="block dashboard-card kpi-card">
                                <div class="kpi-header">
                                    <i class="fa fa-gear kpi-icon text-primary-light"></i>
                                    <div class="kpi-title">@Resources.quantidade_andamento</div>
                                </div>
                                <div class="kpi-value" id="quantidade_andamento_pool">@ViewBag.InfoOrdemServico.quantidade_andamento_pool</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 2, responsavel_apartamento = 2 })" class="block dashboard-card kpi-card">
                                <div class="kpi-header">
                                    <i class="fa fa-gear kpi-icon text-earth-light"></i>
                                    <div class="kpi-title">@Resources.quantidade_realizada</div>
                                </div>
                                <div class="kpi-value" id="quantidade_realizada_pool">@ViewBag.InfoOrdemServico.quantidade_concluida_pool</div>
                            </a>
                        </div>

                    </div>
                }
            </div>

            <!-- ================= KPIs – GAUGES ================= -->
            <div class="dashboard-section">
                <div class="row invisible" data-toggle="appear">

                    @if ((bool)ViewBag.dashboard_preventiva)
                    {
                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("ManutencaoPreventiva", "PCM")"
                               class="block dashboard-card kpi-card">
                                <div class="kpi-title">Preventiva</div>
                                <div class="kpi-subtitle">@Resources.visualizar</div>

                                <div class="js-pie-chart pie-chart"
                                     data-percent="@ViewBag.ChartGauge.preventiva"
                                     data-line-width="4"
                                     data-size="120"
                                     data-bar-color="@ViewBag.ChartGauge.cor_preventiva"
                                     data-track-color="#e5e7eb">
                                    <span class="kpi-gauge-value"
                                          style="color:@ViewBag.ChartGauge.cor_preventiva">
                                        @ViewBag.ChartGauge.preventiva
                                    </span>
                                </div>
                            </a>
                        </div>
                    }

                    @if ((bool)ViewBag.dashboard_laudo)
                    {
                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("ManutencaoLaudo", "PCM")"
                               class="block dashboard-card kpi-card">
                                <div class="kpi-title">Laudo</div>
                                <div class="kpi-subtitle">@Resources.visualizar</div>

                                <div class="js-pie-chart pie-chart"
                                     data-percent="@ViewBag.ChartGauge.laudo"
                                     data-line-width="4"
                                     data-size="120"
                                     data-bar-color="@ViewBag.ChartGauge.cor_laudo"
                                     data-track-color="#e5e7eb">
                                    <span class="kpi-gauge-value"
                                          style="color:@ViewBag.ChartGauge.cor_laudo">
                                        @ViewBag.ChartGauge.laudo
                                    </span>
                                </div>
                            </a>
                        </div>
                    }

                    @if ((bool)ViewBag.dashboard_rotina)
                    {
                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("ManutencaoRotina", "PCM")"
                               class="block dashboard-card kpi-card">
                                <div class="kpi-title">Rotinas do Dia</div>
                                <div class="kpi-subtitle">@Resources.visualizar</div>

                                <div class="js-pie-chart pie-chart"
                                     data-percent="@ViewBag.ChartGauge.rotina"
                                     data-line-width="4"
                                     data-size="120"
                                     data-bar-color="@ViewBag.ChartGauge.cor_rotina"
                                     data-track-color="#e5e7eb">
                                    <span class="kpi-gauge-value"
                                          style="color:@ViewBag.ChartGauge.cor_rotina">
                                        @ViewBag.ChartGauge.rotina
                                    </span>
                                </div>
                            </a>
                        </div>
                    }

                    @if ((bool)ViewBag.dashboard_pmoc)
                    {
                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("PMOC2", "PMOC")"
                               class="block dashboard-card kpi-card">
                                <div class="kpi-title">PMOC</div>
                                <div class="kpi-subtitle">@Resources.visualizar</div>

                                <div class="js-pie-chart pie-chart"
                                     data-percent="@ViewBag.ChartGauge.pmoc"
                                     data-line-width="4"
                                     data-size="120"
                                     data-bar-color="@ViewBag.ChartGauge.cor_pmoc"
                                     data-track-color="#e5e7eb">
                                    <span class="kpi-gauge-value"
                                          style="color:@ViewBag.ChartGauge.cor_pmoc">
                                        @ViewBag.ChartGauge.pmoc
                                    </span>
                                </div>
                            </a>
                        </div>
                    }

                    @if ((bool)ViewBag.dashboard_uh)
                    {
                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("ChecklistUH", "UH")"
                               class="block dashboard-card kpi-card">
                                <div class="kpi-title">U.H em Dia</div>
                                <div class="kpi-subtitle">@Resources.visualizar</div>

                                <div class="js-pie-chart pie-chart"
                                     data-percent="@ViewBag.ChartGauge.uh_dia"
                                     data-line-width="4"
                                     data-size="120"
                                     data-bar-color="@ViewBag.ChartGauge.cor_uh_dia"
                                     data-track-color="#e5e7eb">
                                    <span class="kpi-gauge-value"
                                          style="color:@ViewBag.ChartGauge.cor_uh_dia">
                                        @ViewBag.ChartGauge.uh_dia
                                    </span>
                                </div>
                            </a>
                        </div>
                    }

                    @if ((bool)ViewBag.dashboard_green_planet)
                    {
                        <div class="col-xl-2 col-md-4 col-6">
                            <a href="@Url.Action("LancamentoIndex", "GreenPlanet")"
                               class="block dashboard-card kpi-card">
                                <div class="kpi-title">Green Planet</div>
                                <div class="kpi-subtitle">@Resources.visualizar</div>

                                <div class="js-pie-chart pie-chart"
                                     data-percent="@ViewBag.ChartGauge.green_planet"
                                     data-line-width="4"
                                     data-size="120"
                                     data-bar-color="@ViewBag.ChartGauge.cor_green_planet"
                                     data-track-color="#e5e7eb">
                                    <span class="kpi-gauge-value"
                                          style="color:@ViewBag.ChartGauge.cor_green_planet">
                                        @ViewBag.ChartGauge.green_planet
                                    </span>
                                </div>
                            </a>
                        </div>
                    }

                </div>
            </div>


            <!-- ================= DADOS DA UNIDADE ================= -->
            <div class="dashboard-section">
                <div class="section-title col-12">Dados da Unidade</div>

                <div class="row invisible" data-toggle="appear">
                    <div class="col-md-3">
                        <div class="block dashboard-card">

                            <div class="kpi-line">
                                <div class="kpi-value">@ViewBag.dashboard_info.quantidadeUHs</div>
                                <div class="kpi-title">UH Arrumadas</div>
                            </div>

                            <div class="kpi-line">
                                <div class="kpi-value">@ViewBag.dashboard_info.quantidateUHsGovernanca</div>
                                <div class="kpi-title">UH Vistoriadas</div>
                            </div>

                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="block dashboard-card">

                            <div class="kpi-line">
                                <div class="kpi-value">@ViewBag.dashboard_info.quantidadeCamareira</div>
                                <div class="kpi-title">Camareiras</div>
                            </div>

                            <div class="kpi-line">
                                <div class="kpi-value">@ViewBag.dashboard_info.quantidadeVistoriador</div>
                                <div class="kpi-title">Supervisores</div>
                            </div>

                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="block dashboard-card">

                            <div class="kpi-line">
                                <div class="kpi-value">@ViewBag.dashboard_info.hhDisponivel</div>
                                <div class="kpi-title">HH Disponível</div>
                            </div>

                            <div class="kpi-line">
                                <div class="kpi-value">@ViewBag.dashboard_info.hhUtilizado</div>
                                <div class="kpi-title">HH Utilizado</div>
                            </div>

                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="block dashboard-card">

                            <div class="kpi-line">
                                <div class="row">
                                    <div class="col-6">
                                        <div class="kpi-value">@ViewBag.dashboard_info.quantidadeOSGerada</div>
                                        <div class="kpi-title">OS Gerada</div>
                                    </div>
                                    <div class="col-6">
                                        <div class="kpi-value">@ViewBag.dashboard_info.itensChecklist</div>
                                        <div class="kpi-title">Items vistoriados</div>
                                    </div>
                                </div>
                                
                            </div>

                            <div class="kpi-line">
                                <div class="kpi-value">@ViewBag.dashboard_info.quantidadeTrocaStatus</div>
                                <div class="kpi-title">Troca Status UH</div>
                            </div>

                        </div>
                    </div>

                </div>
            </div>

            <!-- ================= RANKING ================= -->
            <div class="dashboard-section col-12">
                <div class="section-title">@Resources.ranking</div>
                <div class="block dashboard-card">
                    <table class="table table-striped" id="tbRankingCamareira" name="tbRankingCamareira">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>@Resources.camareira</th>
                                <th>Qtde. NC</th>
                                <th>Qtde. Retrabalho</th>
                                <th>Nota (NC + Retrabalho)</th>
                                <th>Qtde. UH</th>
                                <th>Nota x UH</th>
                            </tr>
                        </thead>
                    </table>
                </div>
            </div>

            <!-- ================= GRÁFICOS ================= -->
            <div class="dashboard-section col-12">
                <div class="section-title">Arrumado x Vistoriado </div>
                <div class="block dashboard-card">
                    <div class="block dashboard-card chart-card">
                        <canvas id="chartArrumadoxVistoriado"></canvas>
                    </div>
                </div>
            </div>

            <!-- ================= PRODUTIVIDADE ================= -->
            <div class="dashboard-section">
                <div class="row">
                    <div class="col-6">
                        <!-- PRODUTIVIDADE POR CAMAREIRA -->
                        <div class="section-title">Produtividade por @(Session["codigo_unidade"].ToString() == "-1"? "Unidade": "Camareira")</div>

                        <div class="block dashboard-card">
                            <table class="table table-striped" id="tbProdutividadeCamareira" name="tbProdutividadeCamareira">
                                <thead>
                                    <tr>
                                        <th>@(Session["codigo_unidade"].ToString() == "-1"? "Unidade": "Camareira")</th>
                                        <th>UH's Arrumadas</th>
                                        <th>UH's Saída</th>
                                        <th>UH's Permanência</th>
                                        <th>UH's Manutenção</th>
                                        <th>% Arrumado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- preenchido via JS -->
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="col-6">
                        <!-- PRODUTIVIDADE POR VISTORIADOR -->
                        <div class="section-title">Produtividade por @(Session["codigo_unidade"].ToString() == "-1"? "Unidade": "Vistoriador")</div>
                        <div class="block dashboard-card">
                            <table class="table table-striped" id="tbProdutividadeVistoriador" name="tbProdutividadeVistoriador">
                                <thead>
                                    <tr>
                                        <th>@(Session["codigo_unidade"].ToString() == "-1"? "Unidade": "Vistoriador")</th>
                                        <th>UH's Saídas</th>
                                        <th>UH's Vistoriadas</th>
                                        <th>% Vistoriado Saídas</th>
                                        <th>% Vistoriado Meta</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- preenchido via JS -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-4 mb-4"></div>

            <div class="dashboard-section col-12">
                <div class="section-title">Não Conformidade</div>
                <div class="block dashboard-card">
                    <div class="block dashboard-card chart-card">
                        <canvas id="chartNCDia"></canvas>
                    </div>
                </div>
            </div>

            <!-- ================= NÃO CONFORMIDADE ================= -->
            <div class="dashboard-section">
                <div class="row">
                    <div class="col-6">
                        <!-- NC DETALHADO-->
                        <div class="section-title">NÃO CONFORMIDADE - DETALHADO</div>
                        <div class="block dashboard-card">
                            <table class="table table-striped" id="tbNCDetalhado" name="tbNCDetalhado">
                                <thead>
                                    <tr>
                                        <th>OCORRÊNCIA</th>
                                        <th>QUANTIDADE NC</th>
                                        <th>MÉDIA MÓVEL</th>
                                        <th>TENDÊNCIA</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- preenchido via JS -->
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- PRODUTIVIDADE POR VISTORIADOR -->
                    <div class="col-6">

                        <div class="section-title">Não Conformidade - @(Session["codigo_unidade"].ToString() == "-1"? "Unidade": "Camareira")</div>

                        <div class="block dashboard-card">
                            <table class="table table-striped" id="tbNCCamareira" name="tbNCCamareira">
                                <thead>
                                    <tr>
                                        <th>@(Session["codigo_unidade"].ToString() == "-1"? "Unidade": "Camareira")</th>
                                        <th>QUANTIDADE NC</th>
                                        <th>MÉDIA MÓVEL</th>
                                        <th>TENDÊNCIA</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- preenchido via JS -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>


        }

    </div>
</main>


