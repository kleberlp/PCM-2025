<!-- Main Container -->
<main id="main-container">
    <!-- Page Content -->
    <div class="content">

        @using (Html.BeginForm("IndexGovernanca", "Home", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", @id = "form", enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()


            <div class="row invisible" data-toggle="appear">
                <div class="col-sm-12 col-md-4 col-xl-4">
                    <div class="input-group">
                        @Html.DropDownList("unidade", null, null, new { @class = "form-control material font-w600 js-select2" })
                        <input type="hidden" name="nome_fantasia" id="nome_fantasia" value="@ViewBag.nome_fantasia" />
                    </div>
                </div>
                <div class="col-sm-12 col-md-4 col-xl-4">
                    <div class="input-group">
                        @Html.DropDownList("modulo", null, null, new { @class = "form-control material font-w600 js-select2" })
                    </div>
                </div>
                <div class="col-sm-12 col-md-2 col-xl-2 ">
                    <div class="input-group">
                        @Html.DropDownList("data", null, null, new { @class = "form-control material font-w600 js-select2" })
                    </div>
                </div>
                <input type="hidden" name="codigo_unidade" id="codigo_unidade" value="@Session["codigo_unidade"]" />
            </div>

            <br />


