                                <div class="float-right mt-0 d-none d-sm-block js-pie-chart pie-chart " data-percent="@ViewBag.ChartGauge.preventiva" data-line-width="4" data-size="120" data-bar-color="@ViewBag.ChartGauge.cor_preventiva" data-track-color="rgba(2,2,2,.25)" data-scale-color="rgba(2,2,2,.5)">
                                    <span class="font-size-h1 font-w600" style="color:@ViewBag.ChartGauge.cor_preventiva">@ViewBag.ChartGauge.preventiva</span>
                                </div>
                            </div>
                        </a>
