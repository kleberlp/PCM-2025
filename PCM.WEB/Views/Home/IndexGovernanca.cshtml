@using PCM.WEB.Properties
@using Newtonsoft.Json

<main id="main-container">
    <div class="content">

        @using (Html.BeginForm("IndexGovernanca", "Home", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", id = "form", enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()

            <input type="hidden" id="empresa" value="@Session["empresa"]" />
            <input type="hidden" name="unidade" id="hidden-unidade" value="@Session["codigo_unidade"]" />
            <input type="hidden" name="modulo" id="hidden-modulo" value="@Session["codigo_modulo"]" />

            string _dataSelected = "";
            if (ViewBag.data is SelectList)
            {
                var _selItem = ((SelectList)ViewBag.data).Where(x => x.Selected).FirstOrDefault();
                _dataSelected = _selItem != null ? _selItem.Value : "";
            }

            <input type="hidden" name="data" id="data" value="@_dataSelected" />

            <!-- ================= KPIs – ORDEM DE SERVIÇO (torre-grid) ================= -->
            if ((int)ViewBag.codigo_tipo_unidade == 2)
            {
                <div class="dashboard-section">
                    <div class="section-title">Condomínio</div>
                    <div class="block dashboard-card" style="padding:0; overflow:hidden;">
                        <div class="torre-comando-grid">
                            <a href="@Url.Action("OrdemServicoInsert", "OrdemServico")" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="si si-wrench torre-icon text-primary"></i>
                                    <span class="torre-label">@Resources.ordem_servico</span>
                                </div>
                                <div class="os-value text-primary">@Resources.nova</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 3, responsavel_apartamento = 1 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-danger"></i>
                                    <span class="torre-label">@Resources.quantidade_atrasada</span>
                                </div>
                                <div class="os-value text-danger" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_atrasada_condo" id="quantidade_atrasada_condo">@ViewBag.InfoOrdemServico.quantidade_atrasada_condo</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 1, responsavel_apartamento = 1 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-warning"></i>
                                    <span class="torre-label">@Resources.quantidade_pendente</span>
                                </div>
                                <div class="os-value text-warning" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_pendente_condo" id="quantidade_pendente_condo">@ViewBag.InfoOrdemServico.quantidade_pendente_condo</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 5, responsavel_apartamento = 1 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-info"></i>
                                    <span class="torre-label">@Resources.quantidade_vinculada</span>
                                </div>
                                <div class="os-value text-info" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_vinculada_condo" id="quantidade_vinculada_condo">@ViewBag.InfoOrdemServico.quantidade_vinculada_condo</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 4, responsavel_apartamento = 1 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-primary"></i>
                                    <span class="torre-label">@Resources.quantidade_andamento</span>
                                </div>
                                <div class="os-value text-primary" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_andamento_condo" id="quantidade_andamento_condo">@ViewBag.InfoOrdemServico.quantidade_andamento_condo</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 2, responsavel_apartamento = 1 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-check-circle torre-icon text-earth"></i>
                                    <span class="torre-label">@Resources.quantidade_realizada</span>
                                </div>
                                <div class="os-value text-earth" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_concluida_condo" id="quantidade_realizada_condo">@ViewBag.InfoOrdemServico.quantidade_concluida_condo</div>
                            </a>
                        </div>
                    </div>
                </div>

                <div class="dashboard-section">
                    <div class="section-title">Pool</div>
                    <div class="block dashboard-card" style="padding:0; overflow:hidden;">
                        <div class="torre-comando-grid">
                            <a href="@Url.Action("OrdemServicoInsert", "OrdemServico")" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="si si-wrench torre-icon text-primary"></i>
                                    <span class="torre-label">@Resources.ordem_servico</span>
                                </div>
                                <div class="os-value text-primary">@Resources.nova</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 3, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-danger"></i>
                                    <span class="torre-label">@Resources.quantidade_atrasada</span>
                                </div>
                                <div class="os-value text-danger" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_atrasada_pool" id="quantidade_atrasada_pool">@ViewBag.InfoOrdemServico.quantidade_atrasada_pool</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 1, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-warning"></i>
                                    <span class="torre-label">@Resources.quantidade_pendente</span>
                                </div>
                                <div class="os-value text-warning" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_pendente_pool" id="quantidade_pendente_pool">@ViewBag.InfoOrdemServico.quantidade_pendente_pool</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 5, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-info"></i>
                                    <span class="torre-label">@Resources.quantidade_vinculada</span>
                                </div>
                                <div class="os-value text-info" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_vinculada_pool" id="quantidade_vinculada_pool">@ViewBag.InfoOrdemServico.quantidade_vinculada_pool</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 4, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-primary"></i>
                                    <span class="torre-label">@Resources.quantidade_andamento</span>
                                </div>
                                <div class="os-value text-primary" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_andamento_pool" id="quantidade_andamento_pool">@ViewBag.InfoOrdemServico.quantidade_andamento_pool</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 2, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-check-circle torre-icon text-earth"></i>
                                    <span class="torre-label">@Resources.quantidade_realizada</span>
                                </div>
                                <div class="os-value text-earth" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_concluida_pool" id="quantidade_realizada_pool">@ViewBag.InfoOrdemServico.quantidade_concluida_pool</div>
                            </a>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="dashboard-section">
                    <div class="section-title">Ordem de Serviço</div>
                    <div class="block dashboard-card" style="padding:0; overflow:hidden;">
                        <div class="torre-comando-grid">
                            <a href="@Url.Action("OrdemServicoInsert", "OrdemServico")" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="si si-wrench torre-icon text-primary"></i>
                                    <span class="torre-label">@Resources.ordem_servico</span>
                                </div>
                                <div class="os-value text-primary">@Resources.nova</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 3, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-danger"></i>
                                    <span class="torre-label">@Resources.quantidade_atrasada</span>
                                </div>
                                <div class="os-value text-danger" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_atrasada_pool" id="quantidade_atrasada_pool">@ViewBag.InfoOrdemServico.quantidade_atrasada_pool</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 1, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-warning"></i>
                                    <span class="torre-label">@Resources.quantidade_pendente</span>
                                </div>
                                <div class="os-value text-warning" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_pendente_pool" id="quantidade_pendente_pool">@ViewBag.InfoOrdemServico.quantidade_pendente_pool</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 5, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-info"></i>
                                    <span class="torre-label">@Resources.quantidade_vinculada</span>
                                </div>
                                <div class="os-value text-info" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_vinculada_pool" id="quantidade_vinculada_pool">@ViewBag.InfoOrdemServico.quantidade_vinculada_pool</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 4, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-primary"></i>
                                    <span class="torre-label">@Resources.quantidade_andamento</span>
                                </div>
                                <div class="os-value text-primary" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_andamento_pool" id="quantidade_andamento_pool">@ViewBag.InfoOrdemServico.quantidade_andamento_pool</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 2, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-check-circle torre-icon text-earth"></i>
                                    <span class="torre-label">@Resources.quantidade_realizada</span>
                                </div>
                                <div class="os-value text-earth" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_concluida_pool" id="quantidade_realizada_pool">@ViewBag.InfoOrdemServico.quantidade_concluida_pool</div>
                            </a>
                        </div>
                    </div>
                </div>
            }

            <!-- ================= DADOS DA UNIDADE ================= -->
            <div class="dashboard-section">
                <div class="section-title">Dados da Unidade</div>
                <div class="block dashboard-card" style="padding:0; overflow:hidden;">
                    <div class="torre-comando-grid">
                        <div class="torre-item" style="cursor:default;">
                            <div class="torre-header">
                                <i class="fa fa-bed torre-icon text-info"></i>
                                <span class="torre-label">UH Arrumadas</span>
                            </div>
                            <div class="os-value text-info">@ViewBag.dashboard_info.quantidadeUHs</div>
                        </div>
                        <div class="torre-item" style="cursor:default;">
                            <div class="torre-header">
                                <i class="fa fa-search torre-icon text-success"></i>
                                <span class="torre-label">UH Vistoriadas</span>
                            </div>
                            <div class="os-value text-success">@ViewBag.dashboard_info.quantidateUHsGovernanca</div>
                        </div>
                        <div class="torre-item" style="cursor:default;">
                            <div class="torre-header">
                                <i class="fa fa-female torre-icon text-warning"></i>
                                <span class="torre-label">Camareiras</span>
                            </div>
                            <div class="os-value text-warning">@ViewBag.dashboard_info.quantidadeCamareira</div>
                        </div>
                        <div class="torre-item" style="cursor:default;">
                            <div class="torre-header">
                                <i class="fa fa-user torre-icon text-primary"></i>
                                <span class="torre-label">Supervisores</span>
                            </div>
                            <div class="os-value text-primary">@ViewBag.dashboard_info.quantidadeVistoriador</div>
                        </div>
                        <div class="torre-item" style="cursor:default;">
                            <div class="torre-header">
                                <i class="fa fa-file-text-o torre-icon text-muted"></i>
                                <span class="torre-label">OS Gerada</span>
                            </div>
                            <div class="os-value text-muted">@ViewBag.dashboard_info.quantidadeOSGerada</div>
                        </div>
                        <div class="torre-item" style="cursor:default;">
                            <div class="torre-header">
                                <i class="fa fa-list-ul torre-icon text-muted"></i>
                                <span class="torre-label">Itens Vistoriados</span>
                            </div>
                            <div class="os-value text-muted">@ViewBag.dashboard_info.itensChecklist</div>
                        </div>
                        <div class="torre-item" style="cursor:default;">
                            <div class="torre-header">
                                <i class="fa fa-exchange torre-icon text-muted"></i>
                                <span class="torre-label">Troca Status UH</span>
                            </div>
                            <div class="os-value text-muted">@ViewBag.dashboard_info.quantidadeTrocaStatus</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ================= PAINEL DE CONTROLE ================= -->
            var _dg = ViewBag.dadosGovernanca as List<PCM.WEB.MODELS.dashboardGovernancaApartamentoInfo>;
            var _dgInfo = _dg != null ? _dg.FirstOrDefault() : null;
            <div class="dashboard-section row">
                <div class="col-6">
                    <div class="section-title">Status Front Office</div>
                    <div class="block dashboard-card" style="padding:0; overflow:hidden;">
                        <div class="torre-comando-grid">
                            <div class="torre-item" style="cursor:default;">
                                <div class="torre-header">
                                    <i class="fa fa-bed torre-icon text-success"></i>
                                    <span class="torre-label">Vagos</span>
                                </div>
                                <div class="os-value text-success">@(_dgInfo != null ? _dgInfo.sfoVago.ToString() : "—")</div>
                            </div>
                            <div class="torre-item" style="cursor:default;">
                                <div class="torre-header">
                                    <i class="fa fa-bed torre-icon text-primary"></i>
                                    <span class="torre-label">Ocupados</span>
                                </div>
                                <div class="os-value text-primary">@(_dgInfo != null ? _dgInfo.sfoOcupado.ToString() : "—")</div>
                            </div>
                            <div class="torre-item" style="cursor:default;">
                                <div class="torre-header">
                                    <i class="fa fa-ban torre-icon text-danger"></i>
                                    <span class="torre-label">Bloqueados</span>
                                </div>
                                <div class="os-value text-danger">@(_dgInfo != null ? _dgInfo.sfoBloqueado.ToString() : "—")</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="section-title">Tipo de Arrumação</div>
                    <div class="block dashboard-card" style="padding:0; overflow:hidden;">
                        <div class="torre-comando-grid">
                            <div class="torre-item" style="cursor:default;">
                                <div class="torre-header">
                                    <i class="fa fa-sign-out torre-icon text-warning"></i>
                                    <span class="torre-label">Arrumação Saída</span>
                                </div>
                                <div class="os-value text-warning">@(_dgInfo != null ? _dgInfo.taSaida.ToString() : "—")</div>
                            </div>
                            <div class="torre-item" style="cursor:default;">
                                <div class="torre-header">
                                    <i class="fa fa-home torre-icon text-info"></i>
                                    <span class="torre-label">Permanência</span>
                                </div>
                                <div class="os-value text-info">@(_dgInfo != null ? _dgInfo.taPermanencia.ToString() : "—")</div>
                            </div>
                            <div class="torre-item" style="cursor:default;">
                                <div class="torre-header">
                                    <i class="fa fa-wrench torre-icon text-earth"></i>
                                    <span class="torre-label">Manutenção</span>
                                </div>
                                <div class="os-value text-earth">@(_dgInfo != null ? _dgInfo.taManutencao.ToString() : "—")</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ================= RANKING ================= -->
            <div class="dashboard-section">
                <div class="section-title">@Resources.ranking</div>
                <div class="block dashboard-card">
                    <table class="table table-striped" id="tbRankingCamareira" name="tbRankingCamareira">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>@Resources.camareira</th>
                                <th>Qtde. NC</th>
                                <th>Qtde. Retrabalho</th>
                                <th>Nota (NC + Retrabalho)</th>
                                <th>Qtde. UH</th>
                                <th>Nota x UH</th>
                            </tr>
                        </thead>
                    </table>
                </div>
            </div>

            <!-- ================= GRÁFICO ARRUMADO x VISTORIADO ================= -->
            <div class="dashboard-section">
                <div class="section-title">Arrumado x Vistoriado</div>
                <div class="block dashboard-card chart-card">
                    <div class="chart-wrapper">
                        <canvas id="chartArrumadoxVistoriado"></canvas>
                    </div>
                </div>
            </div>

            <!-- ================= PRODUTIVIDADE ================= -->
            <div class="dashboard-section row">
                <div class="col-6">
                    <div class="section-title">Produtividade por @(Session["codigo_unidade"].ToString() == "-1" ? "Unidade" : "Camareira")</div>
                    <div class="block dashboard-card" style="overflow-x:auto;">
                        <table class="table table-striped" id="tbProdutividadeCamareira" name="tbProdutividadeCamareira" style="min-width:520px;">
                            <thead>
                                <tr>
                                    <th>@(Session["codigo_unidade"].ToString() == "-1" ? "Unidade" : "Camareira")</th>
                                    <th>UH's Arrumadas</th>
                                    <th>UH's Saída</th>
                                    <th>UH's Permanência</th>
                                    <th>UH's Manutenção</th>
                                    <th>% Arrumado</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
                <div class="col-6">
                    <div class="section-title">Produtividade por @(Session["codigo_unidade"].ToString() == "-1" ? "Unidade" : "Vistoriador")</div>
                    <div class="block dashboard-card" style="overflow-x:auto;">
                        <table class="table table-striped" id="tbProdutividadeVistoriador" name="tbProdutividadeVistoriador" style="min-width:480px;">
                            <thead>
                                <tr>
                                    <th>@(Session["codigo_unidade"].ToString() == "-1" ? "Unidade" : "Vistoriador")</th>
                                    <th>UH's Saídas</th>
                                    <th>UH's Vistoriadas</th>
                                    <th>% Vistoriado Saídas</th>
                                    <th>% Vistoriado Meta</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- ================= GRÁFICO NÃO CONFORMIDADE ================= -->
            <div class="dashboard-section">
                <div class="section-title">Não Conformidade</div>
                <div class="block dashboard-card chart-card">
                    <div class="chart-wrapper">
                        <canvas id="chartNCDia"></canvas>
                    </div>
                </div>
            </div>

            <!-- ================= NÃO CONFORMIDADE DETALHADO ================= -->
            <div class="dashboard-section row">
                <div class="col-6">
                    <div class="section-title">Não Conformidade - Detalhado</div>
                    <div class="block dashboard-card">
                        <table class="table table-striped" id="tbNCDetalhado" name="tbNCDetalhado">
                            <thead>
                                <tr>
                                    <th>Ocorrência</th>
                                    <th>Quantidade NC</th>
                                    <th>Média Móvel</th>
                                    <th>Tendência</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
                <div class="col-6">
                    <div class="section-title">Não Conformidade - @(Session["codigo_unidade"].ToString() == "-1" ? "Unidade" : "Camareira")</div>
                    <div class="block dashboard-card">
                        <table class="table table-striped" id="tbNCCamareira" name="tbNCCamareira">
                            <thead>
                                <tr>
                                    <th>@(Session["codigo_unidade"].ToString() == "-1" ? "Unidade" : "Camareira")</th>
                                    <th>Quantidade NC</th>
                                    <th>Média Móvel</th>
                                    <th>Tendência</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>

        }

    </div>
</main>


<div id="api-urls"
     data-chart-arrumado-vistoriado="@Url.Content("~/Governanca/ChartArrumadoxVistoriado")"
     data-chart-arrumacao-dia="@Url.Content("~/Governanca/ChartArrumacaoDia")"
     data-chart-vistoria-dia="@Url.Content("~/Governanca/ChartVistoriaDia")"
     data-chart-produtividade-camareira="@Url.Content("~/Governanca/ChartProdutividadeCamareira")"
     data-chart-produtividade-vistoriador="@Url.Content("~/Governanca/ChartProdutividadeVistoriador")"
     data-chart-nao-conformidade-tipo="@Url.Content("~/Governanca/ChartNaoConformidadeTipo")"
     data-chart-nao-conformidade-dia="@Url.Content("~/Governanca/ChartNaoConformidadeDia")"
     data-resource-checklist="@PCM.WEB.Properties.Resources.checklist"
     data-resource-resultado="@PCM.WEB.Properties.Resources.resultado"
     data-resource-observacao="@PCM.WEB.Properties.Resources.observacao"
     data-resource-enxoval="@PCM.WEB.Properties.Resources.enxoval"
     data-resource-quantidade="@PCM.WEB.Properties.Resources.quantidade"
