@using PCM.WEB.Properties

<!-- Main Container -->
<main id="main-container">
    <div class="content">

        @using (Html.BeginForm("Index", "Home",
            new { ReturnUrl = ViewBag.ReturnUrl },
            FormMethod.Post,
            new { @class = "js-validation-bootstrap", role = "form", @id = "form", enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()

            <!-- ================= FILTROS ================= -->
            <div class="dashboard-section">
                <div class="row invisible g-3" data-toggle="appear">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">@Resources.unidade</label>
                        @Html.DropDownList("unidade", null, null, new { @class = "form-control font-w600 js-select2" })
                        <input type="hidden" name="nome_fantasia" id="nome_fantasia" value="@ViewBag.nome_fantasia" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Módulo</label>
                        @Html.DropDownList("modulo", null, null, new { @class = "form-control font-w600 js-select2" })
                    </div>
                </div>
            </div>

            <!-- ================= KPIs – ORDEM DE SERVIÇO ================= -->
            <div class="dashboard-section">

                @if ((int)ViewBag.codigo_tipo_unidade == 2)
                {
                    <!-- LINHA CONDO -->
                    <div class="row invisible g-3" data-toggle="appear">
                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card"
                               href="@Url.Action("OrdemServicoInsert", "OrdemServico")">
                                <div class="kpi-header">
                                    <i class="si si-wrench kpi-icon text-primary"></i>
                                    <div class="kpi-title">@Resources.ordem_servico</div>
                                </div>
                                <div class="kpi-value">@Resources.nova</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card"
                               href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 3, responsavel_apartamento = 1 })">
                                <div class="kpi-header">
                                    <i class="fa fa-clock kpi-icon text-danger"></i>
                                    <div class="kpi-title">@Resources.quantidade_atrasada CONDO</div>
                                </div>
                                <div class="kpi-value text-danger"
                                     data-toggle="countTo"
                                     data-speed="1000"
                                     data-to="@ViewBag.InfoOrdemServico.quantidade_atrasada_condo"
                                     id="quantidade_atrasada_condo"
                                     name="quantidade_atrasada_condo">0</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card"
                               href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 1, responsavel_apartamento = 1 })">
                                <div class="kpi-header">
                                    <i class="fa fa-exclamation-circle kpi-icon text-warning"></i>
                                    <div class="kpi-title">@Resources.quantidade_pendente CONDO</div>
                                </div>
                                <div class="kpi-value text-warning"
                                     data-toggle="countTo"
                                     data-speed="1000"
                                     data-to="@ViewBag.InfoOrdemServico.quantidade_pendente_condo"
                                     id="quantidade_pendente_condo"
                                     name="quantidade_pendente_condo">0</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card"
                               href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 5, responsavel_apartamento = 1 })">
                                <div class="kpi-header">
                                    <i class="fa fa-link kpi-icon text-info"></i>
                                    <div class="kpi-title">@Resources.quantidade_vinculada CONDO</div>
                                </div>
                                <div class="kpi-value text-info">
                                    <span data-toggle="countTo"
                                          data-speed="1000"
                                          data-to="@ViewBag.InfoOrdemServico.quantidade_vinculada_condo"
                                          id="quantidade_vinculada_condo"
                                          name="quantidade_vinculada_condo">0</span>
                                </div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card"
                               href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 4, responsavel_apartamento = 1 })">
                                <div class="kpi-header">
                                    <i class="fa fa-spinner kpi-icon text-primary"></i>
                                    <div class="kpi-title">@Resources.quantidade_andamento CONDO</div>
                                </div>
                                <div class="kpi-value text-primary">
                                    <span data-toggle="countTo"
                                          data-speed="1000"
                                          data-to="@ViewBag.InfoOrdemServico.quantidade_andamento_condo"
                                          id="quantidade_andamento_condo"
                                          name="quantidade_andamento_condo">0</span>
                                </div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card"
                               href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 2, responsavel_apartamento = 1 })">
                                <div class="kpi-header">
                                    <i class="fa fa-check-circle kpi-icon text-success"></i>
                                    <div class="kpi-title">@Resources.quantidade_realizada CONDO</div>
                                </div>
                                <div class="kpi-value text-success">
                                    <span data-toggle="countTo"
                                          data-speed="1000"
                                          data-to="@ViewBag.InfoOrdemServico.quantidade_concluida_condo"
                                          id="quantidade_realizada_condo"
                                          name="quantidade_realizada_condo">0</span>
                                </div>
                            </a>
                        </div>
                    </div>

                    <!-- LINHA POOL -->
                    <div class="row invisible g-3" data-toggle="appear">
                        <div class="col-xl-2 col-md-4 col-6"></div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card"
                               href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 3, responsavel_apartamento = 2 })">
                                <div class="kpi-header">
                                    <i class="fa fa-clock kpi-icon text-danger"></i>
                                    <div class="kpi-title">@Resources.quantidade_atrasada POOL</div>
                                </div>
                                <div class="kpi-value text-danger"
                                     data-toggle="countTo"
                                     data-speed="1000"
                                     data-to="@ViewBag.InfoOrdemServico.quantidade_atrasada_pool"
                                     id="quantidade_atrasada_pool"
                                     name="quantidade_atrasada_pool">0</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card"
                               href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 1, responsavel_apartamento = 2 })">
                                <div class="kpi-header">
                                    <i class="fa fa-exclamation-circle kpi-icon text-warning"></i>
                                    <div class="kpi-title">@Resources.quantidade_pendente POOL</div>
                                </div>
                                <div class="kpi-value text-warning"
                                     data-toggle="countTo"
                                     data-speed="1000"
                                     data-to="@ViewBag.InfoOrdemServico.quantidade_pendente_pool"
                                     id="quantidade_pendente_pool"
                                     name="quantidade_pendente_pool">0</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card"
                               href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 5, responsavel_apartamento = 2 })">
                                <div class="kpi-header">
                                    <i class="fa fa-link kpi-icon text-info"></i>
                                    <div class="kpi-title">@Resources.quantidade_vinculada POOL</div>
                                </div>
                                <div class="kpi-value text-info">
                                    <span data-toggle="countTo"
                                          data-speed="1000"
                                          data-to="@ViewBag.InfoOrdemServico.quantidade_vinculada_pool"
                                          id="quantidade_vinculada_pool"
                                          name="quantidade_vinculada_pool">0</span>
                                </div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card"
                               href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 4, responsavel_apartamento = 2 })">
                                <div class="kpi-header">
                                    <i class="fa fa-spinner kpi-icon text-primary"></i>
                                    <div class="kpi-title">@Resources.quantidade_andamento POOL</div>
                                </div>
                                <div class="kpi-value text-primary">
                                    <span data-toggle="countTo"
                                          data-speed="1000"
                                          data-to="@ViewBag.InfoOrdemServico.quantidade_andamento_pool"
                                          id="quantidade_andamento_pool"
                                          name="quantidade_andamento_pool">0</span>
                                </div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card"
                               href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 2, responsavel_apartamento = 2 })">
                                <div class="kpi-header">
                                    <i class="fa fa-check-circle kpi-icon text-success"></i>
                                    <div class="kpi-title">@Resources.quantidade_realizada POOL</div>
                                </div>
                                <div class="kpi-value text-success">
                                    <span data-toggle="countTo"
                                          data-speed="1000"
                                          data-to="@ViewBag.InfoOrdemServico.quantidade_concluida_pool"
                                          id="quantidade_realizada_pool"
                                          name="quantidade_realizada_pool">0</span>
                                </div>
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <!-- LINHA PADRÃO (POOL) -->
                    <div class="row invisible g-3" data-toggle="appear">
                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card"
                               href="@Url.Action("OrdemServicoInsert", "OrdemServico")">
                                <div class="kpi-header">
                                    <i class="si si-wrench kpi-icon text-primary"></i>
                                    <div class="kpi-title">@Resources.ordem_servico</div>
                                </div>
                                <div class="kpi-value">@Resources.nova</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card"
                               href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 3, responsavel_apartamento = 2 })">
                                <div class="kpi-header">
                                    <i class="fa fa-clock kpi-icon text-danger"></i>
                                    <div class="kpi-title">@Resources.quantidade_atrasada</div>
                                </div>
                                <div class="kpi-value text-danger"
                                     data-toggle="countTo"
                                     data-speed="1000"
                                     data-to="@ViewBag.InfoOrdemServico.quantidade_atrasada_pool"
                                     id="quantidade_atrasada_pool"
                                     name="quantidade_atrasada_pool">0</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card"
                               href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 1, responsavel_apartamento = 2 })">
                                <div class="kpi-header">
                                    <i class="fa fa-exclamation-circle kpi-icon text-warning"></i>
                                    <div class="kpi-title">@Resources.quantidade_pendente</div>
                                </div>
                                <div class="kpi-value text-warning"
                                     data-toggle="countTo"
                                     data-speed="1000"
                                     data-to="@ViewBag.InfoOrdemServico.quantidade_pendente_pool"
                                     id="quantidade_pendente_pool"
                                     name="quantidade_pendente_pool">0</div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card"
                               href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 5, responsavel_apartamento = 2 })">
                                <div class="kpi-header">
                                    <i class="fa fa-link kpi-icon text-info"></i>
                                    <div class="kpi-title">@Resources.quantidade_vinculada</div>
                                </div>
                                <div class="kpi-value text-info">
                                    <span data-toggle="countTo"
                                          data-speed="1000"
                                          data-to="@ViewBag.InfoOrdemServico.quantidade_vinculada_pool"
                                          id="quantidade_vinculada_pool"
                                          name="quantidade_vinculada_pool">0</span>
                                </div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card"
                               href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 4, responsavel_apartamento = 2 })">
                                <div class="kpi-header">
                                    <i class="fa fa-spinner kpi-icon text-primary"></i>
                                    <div class="kpi-title">@Resources.quantidade_andamento</div>
                                </div>
                                <div class="kpi-value text-primary">
                                    <span data-toggle="countTo"
                                          data-speed="1000"
                                          data-to="@ViewBag.InfoOrdemServico.quantidade_andamento_pool"
                                          id="quantidade_andamento_pool"
                                          name="quantidade_andamento_pool">0</span>
                                </div>
                            </a>
                        </div>

                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card"
                               href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 2, responsavel_apartamento = 2 })">
                                <div class="kpi-header">
                                    <i class="fa fa-check-circle kpi-icon text-success"></i>
                                    <div class="kpi-title">@Resources.quantidade_realizada</div>
                                </div>
                                <div class="kpi-value text-success">
                                    <span data-toggle="countTo"
                                          data-speed="1000"
                                          data-to="@ViewBag.InfoOrdemServico.quantidade_concluida_pool"
                                          id="quantidade_realizada_pool"
                                          name="quantidade_realizada_pool">0</span>
                                </div>
                            </a>
                        </div>
                    </div>
                }
            </div>

            <!-- ================= KPIs – GAUGES (EASY PIE CHART) ================= -->
            <div class="dashboard-section">
                <div class="row invisible g-3" data-toggle="appear">

                    @if ((bool)ViewBag.dashboard_preventiva)
                    {
                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card" href="@Url.Action("ManutencaoPreventiva", "PCM")">
                                <div class="kpi-title">Preventiva</div>
                                <div class="kpi-subtitle">@Resources.visualizar</div>

                                <div class="js-pie-chart pie-chart"
                                     data-percent="@ViewBag.ChartGauge.preventiva"
                                     data-line-width="4"
                                     data-size="120"
                                     data-bar-color="@ViewBag.ChartGauge.cor_preventiva"
                                     data-track-color="rgba(2,2,2,.25)"
                                     data-scale-color="rgba(2,2,2,.5)">
                                    <span class="kpi-gauge-value" style="color:@ViewBag.ChartGauge.cor_preventiva">
                                        @ViewBag.ChartGauge.preventiva
                                    </span>
                                </div>
                            </a>
                        </div>
                    }

                    @if ((bool)ViewBag.dashboard_laudo)
                    {
                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card" href="@Url.Action("ManutencaoLaudo", "PCM")">
                                <div class="kpi-title">Laudo</div>
                                <div class="kpi-subtitle">@Resources.visualizar</div>

                                <div class="js-pie-chart pie-chart"
                                     data-percent="@ViewBag.ChartGauge.laudo"
                                     data-line-width="4"
                                     data-size="120"
                                     data-bar-color="@ViewBag.ChartGauge.cor_laudo"
                                     data-track-color="rgba(2,2,2,.25)"
                                     data-scale-color="rgba(2,2,2,.5)">
                                    <span class="kpi-gauge-value" style="color:@ViewBag.ChartGauge.cor_laudo">
                                        @ViewBag.ChartGauge.laudo
                                    </span>
                                </div>
                            </a>
                        </div>
                    }

                    @if ((bool)ViewBag.dashboard_rotina)
                    {
                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card" href="@Url.Action("ManutencaoRotina", "PCM")">
                                <div class="kpi-title">Rotinas do dia</div>
                                <div class="kpi-subtitle">@Resources.visualizar</div>

                                <div class="js-pie-chart pie-chart"
                                     data-percent="@ViewBag.ChartGauge.rotina"
                                     data-line-width="4"
                                     data-size="120"
                                     data-bar-color="@ViewBag.ChartGauge.cor_rotina"
                                     data-track-color="rgba(2,2,2,.25)"
                                     data-scale-color="rgba(2,2,2,.5)">
                                    <span class="kpi-gauge-value" style="color:@ViewBag.ChartGauge.cor_rotina">
                                        @ViewBag.ChartGauge.rotina
                                    </span>
                                </div>
                            </a>
                        </div>
                    }

                    @if ((bool)ViewBag.dashboard_pmoc)
                    {
                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card" href="@Url.Action("PMOC2", "PMOC")">
                                <div class="kpi-title">PMOC</div>
                                <div class="kpi-subtitle">@Resources.visualizar</div>

                                <div class="js-pie-chart pie-chart"
                                     data-percent="@ViewBag.ChartGauge.pmoc"
                                     data-line-width="4"
                                     data-size="120"
                                     data-bar-color="@ViewBag.ChartGauge.cor_pmoc"
                                     data-track-color="rgba(2,2,2,.25)"
                                     data-scale-color="rgba(2,2,2,.5)">
                                    <span class="kpi-gauge-value" style="color:@ViewBag.ChartGauge.cor_pmoc">
                                        @ViewBag.ChartGauge.pmoc
                                    </span>
                                </div>
                            </a>
                        </div>
                    }

                    @if ((bool)ViewBag.dashboard_uh)
                    {
                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card" href="@Url.Action("ChecklistUH", "UH")">
                                <div class="kpi-title">U.H em Dia</div>
                                <div class="kpi-subtitle">@Resources.visualizar</div>

                                <div class="js-pie-chart pie-chart"
                                     data-percent="@ViewBag.ChartGauge.uh_dia"
                                     data-line-width="4"
                                     data-size="120"
                                     data-bar-color="@ViewBag.ChartGauge.cor_uh_dia"
                                     data-track-color="rgba(2,2,2,.25)"
                                     data-scale-color="rgba(2,2,2,.5)">
                                    <span class="kpi-gauge-value" style="color:@ViewBag.ChartGauge.cor_uh_dia">
                                        @ViewBag.ChartGauge.uh_dia
                                    </span>
                                </div>
                            </a>
                        </div>
                    }

                    @if ((bool)ViewBag.dashboard_green_planet)
                    {
                        <div class="col-xl-2 col-md-4 col-6">
                            <a class="block dashboard-card kpi-card" href="@Url.Action("LancamentoIndex", "GreenPlanet")">
                                <div class="kpi-title">Green Planet</div>
                                <div class="kpi-subtitle">@Resources.visualizar</div>

                                <div class="js-pie-chart pie-chart"
                                     data-percent="@ViewBag.ChartGauge.green_planet"
                                     data-line-width="4"
                                     data-size="120"
                                     data-bar-color="@ViewBag.ChartGauge.cor_green_planet"
                                     data-track-color="rgba(2,2,2,.25)"
                                     data-scale-color="rgba(2,2,2,.5)">
                                    <span class="kpi-gauge-value" style="color:@ViewBag.ChartGauge.cor_green_planet">
                                        @ViewBag.ChartGauge.green_planet
                                    </span>
                                </div>
                            </a>
                        </div>
                    }

                </div>
            </div>

            <!-- ================= RESUMO DAS UNIDADES (somente quando unidade = -1) ================= -->
            if (Session["codigo_unidade"].ToString() == "-1")
            {
                <div class="dashboard-section">
                    <div class="section-title">Resumo das Unidades - @DateTime.Now.Date.ToString("MM/yyyy")</div>

                    <div class="block dashboard-card">
                        <table class="table table-bordered table-striped" id="tb-unidades">
                            <thead>
                                <tr>
                                    <th>@Resources.unidade</th>
                                    <th class="text-center" style="width: 120px;">Nº OS Aberto</th>
                                    <th class="text-center" style="width: 120px;">Nº OS Concluído</th>
                                    <th class="text-center" style="width: 120px;">Nº OS Pendente</th>
                                    <th class="text-center" style="width: 120px;">Laudo</th>
                                    <th class="text-center" style="width: 120px;">Preventiva</th>
                                    <th class="text-center" style="width: 120px;">Rotina</th>
                                    <th class="text-center" style="width: 120px;">PMOC</th>
                                    <th class="text-center" style="width: 120px;">UH Dia</th>
                                    <th class="text-center" style="width: 120px;">Green Planet</th>
                                </tr>
                            </thead>
                            <tbody id="tb-principais">
                                @foreach (var item in ViewBag.dashboardInfo)
                                {
                                    <tr>
                                        <td>@item.unidade</td>
                                        <td class="text-center" style="width: 120px;">@item.quantidadeOSGerada</td>
                                        <td class="text-center" style="width: 120px;">@item.quantidadeOSAtendida</td>
                                        <td class="text-center" style="width: 120px;">@item.quantidadeOSPendente</td>
                                        <td class="text-center @item.corLaudo" style="width: 120px;">@item.laudo.ToString("P2")</td>
                                        <td class="text-center @item.corPreventiva" style="width: 120px;">@item.preventiva.ToString("P2")</td>
                                        <td class="text-center @item.corRotina" style="width: 120px;">@item.rotina.ToString("P2")</td>
                                        <td class="text-center @item.corPMOC" style="width: 120px;">@item.pmoc.ToString("P2")</td>
                                        <td class="text-center @item.corUHDia" style="width: 120px;">@item.uhDia.ToString("P2")</td>
                                        <td class="text-center @item.corGreenPlanet" style="width: 120px;">@item.greenPlanet.ToString("P2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <!-- ================= GRÁFICOS – MANUTENÇÃO ABERTO x CONCLUÍDO ================= -->
            <div class="dashboard-section">
                <div class="row invisible g-3" data-toggle="appear">
                    <div class="col-md-6">
                        <div class="section-title">Gráfico - @Resources.manutencao_aberto_concluido</div>

                        <div class="block dashboard-card chart-card">
                            <div class="chart-inner">
                                <canvas id="chartManutencaoAbertoConcluido"></canvas>
                            </div>

                            <div class="row items-push mt-3">
                                <div class="col-6 col-sm-4 text-center">
                                    <div class="font-size-sm font-w600 text-uppercase text-muted">Aberto</div>
                                    <div class="font-size-h2 font-w600" style="color:rgba(255, 0, 0);" id="aberto">0</div>
                                </div>
                                <div class="col-6 col-sm-4 text-center">
                                    <div class="font-size-sm font-w600 text-uppercase text-muted">Concluído</div>
                                    <div class="font-size-h2 font-w600" style="color:rgba(34, 177, 76);" id="concluido">0</div>
                                </div>
                                <div class="col-12 col-sm-4 text-center">
                                    <div class="font-size-sm font-w600 text-uppercase text-muted">Saldo</div>
                                    <div class="font-size-h2 font-w600" style="color:rgb(255,201,14);" id="saldo">0</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ================= GRÁFICOS – TEMPO MÉDIO DE ATENDIMENTO ================= -->
                    <div class="col-md-6">
                        <div class="section-title">Gráfico - @Resources.manutencao_tempo_medio_atendimento</div>

                        <div class="block dashboard-card chart-card">
                            <div class="chart-inner">
                                <canvas id="chartManutencaoTempoMedioAtendimento"></canvas>
                            </div>

                            <div class="row items-push mt-3">
                                <div class="col-6 col-sm-2 text-center">
                                    <div class="font-size-sm font-w600 text-uppercase text-muted">NO DIA</div>
                                    <div class="font-size-h2 font-w600" style="color: rgba(34, 177, 76);" id="no_dia">0%</div>
                                </div>
                                <div class="col-6 col-sm-2 text-center">
                                    <div class="font-size-sm font-w600 text-uppercase text-muted">1 DIA</div>
                                    <div class="font-size-h2 font-w600" style="color: rgba(63, 72, 204);" id="um_dia">0%</div>
                                </div>
                                <div class="col-12 col-sm-4 text-center">
                                    <div class="font-size-sm font-w600 text-uppercase text-muted">3 DIAS</div>
                                    <div class="font-size-h2 font-w600" style="color: rgb(255,201,14);" id="tres_dia">0%</div>
                                </div>
                                <div class="col-12 col-sm-2 text-center">
                                    <div class="font-size-sm font-w600 text-uppercase text-muted">5 DIAS</div>
                                    <div class="font-size-h2 font-w600" style="color: rgba(255, 128, 0);" id="cinco_dia">0%</div>
                                </div>
                                <div class="col-12 col-sm-2 text-center">
                                    <div class="font-size-sm font-w600 text-uppercase text-muted">>5 DIAS</div>
                                    <div class="font-size-h2 font-w600" style="color: rgba(255, 0, 0);" id="mais_cinco_dia">0%</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ================= GREEN PLANET (PERFIL + UNIDADE) ================= -->
            if ((bool)Session["rel_green_planet"] && Session["codigo_unidade"].ToString() != "-1")
            {
                <div class="dashboard-section">
                    <div class="row invisible g-3" data-toggle="appear">
                        <div class="col-md-12">
                            <div class="section-title">Gráfico - @Resources.green_planet</div>

                            <div class="block dashboard-card">
                                <div class="row g-3 pt-2 pb-2">
                                    <div class="col-md-2">
                                        @Html.DropDownList("agrupado_por", null, Resources.agrupado_por, new { @class = "form-control font-w600" })
                                    </div>
                                    <div class="col-md-2">
                                        @Html.DropDownList("forma_calculo", null, Resources.forma_calculo_green_planet, new { @class = "form-control font-w600" })
                                    </div>
                                    <div class="col-md-4">
                                        @Html.DropDownList("grupo_item_medicao", null, Resources.grupo_item_medicao, new { @class = "form-control font-w600" })
                                    </div>

                                    <div class="col-md-4">
                                        <div class="input-daterange input-group"
                                             data-date-format="dd/mm/yyyy"
                                             data-week-start="1"
                                             data-autoclose="true"
                                             data-today-highlight="true">
                                            <input type="text" class="form-control" id="data_inicio" name="data_inicio" placeholder="De"
                                                   value="@ViewBag.data_inicio">
                                            <span class="input-group-text font-w600">-</span>
                                            <input type="text" class="form-control" id="data_termino" name="data_termino" placeholder="Até"
                                                   value="@ViewBag.data_termino">
                                            <button type="button" class="btn btn-secondary fa fa-refresh"
                                                    onclick="refreshGreenPlanet();"
                                                    id="btnRefreshGreenPlanet"
                                                    name="btnRefreshGreenPlanet"></button>
                                        </div>
                                    </div>
                                </div>

                                <hr />

                                <div class="chart-inner">
                                    <canvas id="chartGreenPlanet" height="70px"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- ================= PRINCIPAIS OCORRÊNCIAS ================= -->
            <div class="dashboard-section">
                <div class="row invisible" data-toggle="appear">
                    <div class="col-12">
                        <div class="section-title d-flex align-items-center justify-content-between">
                            <span>Principais Ocorrências</span>

                            <div class="btn-group" role="group">
                                <button type="button" class="btn btn-sm btn-secondary" onclick="PrincipaisOcorrencias(1);">Dia Anterior</button>
                                <button type="button" class="btn btn-sm btn-secondary" onclick="PrincipaisOcorrencias(7);">Semana</button>
                                <button type="button" class="btn btn-sm btn-secondary" onclick="PrincipaisOcorrencias(30);">Mês</button>
                                <button type="button" class="btn btn-sm btn-secondary" onclick="PrincipaisOcorrencias(365);">Ano</button>
                            </div>
                        </div>

                        <div class="block dashboard-card">
                            <table class="table table-striped" id="tb-principais-ocorrencias">
                                <thead>
                                    <tr>
                                        <th class="text-center" style="width: 100px;">#</th>
                                        <th>@Resources.equipamento</th>
                                        <th class="text-center" style="width: 150px;">Quantidade</th>
                                    </tr>
                                </thead>
                                <tbody id="tb-principais-ocorrencias-body">
                                    @foreach (var item in ViewBag.PrincipaisOcorrencias)
                                    {
                                        <tr>
                                            <td class="text-center" style="width: 100px;">@item.item</td>
                                            <td class="font-w600">@item.local</td>
                                            <td class="text-center">@item.quantidade</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>
            </div>

        }

    </div>

    <!-- From Right Modal (LOGBOOK) -->
    <div class="modal fade" id="modal-fromright" tabindex="-1" role="dialog" aria-labelledby="modal-fromright" aria-hidden="true">
        <div class="modal-dialog modal-dialog-fromright" role="document">
            <div class="modal-content">
                <div class="block block-themed block-transparent mb-0">
                    <div class="block-header bg-primary-dark">
                        <h3 class="block-title">@Resources.log_book</h3>
                    </div>
                    <div class="block-content">
                        <textarea type="text" class="form-control"
                                  id="informacao"
                                  name="informacao"
                                  value="@ViewBag.InfoOrdemServico.log_book"
                                  maxlength="5000"
                                  rows="15">@ViewBag.InfoOrdemServico.log_book</textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn bg-gray-light" onclick="confirmLogBook();" data-bs-dismiss="modal">
                        <i class="fa fa-check"></i>@Resources.confirmado
                    </button>
                </div>
            </div>
        </div>
    </div>
    <!-- END From Right Modal -->

</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/dashboard")
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/dataTables")
    @Styles.Render("~/Content/select")

    <!-- Se você tiver o bundle do dashboard (igual o IndexGovernanca), ajuda MUITO no visual -->
    @* @Styles.Render("~/Content/dashboard") *@

    <!-- (Opcional) animate.css se quiser animação nas notificações -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
}

@section Scripts {
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/chart")
    @Scripts.Render("~/plugins/gauge")
    @Scripts.Render("~/plugins/select")
    @Scripts.Render("~/plugins/easy_pie_chart")

    <script src="https://cdnjs.cloudflare.com/ajax/libs/remarkable-bootstrap-notify/3.1.3/bootstrap-notify.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <script>
        var informacao = $("#informacao");
        var unidade = $("#unidade");
        var modulo = $("#modulo");
        var nome_fantasia = $("#nome_fantasia");
        var agrupado_por = $("#agrupado_por");
        var forma_calculo = $("#forma_calculo");
        var grupo_item_medicao = $("#grupo_item_medicao");
        var data_inicio = $("#data_inicio");
        var data_termino = $("#data_termino");

        var colorNamesAbertoConcluido = Object.keys(window.chartColors);
        var colorNamesTempoMedioAtendimento = Object.keys(window.chartColors);
        var colorNamesGreenPlanet = Object.keys(window.chartColors);

        $(document).ready(function () {
            if (informacao.val() != "") {
                jQuery('#modal-fromright').modal('show');
            }
        });

        $(function () {
            unidade.change(function () { $("#form").submit(); });
            modulo.change(function () { $("#form").submit(); });
        });

        function refreshGreenPlanet() {
            configGreenPlanet.data.labels = [];
            configGreenPlanet.data.datasets = [];
            LoadChartGreenPlanet();
        };

        function confirmLogBook() {
            $.post("Home/ConfirmLogBook");
        }

        var configTempoMedioAtendimento = {
            type: 'horizontalBar',
            options: {
                responsive: true,
                data: {
                    datasets: [{ data: [], backgroundColor: [] }],
                    labels: []
                },
                legend: {
                    display: false,
                    labels: { padding: 20 },
                    position: 'bottom',
                },
                title: { display: false },
                animation: { animateScale: true, animateRotate: true },
                tooltips: { enabled: true }
            }
        };

        var configAbertoConcluido = {
            type: 'line',
            options: {
                responsive: true,
                data: {
                    datasets: [{ data: [], backgroundColor: [] }],
                    labels: []
                },
                legend: { display: false, position: 'bottom' },
                title: { display: false },
                animation: { animateScale: true, animateRotate: true }
            }
        };

        var configGreenPlanet = {
            type: 'line',
            data: { labels: [] },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: false,
                scales: {
                    xAxes: [{
                        ticks: {
                            autoSkip: true,
                            maxTicksLimit: 12,
                            maxRotation: 45,
                            minRotation: 45
                        }
                    }],
                    yAxes: [{
                        ticks: {
                            beginAtZero: true
                        }
                    }]
                },
                legend: {
                    position: 'right'
                }
            }

        };

        function LoadChartManutencaoTempoMedioAtendimento() {
            var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val(), "ano": new Date().getFullYear() };

            $.post("@Url.Content("~/Relatorio/ChartManutencaoTempoMedioAtendimento")", request, function (obj) {
                var newDataset = { label: [], data: [], backgroundColor: [], fill: false };

                $.each(obj, function (indice, result) {
                    switch (result.tipo) {
                        case 'NO DIA':
                            colorName = 'rgba(34, 177, 76, 0.7)';
                            $("#no_dia").text(result.valor + '%');
                            break;
                        case '1 DIA':
                            colorName = 'rgba(63, 72, 204, 0.7)';
                            $("#um_dia").text(result.valor + '%');
                            break;
                        case '3 DIAS':
                            colorName = 'rgba(255, 201, 14, 0.7)';
                            $("#tres_dia").text(result.valor + '%');
                            break;
                        case '5 DIAS':
                            colorName = 'rgba(255, 128, 0, 0.7)';
                            $("#cinco_dia").text(result.valor + '%');
                            break;
                        case '> 5 DIAS':
                            colorName = 'rgba(255, 0, 0, 0.7)';
                            $("#mais_cinco_dia").text(result.valor + '%');
                            break;
                    }

                    configTempoMedioAtendimento.data.labels.push(result.tipo);
                    newDataset.data.push(Number(result.valor));
                    newDataset.backgroundColor.push(colorName);
                });

                configTempoMedioAtendimento.data.datasets.push(newDataset);
                window.TempoMedioAtendimento.update();
            }, "json");
        }

        function LoadChartManutencaoAbertoConcluido() {
            var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val(), "data_inicio": "@ViewBag.data_inicio", "data_termino": new Date().toDateString() };

            $.post("@Url.Content("~/Relatorio/ChartManutencaoAbertoConcluido")", request, function (obj) {

                var Aberto = {
                    label: 'Aberto',
                    data: [],
                    fill: false,
                    backgroundColor: 'rgba(255, 0, 0, 0.7)',
                    borderColor: 'rgba(255, 0, 0, 1)',
                    pointBorderColor: 'rgba(255, 0, 0, 1)',
                };

                var Concluido = {
                    label: 'Concluído',
                    data: [],
                    fill: false,
                    backgroundColor: 'rgba(34, 177, 76, 0.7)',
                    borderColor: 'rgba(34, 177, 76, 1)',
                    pointBorderColor: 'rgba(34, 177, 76, 1)',
                };

                var Saldo = {
                    label: 'Saldo',
                    data: [],
                    fill: true,
                    backgroundColor: 'rgba(255, 201, 14, 0.1)',
                    borderColor: 'rgba(255, 201, 14, 0.6)',
                    pointBorderColor: 'rgba(255, 201, 14, 0.6)',
                };

                $.each(obj, function (indice, result) {
                    configAbertoConcluido.data.labels.push(result.data);
                    Aberto.data.push(result.aberto);
                    Concluido.data.push(result.concluido);
                    Saldo.data.push(result.saldo);
                    $("#aberto").text(result.aberto);
                    $("#concluido").text(result.concluido);
                    $("#saldo").text(result.saldo);
                });

                configAbertoConcluido.data.datasets.push(Aberto);
                configAbertoConcluido.data.datasets.push(Concluido);
                configAbertoConcluido.data.datasets.push(Saldo);
                window.AbertoConcluido.update();
            }, "json");
        }

        function LoadChartGreenPlanet() {
            var session_unidade = '@Session["codigo_unidade"]';
            var unidade = $("#unidade");
            var agrupado_por = $("#agrupado_por");
            var forma_calculo = $("#forma_calculo");
            var grupo_item_medicao = $("#grupo_item_medicao");
            var data_inicio = $("#data_inicio");
            var data_termino = $("#data_termino");

            if ((session_unidade != "-1" || unidade.val() != "-1") && grupo_item_medicao.val() != null) {
                var request = {
                    "data_inicio": data_inicio.val(),
                    "data_termino": data_termino.val(),
                    "unidade": (session_unidade == "-1") ? unidade.val() : session_unidade,
                    "forma_calculo": forma_calculo.val(),
                    "agrupado_por": agrupado_por.val(),
                    "grupo_item_medicao": grupo_item_medicao.val(),
                    "item_medicao": "-1"
                };

                $.post("@Url.Content("~/Relatorio/ChartGreenPlanetData")", request, function (obj) {
                    $.each(obj, function (indice, result) { configGreenPlanet.data.labels.push(result); });
                }, "json");

                $.post("@Url.Content("~/Relatorio/ChartGreenPlanet")", request, function (obj) {
                    if (obj.length == 0) {
                        configGreenPlanet.data.labels = [];
                        configGreenPlanet.data.datasets = [];
                        window.GreenPlanet.update();
                    } else {
                        $.each(obj, function (indice, result) {
                            var colorName = colorNamesGreenPlanet[configGreenPlanet.data.datasets.length % colorNamesGreenPlanet.length];
                            var newColor = window.chartColors[colorName];
                            var borderColor = window.chartBorderColors[colorName];

                            var newDataset = {
                                label: result.item_medicao,
                                backgroundColor: newColor,
                                borderColor: borderColor,
                                data: [],
                                fill: false
                            };

                            for (var index = 0; index < result.valor.length; ++index) {
                                newDataset.data.push(result.valor[index]);
                            }

                            configGreenPlanet.data.datasets.push(newDataset);
                            window.GreenPlanet.update();
                        });
                    }
                }, "json");

            } else {
                configGreenPlanet.data.labels = [];
                configGreenPlanet.data.datasets = [];
                window.GreenPlanet.update();
            }
        }

        function PrincipaisOcorrencias(quantidade) {
            var dataString = { "unidade": unidade.val(), "quantidade": quantidade, "qualidade": false };
            $("#tb-principais-ocorrencias-body").empty();

            jQuery.ajax({
                type: "POST",
                url: "@Url.Content("Home/PrincipaisOcorrencias")",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (response) {
                    for (var i = 0; i < response.length; i++) {
                        var newRowItem = $("<tr>");
                        newRowItem.append('<td class="text-center" style="width: 100px;">' + response[i].item + '</td>');
                        newRowItem.append('<td class="font-w600">' + response[i].local + '</td>');
                        newRowItem.append('<td class="text-center">' + response[i].quantidade + '</td>');
                        $("#tb-principais-ocorrencias").append(newRowItem);
                    }
                }
            });
        }

        window.onload = function () {
            var cManutencaoTempoMedioAtencimento = document.getElementById('chartManutencaoTempoMedioAtendimento').getContext('2d');
            window.TempoMedioAtendimento = new Chart(cManutencaoTempoMedioAtencimento, configTempoMedioAtendimento);

            var cManutencaoAbertoConcluido = document.getElementById('chartManutencaoAbertoConcluido').getContext('2d');
            window.AbertoConcluido = new Chart(cManutencaoAbertoConcluido, configAbertoConcluido);

            if ('@Session["rel_green_planet"]' == 'True' && '@Session["codigo_unidade"].ToString()' != '-1') {
                var cGreenPlanet = document.getElementById('chartGreenPlanet').getContext('2d');
                window.GreenPlanet = new Chart(cGreenPlanet, configGreenPlanet);
            }
        };

        jQuery(function () {
            LoadChartManutencaoTempoMedioAtendimento();
            LoadChartManutencaoAbertoConcluido();
            Codebase.helpers(['datepicker', 'maxlength', 'select2', 'easy-pie-chart']);
        });

        (function ($) {
            if (!$.notify && $.bootstrapGrowl) {
                $.notify = function (opts, cfg) {
                    var msg = (opts && (opts.message || opts.title)) || String(opts || '');
                    var type = (cfg && cfg.type) || 'info';
                    var from = cfg && cfg.placement && cfg.placement.from || 'top';
                    var align = cfg && cfg.placement && cfg.placement.align || 'right';
                    var delay = (cfg && cfg.delay != null) ? cfg.delay : 5000;
                    var allow = (cfg && cfg.allow_dismiss != null) ? cfg.allow_dismiss : true;

                    $.bootstrapGrowl(msg, {
                        type: type,
                        allow_dismiss: allow,
                        align: align,
                        offset: (typeof cfg?.offset === 'number') ? { from: from, amount: cfg.offset } :
                            (cfg?.offset ? { from: from, amount: cfg.offset } : { from: from, amount: 20 }),
                        delay: delay,
                        stackup_spacing: cfg?.spacing || 10,
                        width: 'auto'
                    });
                };
            }
        })(jQuery);

        setTimeout(function () {
            location.reload();
        }, 60000);
    </script>
}
