<!-- Main Container -->
<main id="main-container">
    <div class="content">

        @using (Html.BeginForm("Index2", "Home", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", @id = "form", enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()

            <!-- ================= INDICADOR DE ATUALIZAÇÃO ================= -->
            <div id="refresh-indicator" class="refresh-indicator" title="Atualizando em breve">
                <i class="fa fa-refresh refresh-icon"></i>
                <span>Atualiza em <strong id="refresh-countdown">60s</strong></span>
            </div>

            <!-- ================= KPIs – ORDEM DE SERVIÇO (faixa horizontal) ================= -->
            if ((int)ViewBag.codigo_tipo_unidade == 2)
            {
                <!-- CONDO -->
                <div class="dashboard-section">
                    <div class="section-title">Condomínio</div>
                    <div class="block dashboard-card" style="padding:0; overflow:hidden;">
                        <div class="torre-comando-grid">
                            <a href="@Url.Action("OrdemServicoInsert", "OrdemServico", new { status = 3, responsavel_apartamento = 1 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-danger"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.ordem_servico</span>
                                </div>
                                <div class="os-value text-primary">NOVA</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 3, responsavel_apartamento = 1 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-danger"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.quantidade_atrasada</span>
                                </div>
                                <div class="os-value text-danger" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_atrasada_condo" id="quantidade_atrasada_condo">0</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 1, responsavel_apartamento = 1 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-warning"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.quantidade_pendente</span>
                                </div>
                                <div class="os-value text-warning" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_pendente_condo" id="quantidade_pendente_condo">0</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 5, responsavel_apartamento = 1 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-info"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.quantidade_vinculada</span>
                                </div>
                                <div class="os-value text-info" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_vinculada_condo" id="quantidade_vinculada_condo">0</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 4, responsavel_apartamento = 1 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-primary"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.quantidade_andamento</span>
                                </div>
                                <div class="os-value text-primary" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_andamento_condo" id="quantidade_andamento_condo">0</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 2, responsavel_apartamento = 1 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-check-circle torre-icon text-earth"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.quantidade_realizada</span>
                                </div>
                                <div class="os-value text-earth" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_concluida_condo" id="quantidade_realizada_condo">0</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 0, responsavel_apartamento = 1 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-clock-o torre-icon text-muted"></i>
                                    <span class="torre-label">Backlog</span>
                                </div>
                                <div class="os-value text-muted" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_backlog_condo" id="quantidade_backlog_condo">0</div>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- POOL -->
                <div class="dashboard-section">
                    <div class="section-title">Pool</div>
                    <div class="block dashboard-card" style="padding:0; overflow:hidden;">
                        <div class="torre-comando-grid">
                            <a href="@Url.Action("OrdemServicoInsert", "OrdemServico", new { status = 3, responsavel_apartamento = 1 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-danger"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.ordem_servico</span>
                                </div>
                                <div class="os-value text-primary">NOVA</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 3, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-danger"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.quantidade_atrasada</span>
                                </div>
                                <div class="os-value text-danger" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_atrasada_pool" id="quantidade_atrasada_pool">0</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 1, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-warning"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.quantidade_pendente</span>
                                </div>
                                <div class="os-value text-warning" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_pendente_pool" id="quantidade_pendente_pool">0</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 5, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-info"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.quantidade_vinculada</span>
                                </div>
                                <div class="os-value text-info" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_vinculada_pool" id="quantidade_vinculada_pool">0</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 4, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-primary"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.quantidade_andamento</span>
                                </div>
                                <div class="os-value text-primary" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_andamento_pool" id="quantidade_andamento_pool">0</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 2, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-check-circle torre-icon text-earth"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.quantidade_realizada</span>
                                </div>
                                <div class="os-value text-earth" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_concluida_pool" id="quantidade_realizada_pool">0</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 0, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-clock-o torre-icon text-muted"></i>
                                    <span class="torre-label">Backlog</span>
                                </div>
                                <div class="os-value text-muted" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_backlog_pool" id="quantidade_backlog_pool">0</div>
                            </a>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="dashboard-section">
                    <div class="section-title">Ordem de Serviço</div>
                    <div class="block dashboard-card" style="padding:0; overflow:hidden;">
                        <div class="torre-comando-grid">
                            <a href="@Url.Action("OrdemServicoInsert", "OrdemServico", new { status = 3, responsavel_apartamento = 1 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-danger"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.ordem_servico</span>
                                </div>
                                <div class="os-value text-primary">NOVA</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 3, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-danger"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.quantidade_atrasada</span>
                                </div>
                                <div class="os-value text-danger" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_atrasada_pool" id="quantidade_atrasada_pool">0</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 1, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-warning"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.quantidade_pendente</span>
                                </div>
                                <div class="os-value text-warning" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_pendente_pool" id="quantidade_pendente_pool">0</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 5, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-info"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.quantidade_vinculada</span>
                                </div>
                                <div class="os-value text-info" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_vinculada_pool" id="quantidade_vinculada_pool">0</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 4, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-gear torre-icon text-primary"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.quantidade_andamento</span>
                                </div>
                                <div class="os-value text-primary" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_andamento_pool" id="quantidade_andamento_pool">0</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 2, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-check-circle torre-icon text-earth"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.quantidade_realizada</span>
                                </div>
                                <div class="os-value text-earth" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_concluida_pool" id="quantidade_realizada_pool">0</div>
                            </a>
                            <a href="@Url.Action("OrdemServicoIndex2", "OrdemServico", new { status = 0, responsavel_apartamento = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-clock-o torre-icon text-muted"></i>
                                    <span class="torre-label">Backlog</span>
                                </div>
                                <div class="os-value text-muted" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.InfoOrdemServico.quantidade_backlog_pool" id="quantidade_backlog_pool">0</div>
                            </a>
                        </div>
                    </div>
                </div>
            }

            <!-- ================= PAINEL DE CONTROLE – INDICADORES ================= -->
            var gaugeItems = new List<dynamic>();
            if ((bool)ViewBag.dashboard_preventiva) { gaugeItems.Add(new { id = "torre-preventiva", label = "Preventiva", icon = "fa-wrench", valor = (float)ViewBag.ChartGauge.preventiva, cor = (string)ViewBag.ChartGauge.cor_preventiva, url = Url.Action("ManutencaoPreventiva", "PCM") }); }
            if ((bool)ViewBag.dashboard_laudo) { gaugeItems.Add(new { id = "torre-laudo", label = "Laudo", icon = "fa-file-text-o", valor = (float)ViewBag.ChartGauge.laudo, cor = (string)ViewBag.ChartGauge.cor_laudo, url = Url.Action("ManutencaoLaudo", "PCM") }); }
            if ((bool)ViewBag.dashboard_rotina) { gaugeItems.Add(new { id = "torre-rotina", label = "Rotinas", icon = "fa-calendar-check-o", valor = (float)ViewBag.ChartGauge.rotina, cor = (string)ViewBag.ChartGauge.cor_rotina, url = Url.Action("ManutencaoRotina", "PCM") }); }
            if ((bool)ViewBag.dashboard_pmoc) { gaugeItems.Add(new { id = "torre-pmoc", label = "PMOC", icon = "fa-snowflake-o", valor = (float)ViewBag.ChartGauge.pmoc, cor = (string)ViewBag.ChartGauge.cor_pmoc, url = Url.Action("PMOC2", "PMOC") }); }
            if ((bool)ViewBag.dashboard_uh) { gaugeItems.Add(new { id = "torre-uh", label = "U.H em Dia", icon = "fa-bed", valor = (float)ViewBag.ChartGauge.uh_dia, cor = (string)ViewBag.ChartGauge.cor_uh_dia, url = Url.Action("ChecklistUH", "UH") }); }
            if ((bool)ViewBag.dashboard_green_planet) { gaugeItems.Add(new { id = "torre-green", label = "Green Planet", icon = "fa-leaf", valor = (float)ViewBag.ChartGauge.green_planet, cor = (string)ViewBag.ChartGauge.cor_green_planet, url = Url.Action("LancamentoIndex", "GreenPlanet") }); }

            if (gaugeItems.Any())
            {
                <div class="dashboard-section">
                    <div class="section-title">Painel de Controle</div>
                    <div class="block dashboard-card" style="padding:0; overflow:hidden;">
                        <div class="torre-comando-grid">
                            @foreach (var g in gaugeItems)
                            {
                                var pct = Math.Round((double)g.valor, 1);
                                var pctInt = (int)Math.Round((double)g.valor);
                                var status = pct < 65 ? "Crítico" : pct > 85 ? "Meta atingida" : "Em andamento";
                                <a href="@g.url" class="torre-item" id="@g.id" style="text-decoration:none;">
                                    <div class="torre-header">
                                        <i class="fa @g.icon torre-icon" style="color:@g.cor"></i>
                                        <span class="torre-label">@g.label</span>
                                        <span class="torre-pct" style="color:@g.cor">@pct%</span>
                                    </div>
                                    <div class="torre-bar-track">
                                        <div class="torre-bar-fill" style="width:@pctInt%; background:@g.cor;"></div>
                                    </div>
                                    <div class="torre-meta">
                                        <span>@status</span>
                                        <span class="torre-link">Ver detalhes →</span>
                                    </div>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- ================= RESUMO DAS UNIDADES (multi-unidade) ================= -->
            if (@Session["codigo_unidade"].ToString() == "-1")
            {
                <div class="dashboard-section">
                    <div class="section-title">Resumo das Unidades - @DateTime.Now.Date.ToString("MM/yyyy")</div>
                    <div class="block dashboard-card">
                        <table class="table table-bordered table-striped" id="tb-unidades">
                            <thead>
                                <tr>
                                    <th>@PCM.WEB.Properties.Resources.unidade</th>
                                    <th class="text-center">Nº OS Aberto</th>
                                    <th class="text-center">Nº OS Concluído</th>
                                    <th class="text-center">Nº OS Pendente</th>
                                    <th class="text-center">Laudo</th>
                                    <th class="text-center">Preventiva</th>
                                    <th class="text-center">Rotina</th>
                                    <th class="text-center">PMOC</th>
                                    <th class="text-center">UH Dia</th>
                                    <th class="text-center">Green Planet</th>
                                </tr>
                            </thead>
                            <tbody id="tb-principais">
                                @foreach (var item in ViewBag.dashboardInfo)
                                {
                                    <tr>
                                        <td>@item.unidade</td>
                                        <td class="text-center">@item.quantidadeOSGerada</td>
                                        <td class="text-center">@item.quantidadeOSAtendida</td>
                                        <td class="text-center">@item.quantidadeOSPendente</td>
                                        <td class="text-center @item.corLaudo">@item.laudo.ToString("P2")</td>
                                        <td class="text-center @item.corPreventiva">@item.preventiva.ToString("P2")</td>
                                        <td class="text-center @item.corRotina">@item.rotina.ToString("P2")</td>
                                        <td class="text-center @item.corPMOC">@item.pmoc.ToString("P2")</td>
                                        <td class="text-center @item.corUHDia">@item.uhDia.ToString("P2")</td>
                                        <td class="text-center @item.corGreenPlanet">@item.greenPlanet.ToString("P2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <!-- ================= GRÁFICOS PRINCIPAIS ================= -->
            <div class="dashboard-section row invisible" data-toggle="appear">

                <div class="col-md-6 d-flex flex-column">
                    <div class="section-title">@PCM.WEB.Properties.Resources.manutencao_aberto_concluido</div>
                    <div class="block dashboard-card chart-card flex-fill">
                        <div class="chart-wrapper">
                            <canvas id="chartManutencaoAbertoConcluido"></canvas>
                        </div>
                        <div class="row mt-3 text-center">
                            <div class="col-4">
                                <div class="kpi-title">Aberto</div>
                                <div class="kpi-value" style="color:rgba(255,0,0);" id="aberto">0</div>
                            </div>
                            <div class="col-4">
                                <div class="kpi-title">Concluído</div>
                                <div class="kpi-value" style="color:rgba(34,177,76);" id="concluido">0</div>
                            </div>
                            <div class="col-4">
                                <div class="kpi-title">Saldo</div>
                                <div class="kpi-value" style="color:rgb(255,201,14);" id="saldo">0</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 d-flex flex-column">
                    <div class="section-title">@PCM.WEB.Properties.Resources.manutencao_tempo_medio_atendimento</div>
                    <div class="block dashboard-card chart-card flex-fill">
                        <div class="chart-wrapper">
                            <canvas id="chartManutencaoTempoMedioAtendimento"></canvas>
                        </div>
                        <div class="row mt-3 text-center">
                            <div class="col">
                                <div class="kpi-title">No Dia</div>
                                <div class="kpi-value" style="color:rgba(34,177,76);" id="no_dia">0%</div>
                            </div>
                            <div class="col">
                                <div class="kpi-title">1 Dia</div>
                                <div class="kpi-value" style="color:rgba(63,72,204);" id="um_dia">0%</div>
                            </div>
                            <div class="col">
                                <div class="kpi-title">3 Dias</div>
                                <div class="kpi-value" style="color:rgb(255,201,14);" id="tres_dia">0%</div>
                            </div>
                            <div class="col">
                                <div class="kpi-title">5 Dias</div>
                                <div class="kpi-value" style="color:rgba(255,128,0);" id="cinco_dia">0%</div>
                            </div>
                            <div class="col">
                                <div class="kpi-title">&gt;5 Dias</div>
                                <div class="kpi-value" style="color:rgba(255,0,0);" id="mais_cinco_dia">0%</div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- ================= GREEN PLANET (comentado) ================= -->
            @*@if ((bool)Session["rel_green_planet"] && Session["codigo_unidade"].ToString() != "-1")
                {
                    <div class="dashboard-section">
                        <div class="section-title">@PCM.WEB.Properties.Resources.green_planet</div>
                        <div class="block dashboard-card">
                            <div class="row mb-3">
                                <div class="col-md-2">@Html.DropDownList("agrupado_por", null, @PCM.WEB.Properties.Resources.agrupado_por, new { @class = "form-control font-w600" })</div>
                                <div class="col-md-2">@Html.DropDownList("forma_calculo", null, @PCM.WEB.Properties.Resources.forma_calculo_green_planet, new { @class = "form-control font-w600" })</div>
                                <div class="col-md-4">@Html.DropDownList("grupo_item_medicao", null, @PCM.WEB.Properties.Resources.grupo_item_medicao, new { @class = "form-control font-w600" })</div>
                                <div class="col-md-4">
                                    <div class="input-daterange input-group" data-date-format="dd/mm/yyyy" data-week-start="1" data-autoclose="true" data-today-highlight="true">
                                        <input type="text" class="form-control" id="data_inicio" name="data_inicio" placeholder="De" value="@ViewBag.data_inicio">
                                        <div class="input-group-prepend input-group-append">
                                            <span class="input-group-text font-w600">-</span>
                                        </div>
                                        <input type="text" class="form-control" id="data_termino" name="data_termino" placeholder="Até" value="@ViewBag.data_termino">
                                        <div class="input-group-append">
                                            <button type="button" class="btn btn-square btn-secondary fa fa-refresh" onclick="refreshGreenPlanet();" id="btnRefreshGreenPlanet"></button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="chart-card">
                                <div class="chart-wrapper"><canvas id="chartGreenPlanet"></canvas></div>
                            </div>
                        </div>
                    </div>
                }*@

            <!-- ================= PRINCIPAIS OCORRÊNCIAS ================= -->
            <div class="dashboard-section">
                <div class="section-title">
                    Principais Ocorrências
                    <span>
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn btn-outline-secondary" onclick="PrincipaisOcorrencias(1);">Dia Anterior</button>
                            <button type="button" class="btn btn-outline-secondary" onclick="PrincipaisOcorrencias(7);">Semana</button>
                            <button type="button" class="btn btn-outline-secondary" onclick="PrincipaisOcorrencias(30);">Mês</button>
                            <button type="button" class="btn btn-outline-secondary" onclick="PrincipaisOcorrencias(365);">Ano</button>
                        </div>
                    </span>
                </div>
                <div class="block dashboard-card">
                    <table class="table table-striped" id="tb-principais-ocorrencias">
                        <thead>
                            <tr>
                                <th class="text-center" style="width:80px;">#</th>
                                <th>@PCM.WEB.Properties.Resources.equipamento</th>
                                <th class="text-center" style="width:130px;">Quantidade</th>
                            </tr>
                        </thead>
                        <tbody id="tb-principais-ocorrencias-body">
                            @foreach (var item in ViewBag.PrincipaisOcorrencias)
                            {
                                <tr>
                                    <td class="text-center">@item.item</td>
                                    <td class="font-w600">@item.local</td>
                                    <td class="text-center">@item.quantidade</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        }

    </div>

    <!-- Log Book Modal -->
    <div class="modal fade" id="modal-fromright" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-fromright" role="document">
            <div class="modal-content">
                <div class="block block-themed block-transparent mb-0">
                    <div class="block-header bg-primary-dark">
                        <h3 class="block-title">@PCM.WEB.Properties.Resources.log_book</h3>
                    </div>
                    <div class="block-content">
                        <textarea class="form-control" id="informacao" name="informacao" maxlength="5000" rows="15">@ViewBag.InfoOrdemServico.log_book</textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn bg-gray-light" onclick="confirmLogBook();" data-bs-dismiss="modal">
                        <i class="fa fa-check"></i> @PCM.WEB.Properties.Resources.confirmado
                    </button>
                </div>
            </div>
        </div>
    </div>

</main>

@section Styles {
    @Styles.Render("~/Content/dashboard")
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/dataTables")
    @Styles.Render("~/Content/select")
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
}

@section Scripts {
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/chart")
    @Scripts.Render("~/plugins/gauge")
    @Scripts.Render("~/plugins/select")

    <script src="https://cdnjs.cloudflare.com/ajax/libs/remarkable-bootstrap-notify/3.1.3/bootstrap-notify.min.js"></script>

    <script>

        var informacao   = $("#informacao");
        var unidade      = $("#header-unidade");
        var modulo       = $("#header-modulo");


        $(document).ready(function () {
            if (informacao.val() != "") { jQuery('#modal-fromright').modal('show'); }
        });



        function confirmLogBook() { $.post("Home/ConfirmLogBook"); }

        var configTempoMedioAtendimento = {
            type: 'doughnut',
            options: {
                responsive: true,
                maintainAspectRatio: false,
                legend: {
                    display: true,
                    position: 'right',
                    labels: {
                        padding: 16,
                        boxWidth: 14,
                        fontSize: 12,
                        generateLabels: function(chart) {
                            var data = chart.data;
                            if (!data.labels.length) return [];
                            return data.labels.map(function(label, i) {
                                var ds  = data.datasets[0];
                                var val = ds && ds.data[i] != null ? ds.data[i].toFixed(2) + '%' : '0%';
                                var bg  = ds && ds.backgroundColor ? ds.backgroundColor[i] : '#ccc';
                                return {
                                    text: label + '  ' + val,
                                    fillStyle: bg,
                                    strokeStyle: bg,
                                    lineWidth: 0,
                                    hidden: false,
                                    index: i
                                };
                            });
                        }
                    }
                },
                title: { display: false },
                tooltips: {
                    enabled: true,
                    callbacks: {
                        label: function(item, data) {
                            var label = data.labels[item.index] || '';
                            var val   = data.datasets[0].data[item.index];
                            return ' ' + label + ': ' + (val != null ? val.toFixed(2) : 0) + '%';
                        }
                    }
                },
                cutoutPercentage: 60
            }
        };

        var configAbertoConcluido = {
            type: 'line',
            options: {
                responsive: true,
                maintainAspectRatio: false,
                legend: { display: true, labels: { padding: 20 }, position: 'bottom' },
                title: { display: false },
                tooltips: { enabled: true }
            }
        };

        var configGreenPlanet = {
            type: 'bar',
            options: {
                responsive: true,
                maintainAspectRatio: false,
                legend: { display: true, labels: { padding: 20 }, position: 'bottom' },
                title: { display: false },
                tooltips: { enabled: true }
            }
        };

        function LoadChartManutencaoAbertoConcluido() {
            jQuery.ajax({
                type: "POST",
                url: "@Url.Content("Relatorio/ChartManutencaoAbertoConcluido")",
                async: false,
                data: { "unidade": unidade.val(), "modulo": modulo.val() },
                dataType: "json",
                success: function (r) {
                    // r = [{data, aberto, concluido, saldo}, ...]
                    var labels   = r.map(function(d) { return d.data; });
                    var abertos  = r.map(function(d) { return d.aberto; });
                    var concls   = r.map(function(d) { return d.concluido; });

                    // Totais do último item (acumulado)
                    var ultimo   = r.length ? r[r.length - 1] : { aberto: 0, concluido: 0, saldo: 0 };
                    $("#aberto").html(ultimo.aberto);
                    $("#concluido").html(ultimo.concluido);
                    $("#saldo").html(ultimo.saldo);

                    configAbertoConcluido.data = {
                        labels: labels,
                        datasets: [
                            {
                                label: 'Aberto',
                                data: abertos,
                                borderColor: 'rgba(255,0,0,0.8)',
                                backgroundColor: 'rgba(255,0,0,0.1)',
                                fill: true,
                                tension: 0.3
                            },
                            {
                                label: 'Concluído',
                                data: concls,
                                borderColor: 'rgba(34,177,76,0.8)',
                                backgroundColor: 'rgba(34,177,76,0.1)',
                                fill: true,
                                tension: 0.3
                            }
                        ]
                    };

                    if (window.AbertoConcluido) {
                        window.AbertoConcluido.data = configAbertoConcluido.data;
                        window.AbertoConcluido.update();
                    }
                }
            });
        }

        function LoadChartManutencaoTempoMedioAtendimento() {
            jQuery.ajax({
                type: "POST",
                url: "@Url.Content("Relatorio/ChartManutencaoTempoMedioAtendimento")",
                async: false,
                data: { "unidade": unidade.val(), "modulo": modulo.val() },
                dataType: "json",
                success: function (r) {
                    // r = [{tipo, valor}, ...] ex: [{tipo:"NO DIA", valor:84.44}, ...]
                    var labels = r.map(function(d) { return d.tipo; });
                    var values = r.map(function(d) { return d.valor; });
                    var colors = ['rgba(34,177,76,0.7)', 'rgba(63,72,204,0.7)',
                                  'rgba(255,201,14,0.7)', 'rgba(255,128,0,0.7)', 'rgba(255,0,0,0.7)'];

                    // Atualiza totais abaixo do gráfico
                    var ids = ['no_dia','um_dia','tres_dia','cinco_dia','mais_cinco_dia'];
                    for (var i = 0; i < r.length && i < ids.length; i++) {
                        $('#' + ids[i]).html(r[i].valor.toFixed(2) + '%');
                    }

                    configTempoMedioAtendimento.data = {
                        labels: labels,
                        datasets: [{
                            label: 'Tempo de Atendimento (%)',
                            data: values,
                            backgroundColor: colors.slice(0, r.length)
                        }]
                    };

                    if (window.TempoMedioAtendimento) {
                        window.TempoMedioAtendimento.data = configTempoMedioAtendimento.data;
                        window.TempoMedioAtendimento.update();
                    }
                }
            });
        }

        function PrincipaisOcorrencias(quantidade) {
            $("#tb-principais-ocorrencias-body").empty();
            jQuery.ajax({
                type: "POST",
                url: "@Url.Content("Home/PrincipaisOcorrencias")",
                async: false,
                data: { "unidade": unidade.val(), "quantidade": quantidade, "qualidade": false },
                dataType: "json",
                success: function (r) {
                    for (var i = 0; i < r.length; i++) {
                        var row = $("<tr>");
                        row.append('<td class="text-center" style="width:80px;">' + r[i].item + '</td>');
                        row.append('<td class="font-w600">' + r[i].local + '</td>');
                        row.append('<td class="text-center">' + r[i].quantidade + '</td>');
                        $("#tb-principais-ocorrencias").append(row);
                    }
                }
            });
        }

        // Cria as instâncias dos charts (sem dados ainda)
        function initCharts() {
            if (!window.AbertoConcluido) {
                window.AbertoConcluido = new Chart(
                    document.getElementById('chartManutencaoAbertoConcluido').getContext('2d'),
                    { type: 'line', data: { labels: [], datasets: [] }, options: { responsive: true, maintainAspectRatio: false } }
                );
            }
            if (!window.TempoMedioAtendimento) {
                window.TempoMedioAtendimento = new Chart(
                    document.getElementById('chartManutencaoTempoMedioAtendimento').getContext('2d'),
                    { type: 'doughnut', data: { labels: [], datasets: [] }, options: { responsive: true, maintainAspectRatio: false } }
                );
            }
        }

        // Chamado pelo codebase.js após popular os selects do header
        window.onHeaderReady = function () {
            initCharts();
            LoadChartManutencaoAbertoConcluido();
            LoadChartManutencaoTempoMedioAtendimento();
            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
            startRefreshCycle();
        };

        (function ($) {
            if (!$.notify && $.bootstrapGrowl) {
                $.notify = function (opts, cfg) {
                    var msg   = (opts && (opts.message || opts.title)) || String(opts || '');
                    var type  = (cfg && cfg.type) || 'info';
                    var from  = cfg && cfg.placement && cfg.placement.from || 'top';
                    var align = cfg && cfg.placement && cfg.placement.align || 'right';
                    var delay = (cfg && cfg.delay != null) ? cfg.delay : 5000;
                    var allow = (cfg && cfg.allow_dismiss != null) ? cfg.allow_dismiss : true;
                    $.bootstrapGrowl(msg, {
                        type: type, allow_dismiss: allow, align: align,
                        offset: (typeof cfg?.offset === 'number') ? { from: from, amount: cfg.offset } : { from: from, amount: 20 },
                        delay: delay, stackup_spacing: cfg?.spacing || 10, width: 'auto'
                    });
                };
            }
        })(jQuery);

        // ================================================
        // AUTO-REFRESH via AJAX – sem recarregar a página
        // ================================================
        var REFRESH_INTERVAL = 60; // segundos
        var refreshTimer;
        var countdownTimer;
        var secondsLeft = REFRESH_INTERVAL;

        function startRefreshCycle() {
            secondsLeft = REFRESH_INTERVAL;
            updateCountdown();

            clearInterval(countdownTimer);
            countdownTimer = setInterval(function () {
                secondsLeft--;
                updateCountdown();
                if (secondsLeft <= 0) {
                    clearInterval(countdownTimer);
                    refreshDashboard();
                }
            }, 1000);
        }

        function updateCountdown() {
            var el = document.getElementById('refresh-countdown');
            if (el) el.textContent = secondsLeft + 's';
        }

        function refreshDashboard() {
            var el = document.getElementById('refresh-indicator');
            if (el) {
                el.classList.add('refreshing');
                el.title = 'Atualizando...';
            }

            $.ajax({
                type: 'GET',
                url: '@Url.Action("DashboardSnapshot", "Home")',
                dataType: 'json',
                success: function (data) {
                    if (!data) return;

                    // ----- OS cards -----
                    var os = data.os;
                    if (os) {
                        setVal('quantidade_atrasada_pool',  os.quantidade_atrasada_pool);
                        setVal('quantidade_pendente_pool',  os.quantidade_pendente_pool);
                        setVal('quantidade_vinculada_pool', os.quantidade_vinculada_pool);
                        setVal('quantidade_andamento_pool', os.quantidade_andamento_pool);
                        setVal('quantidade_realizada_pool', os.quantidade_concluida_pool);
                        setVal('quantidade_backlog_pool',   os.quantidade_backlog_pool);
                        setVal('quantidade_atrasada_condo',  os.quantidade_atrasada_condo);
                        setVal('quantidade_pendente_condo',  os.quantidade_pendente_condo);
                        setVal('quantidade_vinculada_condo', os.quantidade_vinculada_condo);
                        setVal('quantidade_andamento_condo', os.quantidade_andamento_condo);
                        setVal('quantidade_realizada_condo', os.quantidade_concluida_condo);
                        setVal('quantidade_backlog_condo',   os.quantidade_backlog_condo);
                    }

                    // ----- Gauges / Painel de Controle -----
                    var g = data.gauge;
                    if (g) {
                        updateTorre('torre-preventiva',   g.preventiva,   g.cor_preventiva);
                        updateTorre('torre-laudo',        g.laudo,        g.cor_laudo);
                        updateTorre('torre-rotina',       g.rotina,       g.cor_rotina);
                        updateTorre('torre-pmoc',         g.pmoc,         g.cor_pmoc);
                        updateTorre('torre-uh',           g.uh_dia,       g.cor_uh_dia);
                        updateTorre('torre-green',        g.green_planet, g.cor_green_planet);
                    }

                    // ----- Gráficos -----
                    LoadChartManutencaoAbertoConcluido();
                    LoadChartManutencaoTempoMedioAtendimento();

                    // ----- Principais ocorrências -----
                    if (data.ocorrencias) {
                        var tbody = $('#tb-principais-ocorrencias-body').empty();
                        $.each(data.ocorrencias, function (i, r) {
                            tbody.append(
                                '<tr>' +
                                '<td class="text-center" style="width:80px;">' + r.item + '</td>' +
                                '<td class="font-w600">' + r.local + '</td>' +
                                '<td class="text-center">' + r.quantidade + '</td>' +
                                '</tr>'
                            );
                        });
                    }

                    if (el) {
                        el.classList.remove('refreshing');
                        el.title = 'Última atualização: ' + new Date().toLocaleTimeString();
                    }
                },
                error: function () {
                    if (el) el.classList.remove('refreshing');
                },
                complete: function () {
                    startRefreshCycle(); // reinicia o ciclo após completar
                }
            });
        }

        function setVal(id, val) {
            var el = document.getElementById(id);
            if (el) el.textContent = val != null ? val : 0;
        }

        function updateTorre(id, valor, cor) {
            var item = document.getElementById(id);
            if (!item) return;
            var pct  = Math.round(valor * 10) / 10;
            var pctI = Math.round(valor);
            var status = pct < 65 ? 'Crítico' : pct > 85 ? 'Meta atingida' : 'Em andamento';
            var pctEl  = item.querySelector('.torre-pct');
            var barEl  = item.querySelector('.torre-bar-fill');
            var stEl   = item.querySelector('.torre-meta span:first-child');
            if (pctEl)  { pctEl.textContent = pct + '%'; pctEl.style.color = cor; }
            if (barEl)  { barEl.style.width = pctI + '%'; barEl.style.background = cor; }
            if (stEl)   { stEl.textContent = status; }
        }

        // startRefreshCycle é iniciado via window.onHeaderReady, chamado pelo _Header

    </script>
}
