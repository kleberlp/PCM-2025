                                        <td class="text-center">@item.total</td>
                                        <td>
                                            <div style="display:flex;align-items:center;gap:6px;">
                                                <div style="flex:1;background:#e9ecef;border-radius:3px;height:14px;overflow:hidden;">
                                                    <div style="width:@(pctPmoc.ToString("0", System.Globalization.CultureInfo.InvariantCulture))%;height:100%;background:@corPmoc;border-radius:3px;transition:width .4s;"></div>
                                                </div>
                                                <span style="font-size:11px;font-weight:600;color:@corPmoc;white-space:nowrap;">@item.percentual_atendido</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="col-md-6 d-flex flex-column">
                    <div class="section-title">@PCM.WEB.Properties.Resources.laudo</div>
                    <div class="block dashboard-card flex-fill">
                        <table class="table table-striped table-sm table-bordered mb-0 tbl-sort">
                            <thead>
                                <tr>
                                    <th>@PCM.WEB.Properties.Resources.unidade</th>
                                    <th class="text-center" style="width:55px;">OK</th>
                                    <th class="text-center" style="width:65px;">Pend.</th>
                                    <th class="text-center" style="width:55px;">Total</th>
                                    <th style="min-width:140px;">% Atend.</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in ViewBag.laudo)
                                {
                                    var pctLaudo = 0.0;
                                    double.TryParse(item.percentual_atendido.ToString().Replace("%", "").Replace(",", "."), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out pctLaudo);
                                    var corLaudo = pctLaudo >= 86 ? "#22b14c" : (pctLaudo >= 65 ? "#ffc90e" : "#e74c3c");
                                    <tr>
                                        <td>@item.unidade</td>
                                        <td class="text-center">@item.quantidade_ok</td>
                                        <td class="text-center">@item.quantidade_pendente</td>
                                        <td class="text-center">@item.total</td>
                                        <td>
                                            <div style="display:flex;align-items:center;gap:6px;">
                                                <div style="flex:1;background:#e9ecef;border-radius:3px;height:14px;overflow:hidden;">
                                                    <div style="width:@(pctLaudo.ToString("0", System.Globalization.CultureInfo.InvariantCulture))%;height:100%;background:@corLaudo;border-radius:3px;transition:width .4s;"></div>
                                                </div>
                                                <span style="font-size:11px;font-weight:600;color:@corLaudo;white-space:nowrap;">@item.percentual_atendido</span>
                                            </div>
