            <!-- ================= UH EM DIA ================= -->
            <div class="dashboard-section">
                <div class="section-title">@PCM.WEB.Properties.Resources.uh_em_dia</div>
                <div class="block dashboard-card">
                    <table class="table table-striped table-sm table-bordered mb-0 tbl-sort">
                        <thead>
                            <tr>
                                <th>@PCM.WEB.Properties.Resources.unidade</th>
                                <th class="text-center" style="width:70px;">OK</th>
                                <th class="text-center" style="width:80px;">Pend.</th>
                                <th class="text-center" style="width:70px;">Total</th>
                                <th style="min-width:200px;">% Atend.</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ViewBag.uh_dia)
                            {
                                var pctUh = 0.0;
                                double.TryParse(item.percentual_atendido.ToString().Replace("%", "").Replace(",", "."), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out pctUh);
                                var corUh = pctUh >= 86 ? "#22b14c" : (pctUh >= 65 ? "#ffc90e" : "#e74c3c");
                                <tr>
                                    <td>@item.unidade</td>
                                    <td class="text-center">@item.quantidade_ok</td>
                                    <td class="text-center">@item.quantidade_pendente</td>
                                    <td class="text-center">@item.total</td>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:6px;">
                                            <div style="flex:1;background:#e9ecef;border-radius:3px;height:14px;overflow:hidden;">
                                                <div style="width:@(pctUh.ToString("0", System.Globalization.CultureInfo.InvariantCulture))%;height:100%;background:@corUh;border-radius:3px;transition:width .4s;"></div>
                                            </div>
                                            <span style="font-size:11px;font-weight:600;color:@corUh;white-space:nowrap;">@item.percentual_atendido</span>
                                        </div>
