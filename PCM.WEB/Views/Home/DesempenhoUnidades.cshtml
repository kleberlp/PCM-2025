            <!-- ================= SLA – TEMPO MÉDIO (tabela com barras inline) ================= -->
            <div class="dashboard-section">
                <div class="section-title">SLA – Tempo Médio de Atendimento por Unidade</div>
                <div class="block dashboard-card" style="overflow-x:auto;">
                    <table class="table table-striped table-sm table-bordered mb-0 tbl-sort">
                        <thead>
                            <tr>
                                <th rowspan="2">@PCM.WEB.Properties.Resources.unidade</th>
                                <th class="text-center" colspan="2" style="color:#22b14c;">No Dia</th>
                                <th class="text-center" colspan="2" style="color:#3f48cc;">1 Dia</th>
                                <th class="text-center" colspan="2" style="color:#b38f00;">2 a 3 Dias</th>
                                <th class="text-center" colspan="2" style="color:#ff8000;">4 a 5 Dias</th>
                                <th class="text-center" colspan="2" style="color:#800080;">&gt; 5 Dias</th>
                                <th class="text-center" colspan="2" style="color:#e74c3c;">Não Atendidas</th>
                                <th rowspan="2" style="min-width:160px;">Distribuição</th>
                            </tr>
                            <tr>
                                <th class="text-center" style="width:55px;color:#22b14c;">Qtde</th>
                                <th class="text-center" style="width:65px;color:#22b14c;">%</th>
                                <th class="text-center" style="width:55px;color:#3f48cc;">Qtde</th>
                                <th class="text-center" style="width:65px;color:#3f48cc;">%</th>
                                <th class="text-center" style="width:55px;color:#b38f00;">Qtde</th>
                                <th class="text-center" style="width:65px;color:#b38f00;">%</th>
                                <th class="text-center" style="width:55px;color:#ff8000;">Qtde</th>
                                <th class="text-center" style="width:65px;color:#ff8000;">%</th>
                                <th class="text-center" style="width:55px;color:#800080;">Qtde</th>
                                <th class="text-center" style="width:65px;color:#800080;">%</th>
                                <th class="text-center" style="width:55px;color:#e74c3c;">Qtde</th>
                                <th class="text-center" style="width:65px;color:#e74c3c;">%</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ViewBag.atendimento_os)
                            {
                                var _inv = System.Globalization.CultureInfo.InvariantCulture;
                                var _ns = System.Globalization.NumberStyles.Any;
                                double slaNodia = 0, sla1dia = 0, sla23 = 0, sla45 = 0, sla5mais = 0, slaNao = 0, totalOS = 0;
                                double.TryParse(item.os_atendimento_dia.ToString().Replace("%", "").Replace(",", "."), _ns, _inv, out slaNodia);
                                double.TryParse(item.os_atendimento_um_dia.ToString().Replace("%", "").Replace(",", "."), _ns, _inv, out sla1dia);
                                double.TryParse(item.os_atendimento_tres_dias.ToString().Replace("%", "").Replace(",", "."), _ns, _inv, out sla23);
                                double.TryParse(item.os_atendimento_cinco_dias.ToString().Replace("%", "").Replace(",", "."), _ns, _inv, out sla45);
                                double.TryParse(item.os_atendimento_acima_cinco_dias.ToString().Replace("%", "").Replace(",", "."), _ns, _inv, out sla5mais);
                                double.TryParse(item.os_nao_atendido.ToString().Replace("%", "").Replace(",", "."), _ns, _inv, out slaNao);
                                double.TryParse(item.quantidade_os_gerada.ToString().Replace(".", "").Replace(",", "."), _ns, _inv, out totalOS);
                                @* quantidades calculadas a partir da % × total de OS geradas *@
                                var qNodia = (int)Math.Round(slaNodia / 100 * totalOS);
                                var q1dia = (int)Math.Round(sla1dia / 100 * totalOS);
                                var q23 = (int)Math.Round(sla23 / 100 * totalOS);
                                var q45 = (int)Math.Round(sla45 / 100 * totalOS);
                                var q5mais = (int)Math.Round(sla5mais / 100 * totalOS);
                                var qNao = (int)Math.Round(slaNao / 100 * totalOS);
                                @* barras proporcionais *@
                                var slaBase = slaNodia + sla1dia + sla23 + sla45 + sla5mais + slaNao;
                                if (slaBase == 0) { slaBase = 1; }
                                var bNodia = Math.Round(slaNodia / slaBase * 100, 1).ToString("0.#", _inv);
                                var b1dia = Math.Round(sla1dia / slaBase * 100, 1).ToString("0.#", _inv);
                                var b23 = Math.Round(sla23 / slaBase * 100, 1).ToString("0.#", _inv);
                                var b45 = Math.Round(sla45 / slaBase * 100, 1).ToString("0.#", _inv);
                                var b5mais = Math.Round(sla5mais / slaBase * 100, 1).ToString("0.#", _inv);
                                var bNao = Math.Round(slaNao / slaBase * 100, 1).ToString("0.#", _inv);
                                <tr>
                                    <td class="font-w600">@item.unidade</td>
                                    <td class="text-center" style="color:#22b14c;">@qNodia</td>
                                    <td class="text-center" style="font-weight:600;color:#22b14c;">@item.os_atendimento_dia</td>
                                    <td class="text-center" style="color:#3f48cc;">@q1dia</td>
                                    <td class="text-center" style="font-weight:600;color:#3f48cc;">@item.os_atendimento_um_dia</td>
                                    <td class="text-center" style="color:#b38f00;">@q23</td>
                                    <td class="text-center" style="font-weight:600;color:#b38f00;">@item.os_atendimento_tres_dias</td>
                                    <td class="text-center" style="color:#ff8000;">@q45</td>
                                    <td class="text-center" style="font-weight:600;color:#ff8000;">@item.os_atendimento_cinco_dias</td>
                                    <td class="text-center" style="color:#800080;">@q5mais</td>
                                    <td class="text-center" style="font-weight:600;color:#800080;">@item.os_atendimento_acima_cinco_dias</td>
                                    <td class="text-center" style="color:#e74c3c;">@qNao</td>
                                    <td class="text-center" style="font-weight:600;color:#e74c3c;">@item.os_nao_atendido</td>
                                    <td>
                                        <div style="display:flex;height:16px;border-radius:3px;overflow:hidden;width:100%;">
                                            <div style="width:@bNodia%;background:#22b14c;" title="No Dia: @item.os_atendimento_dia (@qNodia OS)"></div>
                                            <div style="width:@b1dia%;background:#3f48cc;" title="1 Dia: @item.os_atendimento_um_dia (@q1dia OS)"></div>
                                            <div style="width:@b23%;background:#ffc90e;" title="2-3 Dias: @item.os_atendimento_tres_dias (@q23 OS)"></div>
                                            <div style="width:@b45%;background:#ff8000;" title="4-5 Dias: @item.os_atendimento_cinco_dias (@q45 OS)"></div>
                                            <div style="width:@b5mais%;background:#800080;" title=">5 Dias: @item.os_atendimento_acima_cinco_dias (@q5mais OS)"></div>
                                            <div style="width:@bNao%;background:#e74c3c;" title="Não Atendidas: @item.os_nao_atendido (@qNao OS)"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

