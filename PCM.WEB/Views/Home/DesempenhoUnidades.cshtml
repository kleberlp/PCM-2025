                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ================= ATENDIMENTO OS ================= -->
            <div class="dashboard-section">
                <div class="section-title">@PCM.WEB.Properties.Resources.atendimento_ordem_servico</div>
                <div class="block dashboard-card">
                    <div style="overflow-x:auto;">
