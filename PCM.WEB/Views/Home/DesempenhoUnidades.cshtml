@section Scripts {
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/chart")
    @Scripts.Render("~/plugins/select")

    <script>

        // ── Submit ao mudar data ─────────────────────────────────
        $(function () {
            $(document).on("change", "#filtro-data", function () {
                var unidadeHeader = $("#header-unidade").val();
                if (unidadeHeader) $("#hidden-unidade").val(unidadeHeader);
                $("#form").submit();
            });
        });

        // ── Navegação ao trocar unidade no header ────────────────
        window.onUnidadeChange = function (unidade) {
            var data = $("#filtro-data").val() || "";
            if (String(unidade) === "-1") {
                window.location.href = "@Url.Action("DesempenhoUnidades", "Home")" + (data ? "?data=" + encodeURIComponent(data) : "");
            } else {
                window.location.href = "@Url.Action("DashboardAtual", "Home")" + (data ? "?data=" + encodeURIComponent(data) : "");
            }
        };

        // ── Cores ─────────────────────────────────────────────────
        var colorNamesGeral             = Object.keys(window.chartColors);
        var colorNamesMediaOSColaborador = Object.keys(window.chartColors);

        var geralColors = {
            'LAUDO':      { bg: 'rgba(255,51,91,0.7)',   border: 'rgba(255,51,91,1)' },
            'PMOC':       { bg: 'rgba(68,169,236,0.7)',  border: 'rgba(68,169,236,1)' },
            'PREVENTIVA': { bg: 'rgba(255,208,98,0.7)',  border: 'rgba(255,208,98,1)' },
            'ROTINA':     { bg: 'rgba(88,196,196,0.7)',  border: 'rgba(88,196,196,1)' },
            'U.H EM DIA': { bg: 'rgba(160,113,255,0.7)', border: 'rgba(160,113,255,1)' }
        };

        var osColors = {
            'QUANTIDADE OS ATENDIDA': { bg: 'rgba(34,177,76,0.75)',  border: 'rgba(34,177,76,1)' },
            'QUANTIDADE OS GERADA':   { bg: 'rgba(63,72,204,0.75)',  border: 'rgba(63,72,204,1)' },
            'SALDO OS PENDENTE':      { bg: 'rgba(255,0,0,0.75)',    border: 'rgba(255,0,0,1)' }
        };
        var singleColor = 'rgba(68,114,196,0.85)';



        // ── Configurações ────────────────────────────────────────

        // RADAR – Gráfico Geral
        var configChartGeral = {
            type: 'radar',
            data: { labels: [], datasets: [] },
            options: {
                responsive: true, maintainAspectRatio: false,
                scale: {
                    ticks: { beginAtZero: true, min: 0, max: 100, stepSize: 20 },
                    pointLabels: { fontSize: 12 }
                },
                legend: { display: false },
                tooltips: {
                    callbacks: {
                        title: function(items, data) {
                            // mostra o label do eixo (LAUDO, PMOC…) em vez do valor
                            return data.labels[items[0].index] || '';
                        },
                        label: function(item, data) {
                            var ds = data.datasets[item.datasetIndex];
                            return (ds.label || '') + ': ' + item.value;
                        }
                    }
                }
            }
        };





        var configChartNumeroOS = {
            type: 'bar',
            data: { labels: [], datasets: [] },
            options: {
                responsive: true, maintainAspectRatio: false, animation: false,
                legend: { display: true, position: 'bottom' }
            }
        };



        // chartMediaOSColaborador foi substituído por tabela — var mantida por compatibilidade
        var configChartMediaOSColaborador = { data: { labels: [], datasets: [] } };

        // ── Helpers ──────────────────────────────────────────────
        var dataVal = function() { return $("#filtro-data").val(); };

        function loadUnidades(cfg, win) {
            $.post("@Url.Content("~/Dashboard/Unidades")", { data: dataVal() }, function (obj) {
                cfg.data.labels = obj;
                win.update();
            }, "json");
        }

        function applyDatasets(cfg, win, obj, colorMap) {
            cfg.data.datasets = [];
            $.each(obj, function (i, r) {
                var c = colorMap ? (colorMap[r.serie] || { bg: '#ccc', border: '#999' })
                                 : { bg: singleColor, border: singleColor };
                cfg.data.datasets.push({ label: r.serie, data: r.valor, fill: false, backgroundColor: c.bg, borderColor: c.border });
            });
            win.update();
        }

        // ── Carregamento ─────────────────────────────────────────

        // ── Radar: datasets completos (todos os unidades) ────────
        var _radarAllDatasets = [];
        var _radarMetricas    = [];

        function BuildRadarCheckboxes(unidades) {
            var $box = $('#radar-checkboxes').empty();
            unidades.forEach(function(nome, idx) {
                var ds    = _radarAllDatasets[idx];
                var color = (ds && ds.borderColor) ? ds.borderColor : '#999';
                var id    = 'radar-cb-' + idx;
                var $pill = $('<label>').attr('for', id).addClass('radar-pill');
                var $dot  = $('<span>').addClass('radar-pill-dot').css('background', color);
                var $cb   = $('<input type="checkbox">').attr({type:'checkbox', id:id})
                                .prop('checked', true).data('idx', idx)
                                .on('change', ApplyRadarFilter);
                $pill.append($cb).append($dot).append(nome);
                $box.append($pill);
            });
        }

        function ApplyRadarFilter() {
            var visible = [];
            $('#radar-checkboxes input[type=checkbox]').each(function() {
                if ($(this).prop('checked')) visible.push($(this).data('idx'));
            });
            configChartGeral.data.datasets = visible.map(function(i) { return _radarAllDatasets[i]; });
            window.ChartGeral.update();
        }

        $('#radar-select-all').on('click', function() {
            $('#radar-checkboxes input[type=checkbox]').prop('checked', true);
            ApplyRadarFilter();
        });
        $('#radar-deselect-all').on('click', function() {
            $('#radar-checkboxes input[type=checkbox]').prop('checked', false);
            ApplyRadarFilter();
        });

        function LoadChartGeral() {
            $.post("@Url.Content("~/Dashboard/ChartGeral")", { data: dataVal() }, function (obj) {
                if (!obj || !obj.length) return;
                var metricas  = obj.map(function(s) { return s.serie; });
                var nUnidades = obj[0].valor.length;

                $.post("@Url.Content("~/Dashboard/Unidades")", { data: dataVal() }, function (unidades) {
                    _radarMetricas = metricas;
                    _radarAllDatasets = [];
                    configChartGeral.data.labels = metricas;

                    for (var u = 0; u < nUnidades; u++) {
                        var c       = colorNamesGeral[u % colorNamesGeral.length];
                        var valores = obj.map(function(s) { return s.valor[u] || 0; });
                        _radarAllDatasets.push({
                            label: unidades[u] || ('Unidade ' + (u + 1)),
                            data: valores,
                            backgroundColor: window.chartColors[c].replace('0.7', '0.15'),
                            borderColor: window.chartBorderColors[c],
                            borderWidth: 2, pointRadius: 3
                        });
                    }

                    BuildRadarCheckboxes(unidades);
                    configChartGeral.data.datasets = _radarAllDatasets.slice();
                    window.ChartGeral.update();
                }, "json");
            }, "json");
        }



        function LoadChartNumeroOS() {
            loadUnidades(configChartNumeroOS, window.ChartNumeroOS);
            $.post("@Url.Content("~/Dashboard/ChartNumeroOS")", { data: dataVal() }, function (obj) {
                applyDatasets(configChartNumeroOS, window.ChartNumeroOS, obj, osColors);
            }, "json");
        }



        function LoadChartMediaOSColaborador() {
            $.when(
                $.post("@Url.Content("~/Dashboard/Unidades")", { data: dataVal() }),
                $.post("@Url.Content("~/Dashboard/ChartMediaOSColaborador")", { data: dataVal() })
            ).done(function(resUnidades, resData) {
                var unidades = resUnidades[0];
                var series   = resData[0];
                if (!unidades || !series || !series.length) { $('#tabelaMediaOS').html('<p class="text-muted">Sem dados.</p>'); return; }

                // espera duas séries: OS POR COLABORADOR e QUANTIDADE COLABORADOR
                var serieOS  = series[0] || { valor: [] };
                var serieQtd = series[1] || { valor: [] };
                var corOS    = '#4472c4';
                var corQtd   = '#ed7d31';

                // máximos para escala das barras
                var maxOS  = Math.max.apply(null, serieOS.valor.map(Number).filter(isFinite).concat([1]));
                var maxQtd = Math.max.apply(null, serieQtd.valor.map(Number).filter(isFinite).concat([1]));

                var html = '<table class="table table-striped table-sm table-bordered mb-0 tbl-sort">';
                html += '<thead><tr>';
                html += '<th>' + '@PCM.WEB.Properties.Resources.unidade' + '</th>';
                html += '<th class="text-center" style="width:160px;color:' + corOS  + ';">' + (serieOS.serie  || 'OS por Colaborador') + '</th>';
                html += '<th class="text-center" style="width:160px;color:' + corQtd + ';">' + (serieQtd.serie || 'Qtd. Colaborador')   + '</th>';
                html += '<th style="min-width:200px;">Distribuição</th>';
                html += '</tr></thead><tbody>';

                unidades.forEach(function(nome, i) {
                    var vOS  = parseInt(serieOS.valor[i])  || 0;
                    var vQtd = parseFloat(serieQtd.valor[i]) || 0;
                    var pOS  = Math.round(vOS  / maxOS  * 100);
                    var pQtd = Math.round(vQtd / maxQtd * 100);
                    html += '<tr>';
                    html += '<td class="font-w600">' + nome + '</td>';
                    html += '<td class="text-center" style="font-weight:600;color:' + corOS  + ';">' + vOS  + '</td>';
                    html += '<td class="text-center" style="font-weight:600;color:' + corQtd + ';">' + vQtd + '</td>';
                    html += '<td>';
                    html += '<div style="display:flex;flex-direction:column;gap:3px;padding:2px 0;">';
                    html += '<div style="display:flex;align-items:center;gap:6px;">';
                    html += '<div style="flex:1;background:#e9ecef;border-radius:3px;height:10px;overflow:hidden;">';
                    html += '<div style="width:' + pOS + '%;height:100%;background:' + corOS + ';border-radius:3px;"></div></div>';
                    html += '<span style="font-size:10px;color:' + corOS + ';min-width:30px;">' + vOS + '</span></div>';
                    html += '<div style="display:flex;align-items:center;gap:6px;">';
                    html += '<div style="flex:1;background:#e9ecef;border-radius:3px;height:10px;overflow:hidden;">';
                    html += '<div style="width:' + pQtd + '%;height:100%;background:' + corQtd + ';border-radius:3px;"></div></div>';
                    html += '<span style="font-size:10px;color:' + corQtd + ';min-width:30px;">' + vQtd + '</span></div>';
                    html += '</div></td>';
                    html += '</tr>';
                });

                html += '</tbody>';
                html += '<tfoot><tr style="background:#f8f9fa;">';
                html += '<td colspan="4" style="padding:6px 8px;">';
                html += '<span style="display:inline-flex;align-items:center;gap:16px;">';
                html += '<span><span style="display:inline-block;width:14px;height:10px;background:' + corOS  + ';border-radius:2px;margin-right:4px;"></span>' + (serieOS.serie  || 'OS por Colaborador') + '</span>';
                html += '<span><span style="display:inline-block;width:14px;height:10px;background:' + corQtd + ';border-radius:2px;margin-right:4px;"></span>' + (serieQtd.serie || 'Qtd. Colaborador')   + '</span>';
                html += '</span></td></tr></tfoot>';
                html += '</table>';
                $('#tabelaMediaOS').html(html);

                // re-aplica sortable nas novas linhas
                document.querySelectorAll('#tabelaMediaOS table.tbl-sort thead th').forEach(function(th) {
                    if (parseInt(th.getAttribute('colspan') || 1) > 1) return;
                    th.style.cursor = 'pointer'; th.style.userSelect = 'none';
                    th.title = 'Clique para ordenar';
                    th.addEventListener('click', function() { sortTableEl(th); });
                });
            });
        }

        // ── Calcula índice visual de coluna considerando rowspan/colspan ──
        function getColumnIndex(th) {
            var table = th.closest('table');
            var thead = table.querySelector('thead');
            if (!thead) return Array.from(th.parentNode.children).indexOf(th);
            var rows = Array.from(thead.querySelectorAll('tr'));
            var grid = [];
            rows.forEach(function(row, r) {
                if (!grid[r]) grid[r] = [];
                var col = 0;
                Array.from(row.children).forEach(function(cell) {
                    while (grid[r][col]) col++;
                    var cs = parseInt(cell.getAttribute('colspan') || 1);
                    var rs = parseInt(cell.getAttribute('rowspan') || 1);
                    for (var rr = r; rr < Math.min(r + rs, rows.length); rr++) {
                        if (!grid[rr]) grid[rr] = [];
                        for (var cc = col; cc < col + cs; cc++) {
                            grid[rr][cc] = cell;
                        }
                    }
                    col += cs;
                });
            });
            for (var r = 0; r < grid.length; r++) {
                for (var c = 0; c < grid[r].length; c++) {
                    if (grid[r][c] === th) return c;
                }
            }
            return -1;
        }

        // ── Ordenação de tabelas (global para reutilização) ──────
        function sortTableEl(th) {
            var table = th.closest('table');
            var tbody = table.querySelector('tbody');
            // exclui linhas marcadas como fixas (totais, cabeçalhos internos)
            function isFixed(r) {
                return r.hasAttribute('data-sort-skip') || !!r.querySelector('td.bg-warning-light');
            }
            var rows  = Array.from(tbody.querySelectorAll('tr')).filter(function(r) { return !isFixed(r); });
            var fixed = Array.from(tbody.querySelectorAll('tr')).filter(isFixed);
            var idx   = getColumnIndex(th);
            if (idx < 0) return;
            var asc   = th.dataset.sortDir !== 'asc';
            th.dataset.sortDir = asc ? 'asc' : 'desc';
            table.querySelectorAll('th[data-sort-dir]').forEach(function(t) {
                if (t !== th) delete t.dataset.sortDir;
                t.classList.remove('sort-asc','sort-desc');
            });
            th.classList.toggle('sort-asc', asc);
            th.classList.toggle('sort-desc', !asc);
            rows.sort(function(a, b) {
                var va = a.cells[idx] ? a.cells[idx].innerText.trim() : '';
                var vb = b.cells[idx] ? b.cells[idx].innerText.trim() : '';
                // formato BR: remove separador de milhar (.) depois troca decimal (,) por (.)
                function brFloat(s) { return parseFloat(s.replace(/[^0-9,.\-]/g,'').replace(/\./g,'').replace(',','.')); }
                var na = brFloat(va), nb = brFloat(vb);
                if (!isNaN(na) && !isNaN(nb)) return asc ? na - nb : nb - na;
                return asc ? va.localeCompare(vb,'pt') : vb.localeCompare(va,'pt');
            });
            // reinsere linhas ordenáveis e depois as fixas no final
            rows.forEach(function(r) { tbody.appendChild(r); });
            fixed.forEach(function(r) { tbody.appendChild(r); });
        }

        // ── Inicialização ─────────────────────────────────────────
        jQuery(function () {
            function mk(id, cfg) { return new Chart(document.getElementById(id).getContext('2d'), cfg); }

            window.ChartGeral    = mk('chartGeral',    configChartGeral);
            window.ChartNumeroOS = mk('chartNumeroOS',  configChartNumeroOS);

            LoadChartGeral();
            LoadChartNumeroOS();
            LoadChartMediaOSColaborador();

            // ── Ordenação de tabelas estáticas ────────────────────
            function initSortable() {
                document.querySelectorAll('table.tbl-sort thead th').forEach(function(th) {
                    // colspan > 1 agrupa colunas → não ordenável
                    if (parseInt(th.getAttribute('colspan') || 1) > 1) return;
                    th.style.cursor = 'pointer';
                    th.style.userSelect = 'none';
                    th.title = 'Clique para ordenar';
                    th.addEventListener('click', function() { sortTableEl(th); });
                });
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initSortable);
            } else {
                initSortable();
            }
        });

    </script>

