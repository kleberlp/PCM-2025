<!-- Main Container -->
<main id="main-container">
    <div class="content">

        @using (Html.BeginForm("Desempenho", "Home", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", @id = "form", enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()

            <input type="hidden" name="unidade" id="hidden-unidade" value="@Session["codigo_unidade"]" />

            <!-- ================= KPIs – VISÃO GERAL ================= -->
            <div class="dashboard-section">
                <div class="section-title">
                    Desempenho das Unidades
                    <span class="float-right">
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="Codebase.helpers('print-page');"><i class="si si-printer"></i> @PCM.WEB.Properties.Resources.imprimir</button>
                    </span>
                </div>
                <div class="block dashboard-card" style="padding:0; overflow:hidden;">
                    <div class="torre-comando-grid">
                        <a href="@Url.Action("UsuarioIndex", "Administracao")" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-user torre-icon text-primary"></i><span class="torre-label">@PCM.WEB.Properties.Resources.usuarios</span></div>
                            <div class="os-value text-primary">@ViewBag.dashboard_info.quantidade_usuario</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-users torre-icon text-info"></i><span class="torre-label">Equipe Manutenção</span></div>
                            <div class="os-value text-primary">@ViewBag.dashboard_info.equipe_manutencao</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="fa fa-list torre-icon text-primary"></i><span class="torre-label">Máq. / Equipamentos</span></div>
                            <div class="os-value text-primary">@ViewBag.dashboard_info.quantidade_equipamento</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-settings torre-icon text-warning"></i><span class="torre-label">Total de OS</span></div>
                            <div class="os-value text-primary">@ViewBag.dashboard_info.quantidade_os</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-settings torre-icon text-primary"></i><span class="torre-label">OS Mês</span></div>
                            <div class="os-value text-primary">@ViewBag.dashboard_info.quantidade_os_gerada</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-calendar torre-icon text-primary"></i><span class="torre-label">Qtd. Rotinas</span></div>
                            <div class="os-value text-primary">@ViewBag.dashboard_info.rotinas_implantadas</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="fa fa-list torre-icon text-primary"></i><span class="torre-label">SLA</span></div>
                            <div class="os-value text-primary">@ViewBag.dashboard_info.os_atendimento_dia</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-settings torre-icon text-primary"></i><span class="torre-label">Qtd. Preventivas</span></div>
                            <div class="os-value text-primary">@ViewBag.dashboard_info.preventivas_implantadas</div>
                        </a>
                    </div>
                </div>
            </div>

            <!-- ================= RANKING ================= -->
            <div class="dashboard-section">
                <div class="section-title">@PCM.WEB.Properties.Resources.ranking</div>
                @{
                    var rankingList = ((IEnumerable<dynamic>)ViewBag.ranking_unidades).ToList();
                    bool rankSingle = rankingList.Count <= 15;

                    // helper: ícone de troféu para top-3
                    Func<int, string> trofeu = pos =>
                    {
                        if (pos == 1) return "<span title='1º lugar' style='font-size:15px;'>🥇</span>";
                        if (pos == 2) return "<span title='2º lugar' style='font-size:15px;'>🥈</span>";
                        if (pos == 3) return "<span title='3º lugar' style='font-size:15px;'>🥉</span>";
                        return pos.ToString();
                    };
                }
                @if (rankSingle)
                {
                    <!-- tabela única centralizada quando <= 15 unidades -->
                    <div class="row justify-content-center">
                        <div class="col-md-6">
                            <div class="block dashboard-card" style="padding:0;overflow:hidden;">
                                <table class="table table-striped table-sm mb-0 tbl-sort">
                                    <thead>
                                        <tr>
                                            <th class="text-center" style="width:55px;">#</th>
                                            <th>@PCM.WEB.Properties.Resources.unidade</th>
                                            <th class="text-center" style="width:70px;">@PCM.WEB.Properties.Resources.nota</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in rankingList)
                                        {
                                            int _pos = (int)item.ranking;
                                            <tr class="@(_pos <= 3 ? "ranking-top" : "")">
                                                <td class="text-center font-w600">@Html.Raw(trofeu(_pos))</td>
                                                <td class="@(_pos <= 3 ? "font-w700" : "")">@item.unidade</td>
                                                <td class="text-center font-w600">@item.nota</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <!-- 3 colunas quando > 15 unidades -->
                    var rankPerCol = (int)Math.Ceiling(rankingList.Count / 3.0);
                    var rankCol1 = rankingList.Take(rankPerCol).ToList();
                    var rankCol2 = rankingList.Skip(rankPerCol).Take(rankPerCol).ToList();
                    var rankCol3 = rankingList.Skip(rankPerCol * 2).ToList();

                    <div class="row">
                        @foreach (var col in new[] { rankCol1, rankCol2, rankCol3 })
                        {
                            <div class="col-md-4">
                                <div class="block dashboard-card" style="padding:0;overflow:hidden;">
                                    <table class="table table-striped table-sm mb-0 tbl-sort">
                                        <thead>
                                            <tr>
                                                <th class="text-center" style="width:45px;">#</th>
                                                <th>@PCM.WEB.Properties.Resources.unidade</th>
                                                <th class="text-center" style="width:70px;">@PCM.WEB.Properties.Resources.nota</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in col)
                                            {
                                                int _pos = (int)item.ranking;
                                                <tr class="@(_pos <= 3 ? "ranking-top" : "")">
                                                    <td class="text-center font-w600">@Html.Raw(trofeu(_pos))</td>
                                                    <td class="@(_pos <= 3 ? "font-w700" : "")">@item.unidade</td>
                                                    <td class="text-center font-w600">@item.nota</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- ================= NOTAS ================= -->
            <div class="dashboard-section">
                <div class="section-title">Notas</div>
                <div class="block dashboard-card">
                    <div style="overflow-x:auto;">
                        <table class="table table-striped table-sm table-bordered tbl-sort">
                            <thead>
                                <tr>
                                    <th rowspan="2">@PCM.WEB.Properties.Resources.unidade</th>
                                    <th class="text-center" rowspan="2" style="width:80px;">Nota Final</th>
                                    <th class="text-center" colspan="2">Laudo<br /><span class="font-size-xs">@ViewBag.percentual_nota.laudo</span></th>
                                    <th class="text-center" colspan="2">Preventiva<br /><span class="font-size-xs">@ViewBag.percentual_nota.preventiva</span></th>
                                    <th class="text-center" colspan="2">Rotina<br /><span class="font-size-xs">@ViewBag.percentual_nota.rotina</span></th>
                                    <th class="text-center" colspan="2">PMOC<br /><span class="font-size-xs">@ViewBag.percentual_nota.pmoc</span></th>
                                    <th class="text-center" colspan="2">Atendimento Dia<br /><span class="font-size-xs">@ViewBag.percentual_nota.os_atendimento_dia</span></th>
                                    <th class="text-center" colspan="2">U.H.<br /><span class="font-size-xs">@ViewBag.percentual_nota.uh_dia</span></th>
                                    <th class="text-center" colspan="2">HH NÃO Apontado<br /><span class="font-size-xs">@ViewBag.percentual_nota.hh_nao_apontado</span></th>
                                    <th class="text-center" colspan="2">% OS Pendente<br /><span class="font-size-xs">@ViewBag.percentual_nota.os_pendente</span></th>
                                    <th class="text-center" colspan="2">HH Extra<br /><span class="font-size-xs">@ViewBag.percentual_nota.hh_extra</span></th>
                                    <th class="text-center" colspan="2">Preventiva x Corretiva<br /><span class="font-size-xs">@ViewBag.percentual_nota.preventiva_corretiva</span></th>
                                    <th class="text-center" colspan="2">Green Planet<br /><span class="font-size-xs">@ViewBag.percentual_nota.green_planet</span></th>
                                </tr>
                                <tr>
                                    <th class="text-center">%</th>
                                    <th class="text-center">Nota</th>
                                    <th class="text-center">%</th>
                                    <th class="text-center">Nota</th>
                                    <th class="text-center">%</th>
                                    <th class="text-center">Nota</th>
                                    <th class="text-center">%</th>
                                    <th class="text-center">Nota</th>
                                    <th class="text-center">%</th>
                                    <th class="text-center">Nota</th>
                                    <th class="text-center">%</th>
                                    <th class="text-center">Nota</th>
                                    <th class="text-center">%</th>
                                    <th class="text-center">Nota</th>
                                    <th class="text-center">%</th>
                                    <th class="text-center">Nota</th>
                                    <th class="text-center">%</th>
                                    <th class="text-center">Nota</th>
                                    <th class="text-center">%</th>
                                    <th class="text-center">Nota</th>
                                    <th class="text-center">%</th>
                                    <th class="text-center">Nota</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in ViewBag.notas_unidades)
                                {
                                    <tr>
                                        <td>@item.unidade</td>
                                        <td class="text-center font-w600">@item.nota_final</td>
                                        <td class="text-center">@item.laudo</td>
                                        <td class="text-center text-muted">@item.laudo_peso</td>
                                        <td class="text-center">@item.preventiva</td>
                                        <td class="text-center text-muted">@item.preventiva_peso</td>
                                        <td class="text-center">@item.rotina</td>
                                        <td class="text-center text-muted">@item.rotina_peso</td>
                                        <td class="text-center">@item.pmoc</td>
                                        <td class="text-center text-muted">@item.pmoc_peso</td>
                                        <td class="text-center">@item.os_atendimento_dia</td>
                                        <td class="text-center text-muted">@item.os_atendimento_dia_peso</td>
                                        <td class="text-center">@item.uh_dia</td>
                                        <td class="text-center text-muted">@item.uh_dia_peso</td>
                                        <td class="text-center">@item.hh_nao_apontado</td>
                                        <td class="text-center text-muted">@item.hh_nao_apontado_peso</td>
                                        <td class="text-center">@item.os_pendente</td>
                                        <td class="text-center text-muted">@item.os_pendente_peso</td>
                                        <td class="text-center">@item.hh_extra</td>
                                        <td class="text-center text-muted">@item.hh_extra_peso</td>
                                        <td class="text-center">@item.preventiva_corretiva</td>
                                        <td class="text-center text-muted">@item.preventiva_corretiva_peso</td>
                                        <td class="text-center">@item.green_planet</td>
                                        <td class="text-center text-muted">@item.green_planet_peso</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- ================= GRÁFICO GERAL – RADAR ================= -->
            <div class="dashboard-section">
                <div class="section-title">Gráfico Geral – Perfil por Unidade</div>
                <div class="block dashboard-card">
                    <div id="radar-filter" style="margin-bottom:14px;padding-bottom:12px;border-bottom:1px solid #e9ecef;">
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                            <button type="button" id="radar-select-all" class="btn-radar-ctrl btn-radar-primary">Marcar todas</button>
                            <button type="button" id="radar-deselect-all" class="btn-radar-ctrl btn-radar-secondary">Desmarcar todas</button>
                        </div>
                        <div id="radar-checkboxes" style="display:flex;flex-wrap:wrap;gap:6px;"></div>
                    </div>
                    <div style="height:520px;position:relative;"><canvas id="chartGeral"></canvas></div>
                </div>
            </div>


            <!-- ================= ROTINA + PREVENTIVA ================= -->
            <div class="dashboard-section row">
                <div class="col-md-6 d-flex flex-column">
                    <div class="section-title">@PCM.WEB.Properties.Resources.rotina</div>
                    <div class="block dashboard-card flex-fill">
                        <table class="table table-striped table-sm table-bordered mb-0 tbl-sort">
                            <thead>
                                <tr>
                                    <th>@PCM.WEB.Properties.Resources.unidade</th>
                                    <th class="text-center" style="width:55px;">OK</th>
                                    <th class="text-center" style="width:65px;">Pend.</th>
                                    <th class="text-center" style="width:55px;">Total</th>
                                    <th style="min-width:140px;">% Atend.</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in ViewBag.rotina)
                                {
                                    var pctRotina = 0.0;
                                    double.TryParse(item.percentual_atendido.ToString().Replace("%", "").Replace(",", "."), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out pctRotina);
                                    var corRotina = pctRotina >= 86 ? "#22b14c" : (pctRotina >= 65 ? "#ffc90e" : "#e74c3c");
                                    <tr>
                                        <td>@item.unidade</td>
                                        <td class="text-center">@item.quantidade_ok</td>
                                        <td class="text-center">@item.quantidade_pendente</td>
                                        <td class="text-center">@item.total</td>
                                        <td>
                                            <div style="display:flex;align-items:center;gap:6px;">
                                                <div style="flex:1;background:#e9ecef;border-radius:3px;height:14px;overflow:hidden;">
                                                    <div style="width:@(pctRotina.ToString("0", System.Globalization.CultureInfo.InvariantCulture))%;height:100%;background:@corRotina;border-radius:3px;transition:width .4s;"></div>
                                                </div>
                                                <span style="font-size:11px;font-weight:600;color:@corRotina;white-space:nowrap;">@item.percentual_atendido</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="col-md-6 d-flex flex-column">
                    <div class="section-title">@PCM.WEB.Properties.Resources.preventiva</div>
                    <div class="block dashboard-card flex-fill">
                        <table class="table table-striped table-sm table-bordered mb-0 tbl-sort">
                            <thead>
                                <tr>
                                    <th>@PCM.WEB.Properties.Resources.unidade</th>
                                    <th class="text-center" style="width:55px;">OK</th>
                                    <th class="text-center" style="width:65px;">Pend.</th>
                                    <th class="text-center" style="width:55px;">Total</th>
                                    <th style="min-width:140px;">% Atend.</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in ViewBag.preventiva)
                                {
                                    var pctPrev = 0.0;
                                    double.TryParse(item.percentual_atendido.ToString().Replace("%", "").Replace(",", "."), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out pctPrev);
                                    var corPrev = pctPrev >= 86 ? "#22b14c" : (pctPrev >= 65 ? "#ffc90e" : "#e74c3c");
                                    <tr>
                                        <td>@item.unidade</td>
                                        <td class="text-center">@item.quantidade_ok</td>
                                        <td class="text-center">@item.quantidade_pendente</td>
                                        <td class="text-center">@item.total</td>
                                        <td>
                                            <div style="display:flex;align-items:center;gap:6px;">
                                                <div style="flex:1;background:#e9ecef;border-radius:3px;height:14px;overflow:hidden;">
                                                    <div style="width:@(pctPrev.ToString("0", System.Globalization.CultureInfo.InvariantCulture))%;height:100%;background:@corPrev;border-radius:3px;transition:width .4s;"></div>
                                                </div>
                                                <span style="font-size:11px;font-weight:600;color:@corPrev;white-space:nowrap;">@item.percentual_atendido</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- ================= PMOC + LAUDO / DOCUMENTAÇÃO ================= -->
            <div class="dashboard-section row">
                <div class="col-md-6 d-flex flex-column">
                    <div class="section-title">@PCM.WEB.Properties.Resources.pmoc</div>
                    <div class="block dashboard-card flex-fill">
                        <table class="table table-striped table-sm table-bordered mb-0 tbl-sort">
                            <thead>
                                <tr>
                                    <th>@PCM.WEB.Properties.Resources.unidade</th>
                                    <th class="text-center" style="width:55px;">OK</th>
                                    <th class="text-center" style="width:65px;">Pend.</th>
                                    <th class="text-center" style="width:55px;">Total</th>
                                    <th style="min-width:140px;">% Atend.</th>
                                </tr>
                            </thead>
                            <tbody>
