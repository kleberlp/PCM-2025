<!-- Main Container -->
<main id="main-container">
    <div class="content">

        @using (Html.BeginForm("DashboardAtual", "Home", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", @id = "form", enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()

            <!-- ================= FILTRO DATA ================= -->
            <div class="dashboard-section">
                <div class="block dashboard-card">
                    <div class="row align-items-end">
                        <div class="col-sm-12 col-md-3">
                            <label>@PCM.WEB.Properties.Resources.data</label>
                            @Html.DropDownList("data", null, null, new { @class = "form-control font-w600", id = "filtro-data" })
                        </div>
                        <input type="hidden" name="unidade" id="hidden-unidade" value="@Session["codigo_unidade"]" />
                    </div>
                </div>
            </div>

            if (Session["codigo_unidade"].ToString() != "-1")
            {
                <!-- ================= KPIs – VISÃO GERAL ================= -->
                <div class="dashboard-section">
                    <div class="section-title">
                        @ViewBag.dashboard_info.unidade
                    <span class="float-right">
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="Codebase.helpers('print-page');"><i class="si si-printer"></i> @PCM.WEB.Properties.Resources.imprimir</button>
                    </span>
                </div>
                <div class="block dashboard-card" style="padding:0; overflow:hidden;">
                    <div class="torre-comando-grid">
                        <a href="@Url.Action("UsuarioIndex", "Administracao")" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-user torre-icon text-primary"></i><span class="torre-label">@PCM.WEB.Properties.Resources.usuarios</span></div>
                            <div class="os-value text-primary">@ViewBag.dashboard_info.quantidade_usuario</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-users torre-icon text-info"></i><span class="torre-label">Equipe Manutenção</span></div>
                            <div class="os-value text-info">@ViewBag.dashboard_info.equipe_manutencao</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="fa fa-list torre-icon text-primary"></i><span class="torre-label">@PCM.WEB.Properties.Resources.equipamentos</span></div>
                            <div class="os-value text-primary">@ViewBag.dashboard_info.quantidade_equipamento</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-settings torre-icon text-warning"></i><span class="torre-label">Total de OS</span></div>
                            <div class="os-value text-warning">@ViewBag.dashboard_info.quantidade_os</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-settings torre-icon text-primary"></i><span class="torre-label">OS Mês</span></div>
                            <div class="os-value text-primary">@ViewBag.dashboard_info.quantidade_os_gerada</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-calendar torre-icon text-primary"></i><span class="torre-label">Rotinas Implantadas</span></div>
                            <div class="os-value text-primary">@ViewBag.dashboard_info.rotinas_implantadas</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-clock torre-icon text-primary"></i><span class="torre-label">H.H. Apontado</span></div>
                            <div class="os-value text-primary">@ViewBag.dashboard_info.hh_apontado</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="fa fa-list torre-icon text-primary"></i><span class="torre-label">SLA</span></div>
                            <div class="os-value text-primary">@ViewBag.dashboard_info.os_atendimento_dia</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-settings torre-icon text-primary"></i><span class="torre-label">Preventivas Implantadas</span></div>
                            <div class="os-value text-primary">@ViewBag.dashboard_info.preventivas_implantadas</div>
                        </a>
                    </div>
                </div>
            </div>

            <!-- ================= NOTAS ================= -->
            <div class="dashboard-section">
                <div class="section-title">Notas</div>
                <div class="block dashboard-card" style="padding:0; overflow:hidden;">
                    <div class="torre-comando-grid">
                        @{
                            var notaItems = new List<dynamic>();
                            notaItems.Add(new { icon = "si si-doc", label = PCM.WEB.Properties.Resources.laudo, valor = (string)ViewBag.dashboard_info.laudo + "%" });
                            notaItems.Add(new { icon = "si si-settings", label = PCM.WEB.Properties.Resources.preventiva, valor = (string)ViewBag.dashboard_info.preventiva + "%" });
                            notaItems.Add(new { icon = "fa fa-hotel", label = PCM.WEB.Properties.Resources.uh_em_dia, valor = (string)ViewBag.dashboard_info.uh_dia + "%" });
                            notaItems.Add(new { icon = "fa fa-snowflake-o", label = PCM.WEB.Properties.Resources.pmoc, valor = (string)ViewBag.dashboard_info.pmoc + "%" });
                            notaItems.Add(new { icon = "si si-calendar", label = PCM.WEB.Properties.Resources.rotina, valor = (string)ViewBag.dashboard_info.rotina + "%" });
                            notaItems.Add(new { icon = "si si-trophy", label = PCM.WEB.Properties.Resources.ranking, valor = ViewBag.dashboard_info.ranking + "º" });
                        }
                        @foreach (var n in notaItems)
                        {
                            <a href="#" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header"><i class="@n.icon torre-icon text-primary"></i><span class="torre-label">@n.label</span></div>
                                <div class="os-value text-primary">@n.valor</div>
                            </a>
                        }
                    </div>
                </div>
            </div>

            <!-- ================= EVOLUÇÃO MENSAL (line) ================= -->
            <div class="dashboard-section">
                <div class="section-title">Evolução Mensal</div>
                <div class="block dashboard-card chart-card">
                    <div class="chart-wrapper"><canvas id="chartEvolucaoMensal"></canvas></div>
                </div>
            </div>

            <!-- ================= SLA – MANUTENÇÃO (KPIs) ================= -->
            <div class="dashboard-section">
                <div class="section-title">SLA - Manutenção</div>
                <div class="block dashboard-card" style="padding:0; overflow:hidden;">
                    <div class="torre-comando-grid">
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-settings torre-icon" style="color:rgba(34,177,76)"></i><span class="torre-label">@PCM.WEB.Properties.Resources.no_dia</span></div>
                            <div class="os-value" style="color:rgba(34,177,76)">@ViewBag.dashboard_info.os_atendimento_dia%</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-settings torre-icon" style="color:rgba(63,72,204)"></i><span class="torre-label">@PCM.WEB.Properties.Resources.um_dia</span></div>
                            <div class="os-value" style="color:rgba(63,72,204)">@ViewBag.dashboard_info.os_atendimento_um_dia</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-settings torre-icon" style="color:rgb(255,201,14)"></i><span class="torre-label">@PCM.WEB.Properties.Resources.tres_dias</span></div>
                            <div class="os-value" style="color:rgb(255,201,14)">@ViewBag.dashboard_info.os_atendimento_tres_dias</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-settings torre-icon" style="color:rgba(255,128,0)"></i><span class="torre-label">@PCM.WEB.Properties.Resources.cinco_dias</span></div>
                            <div class="os-value" style="color:rgba(255,128,0)">@ViewBag.dashboard_info.os_atendimento_cinco_dias</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-settings torre-icon" style="color:rgba(255,128,0)"></i><span class="torre-label">@PCM.WEB.Properties.Resources.acima_cinco_dias</span></div>
                            <div class="os-value" style="color:rgba(255,128,0)">@ViewBag.dashboard_info.os_atendimento_acima_cinco_dias</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="si si-settings torre-icon text-danger"></i><span class="torre-label">@PCM.WEB.Properties.Resources.nao_atendido</span></div>
                            <div class="os-value text-danger">@ViewBag.dashboard_info.os_nao_atendido</div>
                        </a>
                    </div>
                </div>
            </div>

            <!-- ================= EVOLUÇÃO SLA (doughnut — mês atual) ================= -->
            <div class="dashboard-section row">
                <div class="col-md-5 d-flex flex-column">
                    <div class="section-title">SLA – Distribuição Atual</div>
                    <div class="block dashboard-card chart-card flex-fill">
                        <div class="chart-wrapper"><canvas id="chartEvolucaoMensalAtendimentoOS"></canvas></div>
                    </div>
                </div>
                <div class="col-md-7 d-flex flex-column">
                    <div class="section-title">SLA – Tendência Mensal</div>
                    <div class="block dashboard-card chart-card flex-fill">
                        <div class="chart-wrapper"><canvas id="chartEvolucaoSLATendencia"></canvas></div>
                    </div>
                </div>
            </div>

            <!-- ================= HORA HOMEM (KPIs) ================= -->
            <div class="dashboard-section">
                <div class="section-title">Hora Homem</div>
                <div class="block dashboard-card" style="padding:0; overflow:hidden;">
                    <div class="torre-comando-grid">
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="fa fa-clock-o torre-icon text-muted"></i><span class="torre-label">H.H. Disponível</span></div>
                            <div class="os-value text-muted">@ViewBag.dashboard_info.hh_disponivel</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="fa fa-clock-o torre-icon text-danger"></i><span class="torre-label">@ViewBag.dashboard_info.percentual_corretiva – @PCM.WEB.Properties.Resources.corretiva</span></div>
                            <div class="os-value text-danger">@ViewBag.dashboard_info.horas_corretivas</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="fa fa-clock-o torre-icon text-primary"></i><span class="torre-label">@ViewBag.dashboard_info.percentual_preventiva – @PCM.WEB.Properties.Resources.preventiva</span></div>
                            <div class="os-value text-primary">@ViewBag.dashboard_info.horas_preventivas</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="fa fa-clock-o torre-icon text-info"></i><span class="torre-label">@ViewBag.dashboard_info.percentual_pmoc – @PCM.WEB.Properties.Resources.pmoc</span></div>
                            <div class="os-value text-info">@ViewBag.dashboard_info.horas_pmoc</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="fa fa-clock-o torre-icon text-success"></i><span class="torre-label">@ViewBag.dashboard_info.percentual_uh – @PCM.WEB.Properties.Resources.uh_em_dia</span></div>
                            <div class="os-value text-success">@ViewBag.dashboard_info.horas_uh</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="fa fa-clock-o torre-icon text-warning"></i><span class="torre-label">@ViewBag.dashboard_info.percentual_mapa_manutencao – Mapa Manutenção</span></div>
                            <div class="os-value text-warning">@ViewBag.dashboard_info.horas_mapa_manutencao</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="fa fa-clock-o torre-icon text-danger"></i><span class="torre-label">@ViewBag.dashboard_info.percentual_horas_ociosas – @PCM.WEB.Properties.Resources.ociosidade</span></div>
                            <div class="os-value text-danger">@ViewBag.dashboard_info.horas_ociosas</div>
                        </a>
                        <a href="#" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header"><i class="fa fa-clock-o torre-icon text-muted"></i><span class="torre-label">Faltas</span></div>
                            <div class="os-value text-muted">@ViewBag.dashboard_info.faltas_justificadas J / <span class="text-danger">@ViewBag.dashboard_info.faltas_nao_justificadas NJ</span></div>
                        </a>
                    </div>
                </div>
            </div>

            <!-- ================= EVOLUÇÃO H.H. (bar+line misto) ================= -->
            <div class="dashboard-section">
                <div class="section-title">Evolução H.H.</div>
                <div class="block dashboard-card chart-card">
                    <div class="chart-wrapper"><canvas id="chartEvolucaoHH"></canvas></div>
                </div>
            </div>

            <!-- ================= EVOLUÇÃO PMOC (bar+line misto) ================= -->
            <div class="dashboard-section">
                <div class="section-title">Evolução PMOC</div>
                <div class="block dashboard-card chart-card">
                    <div class="chart-wrapper"><canvas id="chartEvolucaoPMOC"></canvas></div>
                </div>
            </div>

            <!-- ================= LAUDOS (tabela) ================= -->
            <div class="dashboard-section">
                <div class="section-title">@PCM.WEB.Properties.Resources.laudo</div>
                <div class="block dashboard-card">
                    <table class="table table-striped table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>@PCM.WEB.Properties.Resources.laudo</th>
                                <th class="text-center" style="width:100px;">@PCM.WEB.Properties.Resources.data_validade</th>
                                <th class="text-center" style="width:75px;">@ViewBag.data_atual</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ViewBag.manutencao_laudo)
                            {
                                <tr>
                                    <td><span class="font-w600">@item.nome_fantasia</span>@item.manutencao<span class="text-primary">@item.equipamento</span></td>
                                    @if (item.data_validade == "")
                                    {
                                        <td class="font-w600 text-center">@item.data_validade</td>
                                    }
                                    else if (DateTime.Parse(item.data_validade) < ViewBag.data_atual)
                                    {
                                        <td class="font-w600 text-center"><span class="badge badge-danger">@item.data_validade</span></td>
 }
                                    else
                                    {
                                        <td class="font-w600 text-center">@item.data_validade</td>
}

                                    @if (item.mes_1 == 0)
                                    {
                                        <td class="text-center"><span class="badge badge-primary">X</span></td>
                                    }
                                    else if (item.mes_1 == -1)
                                    {
                                        <td class="text-center"><span class="badge badge-warning">X</span></td>
                                    }
                                    else if (item.mes_1 == -2)
                                    {
                                        <td class="text-center"><span class="badge badge-danger">X</span></td>
                                    }
                                    else if (item.mes_1 == -4)
                                    {
                                        <td class="text-center"></td>
                                    }
                                    else if (item.mes_1 == -5)
                                    {
                                        <td class="text-center"><span class="badge badge-danger">X</span></td>
                                    }
                                    else if (item.mes_1 > 0)
                                    {
                                        <td class="text-center"><span class="badge badge-success">X</span></td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }

    </div>
</main>

@section Styles {
    @Styles.Render("~/Content/dashboard")
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/dataTables")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/chart")
    @Scripts.Render("~/plugins/select")

    <script>

        var colorNamesEvolucaoMensal = Object.keys(window.chartColors);
        var colorNamesEvolucaoHH     = Object.keys(window.chartColors);

        // ── Configurações ────────────────────────────────────────

        var configEvolucaoMensal = {
            type: 'line',
            data: { labels: [], datasets: [] },
            options: {
                responsive: true, maintainAspectRatio: false,
                legend: { display: true, position: 'bottom' }
            }
        };

        // SLA – doughnut do mês atual
        var configSLADonut = {
            type: 'doughnut',
            data: { labels: [], datasets: [] },
            options: {
                responsive: true, maintainAspectRatio: false,
                cutoutPercentage: 60,
                legend: {
                    display: true, position: 'right',
                    labels: {
                        padding: 16, boxWidth: 14, fontSize: 12,
                        generateLabels: function(chart) {
                            var data = chart.data;
                            if (!data.labels.length) return [];
                            return data.labels.map(function(label, i) {
                                var ds  = data.datasets[0];
                                var val = ds && ds.data[i] != null ? ds.data[i].toFixed(1) + '%' : '0%';
                                var bg  = ds && ds.backgroundColor ? ds.backgroundColor[i] : '#ccc';
                                return { text: label + '  ' + val, fillStyle: bg, strokeStyle: bg, lineWidth: 0, index: i };
                            });
                        }
                    },
                    tooltips: {
                        callbacks: {
                            label: function(item, data) {
                                var val = data.datasets[0].data[item.index];
                                return ' ' + data.labels[item.index] + ': ' + (val != null ? val.toFixed(1) : 0) + '%';
                            }
                        }
                    }
                }
            }
        };

        // SLA – line de tendência mensal (stacked area)
        var configSLATendencia = {
            type: 'line',
            data: { labels: [], datasets: [] },
            options: {
                responsive: true, maintainAspectRatio: false,
                legend: { display: true, position: 'bottom' },
                scales: {
                    yAxes: [{ stacked: true, ticks: { min: 0, max: 100, stepSize: 20 } }]
                }
            }
        };

        var configEvolucaoHH = {
            type: 'bar',
            data: { labels: [], datasets: [] },
            options: {
                responsive: true, maintainAspectRatio: false, animation: false,
                legend: { display: true, position: 'bottom' },
                scales: { xAxes: [{ stacked: true }], yAxes: [{ stacked: true }] }
            }
        };

        var configEvolucaoPMOC = {
            type: 'bar',
            data: { labels: [], datasets: [] },
            options: {
                responsive: true, maintainAspectRatio: false, animation: false,
                legend: { display: true, position: 'bottom' }
            }
        };

        // ── Cores SLA ────────────────────────────────────────────
        var slaColors = {
            'No Dia':       { bg: 'rgba(34,177,76,0.75)',  border: 'rgba(34,177,76,1)' },
            '1 Dia':        { bg: 'rgba(63,72,204,0.75)',  border: 'rgba(63,72,204,1)' },
            '3 Dias':       { bg: 'rgba(255,201,14,0.75)', border: 'rgba(255,201,14,1)' },
            '5 Dias':       { bg: 'rgba(255,128,0,0.75)',  border: 'rgba(255,128,0,1)' },
            '> 5 Dias':     { bg: 'rgba(255,0,0,0.75)',    border: 'rgba(255,0,0,1)' },
            'Não atendida': { bg: 'rgba(128,0,128,0.75)',  border: 'rgba(128,0,128,1)' }
        };

        // ── Submit ao mudar data (passa unidade do header) ───────
        $(function () {
            $("#filtro-data").change(function () {
                var unidadeHeader = $("#header-unidade").val();
                if (unidadeHeader) $("#hidden-unidade").val(unidadeHeader);
                $("#form").submit();
            });
        });

        // ── Carregamento dos gráficos ────────────────────────────

        function LoadChartEvolucaoMensal() {
            $.post("@Url.Content("~/Dashboard/DataMonth")", { "data": $("#filtro-data").val() }, function (obj) {
                configEvolucaoMensal.data.labels = obj;
                window.EvolucaoMensal.update();
            }, "json");
            $.post("@Url.Content("~/Dashboard/ChartEvolucaoMensal")", { "data": $("#filtro-data").val() }, function (obj) {
                configEvolucaoMensal.data.datasets = [];
                $.each(obj, function (i, r) {
                    var c = colorNamesEvolucaoMensal[i % colorNamesEvolucaoMensal.length];
                    configEvolucaoMensal.data.datasets.push({
                        label: r.serie, data: r.valor, fill: false,
                        backgroundColor: window.chartColors[c], borderColor: window.chartBorderColors[c]
                    });
                });
                window.EvolucaoMensal.update();
            }, "json");
        }

        function LoadChartSLA() {
            $.post("@Url.Content("~/Dashboard/ChartEvolucaoMensalAtendimentoOS")", { "data": $("#filtro-data").val() }, function (obj) {
                if (!obj || !obj.length) return;

                // Doughnut: pega os valores do último mês disponível
                var donutLabels = [], donutData = [], donutBg = [];
                var tendLabels  = [], tendDatasets = [];

                // Monta eixo X da tendência a partir do primeiro conjunto de valores
                $.post("@Url.Content("~/Dashboard/DataMonth")", { "data": $("#filtro-data").val() }, function (months) {
                    tendLabels = months;

                    $.each(obj, function (i, r) {
                        var c = slaColors[r.serie] || { bg: 'rgba(150,150,150,0.7)', border: '#999' };

                        // Doughnut: último valor de cada série
                        donutLabels.push(r.serie);
                        donutData.push(r.valor.length ? r.valor[r.valor.length - 1] : 0);
                        donutBg.push(c.bg);

                        // Tendência: série completa
                        tendDatasets.push({
                            label: r.serie, data: r.valor, fill: true,
                            backgroundColor: c.bg, borderColor: c.border, borderWidth: 1.5, pointRadius: 2
                        });
                    });

                    // Atualiza doughnut
                    configSLADonut.data = { labels: donutLabels, datasets: [{ data: donutData, backgroundColor: donutBg }] };
                    window.SLADonut.data = configSLADonut.data;
                    window.SLADonut.update();

                    // Atualiza tendência
                    configSLATendencia.data = { labels: tendLabels, datasets: tendDatasets };
                    window.SLATendencia.data = configSLATendencia.data;
                    window.SLATendencia.update();
                }, "json");
            }, "json");
        }

        function LoadChartEvolucaoHH() {
            $.post("@Url.Content("~/Dashboard/DataMonth")", { "data": $("#filtro-data").val() }, function (obj) {
                configEvolucaoHH.data.labels = obj;
                window.EvolucaoHH.update();
            }, "json");
            $.post("@Url.Content("~/Dashboard/ChartEvolucaoHH")", { "data": $("#filtro-data").val() }, function (obj) {
                configEvolucaoHH.data.datasets = [];
                $.each(obj, function (i, r) {
                    var c = colorNamesEvolucaoHH[i % colorNamesEvolucaoHH.length];
                    configEvolucaoHH.data.datasets.push({
                        label: r.serie, data: r.valor, fill: false,
                        backgroundColor: window.chartColors[c], borderColor: window.chartBorderColors[c],
                        type: (r.serie === 'H.H. Disponível') ? 'line' : 'bar'
                    });
                });
                window.EvolucaoHH.update();
            }, "json");
        }

        function LoadChartEvolucaoPMOC() {
            var pmocColors = {
                'Saldo PMOC':          { bg: 'rgba(34,177,76,0.5)',  border: 'rgba(34,177,76,0.9)' },
                'Saldo PMOC Pendente': { bg: 'rgba(255,0,0,0.5)',    border: 'rgba(255,0,0,0.9)' },
                'Qtd. Equipamentos':   { bg: 'rgba(63,72,204,0.5)',  border: 'rgba(63,72,204,0.9)' }
            };
            $.post("@Url.Content("~/Dashboard/DataDay")", { "data": $("#filtro-data").val() }, function (obj) {
                configEvolucaoPMOC.data.labels = obj;
            }, "json");
            $.post("@Url.Content("~/Dashboard/ChartEvolucaoPMOC")", { "data": $("#filtro-data").val() }, function (obj) {
                configEvolucaoPMOC.data.datasets = [];
                $.each(obj, function (i, r) {
                    var c = pmocColors[r.serie] || { bg: '#ccc', border: '#999' };
                    configEvolucaoPMOC.data.datasets.push({
                        label: r.serie, data: r.valor, fill: false,
                        backgroundColor: c.bg, borderColor: c.border,
                        type: (r.serie === 'Qtd. Equipamentos') ? 'bar' : 'line'
                    });
                });
                window.EvolucaoPMOC.update();
            }, "json");
        }

        // ── Inicialização ────────────────────────────────────────
        jQuery(function () {
            window.EvolucaoMensal = new Chart(document.getElementById('chartEvolucaoMensal').getContext('2d'),    configEvolucaoMensal);
            window.SLADonut       = new Chart(document.getElementById('chartEvolucaoMensalAtendimentoOS').getContext('2d'), configSLADonut);
            window.SLATendencia   = new Chart(document.getElementById('chartEvolucaoSLATendencia').getContext('2d'), configSLATendencia);
            window.EvolucaoHH     = new Chart(document.getElementById('chartEvolucaoHH').getContext('2d'),         configEvolucaoHH);
            window.EvolucaoPMOC   = new Chart(document.getElementById('chartEvolucaoPMOC').getContext('2d'),       configEvolucaoPMOC);

            LoadChartEvolucaoMensal();
            LoadChartSLA();
            LoadChartEvolucaoHH();
            LoadChartEvolucaoPMOC();

            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
        });

    </script>
}
