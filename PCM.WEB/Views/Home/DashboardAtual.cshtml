                @*TABLE: LAUDOS*@
    <div class="block">

        <div class="block-header block-header-default bg-gd-default">
            <h3 class="block-title-big text-white font-w600">@PCM.WEB.Properties.Resources.laudo</h3>
        </div>

        <div class="block-content block-content-full pb-1">

            <!-- DataTables init on table by adding .js-dataTable-full-pagination class, functionality initialized in js/pages/be_tables_datatables.js -->
            <table class="table table-striped table-sm table-bordered d-print-table-2">
                <thead>
                    <tr class="table-secondary">
                        <th>@PCM.WEB.Properties.Resources.laudo</th>
                        <th class="text-center" style="width:100px;">@PCM.WEB.Properties.Resources.data_validade</th>
                        <th class="text-center" style="width:75px;">@ViewBag.data_atual</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in ViewBag.manutencao_laudo)
                    {
                        <tr>
                            <td><span class="font-w600">@item.nome_fantasia</span>@item.manutencao<span class="text-primary">@item.equipamento</span></td>
                            @if (item.data_validade == "")
                            {
                                <td class="font-w600 text-center">@item.data_validade</td>
                            }
                            else if (DateTime.Parse(item.data_validade) < ViewBag.data_atual)
                            {
                                <td class="font-w600 text-center"><span class="badge badge-danger">@item.data_validade</span></td>
                            }
                            else
                            {
                                <td class="font-w600 text-center">@item.data_validade</td>
                            }

                            @if (item.mes_1 == 0)
                            {
                                <td class="text-center" style="width:75px;"><span class="badge badge-primary">X</span></td>
                            }
                            else if (item.mes_1 == -1)
                            {
                                <td class="text-center" style="width:75px;"><span class="badge badge-warning">X</span></td>
                            }
                            else if (item.mes_1 == -2)
                            {
                                <td class="text-center" style="width:75px;"><span class="badge badge-danger">X</span></td>
                            }
                            else if (item.mes_1 == -4)
                            {
                                <td class="text-center" style="width:75px;"></td>
                            }
                            else if (item.mes_1 == -5)
                            {
                                <td class="text-center" style="width:75px;"><span class="badge badge-danger">X</span></td>
                            }
                            else if (item.mes_1 > 0)
                            {
                                <td class="text-center" style="width:75px;"><span class="badge badge-success">X</span></td>
                            }
                        </tr>
                    }
                </tbody>
            </table>

        </div>

    </div>

            }
        }

    </div>

</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/dataTables")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/chart")
    @Scripts.Render("~/plugins/gauge")
    @Scripts.Render("~/plugins/select")

<script>

    var colorNamesEvolucaoMensal = Object.keys(window.chartColors);

    var colorNamesEvolucaoMensalAtendimentoOS = Object.keys(window.chartColors);

    var colorNamesEvolucaoHH = Object.keys(window.chartColors);

    var colorNamesEvolucaoPMOC = Object.keys(window.chartColors);

    var configEvolucaoMensal = {
        type: 'line',
        options: {
            responsive: true,
            data: {
                datasets: [{
                    data: [],
                    backgroundColor: [],
                }],
                labels: []
            },
            legend: {
                display: true,
                position: 'bottom',
                fontStyle: 'bold'
            },
            title: {
                display: false,
                text: "Evolução - Últimos 12 meses",
                fontSize: 20,
                padding: 30
            },
            animation: {
                animateScale: false,
                animateRotate: false
            }
        }
    };

    var configEvolucaoMensalAtendimentoOS = {
        type: 'horizontalBar',
        options: {
            responsive: true,
            data: {
                datasets: [{
                    data: [],
                    backgroundColor: [],
                }],
                labels: []
            },
            legend: {
                display: true,
                position: 'bottom',
                fontStyle: 'bold'
            },
            title: {
                display: false,
                text: "Evolução - Últimos 12 meses",
                fontSize: 20,
                padding: 30
            },
            animation: false,
            scales: {
                xAxes: [{
                    stacked: true,
                    ticks: {
                        stepSize: 10.0,
                        min: 0.0,
                        max: 100.0
                    }
                }],
                yAxes: [{
                    stacked: true
                }]
            }
        }
    };

    var configEvolucaoHH = {
        type: 'bar',
        options: {
            responsive: true,
            data: {
                datasets: [{
                    data: [],
                    backgroundColor: []
                }],
                labels: []
            },
            legend: {
                display: true,
                position: 'bottom',
                fontStyle: 'bold'
            },
            title: {
                display: false,
                text: "Evolução - H.H.",
                fontSize: 20,
                padding: 30
            },
            hover: {
                animationDuration: 0
            },
            animation: false,
            scales: {
                xAxes: [{
                    stacked: true,
                    ticks: {
                        stepSize: 10.0,
                        min: 0.0,
                        max: 100.0
                    }
                }],
                yAxes: [{
                    stacked: true
                }]
            }
        }
    };

    var configEvolucaoPMOC = {
        type: 'bar',
        options: {
            responsive: true,
            data: {
                datasets: [{
                    data: [],
                    backgroundColor: []
                }],
                labels: []
            },
            legend: {
                display: true,
                position: 'bottom',
                fontStyle: 'bold'
            },
            title: {
                display: false,
                text: "Evolução - PMOC",
                fontSize: 20,
                padding: 30
            },
            hover: {
                animationDuration: 0
            },
            animation: false
        }
    };

    var configAtendimentoOS = {
        type: 'doughnut',
        options: {
            responsive: true,
            data: {
                datasets: [{
                    data: [],
                    backgroundColor: [],
                    type: []
                }],
                labels: []
            },
            legend: {
                display: true,
                labels: {
                    padding: 20
                },
                position: 'bottom',
            },
            title: {
                display: false,
            },
            animation: false,
            tooltips: {
                enabled: true
            }
        }
    };

    $(function () {

        $("#unidade").change(function () {
            $("#form").submit();
        });

        $("#data").change(function () {
            $("#form").submit();
        });

    });

    function LoadChartEvolucaoMensal() {

        //Obtém eixo X
        $.post("@Url.Content("~/Dashboard/DataMonth")", { "unidade": $("#unidade").val(), "data": $("#data").val() }, function (obj) {
            $.each(obj, function (indice, result) {
                configEvolucaoMensal.data.labels.push(result);
            });
            window.EvolucaoMensal.update();
        }, "json");

        $.post("@Url.Content("~/Dashboard/ChartEvolucaoMensal")", { "data": $("#data").val() }, function (obj) {

            if (obj.length == 0) {
                configEvolucaoMensal.data.labels = [];
                configEvolucaoMensal.data.datasets = [];
                window.EvolucaoMensal.update();
            } else {
                $.each(obj, function (indice, result) {

                    var colorName = colorNamesEvolucaoMensal[configEvolucaoMensal.data.datasets.length % colorNamesEvolucaoMensal.length];
                    var newColor = window.chartColors[colorName];
                    var borderColor = window.chartBorderColors[colorName];

                    var newDataset = {
                        label: result.serie,
                        backgroundColor: newColor,
                        borderColor: borderColor,
                        data: [],
                        fill: false
                    };

                    for (var index = 0; index < result.valor.length; ++index) {
                        newDataset.data.push(result.valor[index]);
                    }

                    configEvolucaoMensal.data.datasets.push(newDataset);
                    window.EvolucaoMensal.update();
                });
            }
        }, "json");

    };

    function LoadChartEvolucaoMensalAtendimentoOS() {

        //Obtém eixo X
        $.post("@Url.Content("~/Dashboard/DataMonth")", { "unidade": $("#unidade").val(), "data": $("#data").val() }, function (obj) {
            $.each(obj, function (indice, result) {
                configEvolucaoMensalAtendimentoOS.data.labels.push(result);
            });
            window.EvolucaoMensalAtendimentoOS.update();
        }, "json");

        $.post("@Url.Content("~/Dashboard/ChartEvolucaoMensalAtendimentoOS")", { "data": $("#data").val() }, function (obj) {

            if (obj.length == 0) {
                configEvolucaoMensalAtendimentoOS.data.labels = [];
                configEvolucaoMensalAtendimentoOS.data.datasets = [];
                window.EvolucaoMensalAtendimentoOS.update();
            } else {
                $.each(obj, function (indice, result) {

                    switch (result.serie) {
                        case 'No Dia':
                            colorName = 'rgba(34, 177, 76, 0.4)';
                            borderColorName = 'rgba(34, 177, 76, 0.8)';
                            break;
                        case '1 Dia':
                            colorName = 'rgba(63, 72, 204, 0.4)';
                            borderColorName = 'rgba(63, 72, 204, 0.8)';
                            break;
                        case '3 Dias':
                            colorName = 'rgba(255, 242, 0, 0.4)';
                            borderColorName = 'rgba(255, 242, 0, 0.8)';
                            break;
                        case '5 Dias':
                            colorName = 'rgba(255, 128, 0, 0.4)';
                            borderColorName = 'rgba(255, 128, 0, 0.8)';
                            break;
                        case '> 5 Dias':
                            colorName = 'rgba(255, 0, 0, 0.4)';
                            borderColorName = 'rgba(255, 0, 0, 0.8)';
                            break;
                        case 'Não atendida':
                            colorName = 'rgba(128, 0, 128, 0.6)';
                            borderColorName = 'rgba(128, 0, 128, 0.8)';
                            break;
                    }

                    var newDataset = {
                        label: result.serie,
                        backgroundColor: colorName,
                        borderColor: borderColorName,
                        data: []
                    };

                    for (var index = 0; index < result.valor.length; ++index) {
                        newDataset.data.push(result.valor[index]);
                    }

                    configEvolucaoMensalAtendimentoOS.data.datasets.push(newDataset);
                    window.EvolucaoMensalAtendimentoOS.update();
                });
            }
        }, "json");

    };

    function LoadChartEvolucaoHH() {

        //Obtém eixo X
        $.post("@Url.Content("~/Dashboard/DataMonth")", { "unidade": $("#unidade").val(), "data": $("#data").val() }, function (obj) {
            $.each(obj, function (indice, result) {
                configEvolucaoHH.data.labels.push(result);
            });
            window.EvolucaoHH.update();
        }, "json");

        $.post("@Url.Content("~/Dashboard/ChartEvolucaoHH")", { "data": $("#data").val() }, function (obj) {

            if (obj.length == 0) {
                configEvolucaoHH.data.labels = [];
                configEvolucaoHH.data.datasets = [];
                window.EvolucaoHH.update();
            } else {
                $.each(obj, function (indice, result) {

                    var colorName = colorNamesEvolucaoHH[configEvolucaoHH.data.datasets.length % colorNamesEvolucaoHH.length];
                    var newColor = window.chartColors[colorName];
                    var borderColor = window.chartBorderColors[colorName];
                    var tipo = (result.serie == 'H.H. Disponível') ? 'line' : 'bar';

                    var newDataset = {
                        label: result.serie,
                        backgroundColor: newColor,
                        borderColor: borderColor,
                        data: [],
                        fill: false,
                        type: tipo
                    };

                    for (var index = 0; index < result.valor.length; ++index) {
                        newDataset.data.push(result.valor[index]);
                    }

                    configEvolucaoHH.data.datasets.push(newDataset);
                    window.EvolucaoHH.update();
                });
            }
        }, "json");

    };

    function LoadChartEvolucaoPMOC() {

        //Obtém eixo X
        $.post("@Url.Content("~/Dashboard/DataDay")", { "data": $("#data").val() }, function (obj) {
            $.each(obj, function (indice, result) {
                configEvolucaoPMOC.data.labels.push(result);
            });
        }, "json");

        $.post("@Url.Content("~/Dashboard/ChartEvolucaoPMOC")", { "data": $("#data").val() }, function (obj) {

            if (obj.length == 0) {
                configEvolucaoPMOC.data.labels = [];
                configEvolucaoPMOC.data.datasets = [];
                window.EvolucaoPMOC.update();
            } else {
                $.each(obj, function (indice, result) {

                    var tipo = (result.serie == 'Qtd. Equipamentos') ? 'bar' : 'line';

                    switch (result.serie) {
                        case 'Saldo PMOC':
                            colorName = 'rgba(34, 177, 76, 0.4)';
                            borderColorName = 'rgba(34, 177, 76, 0.8)';
                            break;
                        case 'Saldo PMOC Pendente':
                            colorName = 'rgba(255, 0, 0, 0.4)';
                            borderColorName = 'rgba(255, 0, 0, 0.8)';
                            break;
                        case 'Qtd. Equipamentos':
                            colorName = 'rgba(63, 72, 204, 0.4)';
                            borderColorName = 'rgba(63, 72, 204, 0.8)';
                            break;
                    }

                    var newDataset = {
                        label: result.serie,
                        backgroundColor: colorName,
                        borderColor: borderColorName,
                        data: [],
                        fill: false,
                        type: tipo
                    };

                    for (var index = 0; index < result.valor.length; ++index) {
                        newDataset.data.push(result.valor[index]);
                    }

                    configEvolucaoPMOC.data.datasets.push(newDataset);
                    window.EvolucaoPMOC.update();
                });
            }
        }, "json");

    };

    function LoadChartAtendimentoOS() {

        var newDataSet = {
            label: [],
            data: [],
            backgroundColor: [],
            fill: false
        };

        configAtendimentoOS.data.labels.push("No Dia");
        configAtendimentoOS.data.labels.push("1 Dia");
        configAtendimentoOS.data.labels.push("3 Dias");
        configAtendimentoOS.data.labels.push("5 Dias");
        configAtendimentoOS.data.labels.push("> 5 Dias");
        configAtendimentoOS.data.labels.push("Ñ Atendido");

        newDataSet.backgroundColor.push('rgba(34, 177, 76, 0.5)');
        newDataSet.backgroundColor.push('rgba(63, 72, 204, 0.5)');
        newDataSet.backgroundColor.push('rgba(255, 242, 0, 0.5)');
        newDataSet.backgroundColor.push('rgba(255, 128, 0, 0.5)');
        newDataSet.backgroundColor.push('rgba(255, 0, 0, 0.5)');
        newDataSet.backgroundColor.push('rgba(128, 0, 128, 0.5)');

        if ($("#codigo_unidade").val() > -1) {

        newDataSet.data.push(Number(@ViewBag.dashboard_info.os_atendimento_dia.Replace("%","")));
        newDataSet.data.push(Number(@ViewBag.dashboard_info.os_atendimento_um_dia.Replace("%","").Replace("%", "")));
        newDataSet.data.push(Number(@ViewBag.dashboard_info.os_atendimento_tres_dias.Replace("%","").Replace("%", "")));
        newDataSet.data.push(Number(@ViewBag.dashboard_info.os_atendimento_cinco_dias.Replace("%","").Replace("%", "")));
        newDataSet.data.push(Number(@ViewBag.dashboard_info.os_atendimento_acima_cinco_dias.Replace("%","").Replace("%", "")));
        newDataSet.data.push(Number(@ViewBag.dashboard_info.os_nao_atendido.Replace("%","").Replace("%", "")));

        }
        configAtendimentoOS.data.datasets.push(newDataSet);
        window.AtendimentoOS.update();
    };

    // Initialize when page loads
    jQuery(function () {

        var cEvolucaoMensal = document.getElementById('chartEvolucaoMensal').getContext('2d');
        window.EvolucaoMensal = new Chart(cEvolucaoMensal, configEvolucaoMensal);
        var cEvolucaoMensalAtendimentoOS = document.getElementById('chartEvolucaoMensalAtendimentoOS').getContext('2d');
        window.EvolucaoMensalAtendimentoOS = new Chart(cEvolucaoMensalAtendimentoOS, configEvolucaoMensalAtendimentoOS);
        var cEvolucaoHH = document.getElementById('chartEvolucaoHH').getContext('2d');
        window.EvolucaoHH = new Chart(cEvolucaoHH, configEvolucaoHH);
        var cEvolucaoPMOC = document.getElementById('chartEvolucaoPMOC').getContext('2d');
        window.EvolucaoPMOC = new Chart(cEvolucaoPMOC, configEvolucaoPMOC);

        LoadChartEvolucaoHH();
        LoadChartEvolucaoMensal();
        LoadChartEvolucaoMensalAtendimentoOS();
        LoadChartEvolucaoPMOC();

        //var cAtendimentoOS = document.getElementById('chartAtendimentoOS').getContext('2d');
        //window.AtendimentoOS = new Chart(cAtendimentoOS, configAtendimentoOS);

        //LoadChartAtendimentoOS();
        Codebase.helpers(['datepicker', 'maxlength', 'select2']);
    });


</script>
