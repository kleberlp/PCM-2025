                                    <div class="font-size-h3 font-w600">@ViewBag.dashboard_info.faltas_nao_justificadas <span class="font-size-h5 font-w600 text-uppercase"> - Faltas <span class="text-danger">NÃO</span> Justificadas</span></div>
                                </div>
                            </a>
