<!-- Main Container -->
<main id="main-container">
    <div class="content">

        @using (Html.BeginForm("QualidadeDesempenho", "Home", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", @id = "form", enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()

            <!-- ================= FILTRO DATA ================= -->
            <div class="dashboard-section">
                <div class="block dashboard-card">
                    <div class="row align-items-end">
                        <div class="col-sm-12 col-md-3">
                            <label>@PCM.WEB.Properties.Resources.data</label>
                            @Html.DropDownList("data", null, null, new { @class = "form-control font-w600", id = "filtro-data" })
                        </div>
                        <input type="hidden" name="unidade" id="hidden-unidade" value="@Session["codigo_unidade"]" />
                    </div>
                </div>
            </div>

            <!-- ================= NOTAS POR UNIDADE ================= -->
            <div class="dashboard-section">
                <div class="section-title">
                    Qualidade – Desempenho da Unidade
                    <span class="float-right">
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="Codebase.helpers('print-page');"><i class="si si-printer"></i> @PCM.WEB.Properties.Resources.imprimir</button>
                    </span>
                </div>
                <div class="block dashboard-card">
                    <table class="table table-striped table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>@PCM.WEB.Properties.Resources.auditoria</th>
                                <th class="text-center">Total de Auditorias</th>
                                <th class="text-center">Realizadas @ViewBag.mes</th>
                                <th class="text-center">Total Perguntas</th>
                                <th class="text-center">Conformes</th>
                                <th class="text-center">Não Conformes</th>
                                <th class="text-center">N/A</th>
                                <th class="text-center">@PCM.WEB.Properties.Resources.media_nota</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ViewBag.nota)
                            {
                                <tr>
                                    <td>@item.auditoria</td>
                                    <td class="text-center"><a href="@Url.Action("AuditoriaHistorico", "Qualidade", new { data_inicio = "SEM", data_termino = "SEM", auditoria_qualidade = item.codigo_auditoria_interna, status = 2 })">@item.quantidade_auditoria</a></td>
                                    <td class="text-center"><a href="@Url.Action("AuditoriaHistorico", "Qualidade", new { data_inicio = @ViewBag.inicio_mes, data_termino = ViewBag.termino_mes, auditoria_qualidade = item.codigo_auditoria_interna, status = 2 })">@item.quantidade_concluida</a></td>
                                    <td class="text-center">@item.total_perguntas</td>
                                    <td class="text-center">@item.total_conformes</td>
                                    <td class="text-center">@item.total_nao_conformes</td>
                                    <td class="text-center">@item.total_na</td>
                                    <td class="text-center">@item.media_nota</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ================= EVOLUÇÃO DE NOTAS (line) ================= -->
            <div class="dashboard-section">
                <div class="section-title">Evolução de Notas</div>
                <div class="block dashboard-card chart-card">
                    <div class="chart-wrapper"><canvas id="chartNotas"></canvas></div>
                </div>
            </div>

            <!-- ================= PLANO DE AÇÃO ================= -->
            <div class="dashboard-section">
                <div class="section-title">@PCM.WEB.Properties.Resources.plano_acao</div>
                <div class="block dashboard-card">
                    <table class="table table-striped table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>@PCM.WEB.Properties.Resources.departamento_responsavel</th>
                                <th class="text-center">@PCM.WEB.Properties.Resources.quantidade</th>
                                <th class="text-center">@PCM.WEB.Properties.Resources.quantidade_concluida</th>
                                <th class="text-center">@PCM.WEB.Properties.Resources.quantidade_pendente</th>
                                <th class="text-center">@PCM.WEB.Properties.Resources.quantidade_atrasada</th>
                                <th class="text-center">@PCM.WEB.Properties.Resources.quantidade_andamento</th>
                                <th class="text-center">@PCM.WEB.Properties.Resources.tempo_medio_em_andamento</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ViewBag.plano_acao)
                            {
                                <tr>
                                    <td>@item.departamento_responsavel</td>
                                    <td class="text-center">@item.quantidade_plano_acao</td>
                                    <td class="text-center">@item.quantidade_concluido</td>
                                    <td class="text-center">@item.quantidade_pendente</td>
                                    <td class="text-center">@item.quantidade_atrasada</td>
                                    <td class="text-center">@item.quantidade_em_andamento</td>
                                    <td class="text-center">@item.tempo_medio_em_andamento</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ================= PLANO DE AÇÃO – ANDAMENTO × JUSTIFICATIVA ================= -->
            <div class="dashboard-section">
                <div class="section-title">@PCM.WEB.Properties.Resources.plano_acao_andamento_justificativa</div>
                <div class="block dashboard-card">
                    <table class="table table-striped table-sm table-bordered">
                        <tbody>
                            @for (int i = 0; i < ViewBag.plano_acao_justificativa.Count; i++)
                            {
                                if (i == 0 || ViewBag.plano_acao_justificativa[i].justificativa != ViewBag.plano_acao_justificativa[i - 1].justificativa)
                                {
                                    <tr class="table-secondary">
                                        <td colspan="3" class="font-w600">@ViewBag.plano_acao_justificativa[i].justificativa</td>
                                    </tr>
                                }
                                <tr>
                                    <td>@ViewBag.plano_acao_justificativa[i].departamento_responsavel</td>
                                    <td class="text-center" style="width:160px;">@ViewBag.plano_acao_justificativa[i].quantidade Plano(s) de Ação</td>
                                    <td class="text-center" style="width:200px;">@ViewBag.plano_acao_justificativa[i].tempo_medio_em_andamento (dias) em Andamento</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ================= PLANO DE AÇÃO – RECORRÊNCIA ================= -->
            <div class="dashboard-section">
                <div class="section-title">
                    @PCM.WEB.Properties.Resources.plano_acao_recorrencia
                    <span class="float-right btn-group">
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="PlanoAcaoRecorrencia(1);">Mês Corrente</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="PlanoAcaoRecorrencia(2);">Ano Corrente</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="PlanoAcaoRecorrencia(3);">Todo Período</button>
                    </span>
                </div>
                <div class="block dashboard-card">
                    <table class="table table-striped table-sm table-bordered" id="tb-planoacao-recorrencia">
                        <thead>
                            <tr>
                                <th class="text-center" style="width:100px;">@PCM.WEB.Properties.Resources.quantidade</th>
                                <th>@PCM.WEB.Properties.Resources.item_plano_acao</th>
                                <th>@PCM.WEB.Properties.Resources.departamento</th>
                                <th class="text-center" style="width:130px;">@PCM.WEB.Properties.Resources.tempo_gasto</th>
                                <th class="text-center" style="width:130px;">@PCM.WEB.Properties.Resources.valor_gasto</th>
                            </tr>
                        </thead>
                        <tbody id="tb-planoacao-recorrencia-body">
                            @foreach (var item in ViewBag.plano_acao_recorrencia)
                            {
                                <tr>
                                    <td class="text-center">@item.quantidade</td>
                                    <td>@item.item_plano_acao</td>
                                    <td>@item.departamento</td>
                                    <td class="text-center">@item.tempo_gasto</td>
                                    <td class="text-center">@item.valor_gasto</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        }

    </div>
</main>

@section Styles {
    @Styles.Render("~/Content/dashboard")
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/dataTables")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/chart")
    @Scripts.Render("~/plugins/select")

    <script>

        // ── Submit ao mudar data (passa unidade do header) ───────
        $(function () {
            $("#filtro-data").change(function () {
                var unidadeHeader = $("#header-unidade").val();
                if (unidadeHeader) $("#hidden-unidade").val(unidadeHeader);
                $("#form").submit();
            });
        });

        // ── Plano de Ação – Recorrência ──────────────────────────
        function PlanoAcaoRecorrencia(filtro) {
            var unidade = $("#header-unidade").val() || $("#hidden-unidade").val();
            $("#tb-planoacao-recorrencia-body").empty();
            $.ajax({
                type: "POST",
                url: "@Url.Content("~/Home/PlanoAcaoRecorrencia")",
                async: false,
                data: { unidade: unidade, filtro: filtro },
                dataType: "json",
                success: function (response) {
                    $.each(response, function (_, r) {
                        var row = '<tr>'
                            + '<td class="text-center">' + r.quantidade + '</td>'
                            + '<td>' + r.item_plano_acao + '</td>'
                            + '<td>' + r.departamento + '</td>'
                            + '<td class="text-center">' + r.tempo_gasto + '</td>'
                            + '<td class="text-center">' + r.valor_gasto + '</td>'
                            + '</tr>';
                        $("#tb-planoacao-recorrencia-body").append(row);
                    });
                }
            });
        }

        // ── Config Chart.js ──────────────────────────────────────
        var colorNamesNotas = Object.keys(window.chartColors);

        var configChartNotas = {
            type: 'line',
            data: { labels: [], datasets: [] },
            options: {
                responsive: true, maintainAspectRatio: false,
                legend: { display: true, position: 'bottom' },
                scales: {
                    yAxes: [{ ticks: { suggestedMin: 0, suggestedMax: 100, beginAtZero: true } }]
                },
                annotation: {
                    annotations: [
                        {
                            drawTime: 'beforeDatasetsDraw', type: 'box', yScaleID: 'y-axis-0',
                            yMin: 85, yMax: 100,
                            backgroundColor: 'rgba(34,177,76,0.1)', borderWidth: 0
                        },
                        {
                            drawTime: 'beforeDatasetsDraw', type: 'box', yScaleID: 'y-axis-0',
                            yMin: 0, yMax: 85,
                            backgroundColor: 'rgba(255,0,0,0.1)', borderWidth: 0
                        }
                    ]
                }
            }
        };

        // ── Carregamento ─────────────────────────────────────────
        function LoadChartNotas() {
            var unidade = $("#header-unidade").val() || $("#hidden-unidade").val();
            var data    = $("#filtro-data").val();

            $.post("@Url.Content("~/Dashboard/QualidadeDataMonth")", { unidade: unidade, data: data }, function (obj) {
                configChartNotas.data.labels = obj;
                window.ChartNotas.update();
            }, "json");

            $.post("@Url.Content("~/Dashboard/QualidadeNotasUnidade")", { unidade: unidade, data: data }, function (obj) {
                configChartNotas.data.datasets = [];
                if (!obj || !obj.length) { window.ChartNotas.update(); return; }
                $.each(obj, function (i, r) {
                    var c = colorNamesNotas[i % colorNamesNotas.length];
                    configChartNotas.data.datasets.push({
                        label: r.serie, data: r.valor, fill: false,
                        backgroundColor: window.chartColors[c],
                        borderColor: window.chartBorderColors[c]
                    });
                });
                window.ChartNotas.update();
            }, "json");
        }

        // ── Inicialização ─────────────────────────────────────────
        jQuery(function () {
            window.ChartNotas = new Chart(
                document.getElementById('chartNotas').getContext('2d'),
                configChartNotas
            );
            LoadChartNotas();
            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
        });

    </script>
}
