<!-- Main Container -->
<main id="main-container">
    <div class="content">

        @using (Html.BeginForm("IndexQA", "Home", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", @id = "form", enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()

            <!-- ================= INDICADOR DE ATUALIZAÇÃO ================= -->
            <div id="refresh-indicator" class="refresh-indicator" title="Atualizando em breve">
                <i class="fa fa-refresh refresh-icon"></i>
                <span>Atualiza em <strong id="refresh-countdown">60s</strong></span>
            </div>

            <!-- ================= NÃO CONFORMIDADES QUALIDADE ================= -->
            <div class="dashboard-section">
                <div class="section-title">Não Conformidades de Qualidade</div>
                <div class="block dashboard-card" style="padding:0; overflow:hidden;">
                    <div class="torre-comando-grid">
                        <a href="@Url.Action("OrdemServicoIndex", "Qualidade", new { status = 1 })" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header">
                                <i class="fa fa-exclamation-triangle torre-icon text-warning"></i>
                                <span class="torre-label">@PCM.WEB.Properties.Resources.pendente</span>
                            </div>
                            <div class="os-value text-warning" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.plano_acao_status.pendente" id="nc_pendente">@ViewBag.plano_acao_status.pendente</div>
                        </a>
                        <a href="@Url.Action("OrdemServicoIndex", "Qualidade", new { status = 3 })" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header">
                                <i class="fa fa-clock-o torre-icon text-danger"></i>
                                <span class="torre-label">@PCM.WEB.Properties.Resources.atrasado</span>
                            </div>
                            <div class="os-value text-danger" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.plano_acao_status.atrasado" id="nc_atrasado">@ViewBag.plano_acao_status.atrasado</div>
                        </a>
                        <a href="@Url.Action("OrdemServicoIndex", "Qualidade", new { status = 2 })" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header">
                                <i class="fa fa-check-circle torre-icon text-success"></i>
                                <span class="torre-label">@PCM.WEB.Properties.Resources.concluido</span>
                            </div>
                            <div class="os-value text-success" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.plano_acao_status.concluido" id="nc_concluido">@ViewBag.plano_acao_status.concluido</div>
                        </a>
                        <a href="@Url.Action("OrdemServicoIndex", "Qualidade", new { status = 4 })" class="torre-item os-item" style="text-decoration:none;">
                            <div class="torre-header">
                                <i class="fa fa-spinner torre-icon text-primary"></i>
                                <span class="torre-label">@PCM.WEB.Properties.Resources.em_andamento</span>
                            </div>
                            <div class="os-value text-primary" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.plano_acao_status.em_andamento" id="nc_em_andamento">@ViewBag.plano_acao_status.em_andamento</div>
                        </a>
                    </div>
                </div>
            </div>

            <!-- ================= AUDITORIA DE QUALIDADE (condicional) ================= -->
            if ((bool)Session["qa_auditoria"])
            {
                <div class="dashboard-section">
                    <div class="section-title">Auditoria de Qualidade</div>
                    <div class="block dashboard-card" style="padding:0; overflow:hidden;">
                        <div class="torre-comando-grid">
                            <a href="@Url.Action("Auditoria", "Qualidade", new { status = 1 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-edit torre-icon text-warning"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.pendente</span>
                                </div>
                                <div class="os-value text-warning" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.status.pendente" id="aud_pendente">@ViewBag.status.pendente</div>
                            </a>
                            <a href="@Url.Action("Auditoria", "Qualidade", new { status = 3 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-clock-o torre-icon text-danger"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.atrasado</span>
                                </div>
                                <div class="os-value text-danger" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.status.atrasado" id="aud_atrasado">@ViewBag.status.atrasado</div>
                            </a>
                            <a href="@Url.Action("Auditoria", "Qualidade", new { status = 2 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-check-circle torre-icon text-success"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.concluido</span>
                                </div>
                                <div class="os-value text-success" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.status.concluido" id="aud_concluido">@ViewBag.status.concluido</div>
                            </a>
                            <a href="@Url.Action("Auditoria", "Qualidade", new { status = 4 })" class="torre-item os-item" style="text-decoration:none;">
                                <div class="torre-header">
                                    <i class="fa fa-spinner torre-icon text-primary"></i>
                                    <span class="torre-label">@PCM.WEB.Properties.Resources.em_andamento</span>
                                </div>
                                <div class="os-value text-primary" data-toggle="countTo" data-speed="1000" data-to="@ViewBag.status.em_andamento" id="aud_em_andamento">@ViewBag.status.em_andamento</div>
                            </a>
                        </div>
                    </div>
                </div>
            }

            <!-- ================= GRÁFICOS ================= -->
            <div class="dashboard-section row invisible" data-toggle="appear">

                <div class="col-md-6 d-flex flex-column">
                    <div class="section-title">@PCM.WEB.Properties.Resources.plano_acao_aberto_concluido</div>
                    <div class="block dashboard-card chart-card flex-fill">
                        <div class="chart-wrapper">
                            <canvas id="chartManutencaoAbertoConcluido"></canvas>
                        </div>
                        <div class="row mt-3 text-center">
                            <div class="col-4">
                                <div class="kpi-title">Aberto</div>
                                <div class="kpi-value" style="color:rgba(255,0,0);" id="aberto">0</div>
                            </div>
                            <div class="col-4">
                                <div class="kpi-title">Concluído</div>
                                <div class="kpi-value" style="color:rgba(34,177,76);" id="concluido">0</div>
                            </div>
                            <div class="col-4">
                                <div class="kpi-title">Saldo</div>
                                <div class="kpi-value" style="color:rgb(255,201,14);" id="saldo">0</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 d-flex flex-column">
                    <div class="section-title">@PCM.WEB.Properties.Resources.manutencao_tempo_medio_atendimento</div>
                    <div class="block dashboard-card chart-card flex-fill">
                        <div class="chart-wrapper">
                            <canvas id="chartManutencaoTempoMedioAtendimento"></canvas>
                        </div>
                        <div class="row mt-3 text-center">
                            <div class="col">
                                <div class="kpi-title">No Dia</div>
                                <div class="kpi-value" style="color:rgba(34,177,76);" id="no_dia">0%</div>
                            </div>
                            <div class="col">
                                <div class="kpi-title">1 Dia</div>
                                <div class="kpi-value" style="color:rgba(63,72,204);" id="um_dia">0%</div>
                            </div>
                            <div class="col">
                                <div class="kpi-title">3 Dias</div>
                                <div class="kpi-value" style="color:rgb(255,201,14);" id="tres_dia">0%</div>
                            </div>
                            <div class="col">
                                <div class="kpi-title">5 Dias</div>
                                <div class="kpi-value" style="color:rgba(255,128,0);" id="cinco_dia">0%</div>
                            </div>
                            <div class="col">
                                <div class="kpi-title">&gt;5 Dias</div>
                                <div class="kpi-value" style="color:rgba(255,0,0);" id="mais_cinco_dia">0%</div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- ================= PRINCIPAIS OCORRÊNCIAS ================= -->
            <div class="dashboard-section">
                <div class="section-title">
                    Principais Ocorrências
                    <span>
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn btn-outline-secondary" onclick="PrincipaisOcorrencias(1);">Dia Anterior</button>
                            <button type="button" class="btn btn-outline-secondary" onclick="PrincipaisOcorrencias(7);">Semana</button>
                            <button type="button" class="btn btn-outline-secondary" onclick="PrincipaisOcorrencias(30);">Mês</button>
                            <button type="button" class="btn btn-outline-secondary" onclick="PrincipaisOcorrencias(365);">Ano</button>
                        </div>
                    </span>
                </div>
                <div class="block dashboard-card">
                    <table class="table table-striped" id="tb-principais-ocorrencias">
                        <thead>
                            <tr>
                                <th class="text-center" style="width:80px;">#</th>
                                <th>Local</th>
                                <th class="text-center" style="width:130px;">Quantidade</th>
                            </tr>
                        </thead>
                        <tbody id="tb-principais-ocorrencias-body">
                            @foreach (var item in ViewBag.PrincipaisOcorrencias)
                            {
                                <tr>
                                    <td class="text-center">@item.item</td>
                                    <td class="font-w600">@item.local</td>
                                    <td class="text-center">@item.quantidade</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        }

    </div>
</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/dashboard")
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/dataTables")
    @Styles.Render("~/Content/select")
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
}

@section Scripts {
    @Scripts.Render("~/plugins/datatables")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/chart")
    @Scripts.Render("~/plugins/select")

    <script>

        var unidade = $("#header-unidade");
        var modulo  = $("#header-modulo");

        var configTempoMedioAtendimento = {
            type: 'doughnut',
            options: {
                responsive: true,
                maintainAspectRatio: false,
                legend: {
                    display: true,
                    position: 'right',
                    labels: {
                        padding: 16,
                        boxWidth: 14,
                        fontSize: 12,
                        generateLabels: function(chart) {
                            var data = chart.data;
                            if (!data.labels.length) return [];
                            return data.labels.map(function(label, i) {
                                var ds  = data.datasets[0];
                                var val = ds && ds.data[i] != null ? ds.data[i].toFixed(2) + '%' : '0%';
                                var bg  = ds && ds.backgroundColor ? ds.backgroundColor[i] : '#ccc';
                                return {
                                    text: label + '  ' + val,
                                    fillStyle: bg,
                                    strokeStyle: bg,
                                    lineWidth: 0,
                                    hidden: false,
                                    index: i
                                };
                            });
                        }
                    }
                },
                title: { display: false },
                tooltips: {
                    enabled: true,
                    callbacks: {
                        label: function(item, data) {
                            var label = data.labels[item.index] || '';
                            var val   = data.datasets[0].data[item.index];
                            return ' ' + label + ': ' + (val != null ? val.toFixed(2) : 0) + '%';
                        }
                    }
                },
                cutoutPercentage: 60
            }
        };

        var configAbertoConcluido = {
            type: 'line',
            options: {
                responsive: true,
                maintainAspectRatio: false,
                legend: { display: true, labels: { padding: 20 }, position: 'bottom' },
                title: { display: false },
                tooltips: { enabled: true }
            }
        };

        function LoadChartManutencaoAbertoConcluido() {
            jQuery.ajax({
                type: "POST",
                url: "@Url.Content("Relatorio/ChartManutencaoAbertoConcluido")",
                async: false,
                data: { "unidade": (unidade.val() == "") ? "-1" : unidade.val(), "data_inicio": "@ViewBag.data_inicio", "data_termino": new Date().toDateString(), "qualidade": true },
                dataType: "json",
                success: function (r) {
                    var labels  = r.map(function(d) { return d.data; });
                    var abertos = r.map(function(d) { return d.aberto; });
                    var concls  = r.map(function(d) { return d.concluido; });
                    var ultimo  = r.length ? r[r.length - 1] : { aberto: 0, concluido: 0, saldo: 0 };
                    $("#aberto").html(ultimo.aberto);
                    $("#concluido").html(ultimo.concluido);
                    $("#saldo").html(ultimo.saldo);

                    configAbertoConcluido.data = {
                        labels: labels,
                        datasets: [
                            {
                                label: 'Aberto',
                                data: abertos,
                                borderColor: 'rgba(255,0,0,0.8)',
                                backgroundColor: 'rgba(255,0,0,0.1)',
                                fill: true,
                                tension: 0.3
                            },
                            {
                                label: 'Concluído',
                                data: concls,
                                borderColor: 'rgba(34,177,76,0.8)',
                                backgroundColor: 'rgba(34,177,76,0.1)',
                                fill: true,
                                tension: 0.3
                            }
                        ]
                    };

                    if (window.AbertoConcluido) {
                        window.AbertoConcluido.data = configAbertoConcluido.data;
                        window.AbertoConcluido.update();
                    }
                }
            });
        }

        function LoadChartManutencaoTempoMedioAtendimento() {
            jQuery.ajax({
                type: "POST",
                url: "@Url.Content("Relatorio/ChartManutencaoTempoMedioAtendimento")",
                async: false,
                data: { "unidade": (unidade.val() == "") ? "-1" : unidade.val(), "ano": new Date().getFullYear(), "qualidade": true },
                dataType: "json",
                success: function (r) {
                    var labels = r.map(function(d) { return d.tipo; });
                    var values = r.map(function(d) { return d.valor; });
                    var colors = ['rgba(34,177,76,0.7)', 'rgba(63,72,204,0.7)',
                                  'rgba(255,201,14,0.7)', 'rgba(255,128,0,0.7)', 'rgba(255,0,0,0.7)'];

                    var ids = ['no_dia','um_dia','tres_dia','cinco_dia','mais_cinco_dia'];
                    for (var i = 0; i < r.length && i < ids.length; i++) {
                        $('#' + ids[i]).html(r[i].valor.toFixed(2) + '%');
                    }

                    configTempoMedioAtendimento.data = {
                        labels: labels,
                        datasets: [{
                            label: 'Tempo de Atendimento (%)',
                            data: values,
                            backgroundColor: colors.slice(0, r.length)
                        }]
                    };

                    if (window.TempoMedioAtendimento) {
                        window.TempoMedioAtendimento.data = configTempoMedioAtendimento.data;
                        window.TempoMedioAtendimento.update();
                    }
                }
            });
        }

        function PrincipaisOcorrencias(quantidade) {
            $("#tb-principais-ocorrencias-body").empty();
            jQuery.ajax({
                type: "POST",
                url: "Home/PrincipaisOcorrencias",
                async: false,
                data: { "unidade": (unidade.val() == "") ? "-1" : unidade.val(), "quantidade": quantidade, "qualidade": true },
                dataType: "json",
                success: function (r) {
                    for (var i = 0; i < r.length; i++) {
                        var row = $("<tr>");
                        row.append('<td class="text-center" style="width:80px;">' + r[i].item + '</td>');
                        row.append('<td class="font-w600">' + r[i].local + '</td>');
                        row.append('<td class="text-center">' + r[i].quantidade + '</td>');
                        $("#tb-principais-ocorrencias-body").append(row);
                    }
                }
            });
        }

        function initCharts() {
            if (!window.AbertoConcluido) {
                window.AbertoConcluido = new Chart(
                    document.getElementById('chartManutencaoAbertoConcluido').getContext('2d'),
                    { type: 'line', data: { labels: [], datasets: [] }, options: { responsive: true, maintainAspectRatio: false } }
                );
            }
            if (!window.TempoMedioAtendimento) {
                window.TempoMedioAtendimento = new Chart(
                    document.getElementById('chartManutencaoTempoMedioAtendimento').getContext('2d'),
                    { type: 'doughnut', data: { labels: [], datasets: [] }, options: { responsive: true, maintainAspectRatio: false } }
                );
            }
        }

        // ================================================
        // AUTO-REFRESH via AJAX
        // ================================================
        var REFRESH_INTERVAL = 60;
        var countdownTimer;
        var secondsLeft = REFRESH_INTERVAL;

        function startRefreshCycle() {
            secondsLeft = REFRESH_INTERVAL;
            updateCountdown();
            clearInterval(countdownTimer);
            countdownTimer = setInterval(function () {
                secondsLeft--;
                updateCountdown();
                if (secondsLeft <= 0) {
                    clearInterval(countdownTimer);
                    refreshDashboard();
                }
            }, 1000);
        }

        function updateCountdown() {
            var el = document.getElementById('refresh-countdown');
            if (el) el.textContent = secondsLeft + 's';
        }

        function refreshDashboard() {
            var el = document.getElementById('refresh-indicator');
            if (el) { el.classList.add('refreshing'); el.title = 'Atualizando...'; }

            LoadChartManutencaoAbertoConcluido();
            LoadChartManutencaoTempoMedioAtendimento();

            if (el) {
                el.classList.remove('refreshing');
                el.title = 'Última atualização: ' + new Date().toLocaleTimeString();
            }
            startRefreshCycle();
        }

        // Chamado pelo codebase.js após popular os selects do header
        window.onHeaderReady = function () {
            initCharts();
            LoadChartManutencaoAbertoConcluido();
            LoadChartManutencaoTempoMedioAtendimento();
            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
            startRefreshCycle();
        };

    </script>
}
