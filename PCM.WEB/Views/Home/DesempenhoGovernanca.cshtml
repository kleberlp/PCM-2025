                    </div>
                    <div class="col-6 text-center mt-10">
                        <label class="h2">UH por dia</label>
                    </div>
                    <div class="col-3 text-right">
                        <label class="h4 font-w600 mt-10">03/11</label>
                    </div>
                </div>
                <hr />
            </div>

            <div class="block">

                <div class="block-header block-header-default bg-secondary">
                    <h3 class="block-title-big text-white font-w600">@PCM.WEB.Properties.Resources.pmoc</h3>
                </div>

                <div class="form-row">

                    <div class="col-xl-7 col-md-12">
                        <div class="block block-rounded block-mode-loading-refresh">
                            <div class="block-content block-content-full">
                                <div class="pull-all pt-30 p-20">
                                    <canvas id="chartPMOC" height="120px" class="chartCanvas"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="block-content block-content-full p-10 col-xl-5 col-md-8">

                        <!-- DataTables init on table by adding .js-dataTable-full-pagination class, functionality initialized in js/pages/be_tables_datatables.js -->
                        <table class="table table-striped table-sm table-bordered">
                            <thead>
                                <tr class="table-secondary">
                                    <th>@PCM.WEB.Properties.Resources.unidade</th>
                                    <th class="text-center" style="width:100px">@PCM.WEB.Properties.Resources.qtde_ok</th>
                                    <th class="text-center" style="width:100px">@PCM.WEB.Properties.Resources.pendente</th>
                                    <th class="text-center" style="width:100px">@PCM.WEB.Properties.Resources.total</th>
                                    <th class="text-center" style="width:100px">@PCM.WEB.Properties.Resources.percentual_atendido</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in ViewBag.pmoc)
                                {
                                    <tr>
                                        <th>@item.unidade</th>
                                        <td class="text-center" style="widtd:100px">@item.quantidade_ok</td>
                                        <td class="text-center" style="widtd:100px">@item.quantidade_pendente</td>
                                        <td class="text-center" style="widtd:100px">@item.total</td>
                                        <td class="text-center" style="widtd:100px">@item.percentual_atendido</td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                    </div>

                </div>

