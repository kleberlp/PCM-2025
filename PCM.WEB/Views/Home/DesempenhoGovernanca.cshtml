
<!-- Main Container -->
<main id="main-container">

    <!-- Page Content -->
    <div class="content bg-white">

        @using (Html.BeginForm("DesempenhoGovernanca", "Home", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", @id = "form", enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()

            <div class="block d-print-normal p-10 m-10" style="display:none">
                <div class="form-row">
                    <div class="col-3">
                        <img class="img-avatar" src="@Session["imagem_sidebar"]" alt="">
                    </div>
                    <div class="col-6 text-center">
                        <label class="h2">Desempenho das Unidades</label>
                    </div>
                    <div class="col-3 text-right">
                        <label class="h4 font-w600">01/11</label>
                    </div>
                </div>
                <hr />
            </div>

            <div class="block d-print-normal bg-white">

                <div class="block-header block-header-default bg-secondary d-print-none">
                    <h3 class="block-title-big text-white font-w600">Desempenho das Unidades</h3>
                    <div class="block-options">
                        <!-- Print Page functionality is initialized in Codebase() -> uiHelperPrint() -->
                        <button type="button" class="btn-block-option text-white" onclick="Codebase.helpers('print-page');">
                            <i class="si si-printer text-white"></i> @PCM.WEB.Properties.Resources.imprimir
                        </button>
                        <button type="button" class="btn-block-option text-white" data-toggle="block-option" data-action="fullscreen_toggle"></button>
                    </div>
                </div>

                <div class="row pt-20 pr-20 pl-20" data-toggle="appear">
                    <div class="col-3 col-sm-12 col-md-3 col-xl-3">
                        <label>@PCM.WEB.Properties.Resources.unidade</label>
                        @Html.DropDownList("unidade", null, null, new { @class = "form-control material font-w600 js-select2" })
                    </div>
                    <div class="col-3 col-sm-12 col-md-3 col-xl-3">
                        <label>@PCM.WEB.Properties.Resources.data</label>
                        @Html.DropDownList("data", null, null, new { @class = "form-control material font-w600" })
                    </div>
                    <input type="hidden" name="nome_fantasia" id="nome_fantasia" value="@ViewBag.nome_fantasia" />
                    <input type="hidden" name="codigo_unidade" id="codigo_unidade" value="@Session["codigo_unidade"]" />
                </div>

                <br />

                <div class="row pt-20 pr-20 pl-20" data-toggle="appear">

                    <div class="col-3 col-sm-12 col-md-6 col-xl-3">
                        <a class="block block-rounded block-bordered block-link-shadow" href="@Url.Action("UsuarioIndex", "Administracao")">
                            <div class="block-content block-content-full clearfix">
                                <div class="float-right mt-15 d-none d-sm-block"><i class="si si-user fa-3x"></i></div>
                                <div class="font-size-h3 font-w600 text-primary" style="text-decoration:none">@ViewBag.dashboard_info.quantidade_camereira</div>
                                <div class="font-size-sm font-w600 text-uppercase text-muted">@PCM.WEB.Properties.Resources.usuarios</div>
                            </div>
                        </a>
                    </div>

                    <div class="col-3 col-sm-12 col-md-6 col-xl-3">
                        <a class="block block-rounded block-bordered block-link-shadow" href="#">
                            <div class="block-content block-content-full clearfix">
                                <div class="float-right mt-15 d-none d-sm-block"><i class="si si-clock fa-3x"></i></div>
                                <div class="font-size-h3 font-w600 text-primary" style="text-decoration:none">@ViewBag.dashboard_info.hh_apontado</div>
                                <div class="font-size-sm font-w600 text-uppercase text-muted">H.H. Apontado</div>
                            </div>
                        </a>
                    </div>

                    <div class="col-3 col-sm-12 col-md-6 col-xl-3">
                        <a class="block block-rounded block-bordered block-link-shadow" href="#">
                            <div class="block-content block-content-full clearfix">
                                <div class="float-right mt-15 d-none d-sm-block"><i class="si si-users fa-3x"></i></div>
                                <div class="font-size-h3 font-w600 text-primary" style="text-decoration:none">@ViewBag.dashboard_info.quantidade_uh</div>
                                <div class="font-size-sm font-w600 text-uppercase text-muted">Quantidade de UH's</div>
                            </div>
                        </a>
                    </div>

                    <div class="col-3 col-sm-12 col-md-6 col-xl-3">
                        <a class="block block-rounded block-bordered block-link-shadow" href="#">
                            <div class="block-content block-content-full clearfix">
                                <div class="float-right mt-15 d-none d-sm-block"><i class="fa fa-list fa-3x"></i></div>
                                <div class="font-size-h3 font-w600 text-primary" style="text-decoration:none">@ViewBag.dashboard_info.os_gerada</div>
                                <div class="font-size-sm font-w600 text-uppercase text-muted">Quantidade de OS geradas</div>
                            </div>
                        </a>
                    </div>

                </div>

            </div>

            <div class="block break-after"></div>

            <div class="block d-print-normal" style="display:none">
                <div class="form-row">
                    <div class="col-3 mt-10">
                        <img class="img-avatar" src="@Session["imagem_sidebar"]" alt="">
                    </div>
                    <div class="col-6 text-center mt-10">
                        <label class="h2">Desempenho das Unidades</label>
                    </div>
                    <div class="col-3 text-right mt-10">
                        <label class="h4 font-w600">02/11</label>
                    </div>
                </div>
                <hr />
            </div>

            <div class="block">

                <div class="block-header block-header-default bg-secondary">
                    <h3 class="block-title-big text-white font-w600">Gráfico - Geral</h3>
                </div>

                <div class="col-md-12">
                    <div class="block block-rounded block-mode-loading-refresh">
                        <div class="block-content block-content-full">
                            <div class="pull-all pt-30 p-20">
                                <canvas id="chartGeral" height="80px" class="chartCanvas"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @*CHART: UH DIA*@
            <div class="block break-after"></div>

            <div class="block d-print-normal" style="display:none">
                <div class="form-row">
                    <div class="col-3 mt-10">
