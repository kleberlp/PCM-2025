    function LoadChartGeral() {

        //Obtém eixo X
        $.post("@Url.Content("~/Dashboard/Unidades")", { "data": $("#data").val() }, function (obj) {
            $.each(obj, function (indice, result) {
                configChartGeral.data.labels.push(result);
            });
            window.ChartGeral.update();
        }, "json");

        $.post("@Url.Content("~/Dashboard/ChartGeral")", { "data": $("#data").val() }, function (obj) {

            if (obj.length == 0) {
                configChartGeral.data.labels = [];
                configChartGeral.data.datasets = [];
                window.ChartGeral.update();
            } else {
                $.each(obj, function (indice, result) {

                    switch (result.serie) {
                        case 'LAUDO':
                            colorName = 'rgba(255, 51, 91, 0.7)';
                            borderColorName = 'rgba(255, 51, 91, 1)';
                            break;
                        case 'PMOC':
                            colorName = 'rgba(68, 169, 236, 0.7)';
                            borderColorName = 'rgba(68, 169, 236, 1)';
                            break;
                        case 'PREVENTIVA':
                            colorName = 'rgba(255, 208, 98, 0.7)';
                            borderColorName = 'rgba(255, 208, 98, 1)';
                            break;
                        case 'ROTINA':
                            colorName = 'rgba(88, 196, 196, 0.7)';
                            borderColorName = 'rgba(88, 196, 196, 1)';
                            break;
                        case 'U.H EM DIA':
                            colorName = 'rgba(160, 113, 255, 0.7)';
                            borderColorName = 'rgba(160, 113, 255, 1)';
                            break;
                    }

                    var newDataset = {
                        label: result.serie,
                        backgroundColor: colorName,
                        borderColor: borderColorName,
                        data: [],
                        fill: false
                    };

                    for (var index = 0; index < result.valor.length; ++index) {
                        newDataset.data.push(result.valor[index]);
                    }

                    configChartGeral.data.datasets.push(newDataset);
                    window.ChartGeral.update();
                });
            }
        }, "json");

    };

    function LoadChartPMOC() {

        //Obtém eixo X
        $.post("@Url.Content("~/Dashboard/Unidades")", { "data": $("#data").val() }, function (obj) {
            $.each(obj, function (indice, result) {
                configChartPMOC.data.labels.push(result);
            });
            window.ChartPMOC.update();
        }, "json");

        var request = { "field": "PMOC", "descricao": "PMOC", "data": $("#data").val() };

        $.post("@Url.Content("~/Dashboard/ChartMetricas")", request, function (obj) {

            if (obj.length == 0) {
                configChartPMOC.data.labels = [];
                configChartPMOC.data.datasets = [];
                window.ChartPMOC.update();
            }
            else
            {
                $.each(obj, function (indice, result) {

                    var colorName = 'rgba(68, 114, 196, 1)';

                    var newDataset = {
                        label: result.serie,
                        backgroundColor: colorName,
                        borderColor: colorName,
                        data: [],
                        fill: false
                    };

                    for (var index = 0; index < result.valor.length; ++index) {
                        newDataset.data.push(result.valor[index]);
                    }

                    configChartPMOC.data.datasets.push(newDataset);
                    window.ChartPMOC.update();
                });
            }
        }, "json");

