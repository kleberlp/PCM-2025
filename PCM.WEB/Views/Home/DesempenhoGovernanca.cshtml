                                <th class="text-center" data-sortable="false">@PCM.WEB.Properties.Resources.hh_disponivel</th>
                                <th class="text-center" data-sortable="false">@PCM.WEB.Properties.Resources.quantidade_os_gerada</th>
                                <th class="text-center" data-sortable="false">@PCM.WEB.Properties.Resources.quantidade_os_atendida</th>
