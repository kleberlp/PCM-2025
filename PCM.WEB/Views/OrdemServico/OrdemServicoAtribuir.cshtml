@model IEnumerable<PCM.WEB.MODELS.OrdemServico>

<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.ordem_servico</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Listagem -->
    <div class="content block-rounded">
            
        @using (Html.BeginForm("OrdemServicoAtribuir", "OrdemServico", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data"  }))        
        {
            @Html.AntiForgeryToken()

            <div class="col-md-12 col-xl-12">
                <!-- Toggle Tasks Navigation on mobile -->
                <button type="button" class="btn btn-block btn-square btn-primary d-md-none mb-10" data-toggle="class-toggle" data-target=".js-tasks-nav" data-class="d-none d-md-block">@PCM.WEB.Properties.Resources.filtros</button>

                <!-- Collapsible Tasks Navigation -->
                <div class="js-tasks-nav d-none d-md-block">
                    <!-- Tasks Info -->
                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.filtro</h3>
                           
                        </div>
                        <div class="block-content">
                            <ul class="list-group push">
                                @if(Session["unidade"] == "")
                                {
                                    <li class="list-group-item">
                                        <div class="row">
                                            <div class="col-md-4"><div>@Html.DropDownList("unidade", null, PCM.WEB.Properties.Resources.unidade, new { @class = "js-select2 form-control" })</div>                                    
                                            </div>
                                        </div>
                                    </li>
                                }
                                <li class="list-group-item">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <div class="input-daterange input-group" data-date-format="dd/mm/yyyy" data-week-start="1" data-autoclose="true" data-today-highlight="true">
                                                <input type="text" class="form-control" id="data_inicio" name="data_inicio" placeholder="De" data-week-start="1" data-autoclose="true" data-today-highlight="true" value="@ViewBag.data_inicio">
                                                <div class="input-group-prepend input-group-append">
                                                    <span class="input-group-text font-w600">-</span>
                                                </div>
                                                <input type="text" class="form-control" id="data_termino" name="data_termino" placeholder="Até" data-week-start="1" data-autoclose="true" data-today-highlight="true" value="@ViewBag.data_termino">
                                            </div>
                                        </div>                            
                                        <div class="col-md-2"><input type="text" id="ordem_servico" name="ordem_servico" value="@ViewBag.ordem_servico" placeholder="@PCM.WEB.Properties.Resources.ordem_servico" class="form-control"></div>
                                        <div class="col-md-4">@Html.DropDownList("setor", null, PCM.WEB.Properties.Resources.setor, new { @class = "js-select2 form-control" })</div>                                    
                                        <div class="col-md-2">@Html.DropDownList("apartamento", null, PCM.WEB.Properties.Resources.apartamento, new { @class = "js-select2 form-control" })</div>                                                       
                                    </div>
                                </li>
                                <li class="list-group-item">
                                    <div class="row">
                                        <div class="col-md-4">@Html.DropDownList("equipamento", null, PCM.WEB.Properties.Resources.equipamento, new { @class = "js-select2 form-control" })</div>                                    
                                        <div class="col-md-2">@Html.DropDownList("prioridade", null, PCM.WEB.Properties.Resources.prioridade, new { @class = "js-select2 form-control" })</div>                                    
                                        <div class="col-md-3">@Html.DropDownList("solicitante", null, PCM.WEB.Properties.Resources.solicitante, new { @class = "js-select2 form-control" })</div>                                    
                                        <div class="col-md-3"><input type="text" id="executor" name="executor" value="@ViewBag.executor" placeholder="@PCM.WEB.Properties.Resources.executor" class="form-control"></div>                                     
                                    </div>
                                </li>
                                <li class="list-group-item text-right">                                                    
                                    <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75" name="filtrar" id="filtrar" ><i class="si si-magnifier mr-5"></i>@PCM.WEB.Properties.Resources.filtrar</button>
                                </li>
                            </ul>
                        </div>
                    </div>
                    <!-- END Tasks Info -->
                </div>
                <!-- END Collapsible Tasks Navigation -->
                          
                <div class="block">

                    <div class="block-content block-content-full">
                        <table class="table table-vcenter table-sm table-bordered table-hover js-dataTable-list">
                            <thead>
                                <tr class="table-secondary">
                                    <th class="text-center d-md-table-cell">@PCM.WEB.Properties.Resources.ordem_servico</th>    
                                    <th class="text-center d-md-table-cell">@PCM.WEB.Properties.Resources.data</th>                                
                                    @if(Session["unidade"] == "")
                                    {
                                        <th class="d-none d-md-table-cell">@PCM.WEB.Properties.Resources.unidade </th>
                                    }
                                    <th class="d-none d-lg-table-cell">@PCM.WEB.Properties.Resources.local</th>
                                    <th class="d-none d-lg-table-cell">@PCM.WEB.Properties.Resources.descricao</th>
                                    <th class="d-none d-md-table-cell">@PCM.WEB.Properties.Resources.executor</th>
                                    <th class="d-none d-md-table-cell text-center" style="width: 120px;">@PCM.WEB.Properties.Resources.prioridade</th>
                                    <th class="d-none d-md-table-cell text-center" style="width: 120px;">@PCM.WEB.Properties.Resources.status</th>
                                </tr>
                            </thead>

                            <tbody>                       
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="text-center d-md-table-cell">@Html.DisplayFor(modelItem => item.numero_documento)</td>     
                                        <td class="text-center d-md-table-cell">@Html.DisplayFor(modelItem => item.data)</td>         
                                        @if(Session["unidade"] == "")
                                        {
                                            <td class="d-none d-md-table-cell">@Html.DisplayFor(modelItem => item.unidade)</td>
                                        }         
                                        <td class="d-none d-lg-table-cell">@Html.DisplayFor(modelItem => item.local)</td>           
                                        <td class="d-none d-lg-table-cell">@Html.DisplayFor(modelItem => item.descricao)</td>                                                                                       
                                        <td class="d-none d-md-table-cell">@Html.DropDownList("funcionario", null, "", new { @class = "js-select2 form-control h-75", @multiple="multiple", @name="funcionario[" + @item.codigo + "]", @id="funcionario[" + @item.codigo + "]" })</td>
                                        <td class="d-none d-md-table-cell text-center">@Html.DisplayFor(modelItem => item.prioridade)</td>  
                                        @if (item.status == 1)
                                        {
                                            <td class="d-none d-md-table-cell text-center" id="td.@item.codigo"><span class="badge badge-warning">@item.status_descricao</span></td>   
                                        }                                  
                                        @if (item.status == 3)
                                        {
                                            <td class="d-none d-md-table-cell text-center" id="td.@item.codigo"><span class="badge badge-danger">@item.status_descricao</span></td>                                                                                               
                                        }                                  
                                        @if (item.status == 5)
                                        {
                                            <td class="d-none d-md-table-cell text-center" id="td.@item.codigo"><span class="badge badge-info">@item.status_descricao</span></td>                                                                                           
                                        }           
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
               
                 </div>

            </div>

        }        
    </div>             
    <!-- END Page Content -->

</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/dataTables")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")

    <script type="text/javascript">

        $(function () {

            var unidade = $("#unidade");
            var setor = $("#setor");
            var equipamento = $("#equipamento");
            var prioridade = $("#prioridade");
            var apartamento = $("#apartamento");
            var solicitante = $("#solicitante");

            apartamento.select2();

            var status = $("#status");
            $.ajaxSetup({async: false});  
            
            unidade.select2({placeholder: '@PCM.WEB.Properties.Resources.unidade', allowClear: true});
            status.select2({placeholder: '@PCM.WEB.Properties.Resources.status', allowClear: true});

            if (unidade.val() == "" || unidade.val() == "-1") {                    
                setor.prop( "disabled", true );
                prioridade.prop( "disabled", true );
                apartamento.prop( "disabled", true );
                equipamento.prop( "disabled", true );
                solicitante.prop( "disabled", true );
                prioridade.select2({placeholder: '@PCM.WEB.Properties.Resources.prioridade', allowClear: true});
                setor.select2({placeholder: '@PCM.WEB.Properties.Resources.setor', allowClear: true});
                apartamento.select2({placeholder: '@PCM.WEB.Properties.Resources.apartamento', allowClear: true});
                solicitante.select2({placeholder: '@PCM.WEB.Properties.Resources.solicitante', allowClear: true});
                equipamento.select2({placeholder: "Máquina / Equipamento / Itens Gerais", allowClear: true});
            }

            unidade.change(function () {

                if (unidade.val() == "") {
                    
                    setor.empty();
                    prioridade.empty();
                    apartamento.empty();
                    equipamento.empty();
                    solicitante.empty();
                    setor.prop( "disabled", true );
                    prioridade.prop( "disabled", true );
                    apartamento.prop( "disabled", true );
                    equipamento.prop( "disabled", true );
                    solicitante.prop( "disabled", true );
                    prioridade.select2({placeholder: '@PCM.WEB.Properties.Resources.prioridade', allowClear: true});
                    setor.select2({placeholder: '@PCM.WEB.Properties.Resources.setor', allowClear: true});
                    apartamento.select2({placeholder: '@PCM.WEB.Properties.Resources.apartamento', allowClear: true});
                    solicitante.select2({placeholder: '@PCM.WEB.Properties.Resources.solicitante', allowClear: true});
                    equipamento.select2({placeholder: "Máquina / Equipamento / Itens Gerais", allowClear: true});

                } else {

                    var request = { "unidade": unidade.val() };

                    $.post("LoadPrioridade", request, function (obj) {
                        prioridade.empty();
                        option = $("<option>", { "value": "" }).text("");
                        prioridade.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            prioridade.append(option);
                        });
                    }, "json");

                    $.post("LoadSetor", request, function (obj) {
                        setor.empty();
                        option = $("<option>", { "value": "" }).text("");
                        setor.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            setor.append(option);
                        });
                    }, "json");

                    $.post("LoadApartamento", request, function (obj) {
                        apartamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        apartamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            apartamento.append(option);
                        });
                    }, "json");

                    $.post("LoadSolicitante", request, function (obj) {
                        solicitante.empty();
                        option = $("<option>", { "value": "" }).text("");
                        solicitante.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            solicitante.append(option);
                        });
                    }, "json");

                    setor.prop( "disabled", false );
                    prioridade.prop( "disabled", false );
                    apartamento.prop( "disabled", false );                    
                    solicitante.prop( "disabled", false );        
                    prioridade.select2({placeholder: '@PCM.WEB.Properties.Resources.prioridade',allowClear: true});
                    setor.select2({placeholder: '@PCM.WEB.Properties.Resources.setor',allowClear: true});
                    apartamento.select2({placeholder: '@PCM.WEB.Properties.Resources.apartamento',allowClear: true});
                    solicitante.select2({placeholder: '@PCM.WEB.Properties.Resources.solicitante',allowClear: true});
                }

            });

            setor.change(function () {

                if (setor.val() == "") {
                    equipamento.empty();                 
                    equipamento.select2({placeholder: "Máquina / Equipamento / Itens Gerais" ,allowClear: true});
                    equipamento.prop( "disabled", true );


                    var request = { "unidade": unidade.val(), "setor": "-1" };

                    $.post("LoadApartamento", request, function (obj) {
                        apartamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        apartamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            apartamento.append(option);
                        });
                    }, "json");                    

                }

                else {

                    var request = { "unidade": unidade.val(), "setor": setor.val() };

                    $.post("LoadApartamento", request, function (obj) {
                        apartamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        apartamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            apartamento.append(option);
                        });
                    }, "json");

                    $.post("LoadEquipamentoSetor", request, function (obj) {
                        equipamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        equipamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            equipamento.append(option);
                        });
                    }, "json");

                    equipamento.prop( "disabled", false );
                    equipamento.select2({placeholder: "Máquina / Equipamento / Itens Gerais" ,allowClear: true});
                }

            });

            apartamento.change(function () {

                if (apartamento.val() == "") {
                    equipamento.empty();
                    equipamento.select2({placeholder: "Máquina / Equipamento / Itens Gerais" ,allowClear: true});
                    equipamento.prop( "disabled", true );
                    if(setor.val() != ""){
                        setor.trigger('change');
                    }
                }

                else{

                    var request = { "unidade": unidade.val(), "apartamento": apartamento.val() };

                    $.post("LoadEquipamentoApartamento", request, function (obj) {
                        equipamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        equipamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            equipamento.append(option);
                        });
                    }, "json");

                    equipamento.prop( "disabled", false );
                    equipamento.select2({placeholder: "Máquina / Equipamento / Itens Gerais" ,allowClear: true});
                }

            });

        });
        
        var BeTableDatatables = function () {
            // Override a few DataTable defaults, for more examples you can check out https://www.datatables.net/
            var exDataTable = function () {
                jQuery.extend(jQuery.fn.dataTable.ext.classes, {
                    sWrapper: "dataTables_wrapper dt-bootstrap4"
                });
            };

            // Init simple DataTable, for more examples you can check out https://www.datatables.net/
            var initDataTableSimple = function () {
                jQuery('.js-dataTable-list').dataTable({
                    fixedHeader: false,
                    searching: false,
                    paging: false,
                    lengthChange: false,
                    autoWidth: true,
                    dom: 'Bfrtip',
                    buttons: [
                        { extend: 'copy', text: 'Copiar'},
                        { extend: 'print',
                       
                            text: 'Imprimir'},
                        { extend: 'excel'},
                        { extend: 'pdf', orientation: 'landscape'},
                    ],
                    language: {
                        "search": "Procurar:",
                        "lengthMenu": "Exibir _MENU_ ",
                        "zeroRecords": "Nenhum Registro Encontrado",
                        "info": "_MAX_ registro(s)",
                        "infoEmpty": "Nenhum Registro encontrado",
                        "infoFiltered": "(filtrado de _MAX_ registro(s))"
                    }
                });
            };

            return {
                init: function () {
                    // Override a few DataTable defaults
                    exDataTable();

                    // Init Datatables
                    initDataTableSimple();
                }
            };
        }();

        function UpdateStatus(codigo, unidade, data, status)
        {
            
            var fromDataOS = data.split("/");
            var data_hoje = new Date();
            data_hoje.setHours(0, 0, 0, 0);
            var data_os = new Date(fromDataOS[2], fromDataOS[1] -1, fromDataOS[0]);
            
            var dataString = {
                "codigo": codigo,
                "unidade": unidade,
                "status": status
            };

            $.post("UpdateStatusOS",
            dataString,
            function (result) {
                if (result == true) {
                    if (data_os < data_hoje){
                        document.getElementById("td." + codigo).innerHTML = (status == 5)? "<span class='badge badge-info'>VINCULADA</span>": "<span class='badge badge-danger'>ATRASADO</span>";
                    } else{
                        document.getElementById("td." + codigo).innerHTML = (status == 5)? "<span class='badge badge-info'>VINCULADA</span>": "<span class='badge badge-warning'>PENDENTE</span>";
                    }
                    if (status == 5)
                    {
                        document.getElementById("btn." + codigo).onclick = function() {UpdateStatus(codigo, unidade, data, 1)};
                        document.getElementById("btn." + codigo).setAttribute("class", "btn btn-sm btn-danger");
                    } else {                    
                        document.getElementById("btn." + codigo).onclick = function() {UpdateStatus(codigo, unidade, data, 5)};
                        document.getElementById("btn." + codigo).setAttribute("class", "btn btn-sm btn-secondary");
                    }                 
                }

            });

        }

        // Initialize when page loads
        jQuery(function () { 
            $.fn.dataTable.moment('DD/MM/YYYY HH:mm'); BeTableDatatables.init(); 
            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
        });

    </script>
}
