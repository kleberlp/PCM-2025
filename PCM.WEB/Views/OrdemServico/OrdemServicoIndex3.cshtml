@section Scripts {
<script>
/* =================================================================
   M01 — ORDEM DE SERVIÇO — Scripts Redesign v2.0
   ================================================================= */

$(document).ready(function () {

    // ----------------------------------------------------------------
    // 1. KPI CARDS — clique aplica filtro de status + dispara busca
    // ----------------------------------------------------------------
    $('#torre-os-kpi .torre-item').on('click', function () {
        var $card    = $(this);
        var statusVal = $card.data('os-status');

        $('#torre-os-kpi .torre-item').removeClass('kpi-ativo');
        $card.addClass('kpi-ativo');

        if (statusVal === 'atrasada') {
            $('#status').val('atrasada').trigger('change');
        } else if (statusVal !== '' && statusVal !== undefined) {
            $('#status').val(statusVal).trigger('change');
        } else {
            $('#status').val('').trigger('change');
        }

        setTimeout(function () {
            $('#filtrar').trigger('click');
        }, 80);
    });

    $('#filtrar').on('click', function () {
        var currentStatus = $('#status').val();
        $('#torre-os-kpi .torre-item').each(function () {
            var match = $(this).data('os-status') == currentStatus;
            $(this).toggleClass('kpi-ativo', match);
        });
        atualizarBadgeFiltros();
    });

    $('#clearFilter').on('click', function () {
        $('#torre-os-kpi .torre-item').removeClass('kpi-ativo');
        $('#filter-body-os .form-control, #filter-body-os .form-select').removeClass('filter-ativo');
        $('#filter-body-os select').each(function () {
            if ($(this).data('select2')) $(this).data('select2').$container.removeClass('filter-ativo');
        });
        $('#badge-filtros').hide();
    });

    // ----------------------------------------------------------------
    // 2. FILTRO COLAPSÁVEL — Ajuste de ícone
    // ----------------------------------------------------------------
    $('#filter-header-btn').on('click', function () {
        $(this).toggleClass('collapsed');
    });

    // ----------------------------------------------------------------
    // 3. BADGE DE FILTROS ATIVOS + HIGHLIGHT
    // ----------------------------------------------------------------
    $('#filter-body-os').on('change input', 'input, select', atualizarBadgeFiltros);
    atualizarBadgeFiltros();

});

function atualizarBadgeFiltros() {
    var camposSelect = [
        '#unidade', '#setor', '#apartamento', '#status',
        '#equipamento', '#prioridade', '#solicitante',
        '#responsavel_apartamento', '#origem', '#departamento',
        '#justificativa_apontamento'
    ];
    var camposText = ['#ordem_servico', '#executor'];
    var count = 0;

    camposSelect.forEach(function (id) {
        var $el = $(id);
        var v = $el.val();
        var ativo = v && v !== '' && v !== '-1';
        var $s2 = $el.data('select2') ? $el.data('select2').$container : $el;
        $s2.toggleClass('filter-ativo', !!ativo);
        if (ativo) count++;
    });

    camposText.forEach(function (id) {
        var $el = $(id);
        var ativo = !!$el.val();
        $el.toggleClass('filter-ativo', ativo);
        if (ativo) count++;
    });

    var dataIni    = $('#data_inicio').val();
    var dataFim    = $('#data_termino').val();
    var execIni    = $('#data_inicio_execucao').val();
    var execFim    = $('#data_termino_execucao').val();
    $('#data_inicio, #data_termino').toggleClass('filter-ativo', !!(dataIni || dataFim));
    $('#data_inicio_execucao, #data_termino_execucao').toggleClass('filter-ativo', !!(execIni || execFim));
    if (dataIni || dataFim) count++;
    if (execIni || execFim) count++;

    var $badge = $('#badge-filtros');
    if (count > 0) { $badge.text(count).show(); }
    else           { $badge.hide(); }
}
</script>
}
