                    exDataTable();

                    // Init Datatables
                    initDataTableSimple();
                }
            };
        }();

        function UpdateStatus(codigo, unidade, data, status){

            if('@ViewBag.administrador_vincular' == 'True' && (status == 5)){

                //Seta Váriaveis
                $("#codigo_ordem_servico").val(codigo);
                $("#codigo_unidade").val(unidade);
                $("#codigo_status").val(status);
                $("#data_os").val(data);
                $('#funcionario').val([]).trigger('change');

                var funcionario = $('#funcionario');

                var request = { "unidade": unidade };

                $.post("LoadFuncionario", request, function (obj) {
                    funcionario.empty();
                    option = $("<option>", { "value": "" }).text("");
                    $('#funcionario').append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        funcionario.append(option);
                    });
                }, "json");

                //Abre Formulário
                jQuery('#modalFuncionario').modal('show');

            } else if('@Session["funcionario"]' != '' || (status != 5)) {

                var fromDataOS = data.split("/");
                var data_hoje = new Date();
                data_hoje.setHours(0, 0, 0, 0);
                var data_os = new Date(fromDataOS[2], fromDataOS[1] -1, fromDataOS[0]);

                var dataString = {
                    "codigo": codigo,
                    "unidade": unidade,
                    "status": status,
                    "funcionario": (status == 5)? '@Session["codigo_funcionario"]': "",
                    "funcionario_nome": (status == 5)? '@Session["funcionario"]': ""
                };

                $.post("VincularFuncionarioOS", dataString,
                    function (result) {
                        if (result == "True") {
                            if (data_os < data_hoje){
                                document.getElementById("td." + codigo).innerHTML = (status == 5)? "<span class='badge badge-info'>VINCULADA</span>": "<span class='badge badge-danger'>ATRASADO</span>";
                            } else{
                                document.getElementById("td." + codigo).innerHTML = (status == 5)? "<span class='badge badge-info'>VINCULADA</span>": "<span class='badge badge-warning'>PENDENTE</span>";
                            }
                            if (status == 5)
                            {
                                document.getElementById("btn." + codigo).onclick = function() {UpdateStatus(codigo, unidade, data, 1)};
                                document.getElementById("btn." + codigo).setAttribute("class", "btn btn-sm btn-danger");
                                document.getElementById("td.executor." + codigo).innerHTML = '@Session["funcionario"]';
                            } else {
                                document.getElementById("btn." + codigo).onclick = function() {UpdateStatus(codigo, unidade, data, 5)};
                                document.getElementById("btn." + codigo).setAttribute("class", "btn btn-sm btn-secondary");
                                document.getElementById("td.executor." + codigo).innerHTML = "-";
                            }
                        }
                    });

            }
        }

        $('#form_funcionario').validate({
            ignore: [],
            errorClass: 'invalid-feedback animated fadeInDown',
            errorElement: 'div',
            errorPlacement: function (error, e) {
                jQuery(e).parents('.form-group > div').append(error);
            },
            highlight: function (e) {
                jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
            },
            success: function (e) {
                jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                jQuery(e).remove();
            },
            rules: {
                'funcionario': {
                    required: true
                }
            },
            messages: {
                'funcionario': {
                    required: '@PCM.WEB.Properties.Resources.campo_requerido'
                }
            },
            submitHandler: function (form) {

                var funcionario = $("#funcionario").val().toString();
                var funcionarios = $("#funcionario").select2('data');
                var codigo = $("#codigo_ordem_servico").val();
                var unidade = $("#codigo_unidade").val();
                var status = $("#codigo_status").val();
                var data = $("#data_os").val();
                var fromDataOS = data.split("/");
                var data_hoje = new Date();
                data_hoje.setHours(0, 0, 0, 0);
                var data_os = new Date(fromDataOS[2], fromDataOS[1] -1, fromDataOS[0]);

                var funcionario_nome = "";

                for(i = 0; i< funcionarios.length; i++)
                {
                    if (funcionarios[i].selected) {
                        funcionario_nome = funcionario_nome.concat((funcionario_nome == "")? "" : "; ", funcionarios[i].text);
                    }
                }

                var dataString = {
                    "codigo": codigo,
                    "unidade": unidade,
                    "status": status,
                    "funcionario": funcionario,
                    "funcionario_nome": funcionario_nome
                };

                $.post("VincularFuncionarioOS", dataString,
                    function (result) {
                        if (result == "True") {
                            if (data_os < data_hoje){
                                document.getElementById("td." + codigo).innerHTML = (status == 5)? "<span class='badge badge-info'>VINCULADA</span>": "<span class='badge badge-danger'>ATRASADO</span>";
                            } else{
                                document.getElementById("td." + codigo).innerHTML = (status == 5)? "<span class='badge badge-info'>VINCULADA</span>": "<span class='badge badge-warning'>PENDENTE</span>";
                            }
                            if (status == 5)
                            {
                                document.getElementById("btn." + codigo).onclick = function() {UpdateStatus(codigo, unidade, data, 1)};
                                document.getElementById("btn." + codigo).setAttribute("class", "btn btn-sm btn-danger");
                                document.getElementById("td.executor." + codigo).innerHTML = funcionario_nome;
                            } else {
                                document.getElementById("btn." + codigo).onclick = function() {UpdateStatus(codigo, unidade, data, 5)};
                                document.getElementById("btn." + codigo).setAttribute("class", "btn btn-sm btn-secondary");
                            }
                        }
                    });

                $('#modalFuncionario').modal('hide');
            }
        });

        // Initialize when page loads
        jQuery(function () {
            $.fn.dataTable.moment('DD/MM/YYYY HH:mm:ss');
            BeTableDatatables.init();
            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
        });

    </script>
}
