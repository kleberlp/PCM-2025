        function editarOS(data) {

            window.open("../OrdemServico/OrdemServicoEdit?codigo=" + data.codigo + "&unidade=" + data.codigo_unidade, "_self");

        }

        function deletarOS(data) {

            //Seta Váriaveis
            $("#codigo_ordem_servico_cancelar").val(data.codigo);
            $("#codigo_unidade_cancelar").val(data.codigo_unidade);

            //Abre Formulário
            jQuery('#modalCancelar').modal('show');

        }

        function viewOS(data) {

            window.open("../OrdemServico/OrdemServicoView?codigo=" + data.codigo + "&unidade=" + data.codigo_unidade, "_self");

        }

        function reopenOS(data) {

            window.open("../OrdemServico/ReabrirOS?codigo_pcm_ordem_servico=" + data.codigo + "&unidade=" + data.codigo_unidade, "_self");

        }

        function updateStatusOS(codigo, unidade, data, status){

            if('@ViewBag.administrador_vincular' == 'True' && (status == 5)){

                //Seta Váriaveis
                $("#codigo_ordem_servico").val(codigo);
                $("#codigo_unidade").val(unidade);
                $("#codigo_status").val(status);
                $("#data_os").val(data);
                $('#funcionario').val([]).trigger('change');

                var funcionario = $('#funcionario');

                var request = { "unidade": unidade};

                $.post("LoadFuncionario", request, function (obj) {
                    funcionario.empty();
                    option = $("<option>", { "value": "" }).text("");
                    $('#funcionario').append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        funcionario.append(option);
                    });
                }, "json");

                //Abre Formulário
                jQuery('#modalFuncionario').modal('show');

            } else if('@Session["funcionario"]' != '' || (status != 5)) {

                var fromDataOS = data.split("/");
                var data_hoje = new Date();
                data_hoje.setHours(0, 0, 0, 0);
                var data_os = new Date(fromDataOS[2], fromDataOS[1] -1, fromDataOS[0]);

                var dataString = {
                    "codigo": codigo,
                    "unidade": unidade,
                    "status": status,
                    "funcionario": (status == 5)? '@Session["codigo_funcionario"]': "",
                    "funcionario_nome": (status == 5)? '@Session["funcionario"]': ""
                };

                $.post("VincularFuncionarioOS", dataString,
                    function (result) {
                        if (result == "True") {
                            var cTable = $('#tb_main').DataTable();
                            cTable.ajax.reload(null, false);
                        }
                    }
                );

            }
        }


        // Add event listener for opening and closing details
        $('#tb_main tbody').on('click', 'td.details-control', function () {
            var tr = $(this).closest('tr');
            var tdi = tr.find("i.fa");
            var row = table.row(tr);

            if (row.child.isShown()) {
                // This row is already open - close it
                row.child.hide();
                tr.removeClass('shown');
                tdi.first().removeClass('fa-minus-square');
                tdi.first().addClass('fa-plus-square');
                // tr.find('svg').attr('data-icon', 'plus-square');    // FontAwesome 5
            }
            else {
                // Open this row
                row.child(format(row.data())).show();
                tr.addClass('shown');
                tdi.first().removeClass('fa-plus-square');
                tdi.first().addClass('fa-minus-square');
                // tr.find('svg').attr('data-icon', 'minus-circle'); // FontAwesome 5
            }
        });

        table.on("user-select", function (e, dt, type, cell, originalEvent) {
            if ($(cell.node()).hasClass("details-control")) {
                e.preventDefault();
            }
        });

        // Reload DataTable
        $('#filtrar').click(function () {
            table.ajax.reload(null, false);
