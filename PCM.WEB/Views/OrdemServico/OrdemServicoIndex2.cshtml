    function format(data) {

        var table_info = '';
        var type = data.tipo;

        jQuery.ajax({
            type: "POST",
            url: "LoadOrdemServicoApontamento",
            async: false,
            data: {
                "empresa": $("#empresa").val(),
                "unidade": data.codigo_unidade,
                "codigo_ordem_servico": data.codigo
            },
            dataType: "json",
            success: function (response) {

                table_info = '<table class="table table-sm table-vcenter table-striped table-bordered js-dataTable-list"> ' +
                    '<thead> ' +
                    '<tr class="table-secondary">' +
                    '<th class="text-center" style="width: 50px;"></th>' +
                    '<th>@Html.Raw(PCM.WEB.Properties.Resources.executor)</th>' +
                    '<th class="text-center" style="width: 250px;">@Html.Raw(PCM.WEB.Properties.Resources.justificativa_apontamento)</th>' +
                    '<th class="text-center" style="width: 150px;">@Html.Raw(PCM.WEB.Properties.Resources.data_inicio)</th>' +
                    '<th class="text-center" style = "width: 150px;">@Html.Raw(PCM.WEB.Properties.Resources.data_termino)</th>' +
                    '<th class="text-center" style="width: 100px;">@Html.Raw(PCM.WEB.Properties.Resources.tempo_gasto)</th>' +
                    '<th>Apontado por</th>' +
                    '<th class="text-center" style="width: 300px;">Imagem</th>' +
                    '</tr>' +
                    '</thead> ' +
                    '<tbody>';

                for (var i = 0; i < response.length; i++) {

                    table_info += '<tr class="bg-white"> ';
                    table_info += '<td class="text-center">' + response[i].item + '</td>';
                    table_info += '<td>';
                    table_info += '<p class="font-w600 mb-5">' + response[i].executor + '</p>';
                    table_info += '<div class="text-muted">' + response[i].solucao + '</div>';
                    table_info += '</td>';
                    table_info += '<td class="text-center">' + response[i].justificativa + '</td>';
                    table_info += '<td class="text-center">' + response[i].data_inicio + '</td>';
                    table_info += '<td class="text-center">' + response[i].data_termino + '</td>';
                    table_info += '<td class="text-center">' + response[i].horas + '</td>';
                    table_info += '<td>' + response[i].usuario + '</td>';
                    table_info += '<td class="text-center">';
                    if (response[i].fotos.Count > 0)
                    {
                        table_info += '<div class="js-slider slick-nav-black slick-nav-hover" data-dots="true" data-arrows="true" data-slides-to-show="1" data-center-mode="true" data-autoplay="true" data-autoplay-speed="3000">';
                        for (var j = 0; j < response[i].fotos.length; i++)
                        {
                            table_info += '<div class="mt-15">'
                            table_info += '<img class="img-galery" src="' + response[i].fotos[j].filename + '" alt="">';
                            table_info += '</div>';
                        }
                        table_info += '</div>';
                    }
                    table_info += '</td>';
                    table_info += '</tr>';

                }

                table_info += '</tbody> ' +
                    '</table>';

            }
        });

        return table_info;

    }

