@model PCM.WEB.MODELS.PlanoAcao

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("PlanoAcaoIndex", "PlanoAcao")">@PCM.WEB.Properties.Resources.ordem_servico</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.editar</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">                
                @using (Html.BeginForm("PlanoAcaoEdit", "PlanoAcao", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data"  }))        
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.codigo)
                    <input type="hidden" name="unidade_old" id="unidade_old" value="@Model.codigo_unidade">
                    <input type="hidden" name="unidade" id="unidade" value="@Model.codigo_unidade">
                    <input type="hidden" name="change_imagem" id="change_imagem" value="">

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.editar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("PlanoAcaoIndex", "PlanoAcao")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.unidade: <span>@Html.DisplayFor(model => model.unidade)</span></label>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.numero_documento: <span>@Html.DisplayFor(model => model.numero_documento)</span></label>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.departamento</label>
                                    <div>@Html.DropDownList("departamento", null, "", new { @class = "js-select2 form-control" })</div>
                                </div>
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.responsavel_departamento</label>
                                    <div>@Html.DropDownList("responsavel", null, "", new { @class = "js-select2 form-control" })</div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-6">
                                    <label>@PCM.WEB.Properties.Resources.solicitante</label>
                                    <div>@Html.DropDownList("solicitante", null, "", new { @class = "js-select2 form-control" })</div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.prazo_execucao</label>
                                    <div><input type="text" class="js-datepicker form-control" id="data_necessidade" name="data_necessidade" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value="@Model.data_necessidade"></div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.prioridade</label>
                                    <div>@Html.DropDownList("prioridade", null, "", new { @class = "js-select2 form-control" })</div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.descricao</label>
                                <div class="col-12">@Html.TextAreaFor(model => model.descricao, new { @class = "form-control", @maxlength = "5000", @rows = "6" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.arquivo</label>
                                <div class="col-12">
                                    <div class="custom-file">
                                        <input type="file" class="custom-file-input" id="imagem" name="imagem" onchange="Arquivo();" accept="image/*">
                                        <label id="lblArquivo" class="custom-file-label" for="imagem">@ViewBag.arquivo</label>
                                    </div>
                                </div>
                            </div>
                        </div>                        
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")
    
<script>

        function Arquivo() {
            document.getElementById("lblArquivo").textContent = document.getElementById("imagem").files[0].name;
            document.getElementById("change_imagem").value = "change";
        }

        $(function () {

            var departamento = $("#departamento");
            var responsavel = $("#responsavel");

            departamento.change(function () {

                if (departamento.val() == "") {

                    responsavel.empty();
                    responsavel.prop("disabled", true);
                    responsavel.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.responsavel_departamento)', allowClear: true });

                } else {

                    var request = { "departamento": departamento.val() };

                    $.post("LoadResponsavelDepartamento", request, function (obj) {
                        responsavel.empty();
                        option = $("<option>", { "value": "" }).text("");
                        responsavel.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            responsavel.append(option);
                        });
                    }, "json");

                    responsavel.prop("disabled", false);
                    responsavel.select2({ placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.responsavel_departamento)', allowClear: true });

                }

            });

        });

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'data_necessidade': {
                            required: true
                        },
                        'prioridade': {
                            required: true
                        },
                        'departamento': {
                            required: true
                        },
                        'descricao': {
                            required: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'data_necessidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'prioridade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'departamento': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'descricao': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        }
                    },
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
        });

</script>
}
