                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.apontamento</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("PlanoAcaoIndex", "PlanoAcao")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>

                        <div class="block-content block-content-full">
                            @if (Session["unidade"] == "")
                            {
                                <div class="form-group row font-w600"><div class="col-12">@PCM.WEB.Properties.Resources.unidade: <span class="text-primary">@ViewBag.apontamento.unidade</span></div></div>
                            }
                            <div class="form-group row font-w600"><div class="col-12">@PCM.WEB.Properties.Resources.plano_acao: <span class="text-primary">@ViewBag.apontamento.plano_acao</span></div></div>
                            <div class="form-group row font-w600"><div class="col-12">@PCM.WEB.Properties.Resources.prioridade: <span class="text-primary">@ViewBag.apontamento.prioridade</span></div></div>
                            <div class="form-group row font-w600"><div class="col-12">@PCM.WEB.Properties.Resources.departamento: <span class="text-primary">@ViewBag.apontamento.departamento</span></div></div>
                            @if (ViewBag.apontamento.responsavel != ""){ 
                                <div class="form-group row font-w600"><div class="col-12">@PCM.WEB.Properties.Resources.responsavel_departamento: <span class="text-primary">@ViewBag.apontamento.responsavel</span></div></div> 
                            }
                            <div class="form-group row font-w600"><div class="col-12">@PCM.WEB.Properties.Resources.descricao: <span class="text-primary">@ViewBag.apontamento.descricao</span></div></div>
                            <hr></hr>
                            <div class="form-group row">
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.data_inicio</label>
                                <div class="col-3"><input type="text" class="js-datepicker form-control" id="data" name="data" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value="@ViewBag.data"></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.descricao </label>
                                <div class="col-12"><textarea class="form-control" id="descricao" name="descricao" maxlength="500" rows="6" value="@ViewBag.apontamento.descricao"></textarea></div>
                            </div>
                            <div class="form-group row">
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.concluido?</label>
                                <div class="col-12">
                                    <label class="css-control css-control-success css-switch">
                                        <input type="checkbox" class="css-control-input" id="concluido" name="concluido" value="true">
                                        <span class="css-control-indicator"></span>
                                    </label>
                                </div>
                            </div>
                            <div id="div_justificativa">
                                <div class="form-group row">
                                    <div class="col-md-9">
                                        <label>@PCM.WEB.Properties.Resources.justificativa_apontamento</label>
                                        <div>@Html.DropDownList("justificativa_apontamento", null, "", new { @class = "form-control js-select2" })</div>
                                    </div>
                                    <div class="col-md-3">
                                        <label>@PCM.WEB.Properties.Resources.percentual_atendido</label>
                                        <div><input type="text" class="form-control" id="percentual" name="percentual" value="@ViewBag.apontamento.percentual"></div>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.observacao</label>
                                <div class="col-12"><textarea class="form-control" id="observacao" name="observacao" maxlength="500" rows="3"></textarea></div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.arquivo</label>
                                <div class="col-12">
                                    <div class="custom-file">
                                        <input type="file" class="custom-file-input" id="arquivo" name="arquivo" onchange="Arquivo();" accept="image/*">
                                        <label id="lblArquivo" class="custom-file-label" for="imagem">@PCM.WEB.Properties.Resources.selecione_arquivo</label>
                                    </div>
                                </div>
                            </div>
                        </div>


                        @*<div class="block block-rounded" id="registros">
                            <div class="block-header block-header-default bg-primary-light">
                                <h3 class="block-title text-dark font-w600">@PCM.WEB.Properties.Resources.registros: <span class="text-danger" id="info_registros">0</span></h3>
                                <div class="block-options">
                                    <label class="css-control css-control-danger css-checkbox">
                                        <input type="checkbox" name="barcode" id="barcode" class="css-control-input" value="true" onchange="productInput();" />
                                        <span class="css-control-indicator"></span>
                                        <span class="h5">@PCM.WEB.Properties.Resources.leitor_codigo_barras</span>
                                    </label>
                                </div>
                            </div>
                            <div class="block-content block-content-full">
                                <div>
                                    <div class="form-group row">
                                        <div class="col-md-2" id="input_barcode" style="display:none">
                                            <label>@PCM.WEB.Properties.Resources.produto</label>
                                            <input type="text" class="form-control" style="text-transform: uppercase;" id="produto" name="produto" autocomplete="off" placeholder="" value="" maxlength="20">
                                        </div>
                                        <div class="col-md-4" id="descricao_barcode" style="display:none">
                                            <label>@PCM.WEB.Properties.Resources.descricao</label>
                                            <input type="text" class="form-control" disabled style="text-transform: uppercase;" id="descricao" name="descricao" autocomplete="off" placeholder="" value="" maxlength="250">
                                        </div>
                                        <div class="col-md-6" id="input_combo">
                                            <label>@PCM.WEB.Properties.Resources.produto</label>
                                            <div>@Html.DropDownList("produto_combo", null, "", new { @class = "form-control js-select2" })</div>
                                        </div>
                                        <div class="col-md-2" id="div_lote" name="div_lote">
                                            <label>@PCM.WEB.Properties.Resources.lote</label>
                                            <div>@Html.DropDownList("lote", null, "", new { @class = "form-control js-select2" })</div>
                                        </div>
                                        <div class="col-md-2">
                                            <label>@PCM.WEB.Properties.Resources.quantidade</label>
                                            <div class="input-group">
