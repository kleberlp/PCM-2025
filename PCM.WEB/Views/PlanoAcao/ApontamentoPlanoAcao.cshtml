                @using (Html.BeginForm("ApontamentoPlanoAcao", "PlanoAcao", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="codigo_pcm_plano_acao" id="codigo_pcm_plano_acao" value="@ViewBag.apontamento.codigo">
