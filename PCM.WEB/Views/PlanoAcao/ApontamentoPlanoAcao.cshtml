                                                <div class="input-group-append">
                                                    <button type="button" class="btn btn-square btn-secondary min-width-40 fa fa-plus mr-5" onclick="adicionarProduto();"></button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <table class="table table-bordered table-sm table-striped table-vcenter" id="table" name="table">
                                    <thead>
                                        <tr class="table-secondary">
                                            <th class="text-center" style="width:200px">@PCM.WEB.Properties.Resources.produto</th>
                                            <th>@PCM.WEB.Properties.Resources.descricao</th>
                                            <th class="text-center" style="width:150px">@PCM.WEB.Properties.Resources.lote</th>
                                            <th class="text-center" style="width:150px">@PCM.WEB.Properties.Resources.quantidade</th>
                                            <th class="text-center" style="width:80px" data-sortable="false"></th>
                                        </tr>
                                    </thead>
                                    <tbody id="table_linha" name="table_linha">
                                        @for (int i = 0; i < Model.Count; i++)
                                        {
                                            <tr id='linha' style="display:none">
                                                @Html.HiddenFor(m => m[i].codigo_produto)
                                                @Html.HiddenFor(m => m[i].excluido)
                                                @Html.HiddenFor(m => m[i].lote)
                                                @Html.HiddenFor(m => m[i].quantidade)
                                                <td class="text-center" style="width:200px">@Html.DisplayFor(m => m[i].produto)</td>
                                                <td>@Html.DisplayFor(m => m[i].descricao_produto)</td>
                                                <td class="text-center" style="width:150px" id="lote_@i" name="lote_@i">@Html.DisplayFor(m => m[i].lote)</td>
                                                <td class="text-center" style="width:150px">@Html.DisplayFor(m => m[i].quantidade)</td>
                                                <td class="text-center">
                                                    <div class="btn-group">
                                                        <a href="#" onclick="remove(this, ' + codigo + ');" class="btn btn-sm btn-secondary"><i class="fa fa-times"></i></a>
                                                        <a href="#" onclick="informacao(this, ' + codigo + ');" class="btn btn-sm btn-secondary"><i class="fa fa-info-circle"></i></a>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>

                            </div>

                        </div>*@

                    </div>

                }
                <!-- END Basic Info -->
            </div>
            <!-- END Update Product -->
        </div>
        <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/clockpicker")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/clockpicker")
    @Scripts.Render("~/plugins/select")

<script>

        $(document).ready(function () {
            $("#data_inicio").mask("99/99/9999");
            $("#percentual").maskMoney({prefix: '', thousands: '.', precision: 2, allowNegative: false, 'placeholder': ''});
        });

        function Arquivo() {
            document.getElementById("lblArquivo").textContent = document.getElementById("arquivo").files[0].name;
        }

        $(function () {

            var concluido = $("#concluido");
            var justificativa = $("#div_justificativa");
            concluido.change(function () {
                if(document.getElementById('concluido').checked){
                    justificativa.hide();
                    $('#percentual').val(100);
                } else {
                    justificativa.show();
                    $('#percentual').val(@ViewBag.apontamento.percentual);
                }
            });

        });

        jQuery.validator.addMethod("justificativa_apontamento", function (funcionario, element) {

            var concluido = document.getElementById('concluido').checked;
            var justificativa_apontamento = $("#justificativa_apontamento").val();
            if (!concluido) {
                if(justificativa_apontamento != "")
                    return true;
                else
                    return false;
            }else {
                return true;
            }
        }, '@PCM.WEB.Properties.Resources.campo_requerido');

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'descricao': {
                            required: true
                        },
                        'justificativa_apontamento': {
                            justificativa_apontamento: true
                        },
                        'percentual': {
                            justificativa_apontamento: true
                        }
                    },
                    messages: {
                        'descricao': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'justificativa_apontamento': {
                            justificativa_apontamento: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'percentual': {
                            justificativa_apontamento: '@PCM.WEB.Properties.Resources.campo_requerido'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['datepicker', 'maxlength', 'select2']);
        });

</script>
}
