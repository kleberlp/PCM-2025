@model IEnumerable<PCM.WEB.MODELS.FuncionarioHorasTrabalhadas>

<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.funcionario_horas_trabalhadas</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->
    <!-- Page Content -->
    <div class="content">

        @using (Html.BeginForm("FuncionarioHorasTrabalhadas", "Relatorio", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", @name = "form", @id = "form", role = "form" }))
        {
            @Html.AntiForgeryToken()

            <!-- Toggle Tasks Navigation on mobile -->
            <button type="button" class="btn btn-block btn-primary d-md-none mb-10" data-toggle="class-toggle" data-target=".js-tasks-nav" data-class="d-none d-md-block">@PCM.WEB.Properties.Resources.filtros</button>

            <!-- Collapsible Tasks Navigation -->
            <div class="js-tasks-nav d-none d-md-block">
                <div class="block block-rounded border">
                    <div class="block-header block-header-default bg-gd-default">
                        <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.filtro</h3>
                    </div>
                    <div class="block-content">
                        <ul class="list-group push">
                            <li class="list-group-item">
                                <div class="row">
                                    <div class="col-md-4">
                                        <label>@PCM.WEB.Properties.Resources.unidade</label>
                                        @Html.DropDownList("unidade", null, PCM.WEB.Properties.Resources.unidade, new { @class = "form-control" })
                                    </div>
                                    <div class="col-md-2">
                                        <label>@PCM.WEB.Properties.Resources.ativo</label>
                                        @Html.DropDownList("ativo", null, PCM.WEB.Properties.Resources.ativo, new { @class = "form-control" })
                                    </div>
                                    <div class="col-md-2">
                                        <label>@PCM.WEB.Properties.Resources.agrupado_por_unidade</label>
                                        @Html.DropDownList("agrupado_por_unidade", null, PCM.WEB.Properties.Resources.agrupado_por_unidade, new { @class = "form-control" })
                                    </div>
                                    <div class="col-md-4">
                                        <label>@PCM.WEB.Properties.Resources.periodo</label>
                                        <div class="input-daterange input-group" data-date-format="dd/mm/yyyy" data-week-start="1" data-autoclose="true" data-today-highlight="true">
                                            <input type="text" class="form-control" id="data_inicio" name="data_inicio" placeholder="De" data-week-start="1" data-autoclose="true" data-today-highlight="true" value="@ViewBag.data_inicio">
                                            <div class="input-group-prepend input-group-append">
                                                <span class="input-group-text font-w600">-</span>
                                            </div>
                                            <input type="text" class="form-control" id="data_termino" name="data_termino" placeholder="Até" data-week-start="1" data-autoclose="true" data-today-highlight="true" value="@ViewBag.data_termino">
                                        </div>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item text-right">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75" name="filtrar" id="filtrar"><i class="si si-magnifier mr-5"></i>@PCM.WEB.Properties.Resources.filtrar</button>
                                @if (ViewBag.imprimir)
                                {
                                    <button type="button" class="btn btn-square btn-secondary min-width-100 h-75" name="imprimir" id="imprimir" onclick="ImprimirRelatorio();"><i class="si si-printer mr-5"></i>@PCM.WEB.Properties.Resources.imprimir</button>
                                }
                            </li>
                        </ul>
                    </div>
                </div>
                <!-- END Tasks Info -->
            </div>
            <!-- END Collapsible Tasks Navigation -->

             @*CHART 
            <div class="block block-rounded d-md-block d-none border">
                <div class="block block-rounded block-mode-loading-refresh">
                    <div class="block-header block-header-default bg-gd-default">
                        <h3 class="block-title text-white font-w600">Gráfico - @PCM.WEB.Properties.Resources.funcionario_horas_trabalhadas</h3>
                    </div>
                    <div class="block-content block-content-full">
                        <div class="pull-all pt-50">
                            <canvas id="canvas" height="70px"></canvas>
                        </div>
                    </div>
                </div>
            </div>
             END CHART*@ 

            <div class="block block-rounded border">
                <div class="block-header block-header-default bg-gd-default">
                    <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.funcionario_horas_trabalhadas</h3>
                    <div class="block-options">
                        <button type="button" class="btn-block-option text-dark font-w600" data-toggle="block-option" data-action="fullscreen_toggle"></button>
                    </div>
                </div>

                <div class="block-content block-content-full border">

                    <!-- Table -->
                    <table class="table table-vcenter table-sm table-hover table-striped js-dataTable-list">
                        <thead>
                            <tr class="table-secondary">
                                @if (Session["unidade"] == "")
                                {
                                    <th rowspan="2">@PCM.WEB.Properties.Resources.unidade</th>
                                }
                                <th rowspan="2">@PCM.WEB.Properties.Resources.funcionario</th>
                                @foreach (var item in ViewBag.meses)
                                {
                                    <th class="text-center" colspan="2" style="width: 80px;">@item</th>
                                }
                                <th class="text-center" colspan="2" style="width: 100px;">Total</th>
                            </tr>

                            <tr class="table-secondary">
                                @foreach (var item in ViewBag.meses)
                                {
                                    <th class="text-center" style="width: 80px;">Horas</th>
                                    <th class="text-center" style="width: 80px;">Falta</th>
                                }
                                <th class="text-center" style="width: 80px;">Horas</th>
                                <th class="text-center" style="width: 80px;">Falta</th>
                            </tr>

                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    @if (Session["unidade"] == "")
                                    {
                                        <td class="font-w600">@Html.DisplayFor(modelItem => item.unidade)</td>
                                    }
                                    <td>@Html.DisplayFor(modelItem => item.funcionario)</td>
                                    @foreach (var valor in item.valores)
                                    {
                                        <td class="text-center" style="width: 80px;">
                                            @if (valor.valor == "0:00")
                                            {
                                                @Html.DisplayFor(modelItem => valor.valor)
                                            }
                                            else
                                            {
                                                @Html.ActionLink(valor.valor, "../PCM/ManutencaoApontamento", new { codigo_unidade = item.codigo_unidade, codigo_funcionario = item.codigo_funcionario, data_inicio = ViewBag.data_inicio, data_termino = ViewBag.data_termino, mes = valor.mes, ano = valor.ano })
                                            }
                                        </td>

                                        <td class="text-center" style="width: 80px;">
                                            @Html.DisplayFor(modelItem => valor.falta)
                                        </td>
                                    }
                                    <td class="text-center table-warning" style="width: 100px;">
                                        <b>@Html.DisplayFor(modelItem => item.total)</b>
                                    </td>
                                    <td class="text-center table-warning" style="width: 100px;">
                                        <b>@Html.DisplayFor(modelItem => item.falta)</b>
                                    </td>
                                </tr>

                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-primary font-w600">
                                @{

                                    long minutos = 0;
                                    long falta_minutos = 0;
                                    int colspan = 0;

                                    foreach (var funcionario in Model)
                                    {
                                        colspan = (funcionario.valores.Count() * 2) + 1;
                                        foreach (var item in funcionario.valores)
                                        {
                                            minutos += item.minutos;
                                            falta_minutos += item.falta_minutos;
                                        }
                                    }

                                    TimeSpan spWorkMin = TimeSpan.FromMinutes(minutos);
                                    TimeSpan spWorkMinFaltas = TimeSpan.FromMinutes(falta_minutos);
                                }
                                <td class="font-w400" colspan="@colspan">TOTAL</td>
                                @if (Session["unidade"] == "")
                                {
                                    <td class="font-w600"></td>
                                }
                                <td class="font-w400 text-center">@string.Format("{0:00}:{1:00}", (int)spWorkMin.TotalHours, spWorkMin.Minutes)</td>
                                <td class="font-w400 text-center">@string.Format("{0:00}:{1:00}", (int)spWorkMinFaltas.TotalHours, spWorkMinFaltas.Minutes)</td>
                            </tr>

                    </tfoot>
                    </table>

                    <!-- END Table -->

                </div>

            </div>

        }

    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->


@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/dataTables")
}

@section Scripts {
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/chart")

    <script>

    $(document).ready(function () { $("#data_inicio").mask("99/99/9999"); });
    $(document).ready(function () { $("#data_termino").mask("99/99/9999"); });
    var colorNames = Object.keys(window.chartColors);

    function ImprimirRelatorio() {

        var unidade = $("#unidade").val();
        var data_inicio = $("#data_inicio").val();
        var data_termino = $("#data_termino").val();

        window.open('PrintHorasTrabalhadas' + '?unidade=' + unidade + '&data_inicio=' + data_inicio + '&data_termino=' + data_termino + '&nome_fantasia=' + $("#unidade option:selected").text(), '_blank');
    }

    var config = {
        type: 'bar',
        data: {
            labels: []
        },
        options: {
            responsive: true,
            elements: {
                line: {
                    tension: 0.000001
                }
            },
            scales: {
                yAxes: [{
                    ticks: {
                        min: 0.0,
                        suggestedMax: 20.0
                    }
                }]
            },
            legend: { position: 'right' }
        }
    };

    function LoadChart() {

        unidade = $("#unidade");
        ativo = $("#ativo");
        data_inicio = $("#data_inicio");
        data_termino = $("#data_termino");

        $.post("Meses", { "data_inicio": data_inicio.val(), "data_termino": data_termino.val() }, function (obj) {

            $.each(obj, function (indice, result) {
                config.data.labels.push(result);
            });

        }, "json");

        var request = { "unidade": (unidade.val() == "")? "-1": unidade.val(), "data_inicio": data_inicio.val(), "data_termino": data_termino.val(), "ativo": (ativo.val() == "")? "-1": ativo.val()};

        $.post("ChartFuncionarioHorasTrabalhadas", request, function (obj) {

            $.each(obj, function (indice, result) {

                var colorName = colorNames[config.data.datasets.length % colorNames.length];
                var newColor = window.chartColors[colorName];
                var borderColor = window.chartBorderColors[colorName];

                var newDataset = {
                    label: result.nome,
                    backgroundColor: newColor,
                    borderColor: borderColor,
                    data: [],
                    fill: false
                };

                for (var index = 0; index < result.valor.length; ++index) {
                    newDataset.data.push(result.valor[index]);
                }

                config.data.datasets.push(newDataset);
                window.myLine.update();
            });
        }, "json");
    }

    //window.onload = function () {
    //    var ctx = document.getElementById('canvas').getContext('2d');
    //    window.myLine = new Chart(ctx, config);
    //};

    var FormValidation = function () {
        // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
        var initValidationBootstrap = function () {
            jQuery('.js-validation-bootstrap').validate({
                ignore: [],
                errorClass: 'invalid-feedback animated fadeInDown',
                errorElement: 'div',
                errorPlacement: function (error, e) {
                    jQuery(e).parents('.list-group-item > div').append(error);
                },
                highlight: function (e) {
                    jQuery(e).closest('.list-group-item').removeClass('is-invalid').addClass('is-invalid');
                },
                success: function (e) {
                    jQuery(e).closest('.list-group-item').removeClass('is-invalid');
                    jQuery(e).remove();
                },
                rules: {
                    'data_inicio': {
                        required: true
                    },
                    'data_termino': {
                        required: true
                    }
                },
                messages: {
                    'data_inicio': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'data_termino': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    }
                }
            });
        };

        return {
            init: function () {
                // Init Bootstrap Forms Validation
                initValidationBootstrap();
            }
        };
    }();

    var BeTableDatatables = function () {
        // Override a few DataTable defaults, for more examples you can check out https://www.datatables.net/
        var exDataTable = function () {
            jQuery.extend(jQuery.fn.dataTable.ext.classes, {
                sWrapper: "dataTables_wrapper dt-bootstrap4"
            });
        };

        // Init simple DataTable, for more examples you can check out https://www.datatables.net/
        var initDataTableSimple = function () {
            jQuery('.js-dataTable-list').dataTable({
                fixedHeader: true,
                searching: false,
                lengthChange: false,
                pageLength: 15,
                columnDefs: [{ orderable: false, targets: [0] }], order: [1],
                autoWidth: false,
                scrollX: false,
                scrollColapse: true,
                dom: 'Bfrtip',
                buttons: [
                    { extend: 'copy', text: 'Copiar' },
                    {
                        extend: 'print',
                        text: 'Imprimir'
                    },
                    { extend: 'excel' },
                    { extend: 'pdf', orientation: 'portrait' },
                ],
                language: {
                    "search": "Procurar:",
                    "lengthMenu": "Exibir _MENU_ ",
                    "zeroRecords": "Nenhum Registro Encontrado",
                    "info": "_MAX_ registro(s)",
                    "infoEmpty": "Nenhum Registro encontrado",
                    "infoFiltered": "(filtrado de _MAX_ registro(s))"
                }
            });
        };

        return {
            init: function () {
                // Override a few DataTable defaults
                exDataTable();

                // Init Datatables
                initDataTableSimple();
            }
        };
    }();

    // Initialize when page loads
    jQuery(function () {
        FormValidation.init();
        BeTableDatatables.init();
        //LoadChart();
        Codebase.helpers(['datepicker', 'maxlength']);
    });

    </script>
}