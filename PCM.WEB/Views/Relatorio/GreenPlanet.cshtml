<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item">@PCM.WEB.Properties.Resources.relatorio</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.green_planet</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->
    <!-- Page Content -->
    <div class="content">

        @using (Html.BeginForm("GreenPlanet", "Relatorio", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", @name = "form", @id = "form", role = "form" }))
        {
            @Html.AntiForgeryToken()

            <div class="col-md-12 col-xl-12">
                <!-- Toggle Tasks Navigation on mobile -->
                <button type="button" class="btn btn-block btn-primary d-md-none mb-10" data-toggle="class-toggle" data-target=".js-tasks-nav" data-class="d-none d-md-block">@PCM.WEB.Properties.Resources.filtros</button>

                <!-- Collapsible Tasks Navigation -->
                <div class="js-tasks-nav d-none d-md-block">
                    <!-- Tasks Info -->
                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.filtro</h3>
                        </div>
                        <div class="block-content">
                            <ul class="list-group push">
                                @if (Session["unidade"] == "")
                                {
                                    <li class="list-group-item">
                                        <div class="row">
                                            <div class="col-md-4">@Html.DropDownList("unidade", null, PCM.WEB.Properties.Resources.unidade, new { @class = "js-select2 form-control" })</div>
                                        </div>
                                    </li>
                                }
                                else
                                {
                                    <input type="hidden" name="unidade" id="unidade" value="@Session["codigo_unidade"]">
                                }
                                <li class="list-group-item">
                                    <div class="row">
                                        <div class="col-md-2">@Html.DropDownList("agrupado_por", null, PCM.WEB.Properties.Resources.agrupado_por, new { @class = "js-select2 form-control" })</div>
                                        <div class="col-md-2">@Html.DropDownList("forma_calculo", null, PCM.WEB.Properties.Resources.forma_calculo_green_planet, new { @class = "js-select2 form-control" })</div>
                                        <div class="col-md-2">@Html.DropDownList("grupo_item_medicao", null, PCM.WEB.Properties.Resources.grupo_item_medicao, new { @class = "js-select2 form-control" })</div>
                                        <div class="col-md-2">@Html.DropDownList("item_medicao", null, PCM.WEB.Properties.Resources.item_medicao, new { @class = "js-select2 form-control" })</div>
                                        <div class="col-md-4">
                                            <div class="input-daterange input-group" data-date-format="dd/mm/yyyy" data-week-start="1" data-autoclose="true" data-today-highlight="true">
                                                <input type="text" class="form-control" id="data_inicio" name="data_inicio" placeholder="De" data-week-start="1" data-autoclose="true" data-today-highlight="true" value="@ViewBag.data_inicio">
                                                <div class="input-group-prepend input-group-append">
                                                    <span class="input-group-text font-w600">-</span>
                                                </div>
                                                <input type="text" class="form-control" id="data_termino" name="data_termino" placeholder="Até" data-week-start="1" data-autoclose="true" data-today-highlight="true" value="@ViewBag.data_termino">
                                            </div>
                                        </div>
                                    </div>
                                </li>
                                <li class="list-group-item text-right">
                                    <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75" name="filtrar" id="filtrar"><i class="si si-magnifier mr-5"></i>@PCM.WEB.Properties.Resources.filtrar</button>
                                    @if (ViewBag.imprimir)
                                    {
                                        <button type="button" class="btn btn-square btn-secondary min-width-100 h-75" name="imprimir" id="imprimir" onclick="ImprimirRelatorio();"><i class="si si-printer mr-5"></i>@PCM.WEB.Properties.Resources.imprimir</button>
                                    }
                                </li>
                            </ul>
                        </div>
                    </div>
                    <!-- END Tasks Info -->
                </div>
                <!-- END Collapsible Tasks Navigation -->
                <!-- CHART -->
                <div class="d-md-block d-none">
                    <div class="block block-rounded block-mode-loading-refresh" id="my-block">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">Gráfico - @PCM.WEB.Properties.Resources.green_planet</h3>
                            <div class="block-options">
                                <button type="button" class="btn-block-option text-white" data-toggle="block-option" data-action="content_toggle"></button>
                            </div>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="pull-all pt-50">
                                <canvas id="canvas" height="70px"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- END CHART -->
                @*<div class="block-header block-header-default bg-gd-default">
                        <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.green_planet</h3>
                        <div class="block-options">
                            <button type="button" class="btn-block-option text-dark font-w600" data-toggle="block-option" data-action="fullscreen_toggle"></button>
                        </div>
                    </div>*@

                <!-- Table -->
                <div class="table-responsive table-sm push block block-content-full p-10">
                    <table class="table table-bordered table-hover js-dataTable-list" name="tbList" id="tbList">
                        <thead>
                            <tr class="table-secondary">
                                <th>@PCM.WEB.Properties.Resources.item_medicao</th>
                                <th class="text-center" style="width: 100px;">@PCM.WEB.Properties.Resources.data</th>
                                <th class="text-center" style="width: 150px;">@PCM.WEB.Properties.Resources.quantidade_hospede</th>
                                <th class="text-center" style="width: 150px;">@PCM.WEB.Properties.Resources.ocupacao_quartos</th>
                                <th class="text-center" style="width: 150px;">@PCM.WEB.Properties.Resources.valor</th>
                                <th class="text-center" style="width: 150px;">@PCM.WEB.Properties.Resources.medicao</th>
                                <th class="text-center" style="width: 20px;"></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
                <!-- END Table -->

                <div>
                    <i><span class="font-w600 text-danger h6">** Erro de Lançamento</span></i>
                </div>


            </div>

        }

    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->
<!-- From Right Modal -->
<div class="modal fade" id="modalEdit" tabindex="-1" role="dialog" aria-labelledby="modal-large" aria-hidden="true">
    <div class="modal-dialog modal-dialog-fromright modal-lg" role="document">
        <div class="modal-content">

            @using (Html.BeginForm("GreenPlanetUpdate", "Relatorio", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", @name = "form_modal", @id = "form_modal", role = "form" }))
            {
                @Html.AntiForgeryToken()

                <input type="hidden" id="codigoUnidade" name="codigoUnidade" value="" />
                <input type="hidden" id="codigoItemMedicao" name="codigoItemMedicao" value="" />
                <input type="hidden" id="dataMedicao" name="dataMedicao" value="" />

                <div class="block block-themed block-transparent mb-15">
                    <div class="block-header block-header-default bg-gd-default">
                        <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.green_planet</h3>
                        <div class="block-options">
                            <button type="button" class="btn-block-option" data-bs-dismiss="modal" aria-label="Close">
                                <i class="si si-close font-w600"></i>
                            </button>
                        </div>
                    </div>
                    <div class="block-content block-content-full">

                        <div class="row">
                            <div class="col-12">
                                <label id="descricaoItemMedicao" name="descricaoItemMedicao"></label>
                            </div>
                            <div class="col-4">
                                <label>@PCM.WEB.Properties.Resources.quantidade_hospede</label>
                                <div><input type="text" class="form-control" id="quantidadeHospede" name="quantidadeHospede" maxlength="5" value=""></div>
                            </div>
                            <div class="col-4">
                                <label>@PCM.WEB.Properties.Resources.ocupacao_quartos</label>
                                <div><input type="text" class="form-control" id="ocupacaoUH" name="ocupacaoUH" maxlength="5" value=""></div>
                            </div>
                            <div class="col-4">
                                <label>@PCM.WEB.Properties.Resources.valor</label>
                                <div><input type="text" class="form-control" id="valor" name="valor" value=""></div>
                            </div>

                        </div>

                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-square btn-secondary min-width-100 h-75" name="btnConfirm" id="btnConfirm" onclick="$('#form_modal').submit();" )><i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar</button>
                    <button type="button" class="btn btn-square btn-secondary min-width-100 h-75" name="btnClose" id="btnClose" data-bs-dismiss="modal"><i class="fa fa-close mr-5"></i>@PCM.WEB.Properties.Resources.sair</button>
                </div>
            }
        </div>
    </div>
</div>
<!-- END From Right Modal -->

<div class="modal fade" id="modalFoto" tabindex="-1" role="dialog" aria-labelledby="modal-large" aria-hidden="true">
    <div class="modal-dialog modal-dialog-fromright modal-lg" role="document">
        <div class="modal-content">
            <div class="block block-themed block-transparent mb-0">
                <div class="block-header block-header-default bg-gd-default">
                    <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.foto</h3>
                </div>
                <div class="block-content">

                    <div class="row items-push js-gallery img-fluid-100" id="galery">
                    </div>
                    <!-- END Advanced Gallery -->
                </div>
            </div>
            <div class="modal-footer">
                @*<input type="hidden" id="codigo_auditoria_interna" value="@Model.codigo_pcm_programada_ordem_servico" />
                    <input type="hidden" id="codigo_auditoria" value="@Model.codigo " />
                    <input type="hidden" id="data" value="@ViewBag.data" />*@
                <input type="hidden" id="codigo_item_checklist" />
                <button type="button" class="btn btn-square btn-secondary min-width-100 h-75" name="close" id="close" onclick="$(this).next('.custom-file-label').addClass('selected').html('');" data-bs-dismiss="modal"><i class="fa fa-close mr-5"></i>@PCM.WEB.Properties.Resources.sair</button>
            </div>
