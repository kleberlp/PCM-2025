@model IEnumerable<PCM.WEB.MODELS.NaoConformidade>

<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action("Index", "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <span class="breadcrumb-item">@PCM.WEB.Properties.Resources.relatorio </span>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.nao_conformidade</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->
    <!-- Page Content -->
    <div class="content">

        @using (Html.BeginForm("NaoConformidade", "Relatorio", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data", name = "form", id = "form" }))
        {
            @Html.AntiForgeryToken()

            <!-- Toggle Tasks Navigation on mobile -->
            <button type="button" class="btn btn-block btn-square btn-primary d-md-none mb-10" data-toggle="class-toggle" data-target=".js-tasks-nav" data-class="d-none d-md-block">@PCM.WEB.Properties.Resources.filtrar </button>

            <div class="js-tasks-nav d-none d-md-block">
                <div class="block block-rounded border">
                    <div class="block-header block-header-default bg-gd-default">
                        <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.nao_conformidade </h3>
                    </div>
                    <div class="block-content">
                        <ul class="list-group push">
                            <li class="list-group-item">
                                <div class="row">
                                    <div class="col-md-3">
                                        <label>@PCM.WEB.Properties.Resources.unidade</label>
                                        @Html.DropDownList("unidade", null, "", new { @class = "form-control" })
                                    </div>
                                    <div class="col-md-2">
                                        <label>@PCM.WEB.Properties.Resources.tipo</label>
                                        @Html.DropDownList("tipo", null, "", new { @class = "form-control" })
                                    </div>
                                    <div class="col-md-4">
                                        <label>@PCM.WEB.Properties.Resources.programada </label>
                                        @Html.DropDownList("manutencao_programada", null, "", new { @class = "form-control" })
                                    </div>
                                    <div class="col-md-2">
                                        <label>@PCM.WEB.Properties.Resources.data</label>
                                        <div><input type="text" class="js-datepicker form-control" id="data" name="data" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value="@ViewBag.data"></div>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item text-right">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75" name="filtrar" id="filtrar"><i class="si si-magnifier mr-5"></i>@PCM.WEB.Properties.Resources.filtrar </button>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <!-- END Collapsible Tasks Navigation -->

            <!-- Listagem -->
            <div class="block block-content block-content-full border">

                <!-- Table -->
                <div class="table-responsive table-sm push">
                    <table class="table table-sm table-vcenter table-striped table-bordered js-dataTable-list">
                        <thead>
                            <tr class="table-secondary">
                                <th>@PCM.WEB.Properties.Resources.programada</th>
                                <th>@PCM.WEB.Properties.Resources.checklist</th>
                                @foreach (var item in ViewBag.meses)
                                {
                                    <th class="text-center" style="width: 80px;">@item</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@Html.DisplayFor(modelItem => item.manutencao_programada)</td>
                                    <td>@Html.DisplayFor(modelItem => item.descricao)</td>
                                    @if (item.mes_1 > 0)
                                    {
                                        <td class="text-center bg-danger text-white" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_1)</td>
                                    }
                                    else
                                    {
                                        <td class="text-center" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_1)</td>
                                    }
                                    @if (item.mes_2 > 0)
                                    {
                                        <td class="text-center bg-danger text-white" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_2)</td>
                                    }
                                    else
                                    {
                                        <td class="text-center" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_2)</td>
                                    }
                                    @if (item.mes_3 > 0)
                                    {
                                        <td class="text-center bg-danger text-white" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_3)</td>
                                    }
                                    else
                                    {
                                        <td class="text-center" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_3)</td>
                                    }
                                    @if (item.mes_4 > 0)
                                    {
                                        <td class="text-center bg-danger text-white" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_4)</td>
                                    }
                                    else
                                    {
                                        <td class="text-center" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_4)</td>
                                    }
                                    @if (item.mes_5 > 0)
                                    {
                                        <td class="text-center bg-danger text-white" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_5)</td>
                                    }
                                    else
                                    {
                                        <td class="text-center" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_5)</td>
                                    }
                                    @if (item.mes_6 > 0)
                                    {
                                        <td class="text-center bg-danger text-white" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_6)</td>
                                    }
                                    else
                                    {
                                        <td class="text-center" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_6)</td>
                                    }
                                    @if (item.mes_7 > 0)
                                    {
                                        <td class="text-center bg-danger text-white" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_7)</td>
                                    }
                                    else
                                    {
                                        <td class="text-center" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_7)</td>
                                    }
                                    @if (item.mes_8 > 0)
                                    {
                                        <td class="text-center bg-danger text-white" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_8)</td>
                                    }
                                    else
                                    {
                                        <td class="text-center" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_8)</td>
                                    }
                                    @if (item.mes_9 > 0)
                                    {
                                        <td class="text-center bg-danger text-white" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_9)</td>
                                    }
                                    else
                                    {
                                        <td class="text-center" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_9)</td>
                                    }
                                    @if (item.mes_10 > 0)
                                    {
                                        <td class="text-center bg-danger text-white" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_10)</td>
                                    }
                                    else
                                    {
                                        <td class="text-center" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_10)</td>
                                    }
                                    @if (item.mes_11 > 0)
                                    {
                                        <td class="text-center bg-danger text-white" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_11)</td>
                                    }
                                    else
                                    {
                                        <td class="text-center" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_11)</td>
                                    }
                                    @if (item.mes_12 > 0)
                                    {
                                        <td class="text-center bg-danger text-white" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_12)</td>
                                    }
                                    else
                                    {
                                        <td class="text-center" style="width: 80px;">@Html.DisplayFor(modelItem => item.mes_12)</td>
                                    }
                                </tr>

                            }
                        </tbody>
                    </table>
                </div>
                <!-- END Table -->

            </div>

        }
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->


@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/dataTables")
}

    @section Scripts {
        @Scripts.Render("~/plugins/dataTables")
        @Scripts.Render("~/plugins/validation")
        @Scripts.Render("~/plugins/maskedinput")
        @Scripts.Render("~/plugins/maxlenght")
        @Scripts.Render("~/plugins/datepicker")
        @Scripts.Render("~/plugins/chart")

        <script>

    $(document).ready(function () { $("#data").mask("99/99/9999"); });

    var FormValidation = function () {
        // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
        var initValidationBootstrap = function () {
            jQuery('.js-validation-bootstrap').validate({
                ignore: [],
                errorClass: 'invalid-feedback animated fadeInDown',
                errorElement: 'div',
                errorPlacement: function (error, e) {
                    jQuery(e).parents('.list-group-item > div > div').append(error);
                },
                highlight: function (e) {
                    jQuery(e).closest('.div').removeClass('is-invalid').addClass('is-invalid');
                },
                success: function (e) {
                    jQuery(e).closest('.div').removeClass('is-invalid');
                    jQuery(e).remove();
                },
                rules: {
                    'unidade': {
                        required: true
                    },
                    'tipo': {
                        required: true
                    },
                    'data': {
                        required: true
                    }
                },
                messages: {
                    'unidade': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'tipo': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    },
                    'data': {
                        required: '@PCM.WEB.Properties.Resources.campo_requerido'
                    }
                }
            });
        };

        return {
            init: function () {
                // Init Bootstrap Forms Validation
                initValidationBootstrap();
            }
        };
    }();


    var BeTableDatatables = function () {
        // Override a few DataTable defaults, for more examples you can check out https://www.datatables.net/
        var exDataTable = function () {
            jQuery.extend(jQuery.fn.dataTable.ext.classes, {
                sWrapper: "dataTables_wrapper dt-bootstrap4"
            });
        };

        // Init simple DataTable, for more examples you can check out https://www.datatables.net/
        var initDataTableSimple = function () {
            jQuery('.js-dataTable-list').dataTable({
                fixedHeader: true,
                searching: true,
                lengthChange: false,
                paging: false,
                pageLength: 15,
                autoWidth: false,
                scrollX: false,
                scrollColapse: true,
                dom: 'Bfrtip',
                buttons: [
                    { extend: 'copy', text: 'Copiar' },
                    {
                        extend: 'print',
                        text: 'Imprimir'
                    },
                    { extend: 'excel' },
                    { extend: 'pdf', orientation: 'portrait' },
                ],
                language: {
                    "search": "Procurar:",
                    "lengthMenu": "Exibir _MENU_ ",
                    "zeroRecords": "Nenhum Registro Encontrado",
                    "info": "_MAX_ registro(s)",
                    "infoEmpty": "Nenhum Registro encontrado",
                    "infoFiltered": "(filtrado de _MAX_ registro(s))"
                }
            });
        };

        return {
            init: function () {
                // Override a few DataTable defaults
                exDataTable();

                // Init Datatables
                initDataTableSimple();
            }
        };
    }();


    // Initialize when page loads
    jQuery(function () {
        FormValidation.init();
        BeTableDatatables.init();
        Codebase.helpers(['datepicker', 'maxlength']);
    });

        </script>
    }