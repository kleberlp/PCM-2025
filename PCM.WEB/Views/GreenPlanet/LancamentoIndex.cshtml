@model List<PCM.WEB.MODELS.LancamentoMedicao>

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("LancamentoIndex", "GreenPlanet")">@PCM.WEB.Properties.Resources.green_planet</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.medicao</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        @using (Html.BeginForm("LancamentoIndex", "GreenPlanet", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", @name = "form", @id = "form", role = "form" }))
        {
            @Html.AntiForgeryToken()

            <div class="row">

                <div class="col-md-5 col-xl-3">
                    <!-- Toggle Tasks Navigation on mobile -->
                    <button type="button" class="btn btn-block btn-primary d-md-none mb-10" data-toggle="class-toggle" data-target=".js-tasks-nav" data-class="d-none d-md-block">@PCM.WEB.Properties.Resources.filtros</button>

                    <!-- Collapsible Tasks Navigation -->
                    <div class="js-tasks-nav d-none d-md-block">
                        <!-- Tasks Info -->
                        <div class="block border">
                            <div class="block-header block-header-default bg-gd-default">
                                <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.filtro</h3>
                            </div>
                            <div class="block-content">
                                <ul class="list-group push">
                                    <li class="list-group-item">
                                        <div>@Html.DropDownList("unidade", null, PCM.WEB.Properties.Resources.unidade, new { @class = "form-control" })</div>
                                    </li>
                                    <li class="list-group-item">
                                        <div><input type="text" class="js-datepicker form-control" id="data" name="data" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value="@ViewBag.data"></div>
                                    </li>
                                    <li class="list-group-item text-right">
                                        <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75" name="filtrar" id="filtrar" onclick="Load();"><i class="si si-magnifier mr-5"></i>@PCM.WEB.Properties.Resources.filtrar</button>
                                    </li>
                                </ul>
                            </div>
                        </div>
                        <!-- END Tasks Info -->

                    </div>
                    <!-- END Collapsible Tasks Navigation -->
                </div>

                <div class="col-md-7 col-xl-9">

                    <div class="js-tasks">

                        <div class="block">
                            <div class="block-header block-header-default bg-gd-default">
                                <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.medicao</h3>
                                @if (ViewBag.inserir)
                                {
                                    <div class="block-options">
                                        <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75" onclick="Insert();"><i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar</button>
                                    </div>
                                }
                            </div>

                            <div class="block-content block-content-full">
                                <div class="form-group row">
                                    <div class="col-6">
                                        @if (ViewBag.quantidade_hospede > 0)
                                        {
                                            <i><label class="font-w600 text-danger">** @PCM.WEB.Properties.Resources.quantidade_hospede</label></i>
                                        }
                                        else
                                        {
                                            <label>@PCM.WEB.Properties.Resources.quantidade_hospede</label>
                                        }
                                        <div><input type="text" class="form-control" id="quantidade_hospede" name="quantidade_hospede" maxlength="5" value="@ViewBag.quantidade_hospede"></div>
                                    </div>
                                    <div class="col-6">
                                        @if (ViewBag.ocupacao_quartos > 0)
                                        {
                                            <i><label class="font-w600 text-danger">** @PCM.WEB.Properties.Resources.ocupacao_quartos</label></i>
                                        }
                                        else
                                        {
                                            <label>@PCM.WEB.Properties.Resources.ocupacao_quartos</label>
                                        }
                                        <div><input type="text" class="form-control" id="ocupacao_quartos" name="ocupacao_quartos" maxlength="5" value="@ViewBag.ocupacao_quartos"></div>
                                    </div>
                                </div>
                            </div>
                            <div class="block-content">

                                <table class="js-table-sections table table-vcenter table-hover">
                                    <thead>
                                        <tr>
                                            <th>@PCM.WEB.Properties.Resources.item_medicao</th>
                                            <th class="text-center" style="width: 150px;">@PCM.WEB.Properties.Resources.medicao</th>
                                        </tr>
                                    </thead>

                                    <tbody>
                                        @for (int i = 0; i < Model.Count; i++)
                                        {
                                            <tr>
                                                @Html.HiddenFor(m => m[i].codigo_item_medicao)
                                                <td>
                                                    @if (Model[i].valor == 0)
                                                    {
                                                        @Html.DisplayFor(m => m[i].item_medicao)
                                                    }
                                                    else
                                                    {
                                                        <i><span class="font-w600 text-danger">** @Html.DisplayFor(m => m[i].item_medicao)</span></i>
                                                    }
                                                </td>
                                                @if (Model[i].numero_digitos == 0)
                                                {
                                                    <td class="text-center" style="width: 150px;">@Html.TextBoxFor(m => m[i].valor, new { @class = "form-control text-center" })</td>

                                                }
                                                else
                                                {
                                                    <td class="text-center" style="width: 150px;">@Html.TextBoxFor(m => m[i].valor, new { @class = "form-control text-center", @maxlength = Model[i].numero_digitos })</td>

                                                }
                                            </tr>
                                        }

                                    </tbody>
                                </table>

                            </div>

                            <div class="block-content border-t">

                                <div class="form-group row">
                                    <div class="col-12"><label>Legenda:</label> <i><span class="font-w600 text-danger"> @PCM.WEB.Properties.Resources.registro_salvo</span></i></div>
                                </div>

                            </div>

                        </div>

                    </div>

                </div>
                
            </div>

            }

    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    
    <script>

        $(function () {

            var unidade = $('#unidade')
            var data = $('#data')

            unidade.change(function () {
                $('#form').attr('action', 'LancamentoIndex');
                $("#form").submit();
            });

            data.change(function () {
                $('#form').attr('action', 'LancamentoIndex');
                $("#form").submit();
            });

        });

        function Load() {
            $('#form').attr('action', 'LancamentoIndex');
        }

        function Insert() {
            $('#form').attr('action', 'LancamentoInsert');
        }

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.list-group-item > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.list-group-item').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.list-group-item').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'data': {
                            required: true
                        },
                        'quantidade_hospede': {
                            required: true,
                            number: true
                        },
                        'ocupacao_quartos': {
                            required: true,
                            number: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'data': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'quantidade_hospede': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            number: '@PCM.WEB.Properties.Resources.campo_numerico'
                        },
                        'ocupacao_quartos': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            number: '@PCM.WEB.Properties.Resources.campo_numerico'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            //FormValidation.init();
            Codebase.helpers(['datepicker', 'maxlength']);
        });

    </script>
}
