@model PCM.WEB.MODELS.Usuario

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-md-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action("UsuarioIndex", "Administracao")">@PCM.WEB.Properties.Resources.usuario</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.excluir</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">                
                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.codigo)

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.deseja_excluir</h3>
                            <div class="block-options"> 
                                @if(ViewBag.erro == "")
                                {
                                    <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                        <i class="si si-trash mr-5"></i>@PCM.WEB.Properties.Resources.excluir
                                    </button>
                                }
                                <a href="@Url.Action("UsuarioIndex", "Administracao")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">  
                            @if(ViewBag.erro != "")
                            {
                                <div class="form-group row">
                                    <i><label class="col-12 font-w600 text-danger">** @ViewBag.erro</label></i>
                                </div>
                            }   
                            @if (Model.unidade != "") {                       
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.unidade: <span class="font-w400">@Html.DisplayFor(model => model.unidade)</span></label> 
                                </div>    
                            }
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.id_usuario: <span class="font-w400">@Html.DisplayFor(model => model.email)</span></label> 
                            </div>         
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.nome: <span class="font-w400">@Html.DisplayFor(model => model.nome)</span></label> 
                            </div>                      
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.apelido: <span class="font-w400">@Html.DisplayFor(model => model.apelido)</span></label> 
                            </div>             
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.perfil: <span class="font-w400">@Html.DisplayFor(model => model.perfil)</span></label> 
                            </div>     
                            @if (Model.departamento != "") {                       
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.departamento: <span class="font-w400">@Html.DisplayFor(model => model.departamento)</span></label> 
                                </div>    
                            } 
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.telefone: <span class="font-w400">@Html.DisplayFor(model => model.telefone)</span></label> 
                            </div>
                        </div>                        
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->
