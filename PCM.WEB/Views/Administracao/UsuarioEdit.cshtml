@model PCM.WEB.MODELS.Usuario

<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-md-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item">@PCM.WEB.Properties.Resources.administracao</a>
                <a class="breadcrumb-item" href="@Url.Action("UsuarioIndex", "Administracao")">@PCM.WEB.Properties.Resources.usuario</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.editar</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->
    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">
                @using (Html.BeginForm("UsuarioEdit", "Administracao", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.codigo)

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.editar</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                                <a href="@Url.Action("UsuarioIndex", "Administracao")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">
                            <div class="form-group row">
				<div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.unidade</label>
                                    <div>@Html.DropDownList("unidade", null, "", new { @class = "form-control" })</div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.modulo</label>
                                    <div>@Html.DropDownList("modulo", null, "", new { @class = "form-control js-select2", @multiple = "multiple" })</div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.modulo_default</label>
                                    <div>@Html.DropDownList("modulo_default", null, "", new { @class = "form-control js-select2" })</div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.id_usuario</label>
                                    <div><input type="text" class="form-control" id="email" name="email" value="@Model.email" maxlength="150" autocomplete="off"></div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.email_senha</label>
                                    <div><input type="text" class="form-control" id="email_senha" name="email_senha" value="@Model.emailSenha" maxlength="150" autocomplete="off"></div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.nome</label>
                                    <div><input type="text" class="form-control" id="nome" name="nome" value="@Model.nome" maxlength="50"></div>
                                </div>
                            </div>

                            <div class="form-group row">
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.apelido</label>
                                    <div><input type="text" class="form-control" id="apelido" name="apelido" value="@Model.apelido" maxlength="50"></div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.perfil</label>
                                    <div>@Html.DropDownList("perfil", null, "", new { @class = "form-control js-select2" })</div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.departamento</label>
                                    <div>@Html.DropDownList("departamento", null, "", new { @class = "form-control js-select2" })</div>
                                </div>

                            </div>
                            <div class="form-group row">
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.celular</label>
                                    <div><input type="text" class="form-control" id="telefone" name="telefone" value="@Model.telefone"></div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.aplicativo</label>
                                    <div>
                                        <label class="css-control css-control-success css-switch">
                                            @Html.CheckBoxFor(model => model.aplicativo, new { @class = "css-control-input" })
                                            <span class="css-control-indicator"></span>
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.website</label>
                                    <div>
                                        <label class="css-control css-control-success css-switch">
                                            @Html.CheckBoxFor(model => model.website, new { @class = "css-control-input" })
                                            <span class="css-control-indicator"></span>
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.ativo</label>
                                    <div>
                                        <label class="css-control css-control-success css-switch">
                                            @Html.CheckBoxFor(model => model.ativo, new { @class = "css-control-input" })
                                            <span class="css-control-indicator"></span>
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label>@PCM.WEB.Properties.Resources.funcionario</label>
                                    <div>
                                        <label class="css-control css-control-success css-switch">
                                            @Html.CheckBoxFor(model => model.colaborador, new { @class = "css-control-input" })
                                            <span class="css-control-indicator"></span>
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-2" id="divContabilizaHora">
                                    <label>@PCM.WEB.Properties.Resources.contabiliza_hora</label>
                                    <div>
                                        <label class="css-control css-control-success css-switch">
                                            @Html.CheckBoxFor(model => model.contabilizaHoras, new { @class = "css-control-input" })
                                            <span class="css-control-indicator"></span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group row" id="divFuncionarioInfo">
                                <div class="col-md-2" id="divValorHora">
                                    <label>@PCM.WEB.Properties.Resources.valor_hora</label>
                                    <div><input type="text" class="form-control" id="valor_hora" name="valor_hora" value="@Model.valorHora" maxlength="10"></div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.tipo_funcionario</label>
                                    <div>@Html.DropDownList("tipo_funcionario", null, "", new { @class = "js-select2 form-control" })</div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.funcao</label>
                                    <div>@Html.DropDownList("funcao", null, "", new { @class = "form-control" })</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Dynamic Table Full Pagination -->
                    <div class="block">
                        <div class="block-content block-content-full">
                            <!-- DataTables init on table by adding .js-dataTable-full-pagination class, functionality initialized in js/pages/be_tables_datatables.js -->
                            <table class="table table-sm table-bordered table-striped table-vcenter js-dataTable-full-pagination">
                                <thead>
                                    <tr class="table-secondary">
                                        <th class="text-center" style="width: 20px;"></th>
                                        <th>@PCM.WEB.Properties.Resources.unidade</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @for (int i = 0; i < Model.unidades.Count; i++)
                                    {
                                        @Html.HiddenFor(m => m.unidades[i].codigoUnidade)
                                        <tr>
                                            <td class="d-none d-sm-table-cell text-center" style="width: 20px">
                                                <div class="col-12">
                                                    <label class="css-control css-control-success css-switch">
                                                        @Html.CheckBoxFor(m => m.unidades[i].selecionado, new { @class = "css-control-input" })
                                                        <span class="css-control-indicator"></span>
                                                    </label>
                                                </div>
                                            </td>
                                            <td class="font-w600">@Html.DisplayFor(m => m.unidades[i].unidade)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->


@section Styles {
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/select")

<script>

        $(document).ready(function () {
            $("#telefone").mask("(99) 99999-9999");
            $("#valor_hora").maskMoney({ decimal: ",", thousands: "." });
            $('#modulo').val([@ViewBag.modulo_associado]).trigger("change");
        });

        //VÁRIAVEIS
        var unidade = $("#unidade");
        var perfil = $("#perfil");

    $("#colaborador").change(function () {

        if ($("#colaborador").is(":checked")) {
                $("#divContabilizaHora").show();
                $("#divValorHora").show();
                $("#divFuncionarioInfo").show();
            } else {
                $("#divContabilizaHora").hide();
                $("#divValorHora").hide();
                $("#divFuncionarioInfo").hide();
            }

        });

        //AJAX
        $.ajaxSetup({ async: false });

        jQuery.validator.addMethod("validate_email_bd", function (value, element) {

            var dataString = {
                "email": value,
                "codigo": @Model.codigo
            };

            var result = false;

            jQuery.ajax({
                type: "POST",
                url: "ValidaUsuario",
                async: false,
                data: dataString,
                dataType: "json",
                success: function (return_data) {
                    if (return_data == false) {
                        result = false;
                    } else if (return_data == true) {
                        result = true;
                    }
                }
            });

            return result;

        }, "");

        jQuery.validator.addMethod("validate_departamento", function (value, element) {

            if (unidade.val() != "" && unidade.val() != "-1" && value == "") {
                return false;
            } else {
                return true;
            }

        }, "");

        jQuery.validator.addMethod("validate_funcionario", function (value, element) {

            if ($("#colaborador").is(":checked") && value == "") {
                return false;
            } else {
                return true;
            }

        }, "");

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'modulo': {
                            required: true
                        },
                        'modulo_default': {
                            required: true
                        },
                        'email': {
                            required: true,
                            email: true,
                            validate_email_bd: true
                        },
                        'email_senha': {
                            required: true,
                            email: true
                        },
                        'perfil': {
                            required: true
                        },
                        'departamento': {
                            validate_departamento: true
                        },
                        'nome': {
                            required: true
                        },
                        'apelido': {
                            required: true
                        },
                        'senha': {
                            required: true
                        },
                        'confirmar_senha': {
                            required: true,
                            minlength: 5,
                            equalTo: '#senha'
                        },
                        'contabiliza_hora': {
                            validate_funcionario: true
                        },
                        'valor_hora': {
                            validate_funcionario: true
                        },
                        'tipo_funcionario': {
                            validate_funcionario: true
                        }
                    },
                    messages: {
                        'unidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'modulo': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'modulo_default': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'email': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            email: '@PCM.WEB.Properties.Resources.valida_email_valido',
                            validate_email_bd: '@PCM.WEB.Properties.Resources.valida_email_valido_bd'
                        },
                        'email_senha': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            email: '@PCM.WEB.Properties.Resources.valida_email_valido'
                        },
                        'perfil': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'departamento': {
                            validate_departamento: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'nome': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'apelido': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'senha': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            minlength: '@PCM.WEB.Properties.Resources.valida_senha_minimo_5'
                        },
                        'confirmar_senha': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            minlength: '@PCM.WEB.Properties.Resources.valida_confirmar_senha_minimo_5',
                            equalTo: '@PCM.WEB.Properties.Resources.erro_confirmacao_senha',
                        },
                        'contabiliza_hora': {
                            validate_funcionario: '@PCM.WEB.Properties.Resources.campo_requerido',
                        },
                        'valor_hora': {
                            validate_funcionario: '@PCM.WEB.Properties.Resources.campo_requerido',
                        },
                        'tipo_funcionario': {
                            validate_funcionario: '@PCM.WEB.Properties.Resources.campo_requerido',
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['maxlength', 'select2']);
        });

</script>
}
