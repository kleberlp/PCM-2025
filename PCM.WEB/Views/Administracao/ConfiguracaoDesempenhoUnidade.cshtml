@model PCM.WEB.MODELS.ConfiguracaoDesempenhoUnidades

<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-md-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item">@PCM.WEB.Properties.Resources.administracao</a>
                <a class="breadcrumb-item" href="@Url.Action("UsuarioIndex", "Administracao")">@PCM.WEB.Properties.Resources.desempenho_unidades</a>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">           
                @using (Html.BeginForm("ConfiguracaoDesempenhoUnidade", "Administracao", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.codigo_empresa)
                    
                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.desempenho_unidades</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar
                                </button>
                            </div>
                        </div>
                        <div class="block-content block-content-full">


                            <div class="form-group row">
                                <div class="col-md-6">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <label>@PCM.WEB.Properties.Resources.laudo</label>
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.laudo, new { @class = "form-control", @maxlength = "6" })
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text">
                                                        <i class="fa fa-percent"></i>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <label>@PCM.WEB.Properties.Resources.preventiva</label>
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.preventiva, new { @class = "form-control", @maxlength = "6" })
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text">
                                                        <i class="fa fa-percent"></i>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <label>@PCM.WEB.Properties.Resources.rotina</label>
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.rotina, new { @class = "form-control", @maxlength = "6" })
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text">
                                                        <i class="fa fa-percent"></i>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <label>@PCM.WEB.Properties.Resources.pmoc</label>
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.pmoc, new { @class = "form-control", @maxlength = "6" })
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text">
                                                        <i class="fa fa-percent"></i>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-4">
                                            <label>@PCM.WEB.Properties.Resources.uh_em_dia</label>
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.uh_dia, new { @class = "form-control", @maxlength = "6" })
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text">
                                                        <i class="fa fa-percent"></i>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-4">
                                            <label>@PCM.WEB.Properties.Resources.os_atendimento_dia</label>
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.os_atendimento_dia, new { @class = "form-control", @maxlength = "6" })
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text">
                                                        <i class="fa fa-percent"></i>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    
                                    </div>

                                    <div class="form-group row">

                                        <div class="col-md-4">
                                            <label>@PCM.WEB.Properties.Resources.hh_nao_apontado</label>
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.hh_nao_apontado, new { @class = "form-control", @maxlength = "6" })
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text">
                                                        <i class="fa fa-percent"></i>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-4">
                                            <label>@PCM.WEB.Properties.Resources.os_pendente</label>
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.os_pendente, new { @class = "form-control", @maxlength = "6" })
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text">
                                                        <i class="fa fa-percent"></i>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-4">
                                            <label>@PCM.WEB.Properties.Resources.hh_extra</label>
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.hh_extra, new { @class = "form-control", @maxlength = "6" })
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text">
                                                        <i class="fa fa-percent"></i>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                    </div>

                                    <div class="form-group row">

                                        <div class="col-md-4">
                                            <label>@PCM.WEB.Properties.Resources.preventiva_corretiva</label>
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.preventiva_corretiva, new { @class = "form-control", @maxlength = "6" })
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text">
                                                        <i class="fa fa-percent"></i>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-md-4">
                                            <label>@PCM.WEB.Properties.Resources.green_planet</label>
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.green_planet, new { @class = "form-control", @maxlength = "6" })
                                                <div class="input-group-prepend">
                                                    <span class="input-group-text">
                                                        <i class="fa fa-percent"></i>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>

                                <div class="col-md-6">
                                    <div class="form-group row">
                                        <div class="col-12 text-center"><label class="text-center h1 font-w600">Soma do percentual das Notas.</label></div>
                                    </div>

                                    <div class="form-group row">
                                        <div class="col-12 text-center">
                                            <label id="soma_percentual" class="display-1 font-w600"></label>
                                            <input type="hidden" id="total" name="total" value="0" />
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->


@section Styles {
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/select")
    
<script>


    $("#laudo").change(function () { calculaSomaPercentual(); });
    $("#preventia").change(function () { calculaSomaPercentual(); });
    $("#rotina").change(function () { calculaSomaPercentual(); });
    $("#pmoc").change(function () { calculaSomaPercentual(); });
    $("#uh_dia").change(function () { calculaSomaPercentual(); });
    $("#os_atendimento_dia").change(function () { calculaSomaPercentual(); });
    $("#hh_nao_apontado").change(function () { calculaSomaPercentual(); });
    $("#os_pendente").change(function () { calculaSomaPercentual(); });
    $("#hh_extra").change(function () { calculaSomaPercentual(); });
    $("#preventiva_corretiva").change(function () { calculaSomaPercentual(); });
    $("#green_planet").change(function () { calculaSomaPercentual(); });

    function calculaSomaPercentual() {

        var percentual = 0.0;

        percentual += parseFloat($("#laudo").val());
        percentual += parseFloat($("#preventiva").val());
        percentual += parseFloat($("#rotina").val());
        percentual += parseFloat($("#pmoc").val());
        percentual += parseFloat($("#uh_dia").val());
        percentual += parseFloat($("#os_atendimento_dia").val());
        percentual += parseFloat($("#hh_nao_apontado").val());
        percentual += parseFloat($("#os_pendente").val());
        percentual += parseFloat($("#hh_extra").val());
        percentual += parseFloat($("#preventiva_corretiva").val());
        percentual += parseFloat($("#green_planet").val());

        $("#total").val(percentual);

        $("#soma_percentual").html(percentual.toString() + '%');

    };

    jQuery.validator.addMethod("valida_total", function (total, element) {

        if (parseFloat($("#total").val()) != parseFloat(100))
            return false;
        else
            return true;
    }, "");


        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'laudo': {
                            required: true
                        },
                        'preventiva': {
                            required: true
                        },
                        'rotina': {
                            required: true
                        },
                        'pmoc': {
                            required: true
                        },
                        'uh_dia': {
                            required: true
                        },
                        'os_atendimento_dia': {
                            required: true
                        },
                        'hh_nao_apontado': {
                            required: true
                        },
                        'os_pendente': {
                            required: true
                        },
                        'hh_extra': {
                            required: true
                        },
                        'preventiva_corretiva': {
                            required: true
                        },
                        'green_planet': {
                            required: true
                        },
                        'total': {
                            valida_total: true
                        }
                    },
                    messages: {
                        'laudo': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'preventiva': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'rotina': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'pmoc': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'uh_dia': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'os_atendimento_dia': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'hh_nao_apontado': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'os_pendente': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'hh_extra': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'preventiva_corretiva': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'green_planet': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'total': {
                            valida_total: '@PCM.WEB.Properties.Resources.total_invalido'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['maxlength', 'select2']);

            $("#laudo").maskMoney({ prefix: '', thousands: '', precision: 2, allowNegative: false, 'placeholder': '' });
            $("#preventiva").maskMoney({ prefix: '', thousands: '', precision: 2, allowNegative: false, 'placeholder': '' });
            $("#rotina").maskMoney({ prefix: '', thousands: '', precision: 2, allowNegative: false, 'placeholder': '' });
            $("#pmoc").maskMoney({ prefix: '', thousands: '', precision: 2, allowNegative: false, 'placeholder': '' });
            $("#uh_dia").maskMoney({ prefix: '', thousands: '', precision: 2, allowNegative: false, 'placeholder': '' });
            $("#os_atendimento_dia").maskMoney({ prefix: '', thousands: '', precision: 2, allowNegative: false, 'placeholder': '' });
            $("#hh_nao_apontado").maskMoney({ prefix: '', thousands: '', precision: 2, allowNegative: false, 'placeholder': '' });
            $("#os_pendente").maskMoney({ prefix: '', thousands: '', precision: 2, allowNegative: false, 'placeholder': '' });
            $("#hh_extra").maskMoney({ prefix: '', thousands: '', precision: 2, allowNegative: false, 'placeholder': '' });
            $("#preventiva_corretiva").maskMoney({ prefix: '', thousands: '', precision: 2, allowNegative: false, 'placeholder': '' });
            $("#green_planet").maskMoney({ prefix: '', thousands: '', precision: 2, allowNegative: false, 'placeholder': '' });

            calculaSomaPercentual();

        });

</script>
}
