@model PCM.WEB.MODELS.login

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0">

        <title>@PCM.WEB.Properties.Resources.title</title>

        <meta name="description" content="Sistema de Planejamento e Controle de Manutenção">
        <meta name="author" content="SIM">
        <meta name="robots" content="noindex, nofollow">

        <!-- Open Graph Meta -->
        <meta property="og:title" content="PCM by SIM">
        <meta property="og:site_name" content="PCM by SIM">
        <meta property="og:description" content="PCM - Planejamento e Controle de Manutenção by SIM">
        <meta property="og:type" content="website">
        <meta property="og:url" content="">
        <meta property="og:image" content="">

        <!-- Icons -->
        <link rel="shortcut icon" href="~/Content/img/favicons/favicon.png">
        <link rel="icon" type="image/png" sizes="192x192" href="~/Content/img/favicons/favicon192x192.png">
        <link rel="apple-touch-icon" sizes="180x180" href="~/Content/img/favicons/favicon180x180.png">
        <!-- END Icons -->

        @Styles.Render("~/Content/codebase")

    </head>

    <body>
        <div id="page-container" class="main-content-boxed align-middle">
            <!-- Main Container -->
            <main id="main-container">
                <!-- Page Content -->

                <div class="bg-image" style="background-image: url('../Content/img/photos/photo1.jpg');">
                    
                    <div class="row mx-0 img justify-content-center animated fadeInDown align-middle">
                        <div class="hero-static col-lg-6 col-xl-4 align-items-center ">
                            <div class="content content-full overflow-hidden">

                                @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-signin", role = "form" }))
                                {                                
                                
                                    <div class="block block-themed block-rounded block-shadow">

                                        <div class="block-content">

                                            <div class="js-tasks-nav d-none d-md-block">
                                                <div class="col-md-12">
                                                    <div class="block-content block-content-full clearfix">
                                                        <div class="text-right float-right mt-10 col-9">
                                                            <div class="font-w600 mb-5 h6">Sistema de Planejamento e Controle de Manutenção</div>
                                                        </div>
                                                        <div class="float-left col-3">
                                                            <img class="img-fluid" src="~/Content/img/photos/logo.png" alt="">
                                                        </div>
                                                    </div>
                                                </div>

                                                <hr />

                                                <div class="row items-push">
                                                    <div class="col-md-12"></div>
                                                </div>

                                                <div class="row items-push">
                                                    <div class="col-md-4"></div>
                                                    <div class="col-md-4">
                                                        <div class="options-container">
                                                            <img class="img-fluid" src="~/Content/img/photos/gjp.png" alt="">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-4"></div>
                                                </div>

                                                <div class="row items-push">
                                                    <div class="col-md-12"></div>
                                                </div>

                                                <div class="row items-push">
                                                    <div class="col-sm-4 align-center">
                                                        <div class="options-container">
                                                            <img class="img-fluid" src="~/Content/img/photos/wish.png" alt="">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4 align-center">
                                                        <div class="options-container">
                                                            <img class="img-fluid" src="~/Content/img/photos/prodigy.png" alt="">
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-4 align-center">
                                                        <div class="options-container">
                                                            <img class="img-fluid" src="~/Content/img/photos/linx.png" alt="">
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="row items-push">
                                                    <div class="col-md-12"></div>
                                                </div>

                                                <hr />

                                            </div>

                                            <div class="form-group row">
                                                <div class="col-12">
                                                    <div class="form-material floating">
                                                        <input type="text" class="form-control" id="email" name="email" autocomplete="off" readonly onfocus="this.removeAttribute('readonly');">
                                                        <label for="email">@PCM.WEB.Properties.Resources.email</label>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="form-group row">
                                                <div class="col-12">
                                                    <div class="form-material floating">
                                                        <input type="password" class="form-control" id="senha" name="senha" autocomplete="off" readonly onfocus="this.removeAttribute('readonly');" onBlur="this.setAttribute('readonly', true);">
                                                        <label for="password">@PCM.WEB.Properties.Resources.senha</label>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="row items-push">
                                                <div class="col-md-12"></div>
                                            </div>

                                            <div class="form-group">
                                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                                    <i class="si si-login mr-5"></i> @PCM.WEB.Properties.Resources.login
                                                </button>
                                                <a class="btn btn-square btn-secondary min-width-100 h-75" href="">
                                                    <i class="fa fa-warning mr-5"></i> @PCM.WEB.Properties.Resources.esqueci_senha
                                                </a>
                                            </div>

                                        </div>

                                    </div>
                                }

                        </div>
                    </div>
                </div>
                <!-- END Page Content -->
            </main>
            <!-- END Main Container -->
        </div>
        <!-- END Page Container -->

    @Scripts.Render("~/plugins/codebase")  
    @Scripts.Render("~/plugins/validation")   

    <!-- Page JS Code -->
    <script>

        document.getElementById("email").value = "";
        document.getElementById("senha").value = "";
        
        var login = function () {

            // Init Sign In Form Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationSignIn = function () {
                jQuery('.js-validation-signin').validate({
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'email': {
                            required: true,
                            email: true
                        },
                        'senha': {
                            required: true
                        }
                    },
                    messages: {
                        'email': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            email: '@PCM.WEB.Properties.Resources.valida_email_valido'
                        },
                        'senha': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Sign In Form Validation
                    initValidationSignIn();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () { login.init(); });

    </script>


    </body>
</html>
