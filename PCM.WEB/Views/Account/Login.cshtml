@model PCM.WEB.MODELS.login

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0">

        <title>@PCM.WEB.Properties.Resources.title</title>

        <meta name="description" content="Sistema de Planejamento e Controle de Manutenção">
        <meta name="author" content="SIM">
        <meta name="robots" content="noindex, nofollow">

        <!-- Open Graph Meta -->
        <meta property="og:title" content="PCM by SIM">
        <meta property="og:site_name" content="PCM by SIM">
        <meta property="og:description" content="PCM - Planejamento e Controle de Manutenção by SIM">
        <meta property="og:type" content="website">
        <meta property="og:url" content="">
        <meta property="og:image" content="">

        <!-- Icons -->
        <link rel="shortcut icon" href="~/Content/img/favicons/favicon.png">
        <link rel="icon" type="image/png" sizes="192x192" href="~/Content/img/favicons/favicon192x192.png">
        <link rel="apple-touch-icon" sizes="180x180" href="~/Content/img/favicons/favicon180x180.png">
        <!-- END Icons -->

        @Styles.Render("~/Content/codebase")

    </head>

    <body>

        <div id="page-container" class="main-content-boxed">
            <!-- Main Container -->
            <main id="main-container">
                <!-- Page Content -->
                <div class="bg-image" style="background-image: url('@Url.Content(ViewBag.imagem.imagem_background)');">
                    <div class="row mx-0 bg-black-op">

                        <div class="hero-static col-md-7 col-xl-7 d-none d-md-flex align-items-md-end">
                            <div class="p-30 invisible" data-toggle="appear">

                                <p class="font-size-h1 font-w600 text-white">
                                    @PCM.WEB.Properties.Resources.nome_sistema
                                </p>
                                <p class="font-italic text-white">@PCM.WEB.Properties.Resources.sim_end</p>
                                <p class="font-italic text-white-op">Copyright &copy; <span class="js-year-copy">2018</span></p>
                            </div>
                        </div>

                        <div class="hero-static col-md-5 col-xl-5 d-flex align-items-center bg-white invisible" data-toggle="appear" data-class="animated fadeInRight">

                            <div class="content content-full">

                                <div class="js-tasks-nav d-none d-md-block">

                                    <div class="row items-push">
                                        <div class="col-md-12">
                                            <div class="options-container text-md-center">
                                                <img class="img-fluid" src="@Url.Content(ViewBag.imagem.imagem_login)" alt="">
                                            </div>
                                        </div>
                                        <div class="col-md-4"></div>
                                    </div>

                                    <div class="row items-push">
                                        <div class="col-md-12"></div>
                                    </div>

                                </div>

                                @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-signin", role = "form" }))
                                {

                                    <div class="form-group row">
                                        <div class="col-12">
                                            <div class="form-material floating">
                                                <input type="text" class="form-control" style="text-transform: lowercase" id="email" name="email">
                                                <label for="email">@PCM.WEB.Properties.Resources.id_usuario</label>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-group row">
                                        <div class="col-12">
                                            <div class="form-material floating">
                                                <input type="password" class="form-control" id="senha" name="senha">
                                                <label for="password">@PCM.WEB.Properties.Resources.senha</label>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-group row">
                                        <div class="col-12"><span class="text-danger font-italic">@ViewBag.errorLogin</span></div>
                                    </div>

                                    <div class="form-group float-right">
                                        <div class="form-group text-right">
                                            <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                                <i class="si si-login mr-5"></i> @PCM.WEB.Properties.Resources.login
                                            </button>
                                        </div>
                                        <div class="form-group">
                                            <a class="btn btn-square btn-secondary min-width-100 h-75" href="mailto:suporte@simservices.com.br">
                                                <i class="si si-envelope mr-5"></i> @PCM.WEB.Properties.Resources.contato
                                            </a>
                                        </div>
                                    </div>

                                        }

                                    </div>
                                </div>
                    </div>
                </div>
                <!-- END Page Content -->
            </main>

            <!-- END Main Container -->
        </div>
          
    @Scripts.Render("~/plugins/codebase")  
    @Scripts.Render("~/plugins/validation")   

    <!-- Page JS Code -->
    <script>

        var login = function () {

            // Init Sign In Form Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationSignIn = function () {
                jQuery('.js-validation-signin').validate({
                    onkeyup: false,
                    onclick: true,
                    onfocusout: false,
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.form-group > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.form-group > div').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'email': {
                            required: true,
                            email: true
                        },
                        'senha': {
                            required: true
                        }
                    },
                    messages: {
                        'email': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido',
                            email: '@PCM.WEB.Properties.Resources.valida_email_valido'
                        },
                        'senha': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        }
                    }
                });
            };

            return {
                init: function () {
                    // Init Sign In Form Validation
                    initValidationSignIn();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () { login.init(); });

        var urlSenha = "@Url.Action("UsuarioUpdate", "Administracao")";
        var urlNotificacao = "@Url.Action("Notificacao", "Home")";
        var urlNotificacaoOSHospede = "@Url.Action("NotificacaoOSHospede", "Home")";

    </script>


    </body>
</html>
