@model IEnumerable<PCM.WEB.MODELS.AgendaOS>


<!-- Main Container -->
<main id="main-container">

    <!-- Page Content -->
    <div class="content">
               
        @using (Html.BeginForm("AgendaOS", "PCM", new {ReturnUrl = ViewBag.ReturnUrl}, FormMethod.Post, new { @class = "js-validation-bootstrap", @name="form", @id="form", role = "form" }))
        {
            @Html.AntiForgeryToken()
                                     
        <!-- Tasks Content -->
        <div class="row">
    
            <div class="col-md-5 col-xl-3">
                <!-- Toggle Tasks Navigation on mobile -->
                <button type="button" class="btn btn-block btn-primary d-md-none mb-10" data-toggle="class-toggle" data-target=".js-tasks-nav" data-class="d-none d-md-block">@PCM.WEB.Properties.Resources.filtros</button>

                <!-- Collapsible Tasks Navigation -->
                <div class="js-tasks-nav d-lg-block">
                    <!-- Tasks Info -->
                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.filtro</h3>
                        </div>
                        <div class="block-content">
                            <ul class="list-group push">
                                <li class="list-group-item">
                                    <div class="input-daterange input-group" data-date-format="dd/mm/yyyy" data-week-start="1" data-autoclose="true" data-today-highlight="true">
                                        <input type="text" class="form-control" id="data_inicio" name="data_inicio" placeholder="De" data-week-start="1" data-autoclose="true" data-today-highlight="true" value="@ViewBag.data_inicio">
                                        <div class="input-group-prepend input-group-append">
                                            <span class="input-group-text font-w600">-</span>
                                        </div>
                                        <input type="text" class="form-control" id="data_termino" name="data_termino" placeholder="Até" data-week-start="1" data-autoclose="true" data-today-highlight="true" value="@ViewBag.data_termino">
                                    </div>
                                </li>    
                                <li class="list-group-item">
                                    <div>@Html.DropDownList("unidade", null, PCM.WEB.Properties.Resources.unidade, new { @class = "form-control" })</div>                                    
                                </li>
                                <li class="list-group-item">
                                    <div><input type="text" class="form-control" id="ordem_servico" name="ordem_servico" placeholder="@PCM.WEB.Properties.Resources.ordem_servico" value=""></div>                                    
                                </li> 
                                <li class="list-group-item">
                                    <div>@Html.DropDownList("setor", null, PCM.WEB.Properties.Resources.setor, new { @class = "form-control" })</div>                                    
                                </li>                                
                                <li class="list-group-item">                                                    
                                    <div>@Html.DropDownList("equipamento", null, PCM.WEB.Properties.Resources.equipamento, new { @class = "form-control" })</div>                                    
                                </li>                             
                                <li class="list-group-item">                                                    
                                    <div>@Html.DropDownList("prioridade", null, PCM.WEB.Properties.Resources.prioridade, new { @class = "form-control" })</div>                                    
                                </li>                             
                                <li class="list-group-item">                                                    
                                    <div>@Html.DropDownList("status", null, PCM.WEB.Properties.Resources.status, new { @class = "form-control js-select2", @multiple="multiple" })</div>
                                </li>                          
                                <li class="list-group-item text-right">                                                    
                                    <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75" name="filtrar" id="filtrar"><i class="si si-magnifier mr-5"></i>@PCM.WEB.Properties.Resources.filtrar</button>
                                </li>
                            </ul>
                        </div>
                    </div>
                    <!-- END Tasks Info -->

                </div>
                <!-- END Collapsible Tasks Navigation -->
            </div>

            <div class="col-md-12 col-xl-9">
                <!-- Tasks -->
                <!-- Tasks functionality (initialized in js/pages/be_pages_generic_todo.js) -->
                <div class="js-tasks">
                    
                    <div class="block">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.servicos - @ViewBag.total registro(s)</h3>
                        </div>
                        <div class="block-content">
                          
                            <table class="js-table-sections table table-sm">
                                <thead>
                                    <tr>
                                        <th style="width: 20px;"></th>
                                        <th></th>                                                                                       
                                        <th class="text-center" style="width: 100px;">@PCM.WEB.Properties.Resources.ordem_servico</th>    
                                        <th class="d-sm-table-cell text-center" style="width: 120px;">@PCM.WEB.Properties.Resources.data</th>
                                        <th class="d-sm-table-cell">@PCM.WEB.Properties.Resources.local</th>                                        
                                        <th class="d-sm-table-cell text-center" style="width: 120px;">@PCM.WEB.Properties.Resources.prioridade</th>
                                        <th class="d-sm-table-cell text-center">@PCM.WEB.Properties.Resources.status</th>                                        
                                    </tr>
                                </thead>                      
                                @foreach (var item in Model)
                                {
                                    <tbody class="js-table-sections-header">
                                        <tr>
                                            <td class="text-center" style="width: 30px;"><i class="fa fa-angle-right"></i></td>
                                            @if(item.ordem_servico.codigo_status == 1)
                                            {                                                                                                    
                                                <td class="text-center">
                                                    <div class="btn-group">
                                                        @if(ViewBag.inserir) { @Html.ActionLink(" ", "ApontamentoOS", new { codigo_pcm_ordem_servico = item.ordem_servico.codigo_pcm_ordem_servico, codigo_unidade = item.ordem_servico.codigo_unidade}, new { @class = "fa fa-crosshairs btn btn-sm btn-secondary", @title= @PCM.WEB.Properties.Resources.apontamento_os, data_toggle="tooltip"})}                            
                                                        @if(ViewBag.inserir && item.apontamento.Count > 0) { @Html.ActionLink(" ", "ConcluirOS", new { codigo_pcm_ordem_servico = item.ordem_servico.codigo_pcm_ordem_servico, unidade = item.ordem_servico.codigo_unidade}, new { @class = "fa fa-lock btn btn-sm btn-secondary", @title= @PCM.WEB.Properties.Resources.concluir_ordem_servico, data_toggle="tooltip"})}
                                                    </div>
                                                </td>
                                                <td class="text-center">@Html.DisplayFor(modelItem => item.ordem_servico.ordem_servico)</td>    
                                                <td class="d-sm-table-cell text-center " style="width: 120px;">@Html.DisplayFor(modelItem => item.ordem_servico.data)</td>
                                                <td class="d-sm-table-cell">@Html.DisplayFor(modelItem => item.ordem_servico.local)</td>  
                                                <td class="d-sm-table-cell text-center" style="width: 120px;">@Html.DisplayFor(modelItem => item.ordem_servico.prioridade)</td>                                                          
                                                <td class="d-sm-table-cell text-center"><button type="button" class="btn btn-sm btn-circle btn-alt-warning mr-5 mb-5"></button></td>
                                            }   
                                            @if(item.ordem_servico.codigo_status == 2)
                                            {       
                                                <td class="text-center">
                                                    <div class="btn-group">
                                                        @if(ViewBag.administrador) { @Html.ActionLink(" ", "ReabrirOS", new { codigo_pcm_ordem_servico = item.ordem_servico.codigo_pcm_ordem_servico, unidade = item.ordem_servico.codigo_unidade}, new { @class = "fa fa-unlock btn btn-sm btn-secondary", @title= @PCM.WEB.Properties.Resources.reabrir_ordem_servico, data_toggle="tooltip"})}
                                                    </div>
                                                </td>                  
                                                <td class="text-center" >@Html.DisplayFor(modelItem => item.ordem_servico.ordem_servico)</td>    
                                                <td class="d-sm-table-cell text-center" style="width: 120px;">@Html.DisplayFor(modelItem => item.ordem_servico.data)</td>
                                                <td class="d-sm-table-cell">@Html.DisplayFor(modelItem => item.ordem_servico.local)</td>   
                                                <td class="d-sm-table-cell text-center" style="width: 120px;">@Html.DisplayFor(modelItem => item.ordem_servico.prioridade)</td>    
                                                <td class="d-sm-table-cell text-center"><button type="button" class="btn btn-sm btn-circle btn-alt-success mr-5 mb-5"></button></td>
                                            }  
                                            @if(item.ordem_servico.codigo_status == 3)
                                            {       
                                                <td class="text-center">
                                                    <div class="btn-group">
                                                        @if(ViewBag.inserir) { @Html.ActionLink(" ", "ApontamentoOS", new { codigo_pcm_ordem_servico = item.ordem_servico.codigo_pcm_ordem_servico, codigo_unidade = item.ordem_servico.codigo_unidade}, new { @class = "fa fa-crosshairs btn btn-sm btn-secondary", @title= @PCM.WEB.Properties.Resources.apontamento_os, data_toggle="tooltip"})}
                                                        @if(ViewBag.inserir && item.apontamento.Count > 0) { @Html.ActionLink(" ", "ConcluirOS", new { codigo_pcm_ordem_servico = item.ordem_servico.codigo_pcm_ordem_servico, unidade = item.ordem_servico.codigo_unidade}, new { @class = "fa fa-lock btn btn-sm btn-secondary", @title= @PCM.WEB.Properties.Resources.concluir_ordem_servico, data_toggle="tooltip"})}
                                                    </div>
                                                </td>
                                                <td class="text-center">@Html.DisplayFor(modelItem => item.ordem_servico.ordem_servico)</td>    
                                                <td class="d-sm-table-cell text-center text-danger font-w600" style="width: 120px;">@Html.DisplayFor(modelItem => item.ordem_servico.data)</td>
                                                <td class="d-sm-table-cell">@Html.DisplayFor(modelItem => item.ordem_servico.local)</td>        
                                                <td class="d-sm-table-cell text-center" style="width: 120px;">@Html.DisplayFor(modelItem => item.ordem_servico.prioridade)</td>  
                                                <td class="d-sm-table-cell text-center"><button type="button" class="btn btn-sm btn-circle btn-alt-danger mr-5 mb-5"></button></td> 
                                            }   
                                            @if(item.ordem_servico.codigo_status ==4)
                                            {       
                                                <td class="text-center">
                                                    <div class="btn-group">
                                                        @if(ViewBag.inserir) { @Html.ActionLink(" ", "ApontamentoOS", new { codigo_pcm_ordem_servico = item.ordem_servico.codigo_pcm_ordem_servico, codigo_unidade = item.ordem_servico.codigo_unidade}, new { @class = "fa fa-crosshairs btn btn-sm btn-secondary", @title= @PCM.WEB.Properties.Resources.apontamento_os, data_toggle="tooltip"})}                            
                                                        @if(ViewBag.inserir && item.apontamento.Count > 0) { @Html.ActionLink(" ", "ConcluirOS", new { codigo_pcm_ordem_servico = item.ordem_servico.codigo_pcm_ordem_servico, unidade = item.ordem_servico.codigo_unidade}, new { @class = "fa fa-lock btn btn-sm btn-secondary", @title= @PCM.WEB.Properties.Resources.concluir_ordem_servico, data_toggle="tooltip"})}
                                                    </div>
                                                </td>
                                                <td class="text-center">@Html.DisplayFor(modelItem => item.ordem_servico.ordem_servico)</td>    
                                                <td class="d-sm-table-cell text-center " style="width: 120px;">@Html.DisplayFor(modelItem => item.ordem_servico.data)</td>
                                                <td class="d-sm-table-cell">@Html.DisplayFor(modelItem => item.ordem_servico.local)</td>  
                                                <td class="d-sm-table-cell text-center" style="width: 120px;">@Html.DisplayFor(modelItem => item.ordem_servico.prioridade)</td>          
                                                <td class="d-sm-table-cell text-center"><button type="button" class="btn btn-sm btn-circle btn-alt-primary mr-5 mb-5"></button></td> 
                                            }   
                                        </tr>
                                    </tbody>
                                    <tbody>
                                        @if(Session["unidade"] == "")
                                        {
                                            <tr class="table-info">
                                                <td colspan="3"><strong>@PCM.WEB.Properties.Resources.unidade:</strong></td>                       
                                                <td colspan="4">@Html.DisplayFor(modelItem => item.ordem_servico.unidade)</td>
                                            </tr>
                                        }
                                        <tr class="table-info">
                                            <td colspan="3"><strong>@PCM.WEB.Properties.Resources.servico:</strong></td>                       
                                            <td colspan="4">@Html.DisplayFor(modelItem => item.ordem_servico.servico)</td>
                                        </tr>
                                        @if (item.ordem_servico.setor != "")
                                        {
                                            <tr class="table-info">
                                                <td colspan="3"><strong>@PCM.WEB.Properties.Resources.setor:</strong></td>     
                                                <td colspan="4">@Html.DisplayFor(modelItem => item.ordem_servico.setor)</td>
                                            </tr>
                                        }
                                        @if (item.ordem_servico.apartamento != "")
                                        {
                                            <tr class="table-info">
                                                <td colspan="3"><strong>@PCM.WEB.Properties.Resources.apartamento:</strong></td>                        
                                                <td colspan="4">@Html.DisplayFor(modelItem => item.ordem_servico.apartamento)</td>
                                            </tr>
                                        }
                                        @if (item.ordem_servico.equipamento != "")
                                        {
                                            <tr class="table-info">
                                                <td colspan="3"><strong>@PCM.WEB.Properties.Resources.equipamento:</strong></td>                        
                                                <td colspan="4">@Html.DisplayFor(modelItem => item.ordem_servico.equipamento)</td>
                                            </tr>
                                        }
                                        @if (item.ordem_servico.solicitante != "")
                                        {
                                            <tr class="table-info">
                                                <td colspan="3"><strong>@PCM.WEB.Properties.Resources.solicitante:</strong></td>                        
                                                <td colspan="4">@Html.DisplayFor(modelItem => item.ordem_servico.solicitante)</td>
                                            </tr>
                                        }
                                        @if (item.apontamento.Count > 0)
                                        {
                                            <tr class="col-12 table-light">
                                                <td colspan="7">        
                                                    <table class="table-sm table-bordered col-12">
                                                        <thead class="thead-light">
                                                            <tr>
                                                                @if((ViewBag.editar || ViewBag.excluir) && item.ordem_servico.codigo_status != 2)
                                                                {    
                                                                    <th style="width: 75px;"></th>                                                                                       
                                                                }
                                                                <th>@PCM.WEB.Properties.Resources.executor</th>    
                                                                <th class="d-none d-sm-table-cell text-center" style="width: 150px;">@PCM.WEB.Properties.Resources.data_inicio</th>
                                                                <th class="d-none d-sm-table-cell text-center" style="width: 150px;">@PCM.WEB.Properties.Resources.data_termino</th>
                                                                <th>@PCM.WEB.Properties.Resources.solucao</th>                                                    
                                                            </tr>
                                                        </thead> 
                                                        <tbody>                                              
                                                        @foreach (var apontamento in item.apontamento)
                                                        {
                                                                <tr>
                                                                    @if((ViewBag.editar || ViewBag.excluir) && item.ordem_servico.codigo_status != 2)
                                                                    {    
                                                                        <td class="text-center">
                                                                            <div class="btn-group">
                                                                                @if(ViewBag.editar) { @Html.ActionLink(" ", "ApontamentoOSEdit", new { codigo = apontamento.codigo, codigo_unidade = item.ordem_servico.codigo_unidade }, new { @class = "fa fa-pencil btn btn-sm btn-secondary", @title= @PCM.WEB.Properties.Resources.editar, data_toggle="tooltip"})}
                                                                                @if(ViewBag.excluir) { @Html.ActionLink(" ", "ApontamentoOSExcluir", new { codigo = apontamento.codigo, codigo_unidade = item.ordem_servico.codigo_unidade}, new { @class = "fa fa-times btn btn-sm btn-secondary", @title= @PCM.WEB.Properties.Resources.excluir, data_toggle="tooltip"})}
                                                                            </div>
                                                                        </td>                  
                                                                    }
                                                                    <td>@Html.DisplayFor(modelItem => apontamento.executor)</td>    
                                                                    <td class="d-none d-sm-table-cell text-center" style="width: 150px;">@Html.DisplayFor(modelItem => apontamento.data_inicio)</td>
                                                                    <td class="d-none d-sm-table-cell text-center" style="width: 150px;">@Html.DisplayFor(modelItem => apontamento.data_termino)</td>
                                                                    <td>@Html.DisplayFor(modelItem => apontamento.descricao_solucao)</tD>                                                    
                                                                </tr>
                                                         }
                                                         </tbody> 
                                                    </table>
                                                </td>    
                                            </tr>
                                        }
                                    </tbody>
                                }
                            </table>
                        </div>
                    </div>
            </div>
            </div>

        <!-- END Tasks Content -->
        </div>

        }

    </div>
    <!-- END Page Content -->

</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")

    <script>

        $(function () {

            var unidade = $("#unidade");
            var setor = $("#setor");
            var equipamento = $("#equipamento");
            var prioridade = $("#prioridade");

            unidade.change(function () {
                var request = { "unidade": (unidade.val() == "")? "-1": unidade.val()};

                $.post("LoadSetor", request, function (obj) {
                    setor.empty();
                    option = $("<option>", { "value": "" }).text("");
                    setor.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        setor.append(option);
                    });
                }, "json");

                $.post("LoadEquipamento", request, function (obj) {
                    equipamento.empty();
                    option = $("<option>", { "value": "" }).text("");
                    equipamento.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        equipamento.append(option);
                    });
                }, "json");

                $.post("LoadPrioridade", request, function (obj) {
                    prioridade.empty();
                    option = $("<option>", { "value": "" }).text("");
                    prioridade.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        prioridade.append(option);
                    });
                }, "json");

            });

            setor.change(function () {
                var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val(), "setor": (setor.val() == "") ? "-1" : setor.val() };
                $.post("LoadEquipamentoSetor", request, function (obj) {
                    equipamento.empty();
                    option = $("<option>", { "value": "" }).text("");
                    equipamento.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        equipamento.append(option);
                    });
                }, "json");
            });

        });

        var FormValidation = function () {
            // Init Bootstrap Forms Validation, for more examples you can check out https://github.com/jzaefferer/jquery-validation
            var initValidationBootstrap = function () {
                jQuery('.js-validation-bootstrap').validate({
                    ignore: [],
                    errorClass: 'invalid-feedback animated fadeInDown',
                    errorElement: 'div',
                    errorPlacement: function (error, e) {
                        jQuery(e).parents('.list-group-item > div').append(error);
                    },
                    highlight: function (e) {
                        jQuery(e).closest('.list-group-item').removeClass('is-invalid').addClass('is-invalid');
                    },
                    success: function (e) {
                        jQuery(e).closest('.list-group-item').removeClass('is-invalid');
                        jQuery(e).remove();
                    },
                    rules: {
                        'unidade': {
                            required: true
                        },
                        'ordem_servico': {
                            number: true
                        }
                    },                        
                    messages: {
                        'unidade': {
                            required: '@PCM.WEB.Properties.Resources.campo_requerido'
                        },
                        'ordem_servico': {
                            number: '@PCM.WEB.Properties.Resources.campo_numerico'
                        }
                    }                    
                });
            };

            return {
                init: function () {
                    // Init Bootstrap Forms Validation
                    initValidationBootstrap();
                }
            };
        }();
        
        // Initialize when page loads
        jQuery(function () {
            FormValidation.init();
            Codebase.helpers(['table-tools', 'datepicker', 'maxlength', 'select2']);
            $('#status').val(@ViewBag.codigo_status).trigger("change");
        });

    </script>
}
