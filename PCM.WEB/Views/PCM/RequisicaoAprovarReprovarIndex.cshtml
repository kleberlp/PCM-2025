@model List<PCM.WEB.MODELS.RequisicaoAprovarReprovar>

<!-- Main Container -->
<main id="main-container">

<!-- Breadcrumb -->
<div class="bg-body-light border-b">
    <div class="content py-0 text-center">
        <nav class="breadcrumb bg-body-light mb-0">
            <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@PCM.WEB.Properties.Resources.sistema</a>
            <a class="breadcrumb-item">@PCM.WEB.Properties.Resources.pcm</a>
            <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.requisicao_aprovar_reprovar</span>
        </nav>
    </div>
</div>

    @using (Html.BeginForm("RequisicaoAprovarReprovarIndex", "PCM", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", name= "form", id = "form", enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()
        <!-- END Breadcrumb -->
        <!-- Page Content -->
        <div class="content">

            <!-- Toggle Tasks Navigation on mobile -->
            <button type="button" class="btn btn-block btn-square btn-primary d-md-none mb-10" data-toggle="class-toggle" data-target=".js-tasks-nav" data-class="d-none d-md-block">@PCM.WEB.Properties.Resources.filtros</button>

            <div class="js-tasks-nav d-none d-md-block">
                <div class="block block-rounded border">
                    <div class="block-header block-header-default bg-gd-default">
                        <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.requisicao_aprovar_reprovar</h3>
                        <div class="block-options">
                            <button type="button" class="btn btn-square btn-secondary min-width-100 h-75" onclick="aprovarRequisicao();"><i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.aprovar</button>
                            <button type="button" class="btn btn-square btn-secondary min-width-100 h-75" onclick="reprovarRequisicao();"><i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.reprovar</button>
                        </div>
                    </div>
                    <div class="block-content">
                        <ul class="list-group push">
                            @if (Session["unidade"] == "")
                            {
                                <li class="list-group-item">
                                    <div class="row">
                                        <div class="col-md-4">@Html.DropDownList("unidade", null, PCM.WEB.Properties.Resources.unidade, new { @class = "js-select2 form-control" })</div>
                                    </div>
                                </li>
                            }
                            @if (Session["unidade"] != "")
                            {
                                <input type="hidden" name="unidade" id="unidade" value="@ViewBag.codigo_unidade">
                            }
                            <li class="list-group-item">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="input-daterange input-group" data-date-format="dd/mm/yyyy" data-week-start="1" data-autoclose="true" data-today-highlight="true">
                                            <input type="text" class="form-control" id="data_inicio" name="data_inicio" placeholder="De" data-week-start="1" data-autoclose="true" data-today-highlight="true" value="@ViewBag.data_inicio">
                                            <div class="input-group-prepend input-group-append">
                                                <span class="input-group-text font-w600">-</span>
                                            </div>
                                            <input type="text" class="form-control" id="data_termino" name="data_termino" placeholder="Até" data-week-start="1" data-autoclose="true" data-today-highlight="true" value="@ViewBag.data_termino">
                                        </div>
                                    </div>
                                    <div class="col-md-2"><div><input type="text" id="numero_requisicao" name="numero_requisicao" value="@ViewBag.numero_requisicao" placeholder="@PCM.WEB.Properties.Resources.numero_requisicao" class="form-control"></div></div>
                                    <div class="col-md-2"><div>@Html.DropDownList("setor", null, PCM.WEB.Properties.Resources.setor, new { @class = "js-select2 form-control" })</div></div>
                                    <div class="col-md-2"><div>@Html.DropDownList("apartamento", null, PCM.WEB.Properties.Resources.apartamento, new { @class = "js-select2 form-control" })</div></div>
                                    <div class="col-md-2"><div>@Html.DropDownList("status", null, PCM.WEB.Properties.Resources.status, new { @class = "js-select2 form-control" })</div></div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="row">
                                    <div class="col-md-5"><div>@Html.DropDownList("equipamento", null, PCM.WEB.Properties.Resources.equipamento, new { @class = "js-select2 form-control" })</div></div>
                                    <div class="col-md-3"><div>@Html.DropDownList("prioridade", null, PCM.WEB.Properties.Resources.prioridade, new { @class = "js-select2 form-control" })</div></div>
                                    <div class="col-md-4"><div>@Html.DropDownList("solicitante", null, PCM.WEB.Properties.Resources.solicitante, new { @class = "js-select2 form-control" })</div></div>
                                </div>
                            </li>
                            <li class="list-group-item text-right">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75" name="filtrar" id="filtrar"><i class="si si-magnifier mr-5"></i>@PCM.WEB.Properties.Resources.filtrar</button>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <!-- END Collapsible Tasks Navigation -->

            <div class="block block-rounded border">
                <div class="block-content block-content-full border">
                    <!-- If you put a checkbox in thead section, it will automatically toggle all tbody section checkboxes -->
                    <table class="table table-hover js-table-checkable">

                        <thead>
                            <tr class="table-secondary">
                                <th class="text-center" style="width: 50px;">
                                    <label class="css-control css-control-primary css-checkbox py-0">
                                        <input type="checkbox" class="css-control-input" id="check-all" name="check-all" value="0">
                                        <span class="css-control-indicator"></span>
                                    </label>
                                </th>
                                <th class="text-center d-md-table-cell" style="width: 120px;">@PCM.WEB.Properties.Resources.numero_requisicao</th>
                                <th class="text-center d-md-table-cell" style="width: 140px;">@PCM.WEB.Properties.Resources.data</th>
                                @if (Session["unidade"] == "")
                                {
                                    <th class="d-none d-md-table-cell">@PCM.WEB.Properties.Resources.unidade </th>
                                }
                                <th class="d-none d-lg-table-cell">@PCM.WEB.Properties.Resources.local</th>
                                <th class="d-none d-lg-table-cell">@PCM.WEB.Properties.Resources.solicitante</th>
                                <th>@PCM.WEB.Properties.Resources.descricao</th>
                                <th class="d-none d-md-table-cell text-center" style="width: 120px;">@PCM.WEB.Properties.Resources.status</th>
                            </tr>
                        </thead>

                        <tbody>
                            @for (int i = 0; i < Model.Count; i++)
                            {
                                <tr>
                                    <td class="text-center" style="width: 50px;">
                                        @if (@Model[i].status == 1)
                                        {
                                            <label class="css-control css-control-primary css-checkbox py-0 px-0">
                                                <input type="checkbox" class="css-control-input" value="@Model[i].codigo|@Model[i].codigo_unidade" name="x">
                                                <span class="css-control-indicator"></span>
                                            </label>
                                        }
                                    </td>
                                    <td class="text-center d-md-table-cell" style="width: 120px;">@Html.DisplayFor(modelItem => modelItem[i].numero_requisicao)</td>
                                    <td class="text-center d-md-table-cell" style="width: 140px;">@Html.DisplayFor(modelItem => modelItem[i].data)</td>
                                    @if (Session["unidade"] == "")
                                    {
                                        <td class="d-none d-md-table-cell">@Html.DisplayFor(modelItem => modelItem[i].unidade)</td>
                                    }
                                    <td class="d-none d-lg-table-cell">@Html.DisplayFor(modelItem => modelItem[i].local)</td>
                                    <td class="d-none d-lg-table-cell">@Html.DisplayFor(modelItem => modelItem[i].solicitante)</td>
                                    <td>@Html.DisplayFor(modelItem => modelItem[i].descricao)</td>
                                    <td class="d-none d-md-table-cell text-center"><span class="@Model[i].status_css">@Html.Raw(Model[i].status_descricao)</span></td>
                                </tr>
                            }
                        </tbody>

                    </table>

                </div>
            </div>            
        </div>

        <!-- From Right Modal -->
        <div class="modal fade" id="modalJustificativa" tabindex="-1" role="dialog" aria-labelledby="modalJustificativa" aria-hidden="true">
            <div class="modal-dialog modal-dialog-fromright" role="document">
                <div class="modal-content">
                    <div class="block block-themed block-transparent mb-15">
                        <div class="block-header bg-gd-primary">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.justificada</h3>
                        </div>
                    </div>

                    <div class="block-content block-content-full">
                        <div class="form-group row">
                            <input type="hidden" name="codigo" id="codigo" />
                            <input type="hidden" name="status" id="status" />
                            <div class="col-12"><textarea class="form-control" id="justificativa" name="justificativa" maxlength="500" rows="10"></textarea></div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-square btn-secondary min-width-100 h-75" name="close" id="close" data-dismiss="modal"><i class="fa fa-close mr-5"></i>@PCM.WEB.Properties.Resources.sair</button>
                        <button type="button" class="btn btn-square btn-secondary min-width-100 h-75" name="reprovar" id="reprovar" onclick="$('#form').attr('action', 'RequisicaoAprovarReprovar'); $('#form').submit();"><i class="fa fa-check mr-5"></i>@PCM.WEB.Properties.Resources.reprovar</button>
                    </div>
                </div>
            </div>
        </div>
        <!-- END From Right Modal -->

    }

</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/dataTables")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")

    <script type="text/javascript">

        var selected = new Array();

        $(function () {

            $.ajaxSetup({async: false});

            var unidade = $("#unidade");
            var setor = $("#setor");
            var equipamento = $("#equipamento");
            var prioridade = $("#prioridade");
            var apartamento = $("#apartamento");
            var solicitante = $("#solicitante");

            apartamento.select2();

            var status = $("#status");
            status.select2({placeholder: '@PCM.WEB.Properties.Resources.status', allowClear: true});

            if (unidade.val() == "" || unidade.val() == "-1") {
                setor.prop( "disabled", true );
                prioridade.prop( "disabled", true );
                apartamento.prop( "disabled", true );
                equipamento.prop( "disabled", true );
                solicitante.prop( "disabled", true );
                prioridade.select2({placeholder: '@PCM.WEB.Properties.Resources.prioridade', allowClear: true});
                setor.select2({placeholder: '@PCM.WEB.Properties.Resources.setor', allowClear: true});
                apartamento.select2({placeholder: '@PCM.WEB.Properties.Resources.apartamento', allowClear: true});
                solicitante.select2({placeholder: '@PCM.WEB.Properties.Resources.solicitante', allowClear: true});
                equipamento.select2({placeholder: "Máquina / Equipamento / Itens Gerais", allowClear: true});
            }

            unidade.change(function () {

                if (unidade.val() == "") {

                    setor.empty();
                    prioridade.empty();
                    apartamento.empty();
                    equipamento.empty();
                    solicitante.empty();
                    setor.prop( "disabled", true );
                    prioridade.prop( "disabled", true );
                    apartamento.prop( "disabled", true );
                    equipamento.prop( "disabled", true );
                    solicitante.prop( "disabled", true );
                    prioridade.select2({placeholder: '@PCM.WEB.Properties.Resources.prioridade', allowClear: true});
                    setor.select2({placeholder: '@PCM.WEB.Properties.Resources.setor', allowClear: true});
                    apartamento.select2({placeholder: '@PCM.WEB.Properties.Resources.apartamento', allowClear: true});
                    solicitante.select2({placeholder: '@PCM.WEB.Properties.Resources.solicitante', allowClear: true});
                    equipamento.select2({placeholder: "Máquina / Equipamento / Itens Gerais", allowClear: true});

                } else {

                    var request = { "unidade": unidade.val() };

                    $.post("LoadPrioridade", request, function (obj) {
                        prioridade.empty();
                        option = $("<option>", { "value": "" }).text("");
                        prioridade.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            prioridade.append(option);
                        });
                    }, "json");

                    $.post("LoadSetor", request, function (obj) {
                        setor.empty();
                        option = $("<option>", { "value": "" }).text("");
                        setor.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            setor.append(option);
                        });
                    }, "json");

                    $.post("LoadApartamento", request, function (obj) {
                        apartamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        apartamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            apartamento.append(option);
                        });
                    }, "json");

                    $.post("LoadSolicitante", request, function (obj) {
                        solicitante.empty();
                        option = $("<option>", { "value": "" }).text("");
                        solicitante.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            solicitante.append(option);
                        });
                    }, "json");

                    setor.prop( "disabled", false );
                    prioridade.prop( "disabled", false );
                    apartamento.prop( "disabled", false );
                    solicitante.prop( "disabled", false );
                    prioridade.select2({placeholder: '@PCM.WEB.Properties.Resources.prioridade',allowClear: true});
                    setor.select2({placeholder: '@PCM.WEB.Properties.Resources.setor',allowClear: true});
                    apartamento.select2({placeholder: '@PCM.WEB.Properties.Resources.apartamento',allowClear: true});
                    solicitante.select2({placeholder: '@PCM.WEB.Properties.Resources.solicitante',allowClear: true});
                }

            });

            setor.change(function () {

                if (setor.val() == "") {
                    equipamento.empty();
                    equipamento.select2({placeholder: "Máquina / Equipamento / Itens Gerais" ,allowClear: true});
                    equipamento.prop( "disabled", true );

                    var request = { "unidade": unidade.val(), "setor": "-1" };

                    $.post("LoadApartamento", request, function (obj) {
                        apartamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        apartamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            apartamento.append(option);
                        });
                    }, "json");

                }

                else {

                    var request = { "unidade": unidade.val(), "setor": setor.val() };

                    $.post("LoadApartamento", request, function (obj) {
                        apartamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        apartamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            apartamento.append(option);
                        });
                    }, "json");

                    $.post("LoadEquipamentoSetor", request, function (obj) {
                        equipamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        equipamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            equipamento.append(option);
                        });
                    }, "json");

                    equipamento.prop( "disabled", false );
                    equipamento.select2({placeholder: "Máquina / Equipamento / Itens Gerais" ,allowClear: true});
                }

            });

            apartamento.change(function () {

                if (apartamento.val() == "") {
                    equipamento.empty();
                    equipamento.select2({placeholder: "Máquina / Equipamento / Itens Gerais" ,allowClear: true});
                    equipamento.prop( "disabled", true );
                    if(setor.val() != ""){
                        setor.trigger('change');
                    }
                }

                else{

                    var request = { "unidade": unidade.val(), "apartamento": apartamento.val() };

                    $.post("LoadEquipamentoApartamento", request, function (obj) {
                        equipamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        equipamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            equipamento.append(option);
                        });
                    }, "json");

                    equipamento.prop( "disabled", false );
                    equipamento.select2({placeholder: "Máquina / Equipamento / Itens Gerais" ,allowClear: true});
                }

            });
            
        });
    
        function reprovarRequisicao()
        {
            objetos = [];
            $('input[type=checkbox]').each(function () {
                if (this.checked) {
                    objetos.push(this.value);
                }
            });
            if (objetos.length > 0) {
                $('#codigo').val(objetos.join(','));
                $('#status').val(3);
                $('#modalJustificativa').modal('show');
            } else {
                swal({
                    title: 'Requisição',
                    text: 'Favor selecionar uma ou mais requisições para Reprovar!',
                    type: 'error',
                    showCancelButton: false,
                    confirmButtonText: 'OK',
                    html: false,
                    preConfirm: function () {
                        return new Promise(function (resolve) {
                            setTimeout(function () {
                                resolve();
                            }, 50);
                        });
                    }
                });
            }
        }

        function aprovarRequisicao()
        {
            objetos = [];
            $('input[type=checkbox]').each(function () {
                if (this.checked) {
                    objetos.push(this.value);
                }
            });
            if (objetos.length > 0) {
                $('#codigo').val(objetos.join(','));
                $('#status').val(2);
                $('#form').attr('action', 'RequisicaoAprovarReprovar');
                $('#form').submit();
            } else {
                swal({
                    title: 'Requisição',
                    text: 'Favor selecionar uma ou mais requisições para Aprovar!',
                    type: 'error',
                    showCancelButton: false,
                    confirmButtonText: 'OK',
                    html: false,
                    preConfirm: function () {
                        return new Promise(function (resolve) {
                            setTimeout(function () {
                                resolve();
                            }, 50);
                        });
                    }
                });
            }
        }

        var BeTableDatatables = function () {
            // Override a few DataTable defaults, for more examples you can check out https://www.datatables.net/
            var exDataTable = function () {
                jQuery.extend(jQuery.fn.dataTable.ext.classes, {
                    sWrapper: "dataTables_wrapper dt-bootstrap4"
                });
            };

            // Init simple DataTable, for more examples you can check out https://www.datatables.net/
            var initDataTableSimple = function () {
                jQuery('.js-table-checkable').dataTable({
                    columnDefs: [
                        { orderable: false, targets: [0] },
                        {type: 'date-br',  targets: [2] }
                    ],                    
                    order: [[ 1, "desc" ]],
                    searching: true,
                    lengthChange: false,
                    pageLength: 15,
                    autoWidth: false,
                    dom: 'Bfrtip',
                    buttons: [
                        { extend: 'copy', text: 'Copiar'},
                        { extend: 'print',
                            text: 'Imprimir'},
                        { extend: 'excel'},
                        { extend: 'pdf', orientation: 'landscape'},
                    ],
                    language: {
                        "search": "Procurar:",
                        "lengthMenu": "Exibir _MENU_ ",
                        "zeroRecords": "Nenhum Registro Encontrado",
                        "info": "_MAX_ registro(s)",
                        "infoEmpty": "Nenhum Registro encontrado",
                        "infoFiltered": "(filtrado de _MAX_ registro(s))"
                    }
                });
            };

            return {
                init: function () {
                    // Override a few DataTable defaults
                    exDataTable();

                    // Init Datatables
                    initDataTableSimple();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            $.fn.dataTable.moment('DD/MM/YYYY HH:mm'); BeTableDatatables.init();
            Codebase.helpers(['datepicker', 'maxlength', 'select2', 'table-tools']);
        });

    </script>
}
