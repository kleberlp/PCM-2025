<!-- Main Container -->
<main id="main-container">
   
    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action(@ViewBag.return_page, "PCM")">@PCM.WEB.Properties.Resources.pcm</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.apontamento_os</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">                
                @using (Html.BeginForm("ApontamentoOSExcluir", "PCM", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data"  }))        
                {
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="codigo_apontamento" id="codigo_apontamento" value="@ViewBag.apontamento.codigo_apontamento">
                    <input type="hidden" name="codigo_unidade" id="codigo_unidade" value="@ViewBag.apontamento.codigo_unidade">

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.deseja_excluir</h3>
                            <div class="block-options">
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.excluir
                                </button>
                                <a href="@Url.Action(@ViewBag.return_page, "PCM")" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>
                        <div class="block-content block-content-full">                             
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.unidade</label>
                                <div class="col-12">@ViewBag.apontamento.unidade</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.setor</label>
                                <div class="col-12">@ViewBag.apontamento.setor</div>
                            </div>                
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.equipamento</label>
                                <div class="col-12">@ViewBag.apontamento.equipamento</div>
                            </div>                
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.servico</label>
                                <div class="col-12">@ViewBag.apontamento.servico</div>
                            </div>       
                            @if(ViewBag.apontamento.codigo_tipo_servico == 1)
                            {         
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.funcionario</label>
                                    <div class="col-12">@ViewBag.apontamento.funcionario</div>
                                </div>                
                            }
                            @if(ViewBag.apontamento.codigo_tipo_servico == 2)
                            {         
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.fornecedor</label>
                                    <div class="col-12">@ViewBag.apontamento.fornecedor</div>
                                </div>                
                            }
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.descricao</label>
                                <div class="col-12">@ViewBag.apontamento.descricao_solucao</div>
                            </div>  
                            <div class="form-group row">
                                <div class="col-4">
                                    <label>@PCM.WEB.Properties.Resources.data_inicio</label>
                                    <div>@ViewBag.apontamento.data_inicio</div>
                                </div>
                                @if(ViewBag.apontamento.aponta_horas)
                                {
                                    <div class="col-4">
                                        <label>@PCM.WEB.Properties.Resources.hora_inicio</label>
                                        <div>@ViewBag.apontamento.hora_inicio</div>
                                    </div>
                                }
                            </div>    
                            <div class="form-group row">
                                <div class="col-4">
                                    <label>@PCM.WEB.Properties.Resources.data_termino</label>
                                    <div>@ViewBag.apontamento.data_termino</div>
                                </div>
                                @if(ViewBag.apontamento.aponta_horas)
                                {
                                    <div class="col-4">
                                        <label>@PCM.WEB.Properties.Resources.hora_termino</label>
                                        <div>@ViewBag.apontamento.hora_termino</div>
                                    </div>
                                }
                            </div>               
                        </div>                        
                    </div>
                }
            <!-- END Basic Info -->
        </div>
        <!-- END Update Product -->
    </div>
    <!-- END Page Content -->
</main>
<!-- END Main Container -->
