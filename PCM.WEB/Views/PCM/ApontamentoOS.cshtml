                    });
                }, "json");
            });
            
            setor.change(function () {
                var request = { "unidade": unidade.val(), "setor": setor.val() };
                $.post("LoadEquipamentoSetor", request, function (obj) {
                    equipamento.empty();
                    option = $("<option>", { "value": "" }).text("");
                    equipamento.append(option);
                    $.each(obj, function (indice, result) {
                        option = $("<option>", { "value": result.codigo }).text(result.descricao);
                        equipamento.append(option);
                    });
                }, "json");
            });
            
            produto.change(function () {
                $("#codigo_produto").val($("#produto_combo").val().toString().split("|")[0]);
                var flag = false;
                var request = { "unidade": @ViewBag.apontamento.codigo_unidade, "produto": produto.val().toString().split("|")[0] };
                lote.empty();
                option = $("<option>", { "value": "" }).text("");
                lote.append(option);                         
                 jQuery.ajax({
                    type: 'POST',
                    url: 'LoadProdutoLote',
                    data: request,
                    async: false,
                     success: function (result) {
                        jQuery.each(result, function(index, item) {
                            if (item.codigo == "PCM_SEM_LOTE") {
                                 flag = true;
                             } else {
                                 option = $("<option>", { "value": item.codigo }).text(item.descricao);
                                 lote.append(option);
                             }
                        });
                     }
                }, "json");

                if (flag) {
                    $("#div_lote").hide();
                } else {
                    $("#div_lote").show();
                }

            });

        });

