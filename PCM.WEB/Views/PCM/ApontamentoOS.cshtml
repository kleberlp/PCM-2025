@model List<PCM.WEB.MODELS.SaidaEstoque>

<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item" href="@Url.Action("Index", "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item" href="@Url.Action(@ViewBag.page, @ViewBag.model)">@PCM.WEB.Properties.Resources.pcm</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.apontamento_os</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->
    <!-- Page Content -->
    <div class="content">

        <!-- Update Product -->
        <div class="row gutters-tiny">
            <!-- Basic Info -->
            <div class="col-md-12">
                @using (Html.BeginForm("ApontamentoOS", "PCM", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data", @name = "form", @id = "form" }))
                {
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="codigo_pcm_ordem_servico" id="codigo_pcm_ordem_servico" value="@ViewBag.apontamento.codigo">
                    <input type="hidden" name="codigo_unidade" id="codigo_unidade" value="@ViewBag.apontamento.codigo_unidade">
                    <input type="hidden" name="codigo_tipo_servico" id="codigo_tipo_servico" value="@ViewBag.apontamento.codigo_tipo_servico">
                    <input type="hidden" name="page" id="page" value="@ViewBag.page">
                    <input type="hidden" name="model" id="model" value="@ViewBag.model">
                    <input type="hidden" id="codigo_produto" name="codigo_produto" value="" />
                    <input type="hidden" id="empresa" name="empresa" value="@ViewBag.empresa" />
                    <input type="hidden" id="usuario" name="usuario" value="@ViewBag.usuario" />

                    <div class="block block-rounded border">
                        <div class="block-header block-header-default bg-gd-default">
                            <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.apontamento_os</h3>
                            <div class="block-options">
                                <button type="button" onclick="document.getElementById('btnSave').disabled = true; $('#form').submit();" id="btnSave" name="btnSave" class="btn btn-square btn-secondary min-width-100 h-75"><i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.salvar</button>
                                <a href="@Url.Action(@ViewBag.page, @ViewBag.model)" class="btn btn-square btn-secondary min-width-100 h-75">
                                    <i class="si si-action-undo mr-5"></i>@PCM.WEB.Properties.Resources.voltar
                                </a>
                            </div>
                        </div>

                        <div class="block-content block-content-full">
                            @if (Session["unidade"] == "")
                            {
                                <div class="form-group row font-w600"><div class="col-12">@PCM.WEB.Properties.Resources.unidade: <span class="text-primary">@ViewBag.apontamento.unidade</span></div></div>
                            }
                            <div class="form-group row font-w600"><div class="col-12">@PCM.WEB.Properties.Resources.ordem_servico: <span class="text-primary">@ViewBag.apontamento.ordem_servico</span></div></div>
                            @if (@ViewBag.apontamento.setor != "")
                            {
                                <div class="form-group row font-w600"><div class="col-12">@PCM.WEB.Properties.Resources.setor: <span class="text-primary">@ViewBag.apontamento.setor</span></div></div>
                            }
                            @if (@ViewBag.apontamento.equipamento != "")
                            {
                                <div class="form-group row font-w600"><div class="col-12">@PCM.WEB.Properties.Resources.equipamento: <span class="text-primary">@ViewBag.apontamento.equipamento</span></div></div>
                            }
                            @if (@ViewBag.apontamento.apartamento != "")
                            {
                                <div class="form-group row font-w600"><div class="col-12">@PCM.WEB.Properties.Resources.apartamento: <span class="text-primary">@ViewBag.apontamento.apartamento</span></div></div>
                            }
                            <div class="form-group row font-w600"><div class="col-12">@PCM.WEB.Properties.Resources.servico: <span class="text-primary">@ViewBag.apontamento.servico</span></div></div>
                            <hr></hr>
                            <div class="form-group row">
                            </div>
                            <div class="form-group row">
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.categoria</label>
                                    <div>@Html.DropDownList("categoria", null, "", new { @class = "form-control" })</div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.tipo_servico</label>
                                    <div>@Html.DropDownList("tipo_servico", null, "", new { @class = "form-control", @onChange = "verificaTipoServico();" })</div>
                                </div>
                                <div class="col-md-4">
                                    <label>@PCM.WEB.Properties.Resources.tipo_ordem_servico</label>
                                    <div>@Html.DropDownList("tipo_ordem_servico", null, "", new { @class = "form-control js-select2" })</div>
                                </div>
                            </div>
                            <div class="form-group row" id="div_funcionario">
                                <label class="col-12">@PCM.WEB.Properties.Resources.funcionario</label>
                                <div class="col-12">@Html.DropDownList("funcionario", null, "", new { @class = "form-control js-select2", @multiple = "multiple" })</div>
                            </div>
                            <div class="form-group row" id="div_fornecedor">
                                <label class="col-12">@PCM.WEB.Properties.Resources.fornecedor</label>
                                <div class="col-12">@Html.DropDownList("fornecedor", null, "", new { @class = "form-control js-select2" })</div>
                            </div>
                            <div class="form-group row">
                                <label class="col-12">@PCM.WEB.Properties.Resources.solucao</label>
                                <div class="col-12"><textarea class="form-control" id="descricao_solucao" name="descricao_solucao" maxlength="5000" rows="6" value="@ViewBag.apontamento.descricao_solucao"></textarea></div>
                            </div>
                            <div class="form-group row">
                                <div class="col-md-3">
                                    <label>@PCM.WEB.Properties.Resources.data_inicio</label>
                                    <div><input type="text" class="js-datepicker form-control" id="data_inicio" name="data_inicio" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value="@ViewBag.data"></div>
                                </div>
                                @if (ViewBag.apontamento.aponta_horas)
                                {
                                    <div class="col-md-3 hora_termino" data-autoclose="true">
                                        <label>@PCM.WEB.Properties.Resources.hora_inicio</label>
                                        <div><input type="text" class="form-control" id="hora_inicio" name="hora_inicio" autocomplete="off"></div>
                                    </div>
                                }
                                <div class="col-md-3">
                                    <label>@PCM.WEB.Properties.Resources.data_termino</label>
                                    <div><input type="text" class="js-datepicker form-control" id="data_termino" name="data_termino" data-week-start="1" data-autoclose="true" data-today-highlight="true" data-date-format="dd/mm/yyyy" placeholder="" value="@ViewBag.data"></div>
                                </div>
                                @if (ViewBag.apontamento.aponta_horas)
                                {
                                    <div class="col-md-3 hora_termino" data-autoclose="true">
                                        <label>@PCM.WEB.Properties.Resources.hora_termino</label>
                                        <div><input type="text" class="form-control" id="hora_termino" name="hora_termino" value="" autocomplete="off"></div>
                                    </div>
                                }
                            </div>
                            <div class="form-group row">
                            </div>
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.concluido?</label>
                                    <div class="col-12">
                                        <label class="css-control css-control-success css-switch">
                                            <input type="checkbox" class="css-control-input" id="concluido" name="concluido" value="true">
                                            <span class="css-control-indicator"></span>
                                        </label>
                                    </div>
                                </div>
                                <div id="div_justificativa">
                                    <div class="form-group row">
                                        <label class="col-12">@PCM.WEB.Properties.Resources.justificativa_apontamento</label>
                                        <div class="col-12">@Html.DropDownList("justificativa_apontamento", null, "", new { @class = "form-control js-select2" })</div>
                                    </div>
                                    @if (ViewBag.apontamento.ar_condicionado)
                                    {
                                        <div class="form-group row">
                                            <label class="col-12">@PCM.WEB.Properties.Resources.desativar_equipamento?</label>
                                            <div class="col-12">
                                                <label class="css-control css-control-success css-switch">
                                                    <input type="checkbox" class="css-control-input" id="desativar_equipamento" name="desativar_equipamento" value="true">
                                                    <span class="css-control-indicator"></span>
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div class="form-group row" style="display:none">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.observacao</label>
                                    <div class="col-12"><textarea class="form-control" id="observacao" name="observacao" maxlength="500" rows="3"></textarea></div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-12">@PCM.WEB.Properties.Resources.arquivo</label>
                                    <div class="col-12">
                                        <div class="custom-file">
                                            <input type="file" class="custom-file-input" id="arquivo" name="arquivo" onchange="Arquivo();" accept="image/*">
                                            <label id="lblArquivo" class="custom-file-label" for="imagem">@PCM.WEB.Properties.Resources.selecione_arquivo</label>
                                        </div>
                                    </div>
                                </div>
                        </div>


                        @*<div class="block block-rounded" id="registros">
                            <div class="block-header block-header-default bg-primary-light">
                                <h3 class="block-title text-dark font-w600">@PCM.WEB.Properties.Resources.registros: <span class="text-danger" id="info_registros">0</span></h3>
                                <div class="block-options">
                                    <label class="css-control css-control-danger css-checkbox">
                                        <input type="checkbox" name="barcode" id="barcode" class="css-control-input" value="true" onchange="productInput();" />
                                        <span class="css-control-indicator"></span>
                                        <span class="h5">@PCM.WEB.Properties.Resources.leitor_codigo_barras</span>
                                    </label>
                                </div>
                            </div>
                            <div class="block-content block-content-full">
                                <div>
                                    <div class="form-group row">
                                        <div class="col-md-2" id="input_barcode" style="display:none">
                                            <label>@PCM.WEB.Properties.Resources.produto</label>
                                            <input type="text" class="form-control" style="text-transform: uppercase;" id="produto" name="produto" autocomplete="off" placeholder="" value="" maxlength="20">
                                        </div>
                                        <div class="col-md-4" id="descricao_barcode" style="display:none">
                                            <label>@PCM.WEB.Properties.Resources.descricao</label>
                                            <input type="text" class="form-control" disabled style="text-transform: uppercase;" id="descricao" name="descricao" autocomplete="off" placeholder="" value="" maxlength="250">
                                        </div>
                                        <div class="col-md-6" id="input_combo">
                                            <label>@PCM.WEB.Properties.Resources.produto</label>
                                            <div>@Html.DropDownList("produto_combo", null, "", new { @class = "form-control js-select2" })</div>
                                        </div>
                                        <div class="col-md-2" id="div_lote" name="div_lote">
                                            <label>@PCM.WEB.Properties.Resources.lote</label>
