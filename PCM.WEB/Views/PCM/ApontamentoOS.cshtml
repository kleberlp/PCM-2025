                            </div>

                        </div>*@

                    </div>

                }
                <!-- END Basic Info -->
            </div>
            <!-- END Update Product -->
        </div>
        <!-- END Page Content -->
</main>
<!-- END Main Container -->

@section Styles {
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/clockpicker")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maskedinput")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/clockpicker")
    @Scripts.Render("~/plugins/select")

    <script>

        var codigo = 1;
        var objetos = [];

        $(document).ready(function () {
            $("#data_inicio").mask("99/99/9999");
            $("#data_termino").mask("99/99/9999");
            $("#hora_inicio").mask("99:99");
            $("#hora_termino").mask("99:99");
        });

        function Arquivo() {
            document.getElementById("lblArquivo").textContent = document.getElementById("arquivo").files[0].name;
        }

        $("#data_inicio").on('changeDate', function(e) {
            $(this).valid();
            $('#data_termino').valid();
        });

        $("#data_termino").on('changeDate', function (e) {
            $(this).valid();
            $('#data_inicio').valid();
        });
        
        function productInput() {
            if ($('#barcode').is(':checked')) {
                $('#input_barcode').show();
                $('#descricao_barcode').show();
                $('#input_combo').hide();
            } else {
                $('#input_barcode').hide();
                $('#descricao_barcode').hide();
                $('#input_combo').show();
            }
        }
        
        function adicionarProduto() {

            objetos.push(codigo);

            var newRowItem = $("<tr id='linha'>");
            var colsItem = "";
            colsItem = '<input data-val="true" name="[' + codigo + '].codigo" type="hidden" value="-1" />';
            newRowItem.append(colsItem);
            colsItem = '<input name="[' + codigo + '].excluido" type="hidden" value="0" />';
            newRowItem.append(colsItem);
            colsItem = '<input name="[' + codigo + '].codigo_produto" type="hidden" value="' +  $("#codigo_produto").val() + '" />';
            newRowItem.append(colsItem);
            colsItem = '<input name="[' + codigo + '].lote" type="hidden" value="' + $("#lote").val() + '" />';
            newRowItem.append(colsItem);
            colsItem = '<input name="[' + codigo + '].quantidade" type="hidden" value="' + $("#quantidade").val() + '" />';
            newRowItem.append(colsItem);
            if ($('#barcode').is(':checked')) {
                colsItem = '<input name="[' + codigo + '].produto" type="hidden" value="' + $("#produto").val() + '" />';
                newRowItem.append(colsItem);
                colsItem = '<input name="[' + codigo + '].descricao_produto" type="hidden" value="' + $("#descricao").val() + '" />';
                newRowItem.append(colsItem);
                colsItem = '<td class="text-center" style="width:200px">' + $("#produto").val() + '</td>';
                newRowItem.append(colsItem);
                colsItem = '<td>' + $("#descricao").val() + '</td>';
                newRowItem.append(colsItem);
            } else {
                colsItem = '<input name="[' + codigo + '].produto" type="hidden" value="' + $("#produto_combo").val().toString().split("|")[1] + '" />';
                newRowItem.append(colsItem);
                colsItem = '<input name="[' + codigo + '].descricao_produto" type="hidden" value="' + $("#produto_combo").val().toString().split("|")[2] + '" />';
                newRowItem.append(colsItem);
                colsItem = '<td class="text-center" style="width:200px">' + $("#produto_combo").val().toString().split("|")[1] + '</td>';
                newRowItem.append(colsItem);
                colsItem = '<td>' + $("#produto_combo").val().toString().split("|")[2] + '</td>';
                newRowItem.append(colsItem);
            }
            colsItem = '<td class="text-center" style="width:150px">' + $("#lote").val().toUpperCase(); + '</td>';
            newRowItem.append(colsItem);
            colsItem = '<td class="text-center" style="width:150px">' + $("#quantidade").val() + '</td>';
            newRowItem.append(colsItem);
            colsItem = '<td class="text-center"><div class="btn-group"><a href="#" onclick="remove(this, ' + codigo + ');" class="btn btn-sm btn-secondary"><i class="fa fa-times"></i></a></div></td>';
            newRowItem.append(colsItem);
            $("#table").append(newRowItem);

            codigo = codigo + 1;

            document.getElementById("quantidade_registros").value = parseInt(document.getElementById("quantidade_registros").value) + 1;
            document.getElementById("info_registros").innerHTML = document.getElementById("quantidade_registros").value;

            $("#produto").val("");
            $("#produto_combo").val("");
            $("#descricao").val("");
            $("#lote").val("");
            $("#quantidade").val("");
            document.getElementById("produto").focus();
        };

        function remove(item, id) {
            var tr = $(item).closest('tr');
            tr.fadeOut(400, function () {
                tr.hide();
                $("input[name$='[" + id + "].excluido']").val("1");
                for (var i = 0; i <= objetos.length - 1; i++) {
                    if (objetos[i] == id) {
                        objetos.splice(i, 1);
                    }
                }
                document.getElementById("quantidade_registros").value = parseInt(document.getElementById("quantidade_registros").value) - 1;
                document.getElementById("info_registros").innerHTML = document.getElementById("quantidade_registros").value;
            });
            return false;
        };

        $(function () {

            var concluido = $("#concluido");
            var justificativa = $("#div_justificativa");
            concluido.change(function () {
                if(document.getElementById('concluido').checked){
                    justificativa.hide();
                } else {
                    justificativa.show();
                }
            });

        });

        function verificaTipoServico() {

            var funcionario = $("#div_funcionario");
            var fornecedor = $("#div_fornecedor");

            var codigo_tipo_servico = $("#tipo_servico").val();
            if (codigo_tipo_servico == 1) {
                fornecedor.hide();
            }
            else if (codigo_tipo_servico == 2) {
                fornecedor.show();
            }

        }

        jQuery.validator.addMethod("categoria", function (funcionario, element) {

            var codigo_pcm_ordem_servico = $("#codigo_pcm_ordem_servico").val();
            var categoria = $("#categoria").attr('checked');
            if (codigo_pcm_ordem_servico != -1) {
                if (categoria != "")
                    return true;
                else
                    return false;
            }
            else{
                return true;
            }
        }, '@PCM.WEB.Properties.Resources.campo_requerido');

        jQuery.validator.addMethod("funcionario", function (funcionario, element) {

            var tipo = $("#tipo_servico").val();
            var funcionario = $("#funcionario").val();
            if (tipo == 1) {
                if(funcionario != "")
                    return true;
                else
                    return false;
            }
            else if (tipo == 2) {
                return true;
            }
        }, '@PCM.WEB.Properties.Resources.campo_requerido');

        jQuery.validator.addMethod("fornecedor", function (funcionario, element) {

            var tipo = $("#tipo_servico").val();
            var fornecedor = $("#fornecedor").val();
            if (tipo == 2) {
                if (fornecedor != "")
                    return true;
                else
                    return false;
            }
            else if (tipo == 1) {
                return true;
            }
        }, '@PCM.WEB.Properties.Resources.campo_requerido');

        jQuery.validator.addMethod("justificativa_apontamento", function (funcionario, element) {

            var concluido = document.getElementById('concluido').checked;
            var justificativa_apontamento = $("#justificativa_apontamento").val();
            if (!concluido) {
                if(justificativa_apontamento != "")
                    return true;
                else
                    return false;
            }else {
                return true;
            }
        }, '@PCM.WEB.Properties.Resources.campo_requerido');

        jQuery.validator.addMethod("maxDate", function (value, element) {

            var curDate = new Date();
            curDate.setHours(0, 0, 0, 0);
            var from = value.split("/");
            var inputDate = new Date(from[2], from[1] - 1, from[0]);
            if (inputDate > curDate) {
                return this.optional(element) || false;
            }
            else {
                return this.optional(element) || true;
            }

        }, '');

        jQuery.validator.addMethod("minDate", function (value, element) {

            if('@ViewBag.administrador' == 'True')
            {
                return this.optional(element) || true;
            } else {
                var curDate = new Date();
                curDate.setDate(curDate.getDate() - 4);
                curDate.setHours(0, 0, 0, 0);
                var from = value.split("/");
                var inputDate = new Date(from[2], from[1] - 1, from[0]);
                if (inputDate > curDate) {
                    return this.optional(element) || true;
                }
                else {
                    return this.optional(element) || false;
                }
            }
        }, '');

        jQuery.validator.addMethod("lessThan", function (value, element, params) {

            var fromCurDate = $(params).val().split("/");
            var curDate = new Date(fromCurDate[2], fromCurDate[1] - 1, fromCurDate[0]);
            var fromMinDate = value.split("/");
            var minDate = new Date(fromMinDate[2], fromMinDate[1] - 1, fromMinDate[0]);
            if (curDate < minDate) {
                return this.optional(element) || false;
            }
            else {
                return this.optional(element) || true;
            }
        }, '');

        jQuery.validator.addMethod("greaterThan", function (value, element, params) {

            var fromCurDate = $(params).val().split("/");
            var curDate = new Date(fromCurDate[2], fromCurDate[1] - 1, fromCurDate[0]);
            var fromMaxDate = value.split("/");
            var maxDate = new Date(fromMaxDate[2], fromMaxDate[1] - 1, fromMaxDate[0]);
            if (curDate > maxDate) {
                return this.optional(element) || false;
            }
            else {
                return this.optional(element) || true;
            }
        }, '');

        jQuery.validator.addMethod("greaterThanTime", function (value, element, params) {

            //Data e Hora - Início
            var fromDataInicio = $(params[0]).val().split("/");
            var fromHoraInicio = $(params[1]).val().split(":");
            var dataInicio = new Date(fromDataInicio[2], fromDataInicio[1] - 1, fromDataInicio[0], fromHoraInicio[0], fromHoraInicio[1], 0, 0);

            //Data e Hora - Término
            var fromDataTermino = $(params[2]).val().split("/");
            var fromHoraTermino = value.split(":");
            var dataTermino = new Date(fromDataTermino[2], fromDataTermino[1] - 1, fromDataTermino[0], fromHoraTermino[0], fromHoraTermino[1], 0, 0);

            if (dataInicio > dataTermino) {
                return this.optional(element) || false;
            }
            else {
                return this.optional(element) || true;
            }
        }, '');

        jQuery.validator.addMethod("apontamentoHoras", function (value, element, params) {

            //Data e Hora - Início
            var fromDataInicio = $(params[0]).val().split("/");
            var fromHoraInicio = $(params[1]).val().split(":");
            var dataInicio = new Date(fromDataInicio[2], fromDataInicio[1] - 1, fromDataInicio[0], fromHoraInicio[0], fromHoraInicio[1], 0, 0);

            //Data e Hora - Término
            var fromDataTermino = $(params[2]).val().split("/");
            var fromHoraTermino = value.split(":");
            var dataTermino = new Date(fromDataTermino[2], fromDataTermino[1] - 1, fromDataTermino[0], fromHoraTermino[0], fromHoraTermino[1], 0, 0);
            var difference = dataTermino - dataInicio;

            if (((difference) / 3600000) > 10) {
                return this.optional(element) || false;
            }
            else {
                return this.optional(element) || true;
            }
        }, '');

        $.validator.addMethod('time', function (value, element, param) {
            return value == '' || value.match(/^([01][0-9]|2[0-3]):[0-5][0-9]$/);
        }, '@PCM.WEB.Properties.Resources.valida_hora');

        $(function () {

