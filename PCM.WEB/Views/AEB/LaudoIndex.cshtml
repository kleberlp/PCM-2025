@model IEnumerable<PCM.WEB.MODELS.Laudo>

<!-- Main Container -->
<main id="main-container">

    <!-- Breadcrumb -->
    <div class="bg-body-light border-b">
        <div class="content py-0 text-md-center">
            <nav class="breadcrumb bg-body-light mb-0">
                <a class="breadcrumb-item font-w600" href="@Url.Action(Session["dashboard"].ToString(), "Home")">@PCM.WEB.Properties.Resources.sistema</a>
                <a class="breadcrumb-item font-w600">@PCM.WEB.Properties.Resources.aeb</a>
                <span class="breadcrumb-item active">@PCM.WEB.Properties.Resources.laudo</span>
            </nav>
        </div>
    </div>
    <!-- END Breadcrumb -->

    <!-- Page Content -->
    <div class="content">        

        <!-- Listagem -->

        @using (Html.BeginForm("LaudoIndex", "AEB", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "js-validation-bootstrap", role = "form", enctype = "multipart/form-data"  }))        
        {
            @Html.AntiForgeryToken()

            <!-- Toggle Tasks Navigation on mobile -->
            <button type="button" class="btn btn-block btn-square btn-primary d-md-none mb-10" data-toggle="class-toggle" data-target=".js-tasks-nav" data-class="d-none d-md-block">@PCM.WEB.Properties.Resources.filtros</button>
               
            <div class="js-tasks-nav d-none d-md-block">
                <div class="block block-rounded border">
                    <div class="block-header block-header-default bg-gd-default">
                        <h3 class="block-title text-white font-w600">@PCM.WEB.Properties.Resources.laudo</h3>
                        @if(ViewBag.inserir)
                        {
                            <div class="block-options">
                                <a href="@Url.Action("LaudoInsert", "AEB")" class="btn btn-square btn-secondary min-width-100 h-75"><i class="fa fa-save mr-5"></i>@PCM.WEB.Properties.Resources.novo</a>
                            </div>
                        }                
                    </div>
                    <div class="block-content">
                        <ul class="list-group push">
                            <li class="list-group-item">
                                <div class="row">
                                    @if(Session["unidade"] == "")
                                    {
                                        <div class="col-md-4">
                                            <div>@Html.DropDownList("unidade", null, @PCM.WEB.Properties.Resources.unidade, new { @class = "js-select2 form-control" })</div>
                                        </div>
                                    }
                                    else   
                                    {
                                        <input type="hidden" id="unidade" name="unidade" value="@Session["codigo_unidade"]">
                                    }
                                    <div class="col-md-4">                                    
                                        <div class="input-daterange input-group" data-date-format="dd/mm/yyyy" data-week-start="1" data-autoclose="true" data-today-highlight="true">
                                            <input type="text" class="form-control" id="data_inicio" name="data_inicio" placeholder="De" data-week-start="1" data-autoclose="true" data-today-highlight="true" value="@ViewBag.data_inicio">
                                            <div class="input-group-prepend input-group-append">
                                                <span class="input-group-text font-w600">-</span>
                                            </div>
                                            <input type="text" class="form-control" id="data_termino" name="data_termino" placeholder="Até" data-week-start="1" data-autoclose="true" data-today-highlight="true" value="@ViewBag.data_termino">
                                        </div>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="row">
                                    <div class="col-md-4">
                                        @Html.DropDownList("programada", null, @PCM.WEB.Properties.Resources.laudo, new { @class = "js-select2 form-control", @allowClear = "true" })    
                                    </div>
                                    <div class="col-md-4">
                                        @Html.DropDownList("fornecedor", null, @PCM.WEB.Properties.Resources.fornecedor, new { @class = "js-select2 form-control", @allowClear = "true" })    
                                    </div>
                                    <div class="col-md-4">
                                        @Html.DropDownList("equipamento", null, "Equipamento", new { @class = "js-select2 form-control", @allowClear = "true" })                
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item block-options text-right">                                                    
                                <button type="submit" class="btn btn-square btn-secondary min-width-100 h-75" name="filtrar" id="filtrar" ><i class="si si-magnifier mr-5"></i>@PCM.WEB.Properties.Resources.filtrar</button>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        }

        <div class="block block-rounded border">

            <div class="block-content block-content-full border">

                <table class="table table-sm table-vcenter js-table-sections">

                    <thead>
                        <tr class="table-secondary">
                            <th class="text-md-center" style="width: 20px;" data-sortable="false"></th>
                            @if(Session["unidade"] == "")
                            {
                                <th class="d-none d-sm-table-cell">@PCM.WEB.Properties.Resources.unidade </th>
                            }                                                                    
                            <th class="d-none d-sm-table-cell text-md-center" style="width: 120px;">@PCM.WEB.Properties.Resources.data</th>
                            <th class="d-none d-sm-table-cell text-md-center" style="width: 120px;">@PCM.WEB.Properties.Resources.data_validade</th>
                            <th>@PCM.WEB.Properties.Resources.descricao</th>
                            <th class="d-none d-sm-table-cell">@PCM.WEB.Properties.Resources.fornecedor</th>
                            <th class="d-none d-sm-table-cell text-md-center" style="width: 120px;">@PCM.WEB.Properties.Resources.valor</th>
                            @if(ViewBag.editar || ViewBag.excluir)
                            {
                                <th class="text-md-center" style="width: 80px;" data-sortable="false"></th>
                            }
                        </tr>
                    </thead>
             
                    @foreach (var item in Model)
                    {
                        <tbody class="js-table-sections-header">          
                            <tr>                 
                                <td class="text-md-center" style="width: 20px;"><i class="fa fa-angle-right"></i></td>                                           
                                @if(Session["unidade"] == "")
                                {
                                    <td class="d-none d-sm-table-cell">@Html.DisplayFor(modelItem => item.unidade)</td>
                                }                                    
                                <td class="d-none d-sm-table-cell text-md-center" style="width: 120px;">@Html.DisplayFor(modelItem => item.data)</td>    
                                <td class="d-none d-sm-table-cell text-md-center" style="width: 120px;">@Html.DisplayFor(modelItem => item.data_validade)</td>    
                                <td>@Html.DisplayFor(modelItem => item.descricao)</td>                                                     
                                <td class="d-none d-sm-table-cell">@Html.DisplayFor(modelItem => item.fornecedor)</td>                                                     
                                <td class="d-none d-sm-table-cell text-md-center" style="width: 120px;">@Html.DisplayFor(modelItem => item.valor_texto)</td>                                                     
                                @if(ViewBag.excluir || item.path_arquivo != "")
                                {
                                    <td class="text-md-center" style="width: 80px;" >
                                        <div class="btn-group">          
                                            @if(ViewBag.excluir) { <a href="@Url.Action("LaudoDelete", "AEB", new { codigo = item.codigo, unidade = item.codigo_unidade })" class="btn btn-sm btn-secondary"><i class="fa fa-times"></i></a>}
                                            @if(item.path_arquivo != "") { <a href="@Url.Content(item.path_arquivo)" target="_blank" class="btn btn-sm btn-secondary"><i class="fa fa-file-pdf-o"></i></a> }
                                        </div>                                        
                                    </td>
                                }                                                    
                            </tr>
                        </tbody>
                        <tbody class="table bg-white">                                
                            @if (item.equipamento.Count > 0)
                            {                   
                                <tr scope="row">   
                                    <td colspan="10" class="py-5"> 
                                        <table class="table table-bordered table-vcenter">
                                            <thead>
                                                <tr class="table-primary">                             
                                                    <th class="d-none d-sm-table-cell text-md-center" style="width: 120px;">@PCM.WEB.Properties.Resources.tag</th>
                                                    <th>@PCM.WEB.Properties.Resources.descricao</th>
                                                </tr>
                                            </thead> 
                                            <tbody>                                                         
                                                @foreach (var equipamento in item.equipamento)
                                                {                     
                                                    <tr class="bg-white">                 
                                                        <td class="d-none d-sm-table-cell text-md-center" style="width: 120px;">@Html.DisplayFor(modelItem => equipamento.tag)</td>                                          
                                                        <td>@Html.DisplayFor(modelItem => equipamento.descricao)</td>                                                
                                                    </tr>
                                                }
                                            </tbody>
                                        </table> 
                                    </td>
                                </tr>
                            }
                        </tbody>
                    }

                </table>

            </div>

        </div>
        
    </div>
    <!-- END Page Content -->

</main>
<!-- END Main Container -->

@section Styles {    
    @Styles.Render("~/Content/datepicker")
    @Styles.Render("~/Content/dataTables")
    @Styles.Render("~/Content/select")
}

@section Scripts {
    @Scripts.Render("~/plugins/dataTables")
    @Scripts.Render("~/plugins/validation")
    @Scripts.Render("~/plugins/maxlenght")
    @Scripts.Render("~/plugins/datepicker")
    @Scripts.Render("~/plugins/select")

    <script type="text/javascript">
        
        $(function () {

            $.ajaxSetup({ async: false });

            var unidade = $("#unidade")
            var programada = $("#programada");
            var fornecedor = $("#fornecedor");
            var equipamento = $("#equipamento");

            programada.select2({ allowClear: true, placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.laudo.ToUpper())' });
            fornecedor.select2({ allowClear: true, placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.fornecedor.ToUpper())' });
            equipamento.select2({ allowClear: true, placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.equipamento_pmoc.ToUpper())' });

            if (programada.val() == "") {
                equipamento.prop("disabled", true);
            }
            if (unidade.val() == "" || unidade.val() == "-1") {
                programada.prop("disabled", true);
                fornecedor.prop("disabled", true);
                equipamento.prop("disabled", true);
                programada.select2({ allowClear: true, placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.laudo.ToUpper())' });
                fornecedor.select2({ allowClear: true, placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.fornecedor.ToUpper())' });
                equipamento.select2({ allowClear: true, placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.equipamento_pmoc.ToUpper())' });
            }

            unidade.change(function () {

                if (unidade.val() == "") {
                    programada.prop("disabled", true);
                    fornecedor.prop("disabled", true);
                    equipamento.prop("disabled", true);
                    programada.select2({ allowClear: true, placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.laudo.ToUpper())' });
                    fornecedor.select2({ allowClear: true, placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.fornecedor.ToUpper())' });
                    equipamento.select2({ allowClear: true, placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.equipamento_pmoc.ToUpper())' });
                }
                else
                {

                    var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val() };

                    $.post("LoadFornecedor", request, function (obj) {
                        fornecedor.empty();
                        option = $("<option>", { "value": "" }).text("");
                        fornecedor.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            fornecedor.append(option);
                        });
                    }, "json");

                    var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val(), "tipo_ordem_servico": 6 };

                    $.post("LoadProgramada", request, function (obj) {
                        programada.empty();
                        option = $("<option>", { "value": "" }).text("");
                        programada.append(option)
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            programada.append(option);
                        });
                    }, "json");

                    fornecedor.prop("disabled", false);
                    programada.prop("disabled", false);
                    programada.select2({ allowClear: true, placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.laudo.ToUpper())' });
                    fornecedor.select2({ allowClear: true, placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.fornecedor.ToUpper())' });
                }

            });

            programada.change(function () {

                if (programada.val() == "") {
                    equipamento.prop("disabled", true);
                    equipamento.select2({ allowClear: true, placeholderValue: '@Html.Raw(PCM.WEB.Properties.Resources.equipamento_pmoc.ToUpper())' });
                } else {

                    var request = { "unidade": (unidade.val() == "") ? "-1" : unidade.val(), "programada": programada.val() };

                    $.post("LoadEquipamentoLaudo", request, function (obj) {
                        equipamento.empty();
                        option = $("<option>", { "value": "" }).text("");
                        equipamento.append(option);
                        $.each(obj, function (indice, result) {
                            option = $("<option>", { "value": result.codigo }).text(result.descricao);
                            equipamento.append(option);
                        });
                    }, "json");

                    equipamento.prop("disabled", false);
                    equipamento.select2({ allowClear: true, placeholder: '@Html.Raw(PCM.WEB.Properties.Resources.equipamento_pmoc.ToUpper())' });
                }

            });

        });

        var BeTableDatatables = function () {
            // Override a few DataTable defaults, for more examples you can check out https://www.datatables.net/
            var exDataTable = function () {
                jQuery.extend(jQuery.fn.dataTable.ext.classes, {
                    sWrapper: "dataTables_wrapper dt-bootstrap4"
                });
            };

            // Init simple DataTable, for more examples you can check out https://www.datatables.net/
            var initDataTableSimple = function () {
                jQuery('.js-table-sections').dataTable({
                    fixedHeader: true,
                    searching: false,
                    lengthChange: false,
                    pageLength: 15,
                    columnDefs: [{ orderable: false, targets: [0] }], order: [1],
                    autoWidth: false,
                    scrollX: false,
                    scrollColapse: true,
                    dom: 'Bfrtip',
                    buttons: [
                        { extend: 'copy', text: 'Copiar' },
                        {
                            extend: 'print',
                            text: 'Imprimir'
                        },
                        { extend: 'excel' },
                        { extend: 'pdf', orientation: 'portrait' },
                    ],
                    language: {
                        "search": "Procurar:",
                        "lengthMenu": "Exibir _MENU_ ",
                        "zeroRecords": "Nenhum Registro Encontrado",
                        "info": "_MAX_ registro(s)",
                        "infoEmpty": "Nenhum Registro encontrado",
                        "infoFiltered": "(filtrado de _MAX_ registro(s))"
                    }
                });
            };

            return {
                init: function () {
                    // Override a few DataTable defaults
                    exDataTable();

                    // Init Datatables
                    initDataTableSimple();
                }
            };
        }();

        // Initialize when page loads
        jQuery(function () {
            $.fn.dataTable.moment('DD/MM/YYYY HH:mm'); BeTableDatatables.init();
            Codebase.helpers(['table-tools', 'datepicker', 'maxlength', 'select2']);
        });

    </script>
}
